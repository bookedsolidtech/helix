              </div>
              <div class="da-matrix-cell" role="cell">
                <div class="da-matrix-rating da-matrix-rating-great">
                  <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                  <span>Views row output drops into slots perfectly</span>
                </div>
              </div>
              <div class="da-matrix-cell" role="cell">
                <div class="da-matrix-rating da-matrix-rating-ok">
                  <i class="fa-solid fa-circle-minus" aria-hidden="true"></i>
                  <span>Slots for content, limited prop use for views</span>
                </div>
              </div>
            </div>

            <!-- Webform -->
            <div class="da-matrix-row" role="row">
              <div class="da-matrix-cell" role="cell">
                <div class="da-matrix-module">
                  <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
                  Webform
                </div>
              </div>
              <div class="da-matrix-cell" role="cell">
                <div class="da-matrix-rating da-matrix-rating-ok">
                  <i class="fa-solid fa-circle-minus" aria-hidden="true"></i>
                  <span>Props work for simple field config (label, type)</span>
                </div>
              </div>
              <div class="da-matrix-cell" role="cell">
                <div class="da-matrix-rating da-matrix-rating-ok">
                  <i class="fa-solid fa-circle-minus" aria-hidden="true"></i>
                  <span>Slots handle form rendering but lose validation</span>
                </div>
              </div>
              <div class="da-matrix-cell" role="cell">
                <div class="da-matrix-rating da-matrix-rating-great">
                  <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                  <span>Props for validation/state, slots for form layout</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================================
           SECTION 5: COMPONENT STRATEGY MAP
           ============================================ -->
      <section id="strategy" class="da-section" aria-label="Component strategy map">
        <div class="da-section-inner">
          <div class="da-section-header scroll-reveal">
            <span class="da-section-label">Strategy Map</span>
            <h2 class="da-section-title">Right Tool for Each Level</h2>
            <p class="da-section-description">
              The component's complexity determines the right strategy. Simple atoms
              use properties. Complex organisms use slots. Forms use both.
            </p>
          </div>

