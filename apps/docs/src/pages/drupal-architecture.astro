    <main id="main-content">
      <!-- STICKY TAB NAV -->
      <nav class="da-section-nav" aria-label="Architecture decisions" role="tablist">
        <div class="da-section-nav-inner">
          <button class="da-nav-tab is-active" role="tab" aria-selected="true" aria-controls="tab-slots-props" data-tab="tab-slots-props">
            <i class="fa-solid fa-code-compare" aria-hidden="true"></i>
