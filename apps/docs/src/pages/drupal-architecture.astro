              </div>
              <div class="da-matrix-cell" role="cell">
                <div class="da-matrix-rating da-matrix-rating-great">
                  <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                  <span>Drupal renders media natively into slots</span>
                </div>
              </div>
              <div class="da-matrix-cell" role="cell">
                <div class="da-matrix-rating da-matrix-rating-great">
                  <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                  <span>Slot for media, props for display config</span>
                </div>
              </div>
