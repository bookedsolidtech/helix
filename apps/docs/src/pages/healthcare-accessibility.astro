---
/**
 * Healthcare Accessibility - Full visual experience page.
 *
 * This is a standalone Astro page (not Starlight content) that provides
 * an immersive visual walkthrough of the WC-2026 accessibility compliance
 * strategy for healthcare web components.
 *
 * Sections:
 * 1. Hero - "Accessibility Is Not Optional"
 * 2. Compliance Landscape - Timeline & competitive positioning
 * 3. 4-Level Testing Strategy - Visual testing pyramid
 * 4. Component A11y Checklist - What every component guarantees
 * 5. Before/After Comparison - Typical vs WC-2026
 * 6. WCAG Success Criteria Coverage - POUR matrix
 * 7. The Business Case - Stats & numbers
 */
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro';
import ScrollRevealScript from '../components/showcase/ScrollRevealScript.astro';
import A11yComplianceLandscape from '../components/showcase/a11y/A11yComplianceLandscape.astro';
import A11yTestingStrategy from '../components/showcase/a11y/A11yTestingStrategy.astro';
import A11yComponentChecklist from '../components/showcase/a11y/A11yComponentChecklist.astro';
import A11yBeforeAfter from '../components/showcase/a11y/A11yBeforeAfter.astro';
import A11yWcagMatrix from '../components/showcase/a11y/A11yWcagMatrix.astro';
import A11yBusinessCase from '../components/showcase/a11y/A11yBusinessCase.astro';

// Code examples for comparison section
const codeBadButton = `<span class="cmt">&lt;!-- Typical component library --&gt;</span>
&lt;<span class="tag">div</span> <span class="attr">class</span>=<span class="val">"btn"</span>
  <span class="attr">onclick</span>=<span class="val">"handleClick()"</span>&gt;
  Submit
&lt;/<span class="tag">div</span>&gt;

<span class="cmt">&lt;!-- No focus indicator --&gt;</span>
<span class="cmt">&lt;!-- No keyboard support --&gt;</span>
<span class="cmt">&lt;!-- No ARIA role --&gt;</span>
<span class="cmt">&lt;!-- No loading state --&gt;</span>
<span class="cmt">&lt;!-- Color-only disabled state --&gt;</span>`;

const codeGoodButton = `<span class="cmt">&lt;!-- WC-2026 component --&gt;</span>
&lt;<span class="tag">wc-button</span>
  <span class="prop-hl">variant</span>=<span class="val">"primary"</span>
  <span class="prop-hl">type</span>=<span class="val">"submit"</span>
  <span class="prop-hl">aria-describedby</span>=<span class="val">"help-text"</span>&gt;
  Submit Form
&lt;/<span class="tag">wc-button</span>&gt;

<span class="cmt">&lt;!-- Focus ring: 3px solid, 3:1 contrast --&gt;</span>
<span class="cmt">&lt;!-- Enter + Space keyboard activation --&gt;</span>
<span class="cmt">&lt;!-- role="button" + aria-pressed --&gt;</span>
<span class="cmt">&lt;!-- aria-busy loading state --&gt;</span>
<span class="cmt">&lt;!-- Icon + text disabled indicator --&gt;</span>`;

const codeBadContrast = `<span class="tag">.btn</span> {
  <span class="attr">background</span>: <span class="val">#6c757d</span>;
  <span class="attr">color</span>: <span class="val">#999</span>;
  <span class="cmt">/* Contrast ratio: 1.9:1 */</span>
  <span class="cmt">/* FAILS WCAG AA (4.5:1) */</span>
}

<span class="tag">.btn:focus</span> {
  <span class="attr">outline</span>: <span class="val">none</span>;
  <span class="cmt">/* Focus indicator removed */</span>
}`;

const codeGoodContrast = `<span class="tag">:host</span> {
  <span class="attr">--btn-bg</span>: <span class="val">var(--hds-interactive-primary)</span>;
  <span class="attr">--btn-text</span>: <span class="val">var(--hds-text-on-primary)</span>;
  <span class="cmt">/* Contrast ratio: 8.2:1 */</span>
  <span class="cmt">/* EXCEEDS WCAG AAA (7:1) */</span>
}

<span class="tag">:host(:focus-visible)</span> {
  <span class="attr">outline</span>: <span class="val">3px solid var(--hds-focus-ring)</span>;
  <span class="attr">outline-offset</span>: <span class="val">3px</span>;
}`;
---

<ShowcaseLayout
  title="Healthcare Accessibility Strategy"
  description="WCAG 2.1 AA compliance strategy for healthcare web components. HHS May 2026 mandate readiness, 4-level testing, and component accessibility guarantees."
>
  <style is:inline>
    /* --- Page-specific token overrides --- */
    :root {
      --gradient-hero: linear-gradient(135deg, #0a0a1a 0%, #0a1a1a 40%, #0f0f2e 100%);
      --glow-health: 0 0 40px rgba(16, 185, 129, 0.25);
    }

    /* --- Page-specific keyframes --- */
    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 8px rgba(239, 68, 68, 0.4); }
      50% { box-shadow: 0 0 24px rgba(239, 68, 68, 0.7); }
    }

    @keyframes pulse-glow-green {
      0%, 100% { box-shadow: 0 0 8px rgba(16, 185, 129, 0.4); }
      50% { box-shadow: 0 0 24px rgba(16, 185, 129, 0.7); }
    }

    @keyframes countdown-pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.03); }
    }

    /* --- Extra scroll-reveal delays (shared has 1-6) --- */
    .scroll-reveal-delay-7 { transition-delay: 0.7s; }
    .scroll-reveal-delay-8 { transition-delay: 0.8s; }

    /* --- Top Navigation Bar --- */
    .ha-topbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-3) var(--space-8);
      background: rgba(10, 10, 20, 0.85);
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .ha-topbar-left {
      display: flex;
      align-items: center;
      gap: var(--space-4);
    }

    .ha-back-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--text-secondary);
      transition: all 0.2s ease;
      padding: var(--space-2) var(--space-3);
      border-radius: var(--radius-md);
    }

    .ha-back-link:hover {
      color: var(--text-primary);
      background: var(--glass-bg-strong);
    }

    .ha-topbar-title {
      font-size: 0.875rem;
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.01em;
    }

    .ha-topbar-right {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }

    .ha-topbar-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--text-muted);
      padding: var(--space-2) var(--space-4);
      border-radius: var(--radius-md);
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: all 0.2s ease;
    }

    .ha-topbar-link:hover {
      color: var(--wc-green);
      border-color: rgba(16, 185, 129, 0.3);
      background: rgba(16, 185, 129, 0.06);
    }

    /* --- Hero --- */
    .ha-hero {
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      isolation: isolate;
      padding: var(--space-24) var(--space-8) var(--space-16);
    }

    .ha-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--gradient-hero);
      z-index: -3;
    }

    .ha-hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 20% 30%, rgba(16, 185, 129, 0.04) 2px, transparent 2px),
        radial-gradient(circle at 60% 70%, rgba(20, 184, 166, 0.04) 3px, transparent 3px),
        radial-gradient(circle at 80% 20%, rgba(6, 182, 212, 0.03) 2px, transparent 2px);
      background-size: 800px 800px;
      animation: particle-drift 60s linear infinite;
      opacity: 0.6;
      z-index: -2;
    }

    .ha-hero-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      opacity: 0.3;
      z-index: -1;
      pointer-events: none;
    }

    .ha-hero-orb-1 {
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(16, 185, 129, 0.4), transparent 70%);
      top: -200px;
      right: -100px;
      animation: float-slow 20s ease-in-out infinite, orb-pulse 8s ease-in-out infinite;
    }

    .ha-hero-orb-2 {
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(239, 68, 68, 0.3), transparent 70%);
      bottom: -100px;
      left: -80px;
      animation: float-slow 25s ease-in-out infinite reverse, orb-pulse 10s ease-in-out infinite;
    }

    .ha-hero-orb-3 {
      width: 350px;
      height: 350px;
      background: radial-gradient(circle, rgba(20, 184, 166, 0.25), transparent 70%);
      top: 40%;
      left: 15%;
      animation: float-drift 18s ease-in-out infinite, orb-pulse 7s ease-in-out infinite;
    }

    .ha-hero-grid {
      position: absolute;
      inset: 0;
      z-index: -1;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 70%);
    }

    .ha-hero-content {
      text-align: center;
      max-width: 900px;
      z-index: 1;
    }

    .ha-hero-badge {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-2) var(--space-6);
      border-radius: var(--radius-full);
      background: rgba(239, 68, 68, 0.08);
      border: 1px solid rgba(239, 68, 68, 0.2);
      backdrop-filter: blur(20px);
      color: var(--wc-red);
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      margin-bottom: var(--space-10);
      animation: fadeInDown 0.8s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    }

    .ha-hero-badge-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--wc-red);
      animation: pulse-glow 2s ease infinite;
      flex-shrink: 0;
    }

    .ha-hero-title {
      font-size: clamp(2.5rem, 8vw, 5rem);
      font-weight: 900;
      line-height: 1.15;
      margin-bottom: var(--space-6);
      background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(255,255,255,0.7) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.04em;
      animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s backwards;
    }

    .ha-hero-subtitle {
      font-size: clamp(1.125rem, 2.5vw, 1.5rem);
      font-weight: 300;
      margin-bottom: var(--space-8);
      background: linear-gradient(90deg, rgba(255,255,255,0.9), rgba(16, 185, 129, 0.9));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s backwards;
    }

    .ha-hero-description {
      font-size: clamp(1rem, 1.5vw, 1.25rem);
      color: rgba(255, 255, 255, 0.55);
      max-width: 700px;
      margin: 0 auto var(--space-10);
      line-height: 1.75;
      animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.3s backwards;
    }

    .ha-hero-deadline {
      display: inline-flex;
      align-items: center;
      gap: var(--space-4);
      padding: var(--space-4) var(--space-8);
      border-radius: var(--radius-xl);
      background: rgba(239, 68, 68, 0.06);
      border: 1px solid rgba(239, 68, 68, 0.15);
      animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.4s backwards, countdown-pulse 3s ease-in-out infinite;
    }

    .ha-hero-deadline-label {
      font-size: 0.8125rem;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.5);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .ha-hero-deadline-date {
      font-size: 1.5rem;
      font-weight: 900;
      color: var(--wc-red);
      font-family: var(--font-mono);
      letter-spacing: -0.02em;
    }

    .ha-hero-scroll {
      position: absolute;
      bottom: var(--space-10);
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-2);
      color: rgba(255, 255, 255, 0.3);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      animation: fadeIn 1s ease 1.5s backwards;
    }

    .ha-hero-scroll-line {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
      position: relative;
      overflow: hidden;
    }

    .ha-hero-scroll-line::after {
      content: '';
      position: absolute;
      top: -100%;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.8), transparent);
      animation: scroll-fade 2s ease-in-out infinite;
    }

    /* --- Shared Section Styles --- */
    .ha-section {
      width: 100%;
      position: relative;
      overflow: hidden;
    }

    .ha-section-inner {
      padding: var(--space-24) var(--space-8);
      max-width: 1400px;
      margin: 0 auto;
    }

    .ha-section-header {
      text-align: center;
      margin-bottom: var(--space-16);
    }

    .ha-section-label {
      display: inline-block;
      padding: var(--space-1) var(--space-4);
      border-radius: var(--radius-full);
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: var(--space-4);
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(20, 184, 166, 0.1));
      color: var(--wc-green);
      border: 1px solid rgba(16, 185, 129, 0.15);
    }

    .ha-section-label-urgent {
      background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(245, 158, 11, 0.1));
      color: var(--wc-red);
      border: 1px solid rgba(239, 68, 68, 0.15);
    }

    .ha-section-title {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 800;
      letter-spacing: -0.035em;
      margin-bottom: var(--space-5);
      color: var(--text-primary);
      line-height: 1.1;
    }

    .ha-section-description {
      font-size: clamp(1rem, 1.5vw, 1.2rem);
      color: var(--text-secondary);
      max-width: 650px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* --- Card base with conic gradient + spotlight --- */
    .ha-card {
      padding: var(--space-8);
      border-radius: var(--radius-2xl);
      background: var(--surface-1);
      border: 1px solid var(--surface-3);
      transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
      position: relative;
      overflow: hidden;
    }

    .ha-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 1.5px;
      background: conic-gradient(from var(--gradient-angle), #10b981, #14b8a6, #06b6d4, #10b981);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: 0;
      transition: opacity 0.5s ease;
      pointer-events: none;
      animation: border-rotate 4s linear infinite;
    }

    .ha-card::after {
      content: '';
      position: absolute;
      width: 300px;
      height: 300px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(16, 185, 129, 0.12), transparent 70%);
      opacity: 0;
      transition: opacity 0.5s ease;
      pointer-events: none;
      top: var(--mouse-y, 50%);
      left: var(--mouse-x, 50%);
      transform: translate(-50%, -50%);
    }

    .ha-card:hover::before { opacity: 1; }
    .ha-card:hover::after { opacity: 1; }
    .ha-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-xl), var(--glow-health);
      background: var(--surface-2);
    }

    /* --- Footer CTA --- */
    .ha-footer-cta {
      text-align: center;
      padding: var(--space-24) var(--space-8);
      background: var(--surface-0);
      border-top: 1px solid var(--surface-3);
    }

    .ha-footer-cta-inner {
      max-width: 700px;
      margin: 0 auto;
    }

    .ha-footer-cta h2 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: var(--space-4);
      color: var(--text-primary);
    }

    .ha-footer-cta p {
      font-size: 1.0625rem;
      color: var(--text-secondary);
      margin-bottom: var(--space-8);
      line-height: 1.7;
    }

    .ha-footer-cta-buttons {
      display: flex;
      gap: var(--space-4);
      justify-content: center;
      flex-wrap: wrap;
    }

    /* --- Buttons --- */
    .ha-btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-4) var(--space-8);
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      border-radius: var(--radius-lg);
      transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
      cursor: pointer;
      border: none;
      white-space: nowrap;
      min-height: 48px;
      line-height: 1;
    }

    .ha-btn-primary {
      background: var(--gradient-teal-emerald);
      color: #0a1a14;
      box-shadow: var(--shadow-md);
    }

    .ha-btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-xl), 0 0 40px rgba(16, 185, 129, 0.25);
      color: #0a1a14;
    }

    .ha-btn-solid {
      background: var(--gradient-primary);
      color: white;
      box-shadow: var(--shadow-md);
    }

    .ha-btn-solid:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-xl), var(--glow-primary);
      color: white;
    }

    .ha-btn-ghost {
      background: transparent;
      color: var(--text-secondary);
      border: 1.5px solid var(--surface-3);
    }

    .ha-btn-ghost:hover {
      background: var(--glass-bg-strong);
      border-color: var(--glass-border-strong);
      color: var(--text-primary);
      transform: translateY(-2px);
    }

    .ha-btn-arrow {
      transition: transform 0.3s ease;
      display: inline-block;
    }

    .ha-btn:hover .ha-btn-arrow {
      transform: translateX(4px);
    }

    /* --- Responsive --- */
    @media (max-width: 1100px) {
      .ha-comparison-grid {
        grid-template-columns: 1fr;
        grid-template-rows: auto;
        gap: var(--space-8);
      }

      .ha-comparison-column {
        grid-template-rows: auto;
        grid-row: auto;
      }

      .ha-stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .ha-wcag-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .ha-topbar {
        padding: var(--space-3) var(--space-4);
      }

      .ha-topbar-title {
        display: none;
      }

      .ha-hero {
        min-height: auto;
        padding: calc(var(--space-24) + var(--space-8)) var(--space-4) var(--space-16);
      }

      .ha-hero-scroll {
        display: none;
      }

      .ha-section-inner {
        padding: var(--space-16) var(--space-4);
      }

      .ha-section-header {
        margin-bottom: var(--space-10);
      }

      .ha-timeline-items {
        grid-template-columns: 1fr;
        gap: var(--space-3);
      }

      .ha-pyramid-level {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .ha-pyramid-icon {
        margin: 0 auto;
      }

      .ha-pyramid-tools {
        justify-content: center;
      }

      .ha-checklist-grid {
        grid-template-columns: 1fr;
      }

      .ha-comparison-grid {
        grid-template-columns: 1fr;
      }

      .ha-stats-grid {
        grid-template-columns: 1fr;
      }

      .ha-wcag-grid {
        grid-template-columns: 1fr;
      }

      .ha-footer-cta-buttons {
        flex-direction: column;
        align-items: stretch;
      }

      .ha-btn {
        width: 100%;
        justify-content: center;
      }

      .ha-hero-deadline {
        flex-direction: column;
        gap: var(--space-2);
      }
    }

    @media (max-width: 480px) {
      .ha-hero-title {
        font-size: clamp(2rem, 10vw, 3rem);
      }

      .ha-topbar-right {
        display: none;
      }
    }

    /* --- Reduced Motion (page-specific additions) --- */
    @media (prefers-reduced-motion: reduce) {
      .ha-hero-orb {
        animation: none !important;
        opacity: 0.15;
      }
    }

    /* --- Focus States --- */
    .ha-btn:focus-visible,
    .ha-back-link:focus-visible,
    .ha-topbar-link:focus-visible,
    .ha-check-card:focus-visible,
    .ha-stat-card:focus-visible {
      outline: 3px solid var(--wc-green);
      outline-offset: 3px;
    }
  </style>

  <!-- Top Navigation Bar -->
  <nav class="ha-topbar" aria-label="Page navigation">
    <div class="ha-topbar-left">
      <a href="/" class="ha-back-link" aria-label="Back to WC-2026 Dashboard">
        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
        Dashboard
      </a>
      <span class="ha-topbar-title" aria-hidden="true">|</span>
      <span class="ha-topbar-title">Healthcare Accessibility</span>
    </div>
    <div class="ha-topbar-right">
      <a href="/pre-planning/components/" class="ha-topbar-link">
        <i class="fa-solid fa-book" aria-hidden="true"></i>
        Full Docs
      </a>
      <a href="/pre-planning/overview/" class="ha-topbar-link">
        <i class="fa-solid fa-clipboard-list" aria-hidden="true"></i>
        Build Plan
      </a>
    </div>
  </nav>

  <main id="main-content">
    <!-- SECTION 1: HERO -->
    <section class="ha-hero" aria-label="Healthcare Accessibility Strategy">
      <div class="ha-hero-grid" aria-hidden="true"></div>
      <div class="ha-hero-orb ha-hero-orb-1" aria-hidden="true"></div>
      <div class="ha-hero-orb ha-hero-orb-2" aria-hidden="true"></div>
      <div class="ha-hero-orb ha-hero-orb-3" aria-hidden="true"></div>

      <div class="ha-hero-content">
        <div class="ha-hero-badge">
          <span class="ha-hero-badge-dot" aria-hidden="true"></span>
          HHS Mandate Active -- Compliance Required
        </div>

        <h1 class="ha-hero-title">Accessibility Is<br />Not Optional</h1>

        <p class="ha-hero-subtitle">WCAG 2.1 AA is now legally required for healthcare. We exceed it.</p>

        <p class="ha-hero-description">
          The HHS final rule mandates WCAG 2.1 Level AA compliance for all healthcare
          organizations receiving federal funding. WC-2026 does not just meet the bar --
          every component is built to <strong>exceed</strong> it, targeting WCAG 2.2 AAA
          for critical interactions. Compliance is the floor, not the ceiling.
        </p>

        <div class="ha-hero-deadline">
          <span class="ha-hero-deadline-label">HHS Compliance Deadline</span>
          <span class="ha-hero-deadline-date">MAY 2026</span>
        </div>
      </div>

      <div class="mouse-scroll-wrap mouse-scroll-wrap--absolute" aria-hidden="true">
        <div class="mouse-scroll-body"><div class="mouse-scroll-wheel"></div></div>
        <span class="mouse-scroll-label">Scroll</span>
      </div>
    </section>

    <!-- SECTION 2: COMPLIANCE LANDSCAPE -->
    <A11yComplianceLandscape />

    <!-- SECTION 3: 4-LEVEL TESTING STRATEGY -->
    <A11yTestingStrategy />

    <!-- SECTION 4: COMPONENT A11Y CHECKLIST -->
    <A11yComponentChecklist />

    <!-- SECTION 5: BEFORE/AFTER COMPARISON -->
    <A11yBeforeAfter
      codeBadButton={codeBadButton}
      codeGoodButton={codeGoodButton}
      codeBadContrast={codeBadContrast}
      codeGoodContrast={codeGoodContrast}
    />

    <!-- SECTION 6: WCAG SUCCESS CRITERIA COVERAGE -->
    <A11yWcagMatrix />

    <!-- SECTION 7: THE BUSINESS CASE -->
    <A11yBusinessCase />

    <!-- FOOTER CTA -->
    <section class="ha-footer-cta" aria-label="Next steps">
      <div class="ha-footer-cta-inner scroll-reveal">
        <h2>Ready to Build Accessible?</h2>
        <p>
          Explore the full documentation for component accessibility patterns,
          testing strategies, and WCAG compliance implementation guides.
        </p>
        <div class="ha-footer-cta-buttons">
          <a href="/pre-planning/components/" class="ha-btn ha-btn-primary">
            Component A11y Docs
            <span class="ha-btn-arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href="/pre-planning/overview/" class="ha-btn ha-btn-ghost">
            Build Plan
            <span class="ha-btn-arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href="/" class="ha-btn ha-btn-ghost">
            Back to Dashboard
            <span class="ha-btn-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Fragment slot="scripts">
    <ScrollRevealScript
      cardSelectors={['.ha-spotlight-card', '.ha-card']}
      enableBarReveal={false}
    />
  </Fragment>
</ShowcaseLayout>
