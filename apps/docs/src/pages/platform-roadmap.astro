---
/**
 * Platform Roadmap - Engineering Health Dashboard
 *
 * Visualizes all platform issues from the centralized issue tracker,
 * categorized by severity with detailed metadata and actionable insights.
 * Reads from .claude/issues/issues.json (TrackedIssue[] data source).
 */
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

interface TrackedIssue {
  id: string;
  title: string;
  description: string;
  severity: 'critical' | 'high' | 'medium' | 'low';
  category: string;
  tags: string[];
  status: 'not-started' | 'in-progress' | 'blocked' | 'complete';
  statusHistory: Array<{ from: string; to: string; date: string; changedBy: string; note?: string }>;
  source: string;
  reporter: string;
  firstSeenIn: string;
  lastSeenIn: string;
  impact?: string;
  recommendation?: string;
  effort?: string;
  owner?: string;
  createdAt: string;
  updatedAt: string;
  resolvedAt?: string;
  notes?: string[];
}

interface IssuesIndex {
  version: string;
  lastUpdated: string;
  stats: {
    total: number;
    bySeverity: Record<string, number>;
    byStatus: Record<string, number>;
    byCategory: Record<string, number>;
    resolvedCount: number;
    resolutionRate: number;
  };
  issues: TrackedIssue[];
}

function loadIssues(): IssuesIndex {
  const issuesPath = join(process.cwd(), '../../.claude/issues/issues.json');
  const content = readFileSync(issuesPath, 'utf-8');
  return JSON.parse(content) as IssuesIndex;
}

const data = loadIssues();
const issues = data.issues;
const stats = data.stats;
---

<ShowcaseLayout
  title="Platform Roadmap &amp; Health"
  description={`Engineering health dashboard showing ${stats.total} issues identified by specialized agents. Track progress from current state to production readiness.`}
>
  <style is:inline>
    :root {
      --roadmap-critical: #dc2626;
      --roadmap-high: #f59e0b;
      --roadmap-medium: #3b82f6;
      --roadmap-low: #10b981;
      --roadmap-complete: #22c55e;
    }

    /* Topbar */
    .roadmap-topbar { position:fixed; top:3.5rem; left:0; right:0; z-index:90; display:flex; align-items:center; justify-content:space-between; padding:1rem 2rem; background:rgba(10,10,20,0.85); backdrop-filter:blur(16px) saturate(180%); border-bottom:1px solid rgba(255,255,255,0.06); }
    .roadmap-back-link { display:inline-flex; align-items:center; gap:0.5rem; font-size:0.875rem; font-weight:600; color:rgba(255,255,255,0.6); transition:all 0.2s ease; padding:0.5rem 0.75rem; border-radius:0.5rem; }
    .roadmap-back-link:hover { color:white; background:rgba(255,255,255,0.08); }
    .roadmap-topbar-title { font-size:0.875rem; font-weight:700; color:white; }

    /* Hero Section — ENHANCED with animated gradient background */
    .roadmap-hero {
      min-height:80vh;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      padding:11.5rem 2rem 4rem;
      position:relative;
      overflow:hidden;
      border-bottom:1px solid rgba(255,255,255,0.06);
    }

    /* Animated gradient background */
    .roadmap-hero::before {
      content:'';
      position:absolute;
      top:-50%;
      left:-50%;
      width:200%;
      height:200%;
      background:
        radial-gradient(circle at 20% 50%, rgba(59,130,246,0.08) 0%, transparent 50%),
        radial-gradient(circle at 80% 50%, rgba(16,185,129,0.08) 0%, transparent 50%),
        radial-gradient(circle at 50% 20%, rgba(102,126,234,0.06) 0%, transparent 50%);
      animation:hero-gradient 20s ease-in-out infinite;
      z-index:0;
    }

    @keyframes hero-gradient {
      0%, 100% { transform:translate(0, 0) rotate(0deg); }
      33% { transform:translate(5%, 5%) rotate(120deg); }
      66% { transform:translate(-5%, 5%) rotate(240deg); }
    }

    .roadmap-hero > * { position:relative; z-index:1; }

    .roadmap-hero-badge { display:inline-flex; align-items:center; gap:0.5rem; padding:0.5rem 1rem; border-radius:2rem; background:rgba(102,126,234,0.1); border:1px solid rgba(102,126,234,0.2); font-size:0.75rem; font-weight:600; color:rgba(102,126,234,0.9); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1.5rem; }
    .roadmap-hero h1 { font-size:3rem; font-weight:900; color:white; text-align:center; margin-bottom:1rem; letter-spacing:-0.02em; }
    .roadmap-hero p { font-size:1.125rem; color:rgba(255,255,255,0.7); text-align:center; max-width:600px; margin-bottom:2rem; }

    /* Executive Summary Section */
    .executive-summary {
      max-width:1200px;
      width:100%;
      margin-top:3rem;
      padding:2rem;
      border-radius:1.5rem;
      background:linear-gradient(135deg, rgba(59,130,246,0.05) 0%, rgba(16,185,129,0.05) 100%);
      border:1px solid rgba(255,255,255,0.1);
      backdrop-filter:blur(10px);
    }

    .executive-summary h2 {
      font-size:1.5rem;
      font-weight:800;
      color:white;
      margin-bottom:1.5rem;
      text-align:center;
      letter-spacing:-0.01em;
    }

    .exec-metrics {
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));
      gap:1.5rem;
    }

    .exec-metric {
      text-align:center;
      padding:1.5rem;
      border-radius:1rem;
      background:rgba(255,255,255,0.03);
      border:1px solid rgba(255,255,255,0.08);
      transition:all 0.3s cubic-bezier(0.22,1,0.36,1);
    }

    .exec-metric:hover {
      transform:translateY(-4px);
      box-shadow:0 12px 40px rgba(0,0,0,0.3);
      border-color:rgba(255,255,255,0.15);
    }

    .exec-metric-value {
      font-size:3rem;
      font-weight:900;
      line-height:1;
      margin-bottom:0.5rem;
      background:linear-gradient(135deg, #3b82f6 0%, #10b981 100%);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
      background-clip:text;
    }

    .exec-metric-label {
      font-size:0.875rem;
      font-weight:600;
      color:rgba(255,255,255,0.6);
      text-transform:uppercase;
      letter-spacing:0.05em;
    }

    .exec-metric-sublabel {
      font-size:0.75rem;
      color:rgba(255,255,255,0.4);
      margin-top:0.25rem;
    }

    /* Stats Grid — ENHANCED with hover lift effect */
    .roadmap-stats {
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(200px, 1fr));
      gap:1.5rem;
      max-width:1000px;
      width:100%;
      margin-top:2rem;
    }

    .roadmap-stat {
      padding:1.5rem;
      border-radius:1rem;
      background:rgba(255,255,255,0.03);
      border:1px solid rgba(255,255,255,0.08);
      text-align:center;
      transition:all 0.3s cubic-bezier(0.22,1,0.36,1);
      position:relative;
      overflow:hidden;
    }

    .roadmap-stat::before {
      content:'';
      position:absolute;
      top:0;
      left:0;
      right:0;
      height:3px;
      background:currentColor;
      opacity:0;
      transition:opacity 0.3s ease;
    }

    .roadmap-stat:hover {
      transform:translateY(-6px);
      box-shadow:0 12px 40px rgba(0,0,0,0.3);
      border-color:rgba(255,255,255,0.15);
    }

    .roadmap-stat:hover::before {
      opacity:0.6;
    }

    .roadmap-stat-value {
      font-size:2.5rem;
      font-weight:900;
      color:white;
      margin-bottom:0.25rem;
    }

    .roadmap-stat-label {
      font-size:0.875rem;
      color:rgba(255,255,255,0.6);
      text-transform:uppercase;
      letter-spacing:0.05em;
      font-weight:600;
    }

    .roadmap-stat.critical .roadmap-stat-value { color:var(--roadmap-critical); }
    .roadmap-stat.critical::before { background:var(--roadmap-critical); }
    .roadmap-stat.high .roadmap-stat-value { color:var(--roadmap-high); }
    .roadmap-stat.high::before { background:var(--roadmap-high); }
    .roadmap-stat.medium .roadmap-stat-value { color:var(--roadmap-medium); }
    .roadmap-stat.medium::before { background:var(--roadmap-medium); }
    .roadmap-stat.low .roadmap-stat-value { color:var(--roadmap-low); }
    .roadmap-stat.low::before { background:var(--roadmap-low); }

    /* Tab Nav */
    .roadmap-tabs { position:sticky; top:7.4rem; z-index:80; background:rgba(10,10,20,0.92); backdrop-filter:blur(20px); border-bottom:1px solid rgba(255,255,255,0.08); }
    .roadmap-tabs-inner { display:flex; max-width:1200px; margin:0 auto; padding:0.5rem; gap:0.5rem; }
    .roadmap-tab { flex:1; padding:0.75rem 1.5rem; border-radius:0.75rem; border:1px solid transparent; background:transparent; color:rgba(255,255,255,0.5); cursor:pointer; transition:all 0.25s ease; font-weight:700; font-size:0.9375rem; text-align:center; }
    .roadmap-tab:hover { color:rgba(255,255,255,0.8); background:rgba(255,255,255,0.04); }
    .roadmap-tab.is-active { color:white; border-color:rgba(102,126,234,0.25); box-shadow:0 0 20px rgba(102,126,234,0.08); }
    .roadmap-tab.is-active.critical { background:rgba(220,38,38,0.1); border-color:rgba(220,38,38,0.25); box-shadow:0 0 20px rgba(220,38,38,0.08); }
    .roadmap-tab.is-active.high { background:rgba(245,158,11,0.1); border-color:rgba(245,158,11,0.25); box-shadow:0 0 20px rgba(245,158,11,0.08); }
    .roadmap-tab.is-active.medium { background:rgba(59,130,246,0.1); border-color:rgba(59,130,246,0.25); box-shadow:0 0 20px rgba(59,130,246,0.08); }
    .roadmap-tab.is-active.low { background:rgba(16,185,129,0.1); border-color:rgba(16,185,129,0.25); box-shadow:0 0 20px rgba(16,185,129,0.08); }

    /* Content */
    .roadmap-content { max-width:1200px; margin:0 auto; padding:2rem; }
    .roadmap-tab-panel { display:none; }
    .roadmap-tab-panel.is-active { display:block; }

    /* Issue Cards — ENHANCED with better hover effects and severity badge glows */
    .roadmap-issues { display:grid; gap:1rem; }
    .roadmap-issue {
      padding:1.5rem;
      border-radius:1rem;
      background:rgba(255,255,255,0.03);
      border:1px solid rgba(255,255,255,0.08);
      transition:all 0.3s cubic-bezier(0.22,1,0.36,1);
      position:relative;
      overflow:hidden;
    }

    .roadmap-issue:hover {
      background:rgba(255,255,255,0.05);
      border-color:rgba(255,255,255,0.12);
      transform:translateY(-4px);
      box-shadow:0 12px 48px rgba(0,0,0,0.3);
    }

    /* Resolved cards — ENHANCED victory state with shimmer and glow */
    .roadmap-issue.is-complete {
      border-color:rgba(34,197,94,0.3);
      background:linear-gradient(135deg, rgba(34,197,94,0.06) 0%, rgba(16,185,129,0.04) 50%, rgba(6,182,212,0.05) 100%);
    }

    .roadmap-issue.is-complete::before {
      content:'';
      position:absolute;
      top:0;
      left:0;
      width:4px;
      height:100%;
      background:linear-gradient(180deg, #22c55e 0%, #10b981 50%, #06b6d4 100%);
      border-radius:4px 0 0 4px;
      opacity:0.8;
      box-shadow:0 0 8px rgba(34,197,94,0.4);
    }

    .roadmap-issue.is-complete::after {
      content:'';
      position:absolute;
      top:0;
      right:0;
      bottom:0;
      width:150px;
      background:linear-gradient(90deg, transparent 0%, rgba(34,197,94,0.05) 100%);
      pointer-events:none;
    }

    .roadmap-issue.is-complete:hover {
      border-color:rgba(34,197,94,0.5);
      background:linear-gradient(135deg, rgba(34,197,94,0.1) 0%, rgba(16,185,129,0.06) 50%, rgba(6,182,212,0.08) 100%);
      box-shadow:0 12px 48px rgba(34,197,94,0.15), 0 0 60px rgba(34,197,94,0.08);
    }

    .roadmap-issue.is-complete .roadmap-issue-title {
      text-decoration:line-through;
      text-decoration-color:rgba(34,197,94,0.4);
      text-decoration-thickness:2px;
    }
    .roadmap-issue-header { display:flex; align-items:flex-start; gap:1rem; margin-bottom:1rem; flex-wrap:wrap; }

    /* Severity badges — ENHANCED with glow effects */
    .roadmap-issue-severity {
      flex-shrink:0;
      padding:0.375rem 0.75rem;
      border-radius:0.5rem;
      font-size:0.75rem;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:0.05em;
      position:relative;
    }

    .roadmap-issue-severity.critical {
      background:rgba(220,38,38,0.15);
      color:#fca5a5;
      border:1px solid rgba(220,38,38,0.3);
      box-shadow:0 0 12px rgba(220,38,38,0.2), inset 0 0 8px rgba(220,38,38,0.1);
    }

    .roadmap-issue:hover .roadmap-issue-severity.critical {
      box-shadow:0 0 20px rgba(220,38,38,0.4), inset 0 0 12px rgba(220,38,38,0.15);
    }

    .roadmap-issue-severity.high {
      background:rgba(245,158,11,0.15);
      color:#fcd34d;
      border:1px solid rgba(245,158,11,0.3);
      box-shadow:0 0 12px rgba(245,158,11,0.2), inset 0 0 8px rgba(245,158,11,0.1);
    }

    .roadmap-issue:hover .roadmap-issue-severity.high {
      box-shadow:0 0 20px rgba(245,158,11,0.4), inset 0 0 12px rgba(245,158,11,0.15);
    }

    .roadmap-issue-severity.medium {
      background:rgba(59,130,246,0.15);
      color:#93c5fd;
      border:1px solid rgba(59,130,246,0.3);
      box-shadow:0 0 12px rgba(59,130,246,0.2), inset 0 0 8px rgba(59,130,246,0.1);
    }

    .roadmap-issue:hover .roadmap-issue-severity.medium {
      box-shadow:0 0 20px rgba(59,130,246,0.4), inset 0 0 12px rgba(59,130,246,0.15);
    }

    .roadmap-issue-severity.low {
      background:rgba(16,185,129,0.15);
      color:#6ee7b7;
      border:1px solid rgba(16,185,129,0.3);
      box-shadow:0 0 12px rgba(16,185,129,0.2), inset 0 0 8px rgba(16,185,129,0.1);
    }

    .roadmap-issue:hover .roadmap-issue-severity.low {
      box-shadow:0 0 20px rgba(16,185,129,0.4), inset 0 0 12px rgba(16,185,129,0.15);
    }
    .roadmap-issue-status { flex-shrink:0; padding:0.375rem 0.75rem; border-radius:0.5rem; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-left:auto; }
    .roadmap-issue-status.complete { background:linear-gradient(135deg, rgba(34,197,94,0.2) 0%, rgba(16,185,129,0.15) 100%); color:#86efac; border:1px solid rgba(34,197,94,0.35); box-shadow:0 0 12px rgba(34,197,94,0.15), inset 0 0 8px rgba(34,197,94,0.05); position:relative; overflow:hidden; }
    .roadmap-issue-status.complete::before { content:'✓'; margin-right:0.25rem; font-weight:900; }
    .roadmap-issue-status.complete::after { content:''; position:absolute; inset:0; background:linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.08) 50%, transparent 100%); background-size:200% 100%; animation:resolved-shimmer 3s ease-in-out infinite; }
    @keyframes resolved-shimmer { 0%,100% { background-position:-200% 0; } 50% { background-position:200% 0; } }
    .roadmap-issue-title-block { flex:1; min-width:0; }
    .roadmap-issue-title { font-size:1.125rem; font-weight:700; color:white; margin-bottom:0.25rem; }
    .roadmap-issue-meta { font-size:0.875rem; color:rgba(255,255,255,0.5); }
    .roadmap-issue-description { font-size:0.9375rem; color:rgba(255,255,255,0.7); line-height:1.6; margin-bottom:1rem; }
    .roadmap-issue-footer { display:flex; gap:1rem; flex-wrap:wrap; }
    .roadmap-issue-detail { font-size:0.8125rem; color:rgba(255,255,255,0.6); }
    .roadmap-issue-detail strong { color:rgba(255,255,255,0.9); font-weight:600; }

    /* Charts Section */
    .charts-section {
      max-width:1200px;
      width:100%;
      margin:3rem auto;
      padding:0 2rem;
    }

    .charts-grid {
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(350px, 1fr));
      gap:2rem;
    }

    .chart-card {
      padding:2rem;
      border-radius:1.5rem;
      background:rgba(255,255,255,0.03);
      border:1px solid rgba(255,255,255,0.08);
      transition:all 0.3s cubic-bezier(0.22,1,0.36,1);
    }

    .chart-card:hover {
      transform:translateY(-4px);
      box-shadow:0 12px 48px rgba(0,0,0,0.3);
      border-color:rgba(255,255,255,0.12);
    }

    .chart-title {
      font-size:1.25rem;
      font-weight:700;
      color:white;
      margin-bottom:1.5rem;
      text-align:center;
    }

    .chart-legend {
      display:flex;
      flex-wrap:wrap;
      gap:1rem;
      margin-top:1.5rem;
      justify-content:center;
    }

    .legend-item {
      display:flex;
      align-items:center;
      gap:0.5rem;
      font-size:0.875rem;
      color:rgba(255,255,255,0.7);
    }

    .legend-color {
      width:12px;
      height:12px;
      border-radius:3px;
    }

    /* Progress Bar — ENHANCED with smooth animation */
    .progress-wrapper {
      max-width:600px;
      width:100%;
      margin-top:2rem;
    }

    .progress-header {
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:0.5rem;
    }

    .progress-label {
      font-size:0.875rem;
      font-weight:600;
      color:rgba(255,255,255,0.6);
    }

    .progress-percentage {
      font-size:1.5rem;
      font-weight:900;
      color:#22c55e;
      text-shadow:0 0 20px rgba(34,197,94,0.4);
    }

    .progress-bar-outer {
      width:100%;
      height:12px;
      border-radius:6px;
      background:rgba(255,255,255,0.06);
      overflow:hidden;
      position:relative;
    }

    .progress-bar-inner {
      height:100%;
      border-radius:6px;
      background:linear-gradient(90deg, #22c55e 0%, #10b981 50%, #06b6d4 100%);
      transition:width 1s cubic-bezier(0.22,1,0.36,1);
      box-shadow:0 0 20px rgba(34,197,94,0.4);
      position:relative;
      overflow:hidden;
    }

    .progress-bar-inner::after {
      content:'';
      position:absolute;
      top:0;
      left:0;
      right:0;
      bottom:0;
      background:linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.2) 50%, transparent 100%);
      background-size:200% 100%;
      animation:progress-shimmer 2s ease-in-out infinite;
    }

    @keyframes progress-shimmer {
      0%, 100% { background-position:-200% 0; }
      50% { background-position:200% 0; }
    }

    .progress-footer {
      display:flex;
      justify-content:space-between;
      margin-top:0.5rem;
    }

    .progress-count {
      font-size:0.75rem;
      color:rgba(255,255,255,0.4);
    }

    /* Status history timeline */
    .status-timeline {
      margin-top:1rem;
      padding-left:1rem;
      border-left:2px solid rgba(34,197,94,0.2);
    }

    .timeline-item {
      margin-bottom:0.75rem;
      padding-left:1rem;
      position:relative;
    }

    .timeline-item::before {
      content:'';
      position:absolute;
      left:-1.3rem;
      top:0.25rem;
      width:10px;
      height:10px;
      border-radius:50%;
      background:#22c55e;
      box-shadow:0 0 8px rgba(34,197,94,0.4);
    }

    .timeline-date {
      font-size:0.75rem;
      color:rgba(255,255,255,0.4);
    }

    .timeline-change {
      font-size:0.875rem;
      color:rgba(255,255,255,0.7);
      margin-top:0.25rem;
    }

    /* Accessibility: respect reduced motion preference */
    @media (prefers-reduced-motion: reduce) {
      .roadmap-hero::before,
      .progress-bar-inner::after,
      .roadmap-issue-status.complete::after,
      * {
        animation:none !important;
        transition:none !important;
      }
    }

    /* Print styles for stakeholder reports */
    @media print {
      .roadmap-topbar,
      .roadmap-tabs,
      .roadmap-back-link { display:none; }
      .roadmap-hero { min-height:auto; padding:2rem; }
      .roadmap-hero::before { display:none; }
      .roadmap-issue { page-break-inside:avoid; }
      .executive-summary { page-break-after:always; }
      .charts-section { page-break-after:always; }
      body { background:white; color:black; }
      .roadmap-issue,
      .roadmap-stat,
      .exec-metric,
      .chart-card { border-color:#ccc; background:white; }
    }

    @media (max-width: 768px) {
      .roadmap-hero h1 { font-size:2rem; }
      .roadmap-stats { grid-template-columns:repeat(2, 1fr); }
      .roadmap-tabs-inner { flex-wrap:wrap; }
      .exec-metrics { grid-template-columns:1fr; }
      .charts-grid { grid-template-columns:1fr; }
    }
  </style>

  <!-- Topbar -->
  <div class="roadmap-topbar">
    <a href="/" class="roadmap-back-link">
      <i class="fa-solid fa-arrow-left"></i>
      Back to Docs
    </a>
    <div class="roadmap-topbar-title">Platform Health Dashboard</div>
  </div>

  <!-- Hero -->
  <div class="roadmap-hero">
    <div class="roadmap-hero-badge">
      <i class="fa-solid fa-chart-line"></i>
      Engineering Health Review
    </div>
    <h1>Platform Roadmap</h1>
    <p>
      Comprehensive review findings from specialized engineering agents,
      identifying {stats.total} issues across all severity levels.
    </p>

    <!-- Executive Summary -->
    <div class="executive-summary">
      <h2>Executive Summary</h2>
      <div class="exec-metrics">
        <div class="exec-metric">
          <div class="exec-metric-value">{stats.total}</div>
          <div class="exec-metric-label">Total Issues</div>
          <div class="exec-metric-sublabel">Tracked in system</div>
        </div>
        <div class="exec-metric">
          <div class="exec-metric-value">{stats.resolvedCount}</div>
          <div class="exec-metric-label">Resolved</div>
          <div class="exec-metric-sublabel">{Math.round(stats.resolutionRate * 100)}% completion</div>
        </div>
        <div class="exec-metric">
          <div class="exec-metric-value">{stats.total - stats.resolvedCount}</div>
          <div class="exec-metric-label">In Progress</div>
          <div class="exec-metric-sublabel">Active work items</div>
        </div>
        <div class="exec-metric">
          <div class="exec-metric-value">
            {(() => {
              const updated = new Date(data.lastUpdated);
              const now = new Date();
              const days = Math.floor((now.getTime() - updated.getTime()) / (1000 * 60 * 60 * 24));
              return days === 0 ? '<1' : days;
            })()}
          </div>
          <div class="exec-metric-label">Days Since Update</div>
          <div class="exec-metric-sublabel">Last sync: {new Date(data.lastUpdated).toLocaleDateString()}</div>
        </div>
      </div>
    </div>

    <div class="roadmap-stats">
      <div class="roadmap-stat critical">
        <div class="roadmap-stat-value">{stats.bySeverity.critical ?? 0}</div>
        <div class="roadmap-stat-label">Critical</div>
      </div>
      <div class="roadmap-stat high">
        <div class="roadmap-stat-value">{stats.bySeverity.high ?? 0}</div>
        <div class="roadmap-stat-label">High Priority</div>
      </div>
      <div class="roadmap-stat medium">
        <div class="roadmap-stat-value">{stats.bySeverity.medium ?? 0}</div>
        <div class="roadmap-stat-label">Medium</div>
      </div>
      <div class="roadmap-stat low">
        <div class="roadmap-stat-value">{stats.bySeverity.low ?? 0}</div>
        <div class="roadmap-stat-label">Low Priority</div>
      </div>
    </div>

    <!-- Resolution Progress — ENHANCED -->
    <div class="progress-wrapper">
      <div class="progress-header">
        <span class="progress-label">Resolution Progress</span>
        <span class="progress-percentage">{Math.round(stats.resolutionRate * 100)}%</span>
      </div>
      <div class="progress-bar-outer">
        <div class="progress-bar-inner" style={`width:${stats.resolutionRate * 100}%;`}></div>
      </div>
      <div class="progress-footer">
        <span class="progress-count">{stats.resolvedCount} resolved</span>
        <span class="progress-count">{stats.total - stats.resolvedCount} remaining</span>
      </div>
    </div>

    <!-- View Full Tracker Link -->
    <div style="margin-top:2rem;">
      <a href="http://localhost:3159/roadmap" target="_blank" rel="noopener noreferrer"
         style="display:inline-flex; align-items:center; gap:0.75rem; padding:0.75rem 1.5rem; border-radius:0.75rem; background:rgba(102,126,234,0.1); border:1px solid rgba(102,126,234,0.2); color:rgba(102,126,234,0.9); font-weight:700; font-size:0.875rem; text-decoration:none; transition:all 0.3s ease;"
         onmouseover="this.style.background='rgba(102,126,234,0.2)'; this.style.borderColor='rgba(102,126,234,0.4)'"
         onmouseout="this.style.background='rgba(102,126,234,0.1)'; this.style.borderColor='rgba(102,126,234,0.2)'">
        <i class="fa-solid fa-arrow-up-right-from-square"></i>
        View Full Issue Tracker
        <span style="font-size:0.75rem; opacity:0.6;">&rarr;</span>
      </a>
    </div>

    <!-- Last Updated -->
    <div style="margin-top:1.5rem; font-size:0.75rem; color:rgba(255,255,255,0.3);">
      Last updated: {new Date(data.lastUpdated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' })}
    </div>
  </div>

  <!-- Charts Section -->
  <div class="charts-section">
    <div class="charts-grid">
      <!-- Severity Breakdown Donut Chart -->
      <div class="chart-card">
        <div class="chart-title">Severity Distribution</div>
        <svg viewBox="0 0 200 200" style="max-width:250px; margin:0 auto; display:block;">
          <defs>
            <filter id="glow-critical">
              <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
              <feMerge>
                <feMergeNode in="coloredBlur"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
            <filter id="glow-high">
              <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
              <feMerge>
                <feMergeNode in="coloredBlur"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
          </defs>
          {(() => {
            const total = stats.total;
            const critical = stats.bySeverity.critical ?? 0;
            const high = stats.bySeverity.high ?? 0;
            const medium = stats.bySeverity.medium ?? 0;
            const low = stats.bySeverity.low ?? 0;

            let offset = 0;
            const radius = 80;
            const circumference = 2 * Math.PI * radius;

            const segments = [
              { value: critical, color: '#dc2626', label: 'Critical', filter: 'url(#glow-critical)' },
              { value: high, color: '#f59e0b', label: 'High', filter: 'url(#glow-high)' },
              { value: medium, color: '#3b82f6', label: 'Medium', filter: 'none' },
              { value: low, color: '#10b981', label: 'Low', filter: 'none' }
            ];

            return segments.map((seg) => {
              const percentage = seg.value / total;
              const dashLength = circumference * percentage;
              const dashOffset = -offset;
              offset += dashLength;

              return `
                <circle
                  cx="100"
                  cy="100"
                  r="${radius}"
                  fill="none"
                  stroke="${seg.color}"
                  stroke-width="30"
                  stroke-dasharray="${dashLength} ${circumference}"
                  stroke-dashoffset="${dashOffset}"
                  transform="rotate(-90 100 100)"
                  filter="${seg.filter}"
                  opacity="0.9"
                />
              `;
            }).join('');
          })()}
          <circle cx="100" cy="100" r="50" fill="rgba(10,10,20,0.8)"/>
          <text x="100" y="95" text-anchor="middle" fill="white" font-size="28" font-weight="900">{stats.total}</text>
          <text x="100" y="115" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-size="12" font-weight="600">ISSUES</text>
        </svg>
        <div class="chart-legend">
          <div class="legend-item">
            <div class="legend-color" style="background:#dc2626;"></div>
            <span>Critical ({stats.bySeverity.critical ?? 0})</span>
          </div>
          <div class="legend-item">
            <div class="legend-color" style="background:#f59e0b;"></div>
            <span>High ({stats.bySeverity.high ?? 0})</span>
          </div>
          <div class="legend-item">
            <div class="legend-color" style="background:#3b82f6;"></div>
            <span>Medium ({stats.bySeverity.medium ?? 0})</span>
          </div>
          <div class="legend-item">
            <div class="legend-color" style="background:#10b981;"></div>
            <span>Low ({stats.bySeverity.low ?? 0})</span>
          </div>
        </div>
      </div>

      <!-- Category Breakdown Bar Chart -->
      <div class="chart-card">
        <div class="chart-title">Issues by Category</div>
        <svg viewBox="0 0 400 300" style="width:100%; max-width:400px; margin:0 auto; display:block;">
          {(() => {
            const categories = Object.entries(stats.byCategory).sort((a, b) => b[1] - a[1]);
            const maxValue = Math.max(...categories.map(([_, v]) => v));
            const barHeight = 20;
            const barSpacing = 10;
            const startY = 20;

            return categories.map(([category, count], index) => {
              const barWidth = (count / maxValue) * 300;
              const y = startY + index * (barHeight + barSpacing);
              const colors = ['#3b82f6', '#10b981', '#f59e0b', '#dc2626', '#8b5cf6'];
              const color = colors[index % colors.length];

              return `
                <g>
                  <rect
                    x="90"
                    y="${y}"
                    width="${barWidth}"
                    height="${barHeight}"
                    fill="${color}"
                    opacity="0.8"
                    rx="4"
                  />
                  <text
                    x="85"
                    y="${y + barHeight / 2 + 5}"
                    text-anchor="end"
                    fill="rgba(255,255,255,0.7)"
                    font-size="11"
                    font-weight="600"
                  >${category}</text>
                  <text
                    x="${95 + barWidth}"
                    y="${y + barHeight / 2 + 5}"
                    fill="white"
                    font-size="12"
                    font-weight="700"
                  >${count}</text>
                </g>
              `;
            }).join('');
          })()}
        </svg>
      </div>

      <!-- Status Overview -->
      <div class="chart-card">
        <div class="chart-title">Resolution Status</div>
        <svg viewBox="0 0 300 200" style="width:100%; max-width:300px; margin:0 auto; display:block;">
          {(() => {
            const statuses = [
              { label: 'Resolved', count: stats.byStatus.complete ?? 0, color: '#22c55e', y: 40 },
              { label: 'In Progress', count: stats.byStatus['in-progress'] ?? 0, color: '#f59e0b', y: 80 },
              { label: 'Blocked', count: stats.byStatus.blocked ?? 0, color: '#dc2626', y: 120 },
              { label: 'Not Started', count: stats.byStatus['not-started'] ?? 0, color: '#6b7280', y: 160 }
            ];

            return statuses.map((status) => {
              const barWidth = (status.count / stats.total) * 200;
              return `
                <g>
                  <text
                    x="10"
                    y="${status.y - 5}"
                    fill="rgba(255,255,255,0.7)"
                    font-size="12"
                    font-weight="600"
                  >${status.label}</text>
                  <rect
                    x="10"
                    y="${status.y}"
                    width="${barWidth}"
                    height="20"
                    fill="${status.color}"
                    opacity="0.8"
                    rx="4"
                  />
                  <text
                    x="${15 + barWidth}"
                    y="${status.y + 15}"
                    fill="white"
                    font-size="14"
                    font-weight="700"
                  >${status.count}</text>
                </g>
              `;
            }).join('');
          })()}
        </svg>
      </div>
    </div>
  </div>

  <!-- Tab Navigation -->
  <div class="roadmap-tabs">
    <div class="roadmap-tabs-inner">
      <button class="roadmap-tab critical is-active" data-tab="critical">
        Critical ({stats.bySeverity.critical ?? 0})
      </button>
      <button class="roadmap-tab high" data-tab="high">
        High ({stats.bySeverity.high ?? 0})
      </button>
      <button class="roadmap-tab medium" data-tab="medium">
        Medium ({stats.bySeverity.medium ?? 0})
      </button>
      <button class="roadmap-tab low" data-tab="low">
        Low ({stats.bySeverity.low ?? 0})
      </button>
    </div>
  </div>

  <!-- Tab Content -->
  <div class="roadmap-content">
    {['critical', 'high', 'medium', 'low'].map((severity) => (
      <div class={`roadmap-tab-panel ${severity === 'critical' ? 'is-active' : ''}`} data-panel={severity}>
        <div class="roadmap-issues">
          {issues
            .filter((issue) => issue.severity === severity)
            .map((issue) => (
              <div class={`roadmap-issue ${issue.status === 'complete' ? 'is-complete' : ''}`}>
                <div class="roadmap-issue-header">
                  <span class={`roadmap-issue-severity ${issue.severity}`}>{issue.severity}</span>
                  <div class="roadmap-issue-title-block">
                    <div class="roadmap-issue-title">{issue.title}</div>
                    <div class="roadmap-issue-meta">
                      Reported by: {issue.reporter} &bull; ID: {issue.id}
                    </div>
                  </div>
                  {issue.status === 'complete' && (
                    <span class="roadmap-issue-status complete">Resolved</span>
                  )}
                </div>
                <div class="roadmap-issue-description">{issue.description}</div>
                <div class="roadmap-issue-footer">
                  {issue.impact && (
                    <div class="roadmap-issue-detail">
                      <strong>Impact:</strong> {issue.impact}
                    </div>
                  )}
                  {issue.effort && (
                    <div class="roadmap-issue-detail">
                      <strong>Effort:</strong> {issue.effort}
                    </div>
                  )}
                  {issue.category && (
                    <div class="roadmap-issue-detail">
                      <strong>Category:</strong> {issue.category}
                    </div>
                  )}
                </div>

                {/* Status History Timeline for Resolved Issues */}
                {issue.status === 'complete' && issue.statusHistory && issue.statusHistory.length > 0 && (
                  <div class="status-timeline">
                    {issue.statusHistory.map((history) => (
                      <div class="timeline-item">
                        <div class="timeline-date">
                          {new Date(history.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                        </div>
                        <div class="timeline-change">
                          <strong>{history.from}</strong> → <strong>{history.to}</strong>
                          {history.changedBy && ` by ${history.changedBy}`}
                          {history.note && (
                            <div style="font-size:0.8125rem; color:rgba(255,255,255,0.5); margin-top:0.25rem;">
                              {history.note}
                            </div>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ))}
        </div>
      </div>
    ))}
  </div>

  <script>
    // Tab switching
    const tabs = document.querySelectorAll('.roadmap-tab');
    const panels = document.querySelectorAll('.roadmap-tab-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetTab = tab.getAttribute('data-tab');

        // Update active tab
        tabs.forEach((t) => t.classList.remove('is-active'));
        tab.classList.add('is-active');

        // Update active panel
        panels.forEach((p) => p.classList.remove('is-active'));
        document.querySelector(`[data-panel="${targetTab}"]`)?.classList.add('is-active');
      });
    });
  </script>
</ShowcaseLayout>
