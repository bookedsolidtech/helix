---
/**
 * Platform Roadmap - Engineering Health Dashboard
 *
 * Visualizes all platform issues from the centralized issue tracker,
 * categorized by severity with detailed metadata and actionable insights.
 * Reads from .claude/issues/issues.json (TrackedIssue[] data source).
 */
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';

interface TrackedIssue {
  id: string;
  title: string;
  description: string;
  severity: 'critical' | 'high' | 'medium' | 'low';
  category: string;
  tags: string[];
  status: 'not-started' | 'in-progress' | 'blocked' | 'complete';
  statusHistory: Array<{ from: string; to: string; date: string; changedBy: string; note?: string }>;
  source: string;
  reporter: string;
  firstSeenIn: string;
  lastSeenIn: string;
  impact?: string;
  recommendation?: string;
  effort?: string;
  owner?: string;
  createdAt: string;
  updatedAt: string;
  resolvedAt?: string;
  notes?: string[];
}

interface IssuesIndex {
  version: string;
  lastUpdated: string;
  stats: {
    total: number;
    bySeverity: Record<string, number>;
    byStatus: Record<string, number>;
    byCategory: Record<string, number>;
    resolvedCount: number;
    resolutionRate: number;
  };
  issues: TrackedIssue[];
}

function loadIssues(): IssuesIndex {
  const issuesPath = join(process.cwd(), '../../.claude/issues/issues.json');
  const content = readFileSync(issuesPath, 'utf-8');
  return JSON.parse(content) as IssuesIndex;
}

const data = loadIssues();
const issues = data.issues;
const stats = data.stats;
---

<ShowcaseLayout
  title="Platform Roadmap &amp; Health"
  description={`Engineering health dashboard showing ${stats.total} issues identified by specialized agents. Track progress from current state to production readiness.`}
>
  <style is:inline>
    :root {
      --roadmap-critical: #dc2626;
      --roadmap-high: #f59e0b;
      --roadmap-medium: #3b82f6;
      --roadmap-low: #10b981;
      --roadmap-complete: #22c55e;
    }

    /* Topbar */
    .roadmap-topbar { position:fixed; top:3.5rem; left:0; right:0; z-index:90; display:flex; align-items:center; justify-content:space-between; padding:1rem 2rem; background:rgba(10,10,20,0.85); backdrop-filter:blur(16px) saturate(180%); border-bottom:1px solid rgba(255,255,255,0.06); }
    .roadmap-back-link { display:inline-flex; align-items:center; gap:0.5rem; font-size:0.875rem; font-weight:600; color:rgba(255,255,255,0.6); transition:all 0.2s ease; padding:0.5rem 0.75rem; border-radius:0.5rem; }
    .roadmap-back-link:hover { color:white; background:rgba(255,255,255,0.08); }
    .roadmap-topbar-title { font-size:0.875rem; font-weight:700; color:white; }

    /* Hero Section */
    .roadmap-hero { min-height:60vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:11.5rem 2rem 4rem; background:linear-gradient(180deg, rgba(102,126,234,0.05) 0%, transparent 100%); border-bottom:1px solid rgba(255,255,255,0.06); }
    .roadmap-hero-badge { display:inline-flex; align-items:center; gap:0.5rem; padding:0.5rem 1rem; border-radius:2rem; background:rgba(102,126,234,0.1); border:1px solid rgba(102,126,234,0.2); font-size:0.75rem; font-weight:600; color:rgba(102,126,234,0.9); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1.5rem; }
    .roadmap-hero h1 { font-size:3rem; font-weight:900; color:white; text-align:center; margin-bottom:1rem; letter-spacing:-0.02em; }
    .roadmap-hero p { font-size:1.125rem; color:rgba(255,255,255,0.7); text-align:center; max-width:600px; margin-bottom:2rem; }

    /* Stats Grid */
    .roadmap-stats { display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:1.5rem; max-width:1000px; width:100%; margin-top:2rem; }
    .roadmap-stat { padding:1.5rem; border-radius:1rem; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); text-align:center; }
    .roadmap-stat-value { font-size:2.5rem; font-weight:900; color:white; margin-bottom:0.25rem; }
    .roadmap-stat-label { font-size:0.875rem; color:rgba(255,255,255,0.6); text-transform:uppercase; letter-spacing:0.05em; font-weight:600; }
    .roadmap-stat.critical .roadmap-stat-value { color:var(--roadmap-critical); }
    .roadmap-stat.high .roadmap-stat-value { color:var(--roadmap-high); }
    .roadmap-stat.medium .roadmap-stat-value { color:var(--roadmap-medium); }
    .roadmap-stat.low .roadmap-stat-value { color:var(--roadmap-low); }

    /* Tab Nav */
    .roadmap-tabs { position:sticky; top:7.4rem; z-index:80; background:rgba(10,10,20,0.92); backdrop-filter:blur(20px); border-bottom:1px solid rgba(255,255,255,0.08); }
    .roadmap-tabs-inner { display:flex; max-width:1200px; margin:0 auto; padding:0.5rem; gap:0.5rem; }
    .roadmap-tab { flex:1; padding:0.75rem 1.5rem; border-radius:0.75rem; border:1px solid transparent; background:transparent; color:rgba(255,255,255,0.5); cursor:pointer; transition:all 0.25s ease; font-weight:700; font-size:0.9375rem; text-align:center; }
    .roadmap-tab:hover { color:rgba(255,255,255,0.8); background:rgba(255,255,255,0.04); }
    .roadmap-tab.is-active { color:white; border-color:rgba(102,126,234,0.25); box-shadow:0 0 20px rgba(102,126,234,0.08); }
    .roadmap-tab.is-active.critical { background:rgba(220,38,38,0.1); border-color:rgba(220,38,38,0.25); box-shadow:0 0 20px rgba(220,38,38,0.08); }
    .roadmap-tab.is-active.high { background:rgba(245,158,11,0.1); border-color:rgba(245,158,11,0.25); box-shadow:0 0 20px rgba(245,158,11,0.08); }
    .roadmap-tab.is-active.medium { background:rgba(59,130,246,0.1); border-color:rgba(59,130,246,0.25); box-shadow:0 0 20px rgba(59,130,246,0.08); }
    .roadmap-tab.is-active.low { background:rgba(16,185,129,0.1); border-color:rgba(16,185,129,0.25); box-shadow:0 0 20px rgba(16,185,129,0.08); }

    /* Content */
    .roadmap-content { max-width:1200px; margin:0 auto; padding:2rem; }
    .roadmap-tab-panel { display:none; }
    .roadmap-tab-panel.is-active { display:block; }

    /* Issue Cards */
    .roadmap-issues { display:grid; gap:1rem; }
    .roadmap-issue { padding:1.5rem; border-radius:1rem; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); transition:all 0.3s cubic-bezier(0.22,1,0.36,1); position:relative; overflow:hidden; }
    .roadmap-issue:hover { background:rgba(255,255,255,0.05); border-color:rgba(255,255,255,0.12); transform:translateY(-1px); box-shadow:0 8px 32px rgba(0,0,0,0.2); }

    /* Resolved cards — victory state with green accent glow */
    .roadmap-issue.is-complete { border-color:rgba(34,197,94,0.25); background:linear-gradient(135deg, rgba(34,197,94,0.04) 0%, rgba(16,185,129,0.02) 50%, rgba(6,182,212,0.03) 100%); }
    .roadmap-issue.is-complete::before { content:''; position:absolute; top:0; left:0; width:4px; height:100%; background:linear-gradient(180deg, #22c55e 0%, #10b981 50%, #06b6d4 100%); border-radius:4px 0 0 4px; opacity:0.8; }
    .roadmap-issue.is-complete::after { content:''; position:absolute; top:0; right:0; bottom:0; width:120px; background:linear-gradient(90deg, transparent 0%, rgba(34,197,94,0.03) 100%); pointer-events:none; }
    .roadmap-issue.is-complete:hover { border-color:rgba(34,197,94,0.4); background:linear-gradient(135deg, rgba(34,197,94,0.07) 0%, rgba(16,185,129,0.04) 50%, rgba(6,182,212,0.05) 100%); box-shadow:0 8px 32px rgba(34,197,94,0.1), 0 0 40px rgba(34,197,94,0.05); }
    .roadmap-issue.is-complete .roadmap-issue-title { text-decoration:line-through; text-decoration-color:rgba(34,197,94,0.4); text-decoration-thickness:2px; }
    .roadmap-issue-header { display:flex; align-items:flex-start; gap:1rem; margin-bottom:1rem; flex-wrap:wrap; }
    .roadmap-issue-severity { flex-shrink:0; padding:0.375rem 0.75rem; border-radius:0.5rem; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; }
    .roadmap-issue-severity.critical { background:rgba(220,38,38,0.15); color:#fca5a5; border:1px solid rgba(220,38,38,0.3); }
    .roadmap-issue-severity.high { background:rgba(245,158,11,0.15); color:#fcd34d; border:1px solid rgba(245,158,11,0.3); }
    .roadmap-issue-severity.medium { background:rgba(59,130,246,0.15); color:#93c5fd; border:1px solid rgba(59,130,246,0.3); }
    .roadmap-issue-severity.low { background:rgba(16,185,129,0.15); color:#6ee7b7; border:1px solid rgba(16,185,129,0.3); }
    .roadmap-issue-status { flex-shrink:0; padding:0.375rem 0.75rem; border-radius:0.5rem; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-left:auto; }
    .roadmap-issue-status.complete { background:linear-gradient(135deg, rgba(34,197,94,0.2) 0%, rgba(16,185,129,0.15) 100%); color:#86efac; border:1px solid rgba(34,197,94,0.35); box-shadow:0 0 12px rgba(34,197,94,0.15), inset 0 0 8px rgba(34,197,94,0.05); position:relative; overflow:hidden; }
    .roadmap-issue-status.complete::before { content:'✓'; margin-right:0.25rem; font-weight:900; }
    .roadmap-issue-status.complete::after { content:''; position:absolute; inset:0; background:linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.08) 50%, transparent 100%); background-size:200% 100%; animation:resolved-shimmer 3s ease-in-out infinite; }
    @keyframes resolved-shimmer { 0%,100% { background-position:-200% 0; } 50% { background-position:200% 0; } }
    .roadmap-issue-title-block { flex:1; min-width:0; }
    .roadmap-issue-title { font-size:1.125rem; font-weight:700; color:white; margin-bottom:0.25rem; }
    .roadmap-issue-meta { font-size:0.875rem; color:rgba(255,255,255,0.5); }
    .roadmap-issue-description { font-size:0.9375rem; color:rgba(255,255,255,0.7); line-height:1.6; margin-bottom:1rem; }
    .roadmap-issue-footer { display:flex; gap:1rem; flex-wrap:wrap; }
    .roadmap-issue-detail { font-size:0.8125rem; color:rgba(255,255,255,0.6); }
    .roadmap-issue-detail strong { color:rgba(255,255,255,0.9); font-weight:600; }

    @media (max-width: 768px) {
      .roadmap-hero h1 { font-size:2rem; }
      .roadmap-stats { grid-template-columns:repeat(2, 1fr); }
      .roadmap-tabs-inner { flex-wrap:wrap; }
    }
  </style>

  <!-- Topbar -->
  <div class="roadmap-topbar">
    <a href="/" class="roadmap-back-link">
      <i class="fa-solid fa-arrow-left"></i>
      Back to Docs
    </a>
    <div class="roadmap-topbar-title">Platform Health Dashboard</div>
  </div>

  <!-- Hero -->
  <div class="roadmap-hero">
    <div class="roadmap-hero-badge">
      <i class="fa-solid fa-chart-line"></i>
      Engineering Health Review
    </div>
    <h1>Platform Roadmap</h1>
    <p>
      Comprehensive review findings from specialized engineering agents,
      identifying {stats.total} issues across all severity levels.
    </p>

    <div class="roadmap-stats">
      <div class="roadmap-stat critical">
        <div class="roadmap-stat-value">{stats.bySeverity.critical ?? 0}</div>
        <div class="roadmap-stat-label">Critical</div>
      </div>
      <div class="roadmap-stat high">
        <div class="roadmap-stat-value">{stats.bySeverity.high ?? 0}</div>
        <div class="roadmap-stat-label">High Priority</div>
      </div>
      <div class="roadmap-stat medium">
        <div class="roadmap-stat-value">{stats.bySeverity.medium ?? 0}</div>
        <div class="roadmap-stat-label">Medium</div>
      </div>
      <div class="roadmap-stat low">
        <div class="roadmap-stat-value">{stats.bySeverity.low ?? 0}</div>
        <div class="roadmap-stat-label">Low Priority</div>
      </div>
    </div>

    <!-- Resolution Progress -->
    <div style="max-width:600px; width:100%; margin-top:2rem;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
        <span style="font-size:0.875rem; font-weight:600; color:rgba(255,255,255,0.6);">Resolution Progress</span>
        <span style="font-size:1.25rem; font-weight:900; color:#22c55e;">{Math.round(stats.resolutionRate * 100)}%</span>
      </div>
      <div style="width:100%; height:8px; border-radius:4px; background:rgba(255,255,255,0.06); overflow:hidden;">
        <div style={`width:${stats.resolutionRate * 100}%; height:100%; border-radius:4px; background:linear-gradient(90deg, #22c55e 0%, #10b981 50%, #06b6d4 100%); transition:width 0.5s ease;`}></div>
      </div>
      <div style="display:flex; justify-content:space-between; margin-top:0.5rem;">
        <span style="font-size:0.75rem; color:rgba(255,255,255,0.4);">{stats.resolvedCount} resolved</span>
        <span style="font-size:0.75rem; color:rgba(255,255,255,0.4);">{stats.total - stats.resolvedCount} remaining</span>
      </div>
    </div>

    <!-- View Full Tracker Link -->
    <div style="margin-top:2rem;">
      <a href="http://localhost:3159/roadmap" target="_blank" rel="noopener noreferrer"
         style="display:inline-flex; align-items:center; gap:0.75rem; padding:0.75rem 1.5rem; border-radius:0.75rem; background:rgba(102,126,234,0.1); border:1px solid rgba(102,126,234,0.2); color:rgba(102,126,234,0.9); font-weight:700; font-size:0.875rem; text-decoration:none; transition:all 0.3s ease;"
         onmouseover="this.style.background='rgba(102,126,234,0.2)'; this.style.borderColor='rgba(102,126,234,0.4)'"
         onmouseout="this.style.background='rgba(102,126,234,0.1)'; this.style.borderColor='rgba(102,126,234,0.2)'">
        <i class="fa-solid fa-arrow-up-right-from-square"></i>
        View Full Issue Tracker
        <span style="font-size:0.75rem; opacity:0.6;">&rarr;</span>
      </a>
    </div>

    <!-- Last Updated -->
    <div style="margin-top:1.5rem; font-size:0.75rem; color:rgba(255,255,255,0.3);">
      Last updated: {new Date(data.lastUpdated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' })}
    </div>
  </div>

  <!-- Tab Navigation -->
  <div class="roadmap-tabs">
    <div class="roadmap-tabs-inner">
      <button class="roadmap-tab critical is-active" data-tab="critical">
        Critical ({stats.bySeverity.critical ?? 0})
      </button>
      <button class="roadmap-tab high" data-tab="high">
        High ({stats.bySeverity.high ?? 0})
      </button>
      <button class="roadmap-tab medium" data-tab="medium">
        Medium ({stats.bySeverity.medium ?? 0})
      </button>
      <button class="roadmap-tab low" data-tab="low">
        Low ({stats.bySeverity.low ?? 0})
      </button>
    </div>
  </div>

  <!-- Tab Content -->
  <div class="roadmap-content">
    {['critical', 'high', 'medium', 'low'].map((severity) => (
      <div class={`roadmap-tab-panel ${severity === 'critical' ? 'is-active' : ''}`} data-panel={severity}>
        <div class="roadmap-issues">
          {issues
            .filter((issue) => issue.severity === severity)
            .map((issue) => (
              <div class={`roadmap-issue ${issue.status === 'complete' ? 'is-complete' : ''}`}>
                <div class="roadmap-issue-header">
                  <span class={`roadmap-issue-severity ${issue.severity}`}>{issue.severity}</span>
                  <div class="roadmap-issue-title-block">
                    <div class="roadmap-issue-title">{issue.title}</div>
                    <div class="roadmap-issue-meta">
                      Reported by: {issue.reporter} &bull; ID: {issue.id}
                    </div>
                  </div>
                  {issue.status === 'complete' && (
                    <span class="roadmap-issue-status complete">Resolved</span>
                  )}
                </div>
                <div class="roadmap-issue-description">{issue.description}</div>
                <div class="roadmap-issue-footer">
                  {issue.impact && (
                    <div class="roadmap-issue-detail">
                      <strong>Impact:</strong> {issue.impact}
                    </div>
                  )}
                  {issue.effort && (
                    <div class="roadmap-issue-detail">
                      <strong>Effort:</strong> {issue.effort}
                    </div>
                  )}
                  {issue.category && (
                    <div class="roadmap-issue-detail">
                      <strong>Category:</strong> {issue.category}
                    </div>
                  )}
                </div>
              </div>
            ))}
        </div>
      </div>
    ))}
  </div>

  <script>
    // Tab switching
    const tabs = document.querySelectorAll('.roadmap-tab');
    const panels = document.querySelectorAll('.roadmap-tab-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetTab = tab.getAttribute('data-tab');

        // Update active tab
        tabs.forEach((t) => t.classList.remove('is-active'));
        tab.classList.add('is-active');

        // Update active panel
        panels.forEach((p) => p.classList.remove('is-active'));
        document.querySelector(`[data-panel="${targetTab}"]`)?.classList.add('is-active');
      });
    });
  </script>
</ShowcaseLayout>
