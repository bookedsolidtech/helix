    <script slot="scripts" is:inline>
      (function () {
        var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // Scroll reveal
        if (prefersReduced) {
          document.querySelectorAll('.scroll-reveal').forEach(function (el) { el.classList.add('is-visible'); });
        } else {
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
              });
            },
            { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
          );
          document.querySelectorAll('.scroll-reveal').forEach(function (el) { observer.observe(el); });
        }

        // Card mouse tracking
        document.querySelectorAll('.fp-card').forEach(function (card) {
          card.addEventListener('mousemove', function (e) {
            var rect = card.getBoundingClientRect();
            card.style.setProperty('--mouse-x', (e.clientX - rect.left) + 'px');
            card.style.setProperty('--mouse-y', (e.clientY - rect.top) + 'px');
          });
        });

        // Section dot navigation
        var slides = document.querySelectorAll('.fp-slide');
        var dots = document.querySelectorAll('.fp-dot');
        var container = document.querySelector('.fp-container');

        // Click handlers for dots
        dots.forEach(function (dot) {
          dot.addEventListener('click', function () {
            var slideIndex = parseInt(dot.getAttribute('data-slide'), 10);
            var target = slides[slideIndex];
            if (target) {
              target.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth' });
            }
          });
        });

        // Update active dot on scroll
        var scrollTarget = container || window;
        var dotObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                var slideId = entry.target.id;
                var slideNum = parseInt(slideId.replace('slide-', ''), 10);
                dots.forEach(function (d, i) {
                  d.classList.toggle('active', i === slideNum);
                });
              }
            });
          },
          { threshold: 0.5, root: container || null }
        );
        slides.forEach(function (slide) { dotObserver.observe(slide); });
      })();
    </script>
