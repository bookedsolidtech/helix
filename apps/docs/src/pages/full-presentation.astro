---
/**
 * Full Presentation - 30-Minute Discussion Experience
 *
 * Full-page section-by-section experience with snap-scrolling on desktop.
 * 10 viewport-height sections covering:
 *  1. Title/Hero
 *  2. The Problem
 *  3. The Vision
 *  4. Architecture Deep Dive
 *  5. The Stack
 *  6. Quality & Compliance
 *  7. The Team & Process
 *  8. Implementation Timeline
 *  9. Risk Mitigation
 * 10. The Ask / Q&A
 *
 * Desktop: CSS scroll-snap-type: y mandatory
 * Mobile: Normal stacking (snap disabled)
 */
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro';
---

<ShowcaseLayout
  title="Full Presentation"
  description="The complete 30-minute presentation: HELIX enterprise web components for healthcare. Architecture, stack, compliance, timeline, and the ask."
>
    <style is:inline>
      /* ============================================
         FULL PRESENTATION - page-specific styles
         ============================================ */

      /* --- Token overrides (page differs from shared tokens) --- */
      :root {
        --gradient-hero: linear-gradient(135deg, #0a0a18 0%, #0f1030 40%, #0a0a2e 100%);
      }

      /* --- Body override: this page uses overflow-x: hidden (shared base uses clip) --- */
      body {
        overflow-x: hidden;
      }

      html {
        scroll-behavior: smooth;
      }

      /* --- Keyframes not in shared animations.css --- */
      @keyframes slide-in-left { from { opacity:0; transform:translateX(-60px); } to { opacity:1; transform:translateX(0); } }
      @keyframes slide-in-right { from { opacity:0; transform:translateX(60px); } to { opacity:1; transform:translateX(0); } }

      /* --- Page-specific pulse-ring (differs from shared: uses box-shadow, not scale) --- */
      @keyframes pulse-ring { 0% { box-shadow: 0 0 0 0 rgba(102,126,234,0.4); } 70% { box-shadow: 0 0 0 15px rgba(102,126,234,0); } 100% { box-shadow: 0 0 0 0 rgba(102,126,234,0); } }

      /* Snap scroll container -- desktop only */
      @media (min-width: 1025px) {
        .fp-container {
          height: 100vh;
          overflow-y: scroll;
          scroll-snap-type: y mandatory;
          scroll-behavior: smooth;
        }
      }

      /* Floating Pitch Nav */
      .pitch-nav {
        position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%); z-index: 200;
        display: flex; align-items: center; gap: 0.25rem; padding: 0.375rem;
        background: rgba(10,10,20,0.9); backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid var(--glass-border-strong); border-radius: var(--radius-full);
        box-shadow: var(--shadow-xl);
      }
      .pitch-nav-link {
        display: inline-flex; align-items: center; gap: 0.375rem;
        padding: 0.5rem 1rem; font-size: 0.8125rem; font-weight: 600;
        color: var(--text-secondary); border-radius: var(--radius-full);
        transition: all 0.25s ease; white-space: nowrap;
      }
      .pitch-nav-link:hover { color: var(--text-primary); background: var(--glass-bg-strong); }
      .pitch-nav-link.active { color: white; background: var(--gradient-primary); box-shadow: 0 2px 12px rgba(102,126,234,0.3); }
      .pitch-nav-divider { width: 1px; height: 20px; background: var(--glass-border-strong); margin: 0 0.25rem; }
      .pitch-nav-home {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; font-size: 0.875rem; color: var(--text-muted);
        border-radius: 50%; transition: all 0.25s ease;
      }
      .pitch-nav-home:hover { color: var(--text-primary); background: var(--glass-bg-strong); }

      /* Section dots nav - right side */
      .fp-dots {
        position: fixed; right: 1.5rem; bottom: 6rem; z-index: 200;
        display: flex; flex-direction: column; gap: 0.75rem;
      }
      .fp-dot {
        width: 10px; height: 10px; border-radius: 50%;
        background: var(--glass-border-strong);
        border: none; cursor: pointer;
        transition: all 0.3s ease; position: relative;
      }
      .fp-dot.active { background: var(--wc-accent); box-shadow: 0 0 10px rgba(139,92,246,0.5); transform: scale(1.3); }
      .fp-dot:hover { background: var(--text-muted); transform: scale(1.2); }
      .fp-dot-label {
        position: absolute; right: 20px; top: 50%; transform: translateY(-50%);
        font-size: 0.6875rem; font-weight: 600; color: var(--text-muted);
        white-space: nowrap; opacity: 0; transition: opacity 0.2s ease;
        pointer-events: none; background: rgba(10,10,20,0.9);
        padding: 0.25rem 0.5rem; border-radius: 4px;
      }
      .fp-dot:hover .fp-dot-label { opacity: 1; }

      /* Slide base */
      .fp-slide {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        padding: 4rem 2rem;
      }

      @media (min-width: 1025px) {
        .fp-slide { scroll-snap-align: start; }
      }

      .fp-slide-inner {
        max-width: 1100px;
        width: 100%;
        position: relative;
        z-index: 2;
      }

      /* Particle & grid backgrounds */
      .fp-particles {
        position: absolute; inset: 0; pointer-events: none;
        background-image:
          radial-gradient(1.5px 1.5px at 10% 20%, rgba(102,126,234,0.2) 50%, transparent 50%),
          radial-gradient(1px 1px at 40% 70%, rgba(6,182,212,0.15) 50%, transparent 50%),
          radial-gradient(1.5px 1.5px at 80% 30%, rgba(236,72,153,0.12) 50%, transparent 50%),
          radial-gradient(1px 1px at 60% 90%, rgba(16,185,129,0.15) 50%, transparent 50%);
        animation: particle-drift 80s linear infinite;
      }
      .fp-grid {
        position: absolute; inset: 0; pointer-events: none;
        background-image: linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px);
        background-size: 60px 60px;
      }
      .fp-orb { position: absolute; border-radius: 50%; pointer-events: none; }

      /* Slide headers */
      .fp-slide-header { text-align: center; margin-bottom: 3rem; }
      .fp-slide-num {
        display: inline-flex; align-items: center; justify-content: center;
        width: 48px; height: 48px; border-radius: 50%;
        font-size: 1.125rem; font-weight: 800; margin-bottom: 1rem;
      }
      .fp-slide-label {
        display: inline-block; font-size: 0.75rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em;
        padding: 0.25rem 1rem; border-radius: var(--radius-full);
        margin-bottom: 1rem;
      }
      .fp-slide-title {
        font-size: clamp(1.75rem, 4vw, 3rem);
        margin-bottom: 1rem;
      }
      .fp-slide-desc {
        font-size: 1.0625rem; color: var(--text-secondary);
        max-width: 700px; margin: 0 auto; line-height: 1.8;
      }
      .gradient-text { background: var(--gradient-cyan-purple); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

      /* Cards */
      .fp-card {
        background: var(--surface-1); border: 1px solid var(--surface-3);
        border-radius: var(--radius-xl); padding: 1.5rem;
        transition: all 0.4s cubic-bezier(0.22,1,0.36,1); position: relative; overflow: hidden;
      }
      .fp-card::before {
        content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
        background: conic-gradient(from var(--gradient-angle), #667eea, #764ba2, #f093fb, #06b6d4, #667eea);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor; mask-composite: exclude;
        opacity: 0; transition: opacity 0.5s ease; pointer-events: none;
        animation: border-rotate 4s linear infinite;
      }
      .fp-card:hover::before { opacity: 1; }
      .fp-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-xl), var(--glow-subtle); background: var(--surface-2); }
      .fp-card-icon {
        width: 48px; height: 48px; border-radius: var(--radius-lg);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.125rem; margin-bottom: 0.75rem; position: relative; z-index: 1;
      }
      .fp-card-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.375rem; position: relative; z-index: 1; }
      .fp-card-desc { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; position: relative; z-index: 1; }

      /* Color helpers */
      .icon-cyan { background:linear-gradient(135deg,rgba(6,182,212,0.15),rgba(6,182,212,0.05)); border:1px solid rgba(6,182,212,0.2); color:var(--wc-cyan); }
      .icon-green { background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(16,185,129,0.05)); border:1px solid rgba(16,185,129,0.2); color:var(--wc-green); }
      .icon-accent { background:linear-gradient(135deg,rgba(139,92,246,0.15),rgba(139,92,246,0.05)); border:1px solid rgba(139,92,246,0.2); color:var(--wc-accent); }
      .icon-pink { background:linear-gradient(135deg,rgba(236,72,153,0.15),rgba(236,72,153,0.05)); border:1px solid rgba(236,72,153,0.2); color:var(--wc-pink); }
      .icon-amber { background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(245,158,11,0.05)); border:1px solid rgba(245,158,11,0.2); color:var(--wc-amber); }
      .icon-electric { background:linear-gradient(135deg,rgba(59,130,246,0.15),rgba(59,130,246,0.05)); border:1px solid rgba(59,130,246,0.2); color:var(--wc-electric); }
      .icon-red { background:linear-gradient(135deg,rgba(239,68,68,0.15),rgba(239,68,68,0.05)); border:1px solid rgba(239,68,68,0.2); color:var(--wc-red); }
      .label-cyan { background:rgba(6,182,212,0.08); color:var(--wc-cyan); border:1px solid rgba(6,182,212,0.15); }
      .label-green { background:rgba(16,185,129,0.08); color:var(--wc-green); border:1px solid rgba(16,185,129,0.15); }
      .label-accent { background:rgba(139,92,246,0.08); color:var(--wc-accent); border:1px solid rgba(139,92,246,0.15); }
      .label-pink { background:rgba(236,72,153,0.08); color:var(--wc-pink); border:1px solid rgba(236,72,153,0.15); }
      .label-amber { background:rgba(245,158,11,0.08); color:var(--wc-amber); border:1px solid rgba(245,158,11,0.15); }
      .label-electric { background:rgba(59,130,246,0.08); color:var(--wc-electric); border:1px solid rgba(59,130,246,0.15); }
      .label-red { background:rgba(239,68,68,0.08); color:var(--wc-red); border:1px solid rgba(239,68,68,0.15); }
      .num-cyan { background:rgba(6,182,212,0.12); color:var(--wc-cyan); border:1px solid rgba(6,182,212,0.25); }
      .num-green { background:rgba(16,185,129,0.12); color:var(--wc-green); border:1px solid rgba(16,185,129,0.25); }
      .num-accent { background:rgba(139,92,246,0.12); color:var(--wc-accent); border:1px solid rgba(139,92,246,0.25); }
      .num-pink { background:rgba(236,72,153,0.12); color:var(--wc-pink); border:1px solid rgba(236,72,153,0.25); }
      .num-amber { background:rgba(245,158,11,0.12); color:var(--wc-amber); border:1px solid rgba(245,158,11,0.25); }
      .num-electric { background:rgba(59,130,246,0.12); color:var(--wc-electric); border:1px solid rgba(59,130,246,0.25); }
      .num-red { background:rgba(239,68,68,0.12); color:var(--wc-red); border:1px solid rgba(239,68,68,0.25); }

      /* Grids */
      .fp-grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
      .fp-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
      .fp-grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }

      /* Stats */
      .fp-stat { text-align: center; padding: 1rem; }
      .fp-stat-value { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.2; }
      .fp-stat-label { font-size: 0.8125rem; color: var(--text-muted); margin-top: 0.25rem; }

      /* Comparison table */
      .fp-table {
        width: 100%; border-collapse: collapse; background: var(--surface-1);
        border-radius: var(--radius-xl); overflow: hidden; border: 1px solid var(--surface-3);
      }
      .fp-table th {
        padding: 0.75rem 1rem; text-align: left; font-size: 0.75rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted);
        background: var(--surface-2); border-bottom: 1px solid var(--surface-3);
      }
      .fp-table td {
        padding: 0.625rem 1rem; font-size: 0.875rem;
        border-bottom: 1px solid rgba(255,255,255,0.03);
      }
      .fp-table tr:last-child td { border-bottom: none; }

      /* Code */
      .fp-code {
        background: var(--surface-1); border: 1px solid var(--surface-3);
        border-radius: var(--radius-lg); overflow: hidden;
      }
      .fp-code-header {
        padding: 0.5rem 1rem; background: var(--surface-2);
        border-bottom: 1px solid var(--surface-3); display: flex; align-items: center;
        gap: 0.5rem; font-size: 0.75rem; font-weight: 600; color: var(--text-muted);
      }
      .fp-code-dots { display: flex; gap: 6px; }
      .fp-code-dot { width: 10px; height: 10px; border-radius: 50%; }
      .fp-code pre {
        padding: 1rem; font-size: 0.75rem; line-height: 1.7;
        color: #d6deeb; overflow-x: auto; margin: 0;
      }

      /* Pipeline - horizontal flow (desktop) */
      .fp-pipeline { display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2rem; position: relative; }
      .fp-pipeline-step { display: flex; flex-direction: column; align-items: center; gap: 0.375rem; text-align: center; min-width: 100px; }
      .fp-pipeline-icon { width: 56px; height: 56px; border-radius: var(--radius-xl); display: flex; align-items: center; justify-content: center; font-size: 1.25rem; }
      .fp-pipeline-label { font-size: 0.8125rem; font-weight: 700; }
      .fp-pipeline-sub { font-size: 0.6875rem; color: var(--text-muted); }
      .fp-pipeline-arrow { font-size: 1rem; color: var(--text-muted); }

      /* Pipeline snake connectors - hidden on desktop */
      .fp-snake-connector { display: none; }

      /* Timeline */
      .fp-timeline-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
      .fp-timeline-phase {
        background: var(--surface-1); border: 1px solid var(--surface-3);
        border-radius: var(--radius-xl); padding: 1.25rem; position: relative;
      }
      .fp-timeline-phase-num {
        font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;
      }
      .fp-timeline-phase-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.375rem; }
      .fp-timeline-phase-time { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.5rem; }
      .fp-timeline-phase-items { list-style: none; }
      .fp-timeline-phase-items li {
        font-size: 0.8125rem; color: var(--text-secondary); padding: 0.25rem 0;
        display: flex; align-items: flex-start; gap: 0.5rem; line-height: 1.4;
      }
      .fp-timeline-phase-items li i { color: var(--wc-green); margin-top: 0.15em; flex-shrink: 0; font-size: 0.625rem; }

      /* Risk items */
      .fp-risk {
        display: grid; grid-template-columns: auto 1fr auto; gap: 1rem;
        align-items: center; padding: 1rem 1.25rem;
        background: var(--surface-1); border: 1px solid var(--surface-3);
        border-radius: var(--radius-lg); margin-bottom: 0.75rem;
      }
      .fp-risk-icon { width: 40px; height: 40px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-size: 1rem; }
      .fp-risk-text { }
      .fp-risk-title { font-size: 0.9375rem; font-weight: 700; margin-bottom: 0.125rem; }
      .fp-risk-desc { font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.4; }
      .fp-risk-badge {
        font-size: 0.6875rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.03em; padding: 0.25rem 0.75rem; border-radius: var(--radius-full);
        white-space: nowrap;
      }

      /* Buttons */
      .fp-btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.75rem 1.5rem; border-radius: var(--radius-full);
        font-weight: 600; font-size: 0.9375rem; transition: all 0.3s ease; text-decoration: none;
      }
      .fp-btn-solid { background: var(--gradient-primary); color: white; border: none; box-shadow: var(--shadow-md), var(--glow-subtle); }
      .fp-btn-solid:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg), var(--glow-primary); color: white; }
      .fp-btn-ghost { background: var(--glass-bg); color: var(--text-secondary); border: 1px solid var(--glass-border-strong); }
      .fp-btn-ghost:hover { background: var(--glass-bg-strong); color: var(--text-primary); transform: translateY(-2px); }
      .fp-btn-arrow { transition: transform 0.2s ease; }
      .fp-btn:hover .fp-btn-arrow { transform: translateX(4px); }
      .fp-btn-group { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem; }

      /* Slide alternating backgrounds */
      .fp-slide-dark { background: var(--surface-0); }
      .fp-slide-mid { background: var(--surface-1); }
      .fp-slide-hero { background: linear-gradient(135deg, #0a0a18 0%, #0f1030 30%, #1a0a2e 60%, #0a0a18 100%); }

      /* Responsive */
      @media (max-width: 1024px) {
        .fp-grid-2 { grid-template-columns: 1fr; }
        .fp-grid-3 { grid-template-columns: 1fr; }
        .fp-grid-4 { grid-template-columns: repeat(2, 1fr); }
        .fp-timeline-grid { grid-template-columns: repeat(2, 1fr); }
        .fp-dots { display: none; }
        .fp-risk { grid-template-columns: auto 1fr; }
        .fp-risk-badge { grid-column: 1 / -1; justify-self: start; }
      }

      @media (max-width: 768px) {
        .fp-slide { padding: 4rem 1rem 5rem; min-height: auto; }
        .fp-grid-4 { grid-template-columns: 1fr; }
        .fp-timeline-grid { grid-template-columns: 1fr; }

        /* Pipeline: 2x2 snake grid on mobile */
        .fp-pipeline {
          display: grid;
          grid-template-columns: 1fr auto 1fr;
          grid-template-rows: auto auto auto;
          gap: 0;
          align-items: center;
          justify-items: center;
        }

        /* Hide desktop inline arrows */
        .fp-pipeline > .fp-pipeline-arrow { display: none; }

        /* Place steps in snake order */
        .fp-pipeline-step.fp-step-1 { grid-column: 1; grid-row: 1; }
        .fp-pipeline-step.fp-step-2 { grid-column: 3; grid-row: 1; }
        .fp-pipeline-step.fp-step-3 { grid-column: 3; grid-row: 3; }
        .fp-pipeline-step.fp-step-4 { grid-column: 1; grid-row: 3; }

        /* Show snake connectors - same style as desktop .fp-pipeline-arrow */
        .fp-snake-connector {
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 1rem;
          color: var(--text-muted);
        }

        .fp-snake-right { grid-column: 2; grid-row: 1; }
        .fp-snake-down  { grid-column: 3; grid-row: 2; padding: 0.25rem 0; }
        .fp-snake-left  { grid-column: 2; grid-row: 3; }

        .fp-btn-group { flex-direction: column; align-items: stretch; }
        .fp-btn { width: 100%; justify-content: center; }
        .pitch-nav { bottom: 1rem; left: 0.5rem; right: 0.5rem; transform: none; justify-content: center; }
        .pitch-nav-link { padding: 0.5rem 0.75rem; font-size: 0.75rem; min-height: 44px; }
        .pitch-nav-home { min-width: 44px; min-height: 44px; }
      }

      /* Page-specific reduced-motion overrides (orb, snap-scroll, html scroll) */
      @media (prefers-reduced-motion: reduce) {
        .fp-orb { animation: none !important; opacity: 0.15; }
        html { scroll-behavior: auto; }
        .fp-container { scroll-snap-type: none !important; scroll-behavior: auto !important; }
      }

      .fp-btn:focus-visible, .pitch-nav-link:focus-visible, .pitch-nav-home:focus-visible, .fp-dot:focus-visible {
        outline: 3px solid var(--wc-accent); outline-offset: 3px;
      }
    </style>

    <!-- Floating pitch navigation -->
    <nav class="pitch-nav" aria-label="Pitch pages">
      <a href="/" class="pitch-nav-home" aria-label="Back to Dashboard">
        <i class="fa-solid fa-house" aria-hidden="true"></i>
      </a>
      <div class="pitch-nav-divider" aria-hidden="true"></div>
      <a href="/elevator-pitch/" class="pitch-nav-link">
        <i class="fa-solid fa-bolt" aria-hidden="true"></i>
        30s
      </a>
      <a href="/detailed-pitch/" class="pitch-nav-link">
        <i class="fa-solid fa-clock" aria-hidden="true"></i>
        5 min
      </a>
      <a href="/full-presentation/" class="pitch-nav-link active" aria-current="page">
        <i class="fa-solid fa-presentation-screen" aria-hidden="true"></i>
        30 min
      </a>
    </nav>

    <!-- Section dots navigation (desktop) -->
    <nav class="fp-dots" aria-label="Slide navigation">
      <button class="fp-dot active" data-slide="0" aria-label="Slide 1: Title"><span class="fp-dot-label">Title</span></button>
      <button class="fp-dot" data-slide="1" aria-label="Slide 2: The Problem"><span class="fp-dot-label">Problem</span></button>
      <button class="fp-dot" data-slide="2" aria-label="Slide 3: The Vision"><span class="fp-dot-label">Vision</span></button>
      <button class="fp-dot" data-slide="3" aria-label="Slide 4: Architecture"><span class="fp-dot-label">Architecture</span></button>
      <button class="fp-dot" data-slide="4" aria-label="Slide 5: The Stack"><span class="fp-dot-label">Stack</span></button>
      <button class="fp-dot" data-slide="5" aria-label="Slide 6: Quality"><span class="fp-dot-label">Quality</span></button>
      <button class="fp-dot" data-slide="6" aria-label="Slide 7: Team"><span class="fp-dot-label">Team</span></button>
      <button class="fp-dot" data-slide="7" aria-label="Slide 8: Timeline"><span class="fp-dot-label">Timeline</span></button>
      <button class="fp-dot" data-slide="8" aria-label="Slide 9: Risk"><span class="fp-dot-label">Risk</span></button>
      <button class="fp-dot" data-slide="9" aria-label="Slide 10: The Ask"><span class="fp-dot-label">The Ask</span></button>
    </nav>

    <main id="main-content" class="fp-container">

      <!-- SLIDE 1: TITLE / HERO -->
      <section class="fp-slide fp-slide-hero" id="slide-0" aria-label="Title">
