---
/**
 * System Architecture - Full visual experience page with tabbed ADRs.
 *
 * This is a standalone Astro page (not Starlight content) that provides
 * an immersive visual walkthrough of core architectural decisions for
 * the WC-2026 web component system.
 *
 * Tabs / ADRs:
 * 1. Slots vs Props - Architecture Decision (property-driven vs slot-driven)
 * 2. Component Loading - Delivery Strategy (bundle vs per-component vs hybrid)
 * 3. Attribute Naming - HTML Safety Convention (wc- prefix for collision avoidance)
 * 4. Light DOM - Rendering Strategy (Shadow DOM vs Light DOM, adopted stylesheets)
 *
 * Decomposed into:
 * - ArchCodeExamples.ts — all code example string constants
 * - ArchTab1SlotsVsProps.astro — Tab 1 content + tab-specific CSS
 * - ArchTab2ComponentLoading.astro — Tab 2 content + tab-specific CSS
 * - ArchTab3AttributeNaming.astro — Tab 3 content + tab-specific CSS
 * - ArchTab4LightDOM.astro — Tab 4 content + tab-specific CSS
 */
import ArchTab1SlotsVsProps from '../components/showcase/arch/ArchTab1SlotsVsProps.astro';
import ArchTab2ComponentLoading from '../components/showcase/arch/ArchTab2ComponentLoading.astro';
import ArchTab3AttributeNaming from '../components/showcase/arch/ArchTab3AttributeNaming.astro';
import ArchTab4LightDOM from '../components/showcase/arch/ArchTab4LightDOM.astro';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>System Architecture | WC-2026</title>
    <meta
      name="description"
      content="Architecture Decision Records for the WC-2026 web component system: Slots vs Props, Component Loading, and Attribute Naming conventions."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <style is:inline>
      /* ============================================
         SYSTEM ARCHITECTURE PAGE — Shared styles
         Tokens, reset, keyframes, scroll-reveal,
         topbar, hero, section layout, card base,
         code blocks, footer CTA, buttons, tab nav,
         focus states, responsive, reduced motion.
         ============================================ */

      /* --- CSS Custom Properties --- */
      @property --gradient-angle {
        syntax: '<angle>';
        initial-value: 0deg;
        inherits: false;
      }

      :root {
        --wc-accent-h: 250;
        --wc-accent-s: 70%;
        --wc-accent-l: 60%;
        --wc-accent: hsl(var(--wc-accent-h), var(--wc-accent-s), var(--wc-accent-l));
        --wc-cyan: #06b6d4;
        --wc-pink: #ec4899;
        --wc-green: #10b981;
        --wc-amber: #f59e0b;
        --wc-red: #ef4444;

        --gradient-primary: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --gradient-hero: linear-gradient(135deg, #0a0a1a 0%, #1a1040 40%, #0f0f2e 100%);
        --gradient-cyan-purple: linear-gradient(135deg, #06b6d4, #8b5cf6);
        --gradient-pink-orange: linear-gradient(135deg, #ec4899, #f97316);
        --gradient-green-cyan: linear-gradient(135deg, #10b981, #06b6d4);

        --font-heading: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;

        --space-1: 0.25rem;
        --space-2: 0.5rem;
        --space-3: 0.75rem;
        --space-4: 1rem;
        --space-5: 1.25rem;
        --space-6: 1.5rem;
        --space-8: 2rem;
        --space-10: 2.5rem;
        --space-12: 3rem;
        --space-16: 4rem;
        --space-20: 5rem;
        --space-24: 6rem;

        --radius-sm: 0.5rem;
        --radius-md: 0.75rem;
        --radius-lg: 1rem;
        --radius-xl: 1.5rem;
        --radius-2xl: 2rem;
        --radius-full: 9999px;

        --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
        --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
        --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
        --shadow-xl: 0 16px 64px rgba(0, 0, 0, 0.6);
        --shadow-2xl: 0 24px 80px rgba(0, 0, 0, 0.2);

        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-bg-strong: rgba(255, 255, 255, 0.06);
        --glass-border: rgba(255, 255, 255, 0.06);
        --glass-border-strong: rgba(255, 255, 255, 0.12);

        --glow-primary: 0 0 50px rgba(102, 126, 234, 0.25);
        --glow-subtle: 0 0 20px rgba(102, 126, 234, 0.15);

        --surface-0: #0a0a14;
        --surface-1: #111122;
        --surface-2: #1a1a32;
        --surface-3: #252545;
        --text-primary: #eaeaf4;
        --text-secondary: #a8a8c8;
        --text-muted: #6868a0;
      }

      /* --- Reset & Base --- */
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: var(--font-body);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background: var(--surface-0);
        color: var(--text-primary);
        scroll-behavior: smooth;
        overflow-x: clip;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.15;
      }

      code, pre {
        font-family: var(--font-mono);
      }

      a {
        color: var(--wc-accent);
        text-decoration: none;
        transition: color 0.2s ease;
      }

      a:hover {
        color: hsl(var(--wc-accent-h), var(--wc-accent-s), 75%);
      }

      /* --- Keyframes --- */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      @keyframes float-slow {
        0%, 100% { transform: translate(0, 0) scale(1); }
        25% { transform: translate(30px, -20px) scale(1.05); }
        50% { transform: translate(-10px, -35px) scale(0.97); }
        75% { transform: translate(-25px, -10px) scale(1.02); }
      }

      @keyframes float-drift {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33% { transform: translate(20px, 15px) rotate(2deg); }
        66% { transform: translate(-15px, -20px) rotate(-2deg); }
      }

      @keyframes orb-pulse {
        0%, 100% { opacity: 0.3; filter: blur(100px); }
        50% { opacity: 0.5; filter: blur(120px); }
      }

      @keyframes pulse-glow {
        0%, 100% { box-shadow: 0 0 8px rgba(74, 222, 128, 0.4); }
        50% { box-shadow: 0 0 24px rgba(74, 222, 128, 0.7); }
      }

      @keyframes border-rotate {
        0% { --gradient-angle: 0deg; }
        100% { --gradient-angle: 360deg; }
      }

      @keyframes spectrum-pulse {
        0%, 100% { transform: scaleX(1); }
        50% { transform: scaleX(1.02); }
      }

      @keyframes particle-drift {
        0% { background-position: 0 0, 200px 200px, 400px 100px; }
        100% { background-position: 800px 800px, 1000px 1000px, 1200px 900px; }
      }

      @keyframes flow-line {
        0% { stroke-dashoffset: 100; }
        100% { stroke-dashoffset: 0; }
      }

      @keyframes scroll-fade {
        0% { opacity: 1; transform: translateX(-50%) translateY(0); }
        100% { opacity: 0; transform: translateX(-50%) translateY(12px); }
      }

      @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
      }

      /* --- Scroll Reveal --- */
      .scroll-reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                    filter 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        filter: blur(4px);
      }

      .scroll-reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
      }

      .scroll-reveal-delay-1 { transition-delay: 0.1s; }
      .scroll-reveal-delay-2 { transition-delay: 0.2s; }
      .scroll-reveal-delay-3 { transition-delay: 0.3s; }
      .scroll-reveal-delay-4 { transition-delay: 0.4s; }
      .scroll-reveal-delay-5 { transition-delay: 0.5s; }
      .scroll-reveal-delay-6 { transition-delay: 0.6s; }

      /* --- Top Navigation Bar --- */
      .da-topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-3) var(--space-8);
        background: rgba(10, 10, 20, 0.85);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .da-topbar-left {
        display: flex;
        align-items: center;
        gap: var(--space-4);
      }

      .da-back-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-secondary);
        transition: all 0.2s ease;
        padding: var(--space-2) var(--space-3);
        border-radius: var(--radius-md);
      }

      .da-back-link:hover {
        color: var(--text-primary);
        background: var(--glass-bg-strong);
      }

      .da-topbar-title {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.01em;
      }

      .da-topbar-right {
        display: flex;
        align-items: center;
        gap: var(--space-3);
      }

      .da-topbar-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-muted);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-md);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.2s ease;
      }

      .da-topbar-link:hover {
        color: var(--wc-accent);
        border-color: rgba(102, 126, 234, 0.3);
        background: rgba(102, 126, 234, 0.06);
      }

      /* --- Hero Section --- */
      .da-hero {
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        isolation: isolate;
        padding: var(--space-24) var(--space-8) var(--space-16);
      }

      .da-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: var(--gradient-hero);
        z-index: -3;
      }

      .da-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          radial-gradient(circle at 20% 30%, rgba(6, 120, 190, 0.04) 2px, transparent 2px),
          radial-gradient(circle at 60% 70%, rgba(102, 126, 234, 0.04) 3px, transparent 3px),
          radial-gradient(circle at 80% 20%, rgba(236, 72, 153, 0.03) 2px, transparent 2px);
        background-size: 800px 800px;
        animation: particle-drift 60s linear infinite;
        opacity: 0.6;
        z-index: -2;
      }

      .da-hero-orb { position: absolute; border-radius: 50%; filter: blur(100px); opacity: 0.3; z-index: -1; pointer-events: none; }
      .da-hero-orb-1 { width: 600px; height: 600px; background: radial-gradient(circle, rgba(6, 120, 190, 0.4), transparent 70%); top: -200px; right: -100px; animation: float-slow 20s ease-in-out infinite, orb-pulse 8s ease-in-out infinite; }
      .da-hero-orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(236, 72, 153, 0.3), transparent 70%); bottom: -100px; left: -80px; animation: float-slow 25s ease-in-out infinite reverse, orb-pulse 10s ease-in-out infinite; }
      .da-hero-orb-3 { width: 350px; height: 350px; background: radial-gradient(circle, rgba(16, 185, 129, 0.25), transparent 70%); top: 40%; left: 15%; animation: float-drift 18s ease-in-out infinite, orb-pulse 7s ease-in-out infinite; }

      .da-hero-grid { position: absolute; inset: 0; z-index: -1; background-image: linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 70%); -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 70%); }

      .da-hero-content { text-align: center; max-width: 900px; z-index: 1; }

      .da-hero-badge { display: inline-flex; align-items: center; gap: var(--space-3); padding: var(--space-2) var(--space-6); border-radius: var(--radius-full); background: rgba(255, 255, 255, 0.06); border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); color: rgba(255, 255, 255, 0.85); font-size: 0.875rem; font-weight: 500; letter-spacing: 0.02em; margin-bottom: var(--space-10); animation: fadeInDown 0.8s cubic-bezier(0.22, 1, 0.36, 1) backwards; }
      .da-hero-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--wc-cyan); animation: pulse-glow 2s ease infinite; flex-shrink: 0; }

      .da-hero-title { font-size: clamp(2.5rem, 8vw, 5rem); font-weight: 900; line-height: 1.15; margin-bottom: var(--space-6); background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(255,255,255,0.7) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: -0.04em; animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s backwards; }
      .da-hero-subtitle { font-size: clamp(1.125rem, 2.5vw, 1.5rem); font-weight: 300; margin-bottom: var(--space-8); background: linear-gradient(90deg, rgba(255,255,255,0.9), rgba(6, 182, 212, 0.9)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s backwards; }
      .da-hero-description { font-size: clamp(1rem, 1.5vw, 1.25rem); color: rgba(255, 255, 255, 0.55); max-width: 700px; margin: 0 auto var(--space-12); line-height: 1.75; animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.3s backwards; }

      .da-hero-scroll { position: absolute; bottom: var(--space-10); left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: var(--space-2); color: rgba(255, 255, 255, 0.3); font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; animation: fadeIn 1s ease 1.5s backwards; }
      .da-hero-scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent); position: relative; overflow: hidden; }
      .da-hero-scroll-line::after { content: ''; position: absolute; top: -100%; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.8), transparent); animation: scroll-fade 2s ease-in-out infinite; }

      /* --- Shared Section Styles --- */
      .da-section { width: 100%; position: relative; overflow: hidden; }
      .da-section-inner { padding: var(--space-24) var(--space-8); max-width: 1400px; margin: 0 auto; }
      .da-section-header { text-align: center; margin-bottom: var(--space-16); }
      .da-section-label { display: inline-block; padding: var(--space-1) var(--space-4); border-radius: var(--radius-full); font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: var(--space-4); background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1)); color: var(--wc-accent); border: 1px solid rgba(102, 126, 234, 0.15); }
      .da-section-title { font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; letter-spacing: -0.035em; margin-bottom: var(--space-5); color: var(--text-primary); line-height: 1.1; }
      .da-section-description { font-size: clamp(1rem, 1.5vw, 1.2rem); color: var(--text-secondary); max-width: 650px; margin: 0 auto; line-height: 1.7; }

      /* --- Cards base --- */
      .da-card { padding: var(--space-8); border-radius: var(--radius-2xl); background: var(--surface-1); border: 1px solid var(--surface-3); transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1); position: relative; overflow: hidden; }
      .da-card::before { content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px; background: conic-gradient(from var(--gradient-angle), #667eea, #764ba2, #f093fb, #06b6d4, #667eea); -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); -webkit-mask-composite: xor; mask-composite: exclude; opacity: 0; transition: opacity 0.5s ease; pointer-events: none; animation: border-rotate 4s linear infinite; }
      .da-card::after { content: ''; position: absolute; width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, rgba(102, 126, 234, 0.12), transparent 70%); opacity: 0; transition: opacity 0.5s ease; pointer-events: none; top: var(--mouse-y, 50%); left: var(--mouse-x, 50%); transform: translate(-50%, -50%); }
      .da-card:hover::before { opacity: 1; }
      .da-card:hover::after { opacity: 1; }
      .da-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-xl), var(--glow-subtle); background: var(--surface-2); }

      /* --- Code blocks --- */
      .da-code-block { position: relative; background: #0a0e18; border: 1px solid rgba(255, 255, 255, 0.06); border-radius: var(--radius-lg); overflow: hidden; }
      .da-code-titlebar { display: flex; align-items: center; gap: 6px; padding: 10px 16px; background: rgba(0, 0, 0, 0.3); border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
      .da-code-dot { width: 10px; height: 10px; border-radius: 50%; }
      .da-code-dot:nth-child(1) { background: #ff5f57; }
      .da-code-dot:nth-child(2) { background: #ffbd2e; }
      .da-code-dot:nth-child(3) { background: #28c840; }
      .da-code-filename { margin-left: auto; font-size: 0.75rem; color: rgba(255, 255, 255, 0.4); font-family: var(--font-mono); }
      .da-code-body { padding: var(--space-4) var(--space-5); overflow-x: auto; }
      .da-code-body pre { margin: 0; font-size: 0.8125rem; line-height: 1.7; color: #d6deeb; white-space: pre; }
      .da-code-body .kw { color: #c792ea; }
      .da-code-body .tag { color: #7fdbca; }
      .da-code-body .attr { color: #addb67; }
      .da-code-body .val { color: #ecc48d; }
      .da-code-body .str { color: #c3e88d; }
      .da-code-body .cmt { color: #637777; font-style: italic; }
      .da-code-body .var { color: #82aaff; }
      .da-code-body .fn { color: #82aaff; }
      .da-code-body .slot-hl { color: #ff79c6; font-weight: 600; }
      .da-code-body .prop-hl { color: #06b6d4; font-weight: 600; }

      .da-code-label { display: inline-block; padding: var(--space-1) var(--space-3); border-radius: var(--radius-sm); font-size: 0.6875rem; font-weight: 600; font-family: var(--font-mono); margin-bottom: var(--space-3); }
      .da-code-label-twig { background: rgba(245, 158, 11, 0.12); color: var(--wc-amber); border: 1px solid rgba(245, 158, 11, 0.2); }
      .da-code-label-sb { background: rgba(236, 72, 153, 0.12); color: var(--wc-pink); border: 1px solid rgba(236, 72, 153, 0.2); }
      .da-code-label-html { background: rgba(6, 182, 212, 0.12); color: var(--wc-cyan); border: 1px solid rgba(6, 182, 212, 0.2); }

      /* --- Footer CTA --- */
      .da-footer-cta { text-align: center; padding: var(--space-24) var(--space-8); background: var(--surface-0); border-top: 1px solid var(--surface-3); }
      .da-footer-cta-inner { max-width: 700px; margin: 0 auto; }
      .da-footer-cta h2 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; letter-spacing: -0.03em; margin-bottom: var(--space-4); color: var(--text-primary); }
      .da-footer-cta p { font-size: 1.0625rem; color: var(--text-secondary); margin-bottom: var(--space-8); line-height: 1.7; }
      .da-footer-cta-buttons { display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap; }

      /* --- Buttons --- */
      .da-btn { display: inline-flex; align-items: center; gap: var(--space-2); padding: var(--space-4) var(--space-8); font-size: 1rem; font-weight: 600; text-decoration: none; border-radius: var(--radius-lg); transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1); cursor: pointer; border: none; white-space: nowrap; min-height: 48px; line-height: 1; }
      .da-btn-primary { background: white; color: #1a1040; box-shadow: var(--shadow-md); }
      .da-btn-primary:hover { transform: translateY(-3px); box-shadow: var(--shadow-xl), 0 0 40px rgba(255,255,255,0.15); color: #1a1040; }
      .da-btn-secondary { background: rgba(255, 255, 255, 0.05); color: white; border: 1.5px solid rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); }
      .da-btn-secondary:hover { background: rgba(255, 255, 255, 0.1); border-color: rgba(255, 255, 255, 0.3); transform: translateY(-3px); color: white; }
      .da-btn-solid { background: var(--gradient-primary); color: white; box-shadow: var(--shadow-md); }
      .da-btn-solid:hover { transform: translateY(-3px); box-shadow: var(--shadow-xl), var(--glow-primary); color: white; }
      .da-btn-ghost { background: transparent; color: var(--text-secondary); border: 1.5px solid var(--surface-3); }
      .da-btn-ghost:hover { background: var(--glass-bg-strong); border-color: var(--glass-border-strong); color: var(--text-primary); transform: translateY(-2px); }
      .da-btn-arrow { transition: transform 0.3s ease; display: inline-block; }
      .da-btn:hover .da-btn-arrow { transform: translateX(4px); }

      /* --- Sticky Tab Nav --- */
      .da-section-nav { position: sticky; top: 3.9rem; z-index: 90; background: rgba(10, 10, 20, 0.92); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
      .da-section-nav-inner { display: flex; max-width: 1200px; margin: 0 auto; padding: 0.5rem; gap: 0.5rem; }
      .da-nav-tab { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 0.25rem; padding: 0.75rem 1.5rem; border-radius: 0.75rem; border: 1px solid transparent; background: transparent; color: rgba(255, 255, 255, 0.45); cursor: pointer; transition: all 0.25s ease; font-family: var(--font-heading); }
      .da-nav-tab i { font-size: 1.25rem; opacity: 0.5; transition: all 0.25s ease; }
      .da-nav-tab-label { font-size: 0.9375rem; font-weight: 700; letter-spacing: -0.01em; }
      .da-nav-tab-subtitle { font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.5; }
      .da-nav-tab:hover { color: rgba(255, 255, 255, 0.8); background: rgba(255, 255, 255, 0.04); }
      .da-nav-tab:hover i { opacity: 0.9; }
      .da-nav-tab.is-active { color: white; background: rgba(102, 126, 234, 0.1); border-color: rgba(102, 126, 234, 0.25); box-shadow: 0 0 20px rgba(102, 126, 234, 0.08); }
      .da-nav-tab.is-active i { opacity: 1; color: var(--wc-accent); }
      .da-nav-tab.is-active .da-nav-tab-subtitle { opacity: 0.8; }
      .da-nav-tab:focus-visible { outline: 2px solid var(--wc-accent); outline-offset: 2px; }

      /* Tab content panels */
      .da-tab-content { display: none; }
      .da-tab-content.is-active { display: block; }

      /* --- Focus States --- */
      .da-btn:focus-visible,
      .da-back-link:focus-visible,
      .da-topbar-link:focus-visible,
      .da-strategy-card-inner:focus-visible {
        outline: 3px solid var(--wc-accent);
        outline-offset: 3px;
      }

      /* --- Responsive --- */
      @media (max-width: 768px) {
        .da-topbar { padding: var(--space-3) var(--space-4); }
        .da-topbar-title { display: none; }
        .da-hero { min-height: auto; padding: calc(var(--space-24) + var(--space-8)) var(--space-4) var(--space-16); }
        .da-hero-scroll { display: none; }
        .da-section-inner { padding: var(--space-16) var(--space-4); }
        .da-section-header { margin-bottom: var(--space-10); }
        .da-footer-cta-buttons { flex-direction: column; align-items: stretch; }
        .da-btn { width: 100%; justify-content: center; }
        .da-nav-tab { padding: 0.625rem 1rem; }
        .da-nav-tab-label { font-size: 0.8125rem; }
        .da-nav-tab-subtitle { font-size: 0.625rem; }
      }

      @media (max-width: 480px) {
        .da-hero-title { font-size: clamp(2rem, 10vw, 3rem); }
        .da-topbar-right { display: none; }
      }

      /* --- Reduced Motion --- */
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }

        .scroll-reveal {
          opacity: 1;
          transform: none;
          filter: none;
          transition: none;
        }

        .da-hero-orb {
          animation: none !important;
          opacity: 0.15;
        }

        .da-nav-tab {
          transition: none;
        }
      }
    </style>
  </head>

  <body>
    <!-- Top Navigation Bar -->
    <nav class="da-topbar" aria-label="Page navigation">
      <div class="da-topbar-left">
        <a href="/" class="da-back-link" aria-label="Back to WC-2026 Dashboard">
