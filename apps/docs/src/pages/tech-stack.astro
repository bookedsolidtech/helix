---
/**
 * Tech Stack — page orchestrator.
 *
 * Standalone Astro page (not Starlight content) showcasing every
 * technology choice and WHY it was chosen for the WC-2026 project.
 *
 * Sections (delegated to components in components/showcase/stack/):
 * 1. Hero - Every Tool Chosen for a Reason          (inline below)
 * 2. The Stack Visualization - Layered architecture  (StackVisualization)
 * 3. Head-to-Head Comparisons - Decision matrices    (StackComparisons)
 * 4. Bundle Size Showdown - Framework weight         (StackBundleSize)
 * 5. The Integration Map - Tool connection flow      (StackIntegrationMap)
 * 6. Performance Benchmarks - Visualized metrics     (StackPerformance)
 * 7. Future-Proof Guarantees - Standards timeline     (StackFutureProof)
 * 8. Footer CTA                                      (inline below)
 */
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro';
import ScrollRevealScript from '../components/showcase/ScrollRevealScript.astro';
import StackVisualization from '../components/showcase/stack/StackVisualization.astro';
import StackComparisons from '../components/showcase/stack/StackComparisons.astro';
import StackBundleSize from '../components/showcase/stack/StackBundleSize.astro';
import StackIntegrationMap from '../components/showcase/stack/StackIntegrationMap.astro';
import StackPerformance from '../components/showcase/stack/StackPerformance.astro';
import StackFutureProof from '../components/showcase/stack/StackFutureProof.astro';
---

<ShowcaseLayout
  title="The 2026 Stack"
  description="Every technology in WC-2026 was chosen for a reason. Explore the head-to-head comparisons, bundle analysis, and architectural decisions behind the cutting-edge 2026 stack."
>
  <style is:inline>
    /* ============================================
       TECH STACK PAGE — page-level styles
       (topbar, hero, shared section scaffolding,
        card base, footer CTA, buttons, responsive)
       ============================================ */

    /* --- Top Navigation Bar --- */
    .ts-topbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-3) var(--space-8);
      background: rgba(10, 10, 20, 0.85);
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .ts-topbar-left {
      display: flex;
      align-items: center;
      gap: var(--space-4);
    }

    .ts-back-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--text-secondary);
      transition: all 0.2s ease;
      padding: var(--space-2) var(--space-3);
      border-radius: var(--radius-md);
    }

    .ts-back-link:hover {
      color: var(--text-primary);
      background: var(--glass-bg-strong);
    }

    .ts-topbar-title {
      font-size: 0.875rem;
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.01em;
    }

    .ts-topbar-right {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }

    .ts-topbar-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--text-muted);
      padding: var(--space-2) var(--space-4);
      border-radius: var(--radius-md);
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: all 0.2s ease;
    }

    .ts-topbar-link:hover {
      color: var(--wc-cyan);
      border-color: rgba(6, 182, 212, 0.3);
      background: rgba(6, 182, 212, 0.06);
    }

    /* ============================================
       SECTION 1: HERO
       ============================================ */
    .ts-hero {
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      isolation: isolate;
      padding: var(--space-24) var(--space-8) var(--space-16);
    }

    .ts-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--gradient-hero);
      z-index: -3;
    }

    .ts-hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 20% 30%, rgba(6, 182, 212, 0.04) 2px, transparent 2px),
        radial-gradient(circle at 60% 70%, rgba(102, 126, 234, 0.04) 3px, transparent 3px),
        radial-gradient(circle at 80% 20%, rgba(34, 211, 238, 0.03) 2px, transparent 2px);
      background-size: 800px 800px;
      animation: particle-drift 60s linear infinite;
      opacity: 0.6;
      z-index: -2;
    }

    .ts-hero-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      opacity: 0.3;
      z-index: -1;
      pointer-events: none;
    }

    .ts-hero-orb-1 {
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(6, 182, 212, 0.4), transparent 70%);
      top: -200px;
      right: -100px;
      animation: float-slow 20s ease-in-out infinite, orb-pulse 8s ease-in-out infinite;
    }

    .ts-hero-orb-2 {
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(59, 130, 246, 0.3), transparent 70%);
      bottom: -100px;
      left: -80px;
      animation: float-slow 25s ease-in-out infinite reverse, orb-pulse 10s ease-in-out infinite;
    }

    .ts-hero-orb-3 {
      width: 350px;
      height: 350px;
      background: radial-gradient(circle, rgba(139, 92, 246, 0.25), transparent 70%);
      top: 40%;
      left: 15%;
      animation: float-drift 18s ease-in-out infinite, orb-pulse 7s ease-in-out infinite;
    }

    .ts-hero-grid {
      position: absolute;
      inset: 0;
      z-index: -1;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 70%);
    }

    /* Floating logos in hero background */
    .ts-hero-floating-logos {
      position: absolute;
      inset: 0;
      z-index: -1;
      pointer-events: none;
    }

    .ts-hero-floating-logo {
      position: absolute;
      opacity: 0.07;
      filter: grayscale(0.5) brightness(1.5);
    }

    .ts-hero-floating-logo:nth-child(1) { top: 12%; left: 8%; width: 64px; animation: float-logo 15s ease-in-out infinite; }
    .ts-hero-floating-logo:nth-child(2) { top: 20%; right: 12%; width: 56px; animation: float-logo 18s ease-in-out 2s infinite; }
    .ts-hero-floating-logo:nth-child(3) { top: 55%; left: 5%; width: 48px; animation: float-logo 20s ease-in-out 4s infinite; }
    .ts-hero-floating-logo:nth-child(4) { bottom: 25%; right: 8%; width: 60px; animation: float-logo 16s ease-in-out 1s infinite; }
    .ts-hero-floating-logo:nth-child(5) { top: 35%; right: 20%; width: 44px; animation: float-logo 22s ease-in-out 3s infinite; }
    .ts-hero-floating-logo:nth-child(6) { bottom: 15%; left: 18%; width: 52px; animation: float-logo 19s ease-in-out 5s infinite; }
    .ts-hero-floating-logo:nth-child(7) { top: 8%; left: 40%; width: 40px; animation: float-logo 21s ease-in-out 2.5s infinite; }
    .ts-hero-floating-logo:nth-child(8) { bottom: 35%; right: 30%; width: 50px; animation: float-logo 17s ease-in-out 1.5s infinite; }

    .ts-hero-content {
      text-align: center;
      max-width: 900px;
      z-index: 1;
    }

    .ts-hero-badge {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-2) var(--space-6);
      border-radius: var(--radius-full);
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(20px);
      color: rgba(255, 255, 255, 0.85);
      font-size: 0.875rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      margin-bottom: var(--space-10);
      animation: fadeInDown 0.8s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    }

    .ts-hero-badge-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--wc-neon);
      animation: pulse-glow 2s ease infinite;
      flex-shrink: 0;
    }

    .ts-hero-title {
      font-size: clamp(2.5rem, 8vw, 5rem);
      font-weight: 900;
      line-height: 1.15;
      margin-bottom: var(--space-6);
      background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(255,255,255,0.7) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.04em;
      animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s backwards;
    }

    .ts-hero-title span {
      background: linear-gradient(135deg, var(--wc-cyan), var(--wc-electric));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .ts-hero-subtitle {
      font-size: clamp(1.125rem, 2.5vw, 1.5rem);
      font-weight: 300;
      margin-bottom: var(--space-8);
      background: linear-gradient(90deg, rgba(255,255,255,0.9), rgba(6, 182, 212, 0.9));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s backwards;
    }

    .ts-hero-description {
      font-size: clamp(1rem, 1.5vw, 1.25rem);
      color: rgba(255, 255, 255, 0.55);
      max-width: 700px;
      margin: 0 auto var(--space-12);
      line-height: 1.75;
      animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.3s backwards;
    }

    .ts-hero-scroll {
      position: absolute;
      bottom: var(--space-10);
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-2);
      color: rgba(255, 255, 255, 0.3);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      animation: fadeIn 1s ease 1.5s backwards;
    }

    .ts-hero-scroll-line {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
      position: relative;
      overflow: hidden;
    }

    .ts-hero-scroll-line::after {
      content: '';
      position: absolute;
      top: -100%;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.8), transparent);
      animation: scroll-fade 2s ease-in-out infinite;
    }

    /* ============================================
       SHARED SECTION STYLES
       ============================================ */
    .ts-section {
      width: 100%;
      position: relative;
      overflow: hidden;
    }

    .ts-section-inner {
      padding: var(--space-24) var(--space-8);
      max-width: 1400px;
      margin: 0 auto;
    }

    .ts-section-header {
      text-align: center;
      margin-bottom: var(--space-16);
    }

    .ts-section-label {
      display: inline-block;
      padding: var(--space-1) var(--space-4);
      border-radius: var(--radius-full);
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: var(--space-4);
      background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(59, 130, 246, 0.1));
      color: var(--wc-cyan);
      border: 1px solid rgba(6, 182, 212, 0.15);
    }

    .ts-section-title {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 800;
      letter-spacing: -0.035em;
      margin-bottom: var(--space-5);
      color: var(--text-primary);
      line-height: 1.1;
    }

    .ts-section-description {
      font-size: clamp(1rem, 1.5vw, 1.2rem);
      color: var(--text-secondary);
      max-width: 650px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* --- Card base --- */
    .ts-card {
      padding: var(--space-8);
      border-radius: var(--radius-2xl);
      background: var(--surface-1);
      border: 1px solid var(--surface-3);
      transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
      position: relative;
      overflow: hidden;
    }

    .ts-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 1.5px;
      background: conic-gradient(from var(--gradient-angle), #06b6d4, #3b82f6, #8b5cf6, #06b6d4);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: 0;
      transition: opacity 0.5s ease;
      pointer-events: none;
      animation: border-rotate 4s linear infinite;
    }

    .ts-card::after {
      content: '';
      position: absolute;
      width: 300px;
      height: 300px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(6, 182, 212, 0.12), transparent 70%);
      opacity: 0;
      transition: opacity 0.5s ease;
      pointer-events: none;
      top: var(--mouse-y, 50%);
      left: var(--mouse-x, 50%);
      transform: translate(-50%, -50%);
    }

    .ts-card:hover::before { opacity: 1; }
    .ts-card:hover::after { opacity: 1; }
    .ts-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-xl), var(--glow-subtle);
      background: var(--surface-2);
    }

    /* ============================================
       FOOTER CTA
       ============================================ */
    .ts-footer-cta {
      padding: var(--space-24) var(--space-8);
      text-align: center;
      background: linear-gradient(180deg, var(--surface-0), var(--surface-1));
    }

    .ts-footer-cta-inner {
      max-width: 700px;
      margin: 0 auto;
    }

    .ts-footer-cta h2 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 900;
      letter-spacing: -0.035em;
      margin-bottom: var(--space-5);
      background: linear-gradient(135deg, var(--wc-cyan), var(--wc-electric), var(--wc-accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .ts-footer-cta p {
      font-size: 1.125rem;
      color: var(--text-secondary);
      margin-bottom: var(--space-10);
      line-height: 1.7;
    }

    .ts-footer-cta-buttons {
      display: flex;
      gap: var(--space-4);
      justify-content: center;
      flex-wrap: wrap;
    }

    .ts-btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-4) var(--space-8);
      border-radius: var(--radius-xl);
      font-size: 0.9375rem;
      font-weight: 700;
      transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
      cursor: pointer;
      border: none;
      text-decoration: none;
    }

    .ts-btn-solid {
      background: linear-gradient(135deg, #06b6d4, #3b82f6);
      color: white;
      box-shadow: 0 4px 20px rgba(6, 182, 212, 0.3);
    }

    .ts-btn-solid:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(6, 182, 212, 0.4);
      color: white;
    }

    .ts-btn-ghost {
      background: transparent;
      color: var(--text-secondary);
      border: 1px solid var(--glass-border-strong);
    }

    .ts-btn-ghost:hover {
      color: var(--text-primary);
      background: var(--glass-bg-strong);
      transform: translateY(-2px);
    }

    .ts-btn-arrow {
      transition: transform 0.2s ease;
    }

    .ts-btn:hover .ts-btn-arrow {
      transform: translateX(4px);
    }

    /* ============================================
       RESPONSIVE
       ============================================ */
    @media (max-width: 768px) {
      .ts-topbar {
        padding: var(--space-2) var(--space-4);
      }

      .ts-topbar-right {
        display: none;
      }

      .ts-section-inner {
        padding: var(--space-16) var(--space-4);
      }

      .ts-footer-cta-buttons {
        flex-direction: column;
        align-items: center;
      }
    }
  </style>

  <!-- Top Navigation Bar -->
  <nav class="ts-topbar" aria-label="Page navigation">
    <div class="ts-topbar-left">
      <a href="/" class="ts-back-link">
        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
        Dashboard
      </a>
      <span class="ts-topbar-title">The 2026 Stack</span>
    </div>
    <div class="ts-topbar-right">
      <a href="/prototype/tech-stack-validation/" class="ts-topbar-link">
        <i class="fa-solid fa-flask-vial" aria-hidden="true"></i>
        Validation Docs
      </a>
      <a href="/pre-planning/architecture/" class="ts-topbar-link">
        <i class="fa-solid fa-sitemap" aria-hidden="true"></i>
        Architecture
      </a>
    </div>
  </nav>

  <main>
    <!-- SECTION 1: HERO -->
    <section class="ts-hero" aria-label="Hero">
      <div class="ts-hero-orb ts-hero-orb-1" aria-hidden="true"></div>
      <div class="ts-hero-orb ts-hero-orb-2" aria-hidden="true"></div>
      <div class="ts-hero-orb ts-hero-orb-3" aria-hidden="true"></div>
      <div class="ts-hero-grid" aria-hidden="true"></div>

      <!-- Floating tech logos -->
      <div class="ts-hero-floating-logos" aria-hidden="true">
        <img src="/logos/lit.svg" alt="" class="ts-hero-floating-logo" />
        <img src="/logos/typescript.svg" alt="" class="ts-hero-floating-logo" />
        <img src="/logos/storybook.svg" alt="" class="ts-hero-floating-logo" />
        <img src="/logos/vitest.svg" alt="" class="ts-hero-floating-logo" />
        <img src="/logos/astro.svg" alt="" class="ts-hero-floating-logo" />
        <img src="/logos/turborepo.svg" alt="" class="ts-hero-floating-logo" />
        <img src="/logos/npm.svg" alt="" class="ts-hero-floating-logo" />
        <img src="/logos/drupal.svg" alt="" class="ts-hero-floating-logo" />
      </div>

      <div class="ts-hero-content">
        <div class="ts-hero-badge">
          <span class="ts-hero-badge-dot" aria-hidden="true"></span>
          8 Technologies. Zero Defaults. All Deliberate.
        </div>

        <h1 class="ts-hero-title">
          Every Tool Chosen<br />for a <span>Reason</span>
        </h1>

        <p class="ts-hero-subtitle">
          The 2026 Stack: Standards-First, Framework-Agnostic, Future-Proof
        </p>

        <p class="ts-hero-description">
          Nothing in this stack was chosen by popularity or convenience.
          Every technology was evaluated head-to-head against alternatives,
          measured on bundle size, Drupal compatibility, developer experience,
          and long-term standards alignment. This page shows the receipts.
        </p>
      </div>

      <div class="mouse-scroll-wrap mouse-scroll-wrap--absolute" aria-hidden="true">
        <div class="mouse-scroll-body"><div class="mouse-scroll-wheel"></div></div>
        <span class="mouse-scroll-label">Scroll</span>
      </div>
    </section>

    <!-- SECTION 2: STACK VISUALIZATION -->
    <StackVisualization />

    <!-- SECTION 3: HEAD-TO-HEAD COMPARISONS -->
    <StackComparisons />

    <!-- SECTION 4: BUNDLE SIZE SHOWDOWN -->
    <StackBundleSize />

    <!-- SECTION 5: INTEGRATION MAP -->
    <StackIntegrationMap />

    <!-- SECTION 6: PERFORMANCE BENCHMARKS -->
    <StackPerformance />

    <!-- SECTION 7: FUTURE-PROOF GUARANTEES -->
    <StackFutureProof />

    <!-- FOOTER CTA -->
    <section class="ts-footer-cta" aria-label="Next steps">
      <div class="ts-footer-cta-inner scroll-reveal">
        <h2>Explore the Full Documentation</h2>
        <p>
          Dive deeper into each technology decision with detailed comparison tables,
          validation checklists, and architecture diagrams.
        </p>
        <div class="ts-footer-cta-buttons">
          <a href="/prototype/tech-stack-validation/" class="ts-btn ts-btn-solid">
            Tech Stack Validation
            <span class="ts-btn-arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href="/pre-planning/architecture/" class="ts-btn ts-btn-ghost">
            Full Architecture Docs
            <span class="ts-btn-arrow" aria-hidden="true">&rarr;</span>
          </a>
          <a href="/" class="ts-btn ts-btn-ghost">
            Back to Dashboard
            <span class="ts-btn-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <ScrollRevealScript
    slot="scripts"
    cardSelectors={['.ts-comparison', '.ts-card']}
  />

  <script is:inline>
    // Animate bundle bars on scroll
    (function () {
      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReduced) return;

      var bundleObserver = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.querySelectorAll('.ts-bundle-fill').forEach(function (bar) {
                bar.style.animationPlayState = 'running';
              });
              bundleObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.3 }
      );

      var bundleBars = document.querySelector('.ts-bundle-bars');
      if (bundleBars) {
        bundleObserver.observe(bundleBars);
      }
    })();
  </script>
</ShowcaseLayout>
