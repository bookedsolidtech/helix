---
/**
 * Tech Stack - Full visual experience page.
 *
 * Standalone Astro page (not Starlight content) showcasing every
 * technology choice and WHY it was chosen for the WC-2026 project.
 *
 * Sections:
 * 1. Hero - Every Tool Chosen for a Reason
 * 2. The Stack Visualization - Layered architecture
 * 3. Head-to-Head Comparisons - Decision matrices
 * 4. Bundle Size Showdown - Framework weight comparison
 * 5. The Integration Map - Tool connection flow
 * 6. Performance Benchmarks - Visualized metrics
 * 7. Future-Proof Guarantees - Standards timeline
 * 8. Footer CTA
 */
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The 2026 Stack | WC-2026</title>
    <meta
      name="description"
      content="Every technology in WC-2026 was chosen for a reason. Explore the head-to-head comparisons, bundle analysis, and architectural decisions behind the cutting-edge 2026 stack."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <style>
      /* ============================================
         TECH STACK PAGE - Self-contained styles
         Uses same design tokens as the main site
         ============================================ */

      @property --gradient-angle {
        syntax: '<angle>';
        initial-value: 0deg;
        inherits: false;
      }

      :root {
        --wc-accent-h: 250;
        --wc-accent-s: 70%;
        --wc-accent-l: 60%;
        --wc-accent: hsl(var(--wc-accent-h), var(--wc-accent-s), var(--wc-accent-l));
        --wc-cyan: #06b6d4;
        --wc-pink: #ec4899;
        --wc-green: #10b981;
        --wc-amber: #f59e0b;
        --wc-red: #ef4444;
        --wc-electric: #3b82f6;
        --wc-neon: #22d3ee;
        --wc-lime: #84cc16;

        --gradient-primary: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --gradient-hero: linear-gradient(135deg, #0a0a1a 0%, #1a1040 40%, #0f0f2e 100%);
        --gradient-cyan-purple: linear-gradient(135deg, #06b6d4, #8b5cf6);
        --gradient-pink-orange: linear-gradient(135deg, #ec4899, #f97316);
        --gradient-green-cyan: linear-gradient(135deg, #10b981, #06b6d4);
        --gradient-electric: linear-gradient(135deg, #06b6d4, #3b82f6, #8b5cf6);

        --font-heading: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;

        --space-1: 0.25rem;
        --space-2: 0.5rem;
        --space-3: 0.75rem;
        --space-4: 1rem;
        --space-5: 1.25rem;
        --space-6: 1.5rem;
        --space-8: 2rem;
        --space-10: 2.5rem;
        --space-12: 3rem;
        --space-16: 4rem;
        --space-20: 5rem;
        --space-24: 6rem;

        --radius-sm: 0.5rem;
        --radius-md: 0.75rem;
        --radius-lg: 1rem;
        --radius-xl: 1.5rem;
        --radius-2xl: 2rem;
        --radius-full: 9999px;

        --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
        --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
        --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
        --shadow-xl: 0 16px 64px rgba(0, 0, 0, 0.6);

        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-bg-strong: rgba(255, 255, 255, 0.06);
        --glass-border: rgba(255, 255, 255, 0.06);
        --glass-border-strong: rgba(255, 255, 255, 0.12);

        --glow-primary: 0 0 50px rgba(102, 126, 234, 0.25);
        --glow-subtle: 0 0 20px rgba(102, 126, 234, 0.15);

        --surface-0: #0a0a14;
        --surface-1: #111122;
        --surface-2: #1a1a32;
        --surface-3: #252545;
        --text-primary: #eaeaf4;
        --text-secondary: #a8a8c8;
        --text-muted: #6868a0;
      }

      /* --- Reset & Base --- */
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: var(--font-body);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background: var(--surface-0);
        color: var(--text-primary);
        scroll-behavior: smooth;
        overflow-x: hidden;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.15;
      }

      code, pre {
        font-family: var(--font-mono);
      }

      a {
        color: var(--wc-accent);
        text-decoration: none;
        transition: color 0.2s ease;
      }

      a:hover {
        color: hsl(var(--wc-accent-h), var(--wc-accent-s), 75%);
      }

      /* --- Keyframes --- */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      @keyframes float-slow {
        0%, 100% { transform: translate(0, 0) scale(1); }
        25% { transform: translate(30px, -20px) scale(1.05); }
        50% { transform: translate(-10px, -35px) scale(0.97); }
        75% { transform: translate(-25px, -10px) scale(1.02); }
      }

      @keyframes float-drift {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33% { transform: translate(20px, 15px) rotate(2deg); }
        66% { transform: translate(-15px, -20px) rotate(-2deg); }
      }

      @keyframes orb-pulse {
        0%, 100% { opacity: 0.3; filter: blur(100px); }
        50% { opacity: 0.5; filter: blur(120px); }
      }

      @keyframes pulse-glow {
        0%, 100% { box-shadow: 0 0 8px rgba(6, 182, 212, 0.4); }
        50% { box-shadow: 0 0 24px rgba(6, 182, 212, 0.7); }
      }

      @keyframes border-rotate {
        0% { --gradient-angle: 0deg; }
        100% { --gradient-angle: 360deg; }
      }

      @keyframes particle-drift {
        0% { background-position: 0 0, 200px 200px, 400px 100px; }
        100% { background-position: 800px 800px, 1000px 1000px, 1200px 900px; }
      }

      @keyframes scroll-fade {
        0% { opacity: 1; transform: translateX(-50%) translateY(0); }
        100% { opacity: 0; transform: translateX(-50%) translateY(12px); }
      }

      @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
      }

      @keyframes bar-grow {
        from { width: 0; }
      }

      @keyframes float-logo {
        0%, 100% { transform: translate(0, 0) rotate(0deg); opacity: 0.07; }
        25% { transform: translate(10px, -15px) rotate(3deg); opacity: 0.12; }
        50% { transform: translate(-8px, -25px) rotate(-2deg); opacity: 0.08; }
        75% { transform: translate(-15px, -8px) rotate(1deg); opacity: 0.1; }
      }

      @keyframes pulse-ring {
        0% { transform: scale(0.95); opacity: 0.5; }
        50% { transform: scale(1.05); opacity: 1; }
        100% { transform: scale(0.95); opacity: 0.5; }
      }

      @keyframes flow-dash {
        to { stroke-dashoffset: -20; }
      }

      /* --- Scroll Reveal --- */
      .scroll-reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.8s cubic-bezier(0.22, 1, 0.36, 1),
                    filter 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        filter: blur(4px);
      }

      .scroll-reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
      }

      .scroll-reveal-delay-1 { transition-delay: 0.1s; }
      .scroll-reveal-delay-2 { transition-delay: 0.2s; }
      .scroll-reveal-delay-3 { transition-delay: 0.3s; }
      .scroll-reveal-delay-4 { transition-delay: 0.4s; }
      .scroll-reveal-delay-5 { transition-delay: 0.5s; }
      .scroll-reveal-delay-6 { transition-delay: 0.6s; }

      /* --- Top Navigation Bar --- */
      .ts-topbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-3) var(--space-8);
        background: rgba(10, 10, 20, 0.85);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .ts-topbar-left {
        display: flex;
        align-items: center;
        gap: var(--space-4);
      }

      .ts-back-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-secondary);
        transition: all 0.2s ease;
        padding: var(--space-2) var(--space-3);
        border-radius: var(--radius-md);
      }

      .ts-back-link:hover {
        color: var(--text-primary);
        background: var(--glass-bg-strong);
      }

      .ts-topbar-title {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.01em;
      }

      .ts-topbar-right {
        display: flex;
        align-items: center;
        gap: var(--space-3);
      }

      .ts-topbar-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-muted);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-md);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.2s ease;
      }

      .ts-topbar-link:hover {
        color: var(--wc-cyan);
        border-color: rgba(6, 182, 212, 0.3);
        background: rgba(6, 182, 212, 0.06);
      }

      /* ============================================
         SECTION 1: HERO
         ============================================ */
      .ts-hero {
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        isolation: isolate;
        padding: var(--space-24) var(--space-8) var(--space-16);
      }

      .ts-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: var(--gradient-hero);
        z-index: -3;
      }

      .ts-hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          radial-gradient(circle at 20% 30%, rgba(6, 182, 212, 0.04) 2px, transparent 2px),
          radial-gradient(circle at 60% 70%, rgba(102, 126, 234, 0.04) 3px, transparent 3px),
          radial-gradient(circle at 80% 20%, rgba(34, 211, 238, 0.03) 2px, transparent 2px);
        background-size: 800px 800px;
        animation: particle-drift 60s linear infinite;
        opacity: 0.6;
        z-index: -2;
      }

      .ts-hero-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.3;
        z-index: -1;
        pointer-events: none;
      }

      .ts-hero-orb-1 {
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(6, 182, 212, 0.4), transparent 70%);
        top: -200px;
        right: -100px;
        animation: float-slow 20s ease-in-out infinite, orb-pulse 8s ease-in-out infinite;
      }

      .ts-hero-orb-2 {
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.3), transparent 70%);
        bottom: -100px;
        left: -80px;
        animation: float-slow 25s ease-in-out infinite reverse, orb-pulse 10s ease-in-out infinite;
      }

      .ts-hero-orb-3 {
        width: 350px;
        height: 350px;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.25), transparent 70%);
        top: 40%;
        left: 15%;
        animation: float-drift 18s ease-in-out infinite, orb-pulse 7s ease-in-out infinite;
      }

      .ts-hero-grid {
        position: absolute;
        inset: 0;
        z-index: -1;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 70%);
        -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 70%);
      }

      /* Floating logos in hero background */
      .ts-hero-floating-logos {
        position: absolute;
        inset: 0;
        z-index: -1;
        pointer-events: none;
      }

      .ts-hero-floating-logo {
        position: absolute;
        opacity: 0.07;
        filter: grayscale(0.5) brightness(1.5);
      }

      .ts-hero-floating-logo:nth-child(1) { top: 12%; left: 8%; width: 64px; animation: float-logo 15s ease-in-out infinite; }
      .ts-hero-floating-logo:nth-child(2) { top: 20%; right: 12%; width: 56px; animation: float-logo 18s ease-in-out 2s infinite; }
      .ts-hero-floating-logo:nth-child(3) { top: 55%; left: 5%; width: 48px; animation: float-logo 20s ease-in-out 4s infinite; }
      .ts-hero-floating-logo:nth-child(4) { bottom: 25%; right: 8%; width: 60px; animation: float-logo 16s ease-in-out 1s infinite; }
      .ts-hero-floating-logo:nth-child(5) { top: 35%; right: 20%; width: 44px; animation: float-logo 22s ease-in-out 3s infinite; }
      .ts-hero-floating-logo:nth-child(6) { bottom: 15%; left: 18%; width: 52px; animation: float-logo 19s ease-in-out 5s infinite; }
      .ts-hero-floating-logo:nth-child(7) { top: 8%; left: 40%; width: 40px; animation: float-logo 21s ease-in-out 2.5s infinite; }
      .ts-hero-floating-logo:nth-child(8) { bottom: 35%; right: 30%; width: 50px; animation: float-logo 17s ease-in-out 1.5s infinite; }

      .ts-hero-content {
        text-align: center;
        max-width: 900px;
        z-index: 1;
      }

      .ts-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-2) var(--space-6);
        border-radius: var(--radius-full);
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        margin-bottom: var(--space-10);
        animation: fadeInDown 0.8s cubic-bezier(0.22, 1, 0.36, 1) backwards;
      }

      .ts-hero-badge-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--wc-neon);
        animation: pulse-glow 2s ease infinite;
        flex-shrink: 0;
      }

      .ts-hero-title {
        font-size: clamp(2.5rem, 8vw, 5rem);
        font-weight: 900;
        line-height: 1.15;
        margin-bottom: var(--space-6);
        background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(255,255,255,0.7) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -0.04em;
        animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s backwards;
      }

      .ts-hero-title span {
        background: linear-gradient(135deg, var(--wc-cyan), var(--wc-electric));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .ts-hero-subtitle {
        font-size: clamp(1.125rem, 2.5vw, 1.5rem);
        font-weight: 300;
        margin-bottom: var(--space-8);
        background: linear-gradient(90deg, rgba(255,255,255,0.9), rgba(6, 182, 212, 0.9));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s backwards;
      }

      .ts-hero-description {
        font-size: clamp(1rem, 1.5vw, 1.25rem);
        color: rgba(255, 255, 255, 0.55);
        max-width: 700px;
        margin: 0 auto var(--space-12);
        line-height: 1.75;
        animation: fadeInUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.3s backwards;
      }

      .ts-hero-scroll {
        position: absolute;
        bottom: var(--space-10);
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-2);
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.6875rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        animation: fadeIn 1s ease 1.5s backwards;
      }

      .ts-hero-scroll-line {
        width: 1px;
        height: 40px;
        background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
        position: relative;
        overflow: hidden;
      }

      .ts-hero-scroll-line::after {
        content: '';
        position: absolute;
        top: -100%;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.8), transparent);
        animation: scroll-fade 2s ease-in-out infinite;
      }

      /* ============================================
         SHARED SECTION STYLES
         ============================================ */
      .ts-section {
        width: 100%;
        position: relative;
        overflow: hidden;
      }

      .ts-section-inner {
        padding: var(--space-24) var(--space-8);
        max-width: 1400px;
        margin: 0 auto;
      }

      .ts-section-header {
        text-align: center;
        margin-bottom: var(--space-16);
      }

      .ts-section-label {
        display: inline-block;
        padding: var(--space-1) var(--space-4);
        border-radius: var(--radius-full);
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: var(--space-4);
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(59, 130, 246, 0.1));
        color: var(--wc-cyan);
        border: 1px solid rgba(6, 182, 212, 0.15);
      }

      .ts-section-title {
        font-size: clamp(2rem, 5vw, 3.25rem);
        font-weight: 800;
        letter-spacing: -0.035em;
        margin-bottom: var(--space-5);
        color: var(--text-primary);
        line-height: 1.1;
      }

      .ts-section-description {
        font-size: clamp(1rem, 1.5vw, 1.2rem);
        color: var(--text-secondary);
        max-width: 650px;
        margin: 0 auto;
        line-height: 1.7;
      }

      /* --- Card base --- */
      .ts-card {
        padding: var(--space-8);
        border-radius: var(--radius-2xl);
        background: var(--surface-1);
        border: 1px solid var(--surface-3);
        transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
        position: relative;
        overflow: hidden;
      }

      .ts-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1.5px;
        background: conic-gradient(from var(--gradient-angle), #06b6d4, #3b82f6, #8b5cf6, #06b6d4);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 0.5s ease;
        pointer-events: none;
        animation: border-rotate 4s linear infinite;
      }

      .ts-card::after {
        content: '';
        position: absolute;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(6, 182, 212, 0.12), transparent 70%);
        opacity: 0;
        transition: opacity 0.5s ease;
        pointer-events: none;
        top: var(--mouse-y, 50%);
        left: var(--mouse-x, 50%);
        transform: translate(-50%, -50%);
      }

      .ts-card:hover::before { opacity: 1; }
      .ts-card:hover::after { opacity: 1; }
      .ts-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-xl), var(--glow-subtle);
        background: var(--surface-2);
      }

      /* ============================================
         SECTION 2: STACK VISUALIZATION
         ============================================ */
      .ts-stack-section {
        background: var(--surface-0);
        border-top: 1px solid var(--surface-3);
        border-bottom: 1px solid var(--surface-3);
      }

      .ts-stack-container {
        display: flex;
        gap: var(--space-8);
        align-items: stretch;
        max-width: 1100px;
        margin: 0 auto;
      }

      .ts-stack-layers {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
      }

      .ts-stack-layer {
        padding: var(--space-6) var(--space-8);
        border-radius: var(--radius-xl);
        border: 1px solid;
        position: relative;
        transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .ts-stack-layer:hover {
        transform: translateX(8px);
      }

      .ts-stack-layer-tag {
        display: inline-block;
        font-size: 0.6875rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: var(--space-1) var(--space-3);
        border-radius: var(--radius-full);
        margin-bottom: var(--space-3);
      }

      .ts-stack-layer-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: var(--space-2);
      }

      .ts-stack-layer-techs {
        display: flex;
        gap: var(--space-4);
        flex-wrap: wrap;
        align-items: center;
      }

      .ts-stack-layer-tech {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-secondary);
      }

      .ts-stack-layer-tech img {
        width: 24px;
        height: 24px;
      }

      /* Layer colors */
      .ts-layer-docs {
        background: linear-gradient(135deg, rgba(255, 93, 1, 0.08), rgba(255, 71, 133, 0.04));
        border-color: rgba(255, 93, 1, 0.2);
      }
      .ts-layer-docs .ts-stack-layer-tag {
        background: rgba(255, 93, 1, 0.15);
        color: #ff5d01;
      }
      .ts-layer-docs .ts-stack-layer-title { color: #ff8a4c; }

      .ts-layer-dx {
        background: linear-gradient(135deg, rgba(255, 71, 133, 0.08), rgba(114, 155, 27, 0.04));
        border-color: rgba(255, 71, 133, 0.2);
      }
      .ts-layer-dx .ts-stack-layer-tag {
        background: rgba(255, 71, 133, 0.15);
        color: #ff4785;
      }
      .ts-layer-dx .ts-stack-layer-title { color: #ff6ea1; }

      .ts-layer-core {
        background: linear-gradient(135deg, rgba(50, 79, 255, 0.1), rgba(49, 120, 198, 0.06));
        border-color: rgba(50, 79, 255, 0.25);
      }
      .ts-layer-core .ts-stack-layer-tag {
        background: rgba(50, 79, 255, 0.15);
        color: #324fff;
      }
      .ts-layer-core .ts-stack-layer-title { color: #6b8aff; }

      .ts-layer-build {
        background: linear-gradient(135deg, rgba(0, 150, 255, 0.08), rgba(193, 33, 39, 0.04));
        border-color: rgba(0, 150, 255, 0.2);
      }
      .ts-layer-build .ts-stack-layer-tag {
        background: rgba(0, 150, 255, 0.15);
        color: #0096ff;
      }
      .ts-layer-build .ts-stack-layer-title { color: #4db8ff; }

      /* Design tokens sidebar */
      .ts-stack-sidebar {
        width: 180px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: var(--space-6) var(--space-4);
        border-radius: var(--radius-xl);
        background: linear-gradient(180deg, rgba(16, 185, 129, 0.08), rgba(6, 182, 212, 0.08));
        border: 1px solid rgba(16, 185, 129, 0.2);
        text-align: center;
        position: relative;
      }

      .ts-stack-sidebar::before {
        content: '';
        position: absolute;
        top: 10%;
        bottom: 10%;
        left: -1px;
        width: 3px;
        background: linear-gradient(180deg, var(--wc-green), var(--wc-cyan));
        border-radius: 2px;
      }

      .ts-stack-sidebar-icon {
        font-size: 2rem;
        color: var(--wc-green);
        margin-bottom: var(--space-4);
      }

      .ts-stack-sidebar-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--wc-green);
        margin-bottom: var(--space-2);
      }

      .ts-stack-sidebar-techs {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        line-height: 1.6;
      }

      /* ============================================
         SECTION 3: HEAD-TO-HEAD COMPARISONS
         ============================================ */
      .ts-comparisons-section {
        background: var(--surface-0);
      }

      .ts-comparison-grid {
        display: grid;
        gap: var(--space-10);
        max-width: 1100px;
        margin: 0 auto;
      }

      .ts-comparison {
        padding: var(--space-10);
        border-radius: var(--radius-2xl);
        background: var(--surface-1);
        border: 1px solid var(--surface-3);
        position: relative;
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .ts-comparison::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1.5px;
        background: conic-gradient(from var(--gradient-angle), #06b6d4, #3b82f6, #8b5cf6, #06b6d4);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 0.5s ease;
        pointer-events: none;
        animation: border-rotate 4s linear infinite;
      }

      .ts-comparison::after {
        content: '';
        position: absolute;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(6, 182, 212, 0.08), transparent 70%);
        opacity: 0;
        transition: opacity 0.5s ease;
        pointer-events: none;
        top: var(--mouse-y, 50%);
        left: var(--mouse-x, 50%);
        transform: translate(-50%, -50%);
      }

      .ts-comparison:hover::before { opacity: 1; }
      .ts-comparison:hover::after { opacity: 1; }

      .ts-comparison-header {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        margin-bottom: var(--space-8);
      }

      .ts-comparison-icon {
        width: 56px;
        height: 56px;
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
      }

      .ts-comparison-category {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--space-1);
      }

      .ts-comparison-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-primary);
      }

      /* Comparison table */
      .ts-comp-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: var(--space-6);
        font-size: 0.875rem;
      }

      .ts-comp-table th {
        text-align: left;
        padding: var(--space-3) var(--space-4);
        font-weight: 600;
        color: var(--text-muted);
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        border-bottom: 1px solid var(--surface-3);
      }

      .ts-comp-table td {
        padding: var(--space-3) var(--space-4);
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        color: var(--text-secondary);
      }

      .ts-comp-table tr:last-child td {
        border-bottom: none;
      }

      .ts-comp-table .ts-winner-col {
        background: rgba(6, 182, 212, 0.04);
      }

      .ts-comp-table th.ts-winner-col {
        color: var(--wc-cyan);
        background: rgba(6, 182, 212, 0.06);
      }

      .ts-check { color: var(--wc-green); }
      .ts-cross { color: var(--wc-red); opacity: 0.6; }
      .ts-partial { color: var(--wc-amber); }

      /* Winner badge */
      .ts-winner-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-full);
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.15), rgba(16, 185, 129, 0.1));
        border: 1px solid rgba(6, 182, 212, 0.25);
        color: var(--wc-cyan);
        font-size: 0.8125rem;
        font-weight: 700;
        letter-spacing: 0.02em;
      }

      .ts-winner-badge i {
        color: var(--wc-green);
      }

      .ts-decision-text {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        line-height: 1.7;
        margin-top: var(--space-4);
      }

      .ts-decision-text strong {
        color: var(--text-primary);
      }

      /* ============================================
         SECTION 4: BUNDLE SIZE SHOWDOWN
         ============================================ */
      .ts-bundle-section {
        background: var(--surface-0);
        border-top: 1px solid var(--surface-3);
        border-bottom: 1px solid var(--surface-3);
      }

      .ts-bundle-container {
        max-width: 900px;
        margin: 0 auto;
      }

      .ts-bundle-bars {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
      }

      .ts-bundle-row {
        display: grid;
        grid-template-columns: 140px 1fr 60px;
        align-items: center;
        gap: var(--space-4);
      }

      .ts-bundle-label {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: var(--space-3);
      }

      .ts-bundle-label img {
        width: 24px;
        height: 24px;
      }

      .ts-bundle-track {
        height: 40px;
        border-radius: var(--radius-md);
        background: var(--surface-2);
        position: relative;
        overflow: hidden;
      }

      .ts-bundle-fill {
        height: 100%;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding-right: var(--space-4);
        font-size: 0.8125rem;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.9);
        transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1);
        position: relative;
        overflow: hidden;
      }

      .ts-bundle-fill::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.1) 50%, transparent 100%);
        background-size: 200% 100%;
        animation: shimmer 3s ease-in-out infinite;
      }

      .ts-bundle-fill.ts-fill-lit {
        background: linear-gradient(90deg, #06b6d4, #22d3ee);
        width: 6.25%;
      }
      .ts-bundle-fill.ts-fill-vue {
        background: linear-gradient(90deg, #42b883, #35495e);
        width: 37.5%;
      }
      .ts-bundle-fill.ts-fill-react {
        background: linear-gradient(90deg, #61dafb, #3178c6);
        width: 50%;
      }
      .ts-bundle-fill.ts-fill-angular {
        background: linear-gradient(90deg, #dd0031, #c3002f);
        width: 100%;
      }

      .ts-bundle-size {
        font-size: 1rem;
        font-weight: 800;
        color: var(--text-primary);
        text-align: right;
        font-family: var(--font-mono);
      }

      .ts-bundle-highlight {
        text-align: center;
        margin-top: var(--space-12);
        padding: var(--space-8);
        border-radius: var(--radius-2xl);
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.08), rgba(59, 130, 246, 0.04));
        border: 1px solid rgba(6, 182, 212, 0.2);
      }

      .ts-bundle-highlight-number {
        font-size: clamp(3rem, 8vw, 5rem);
        font-weight: 900;
        background: linear-gradient(135deg, var(--wc-cyan), var(--wc-electric));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
        margin-bottom: var(--space-3);
      }

      .ts-bundle-highlight-text {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: var(--space-2);
      }

      .ts-bundle-highlight-sub {
        font-size: 0.9375rem;
        color: var(--text-secondary);
      }

      /* ============================================
         SECTION 5: INTEGRATION MAP
         ============================================ */
      .ts-flow-section {
        background: var(--surface-0);
      }

      .ts-flow-pipeline {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        max-width: 1200px;
        margin: 0 auto;
        flex-wrap: wrap;
      }

      .ts-flow-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-6) var(--space-4);
        text-align: center;
        flex: 0 0 auto;
        min-width: 120px;
      }

      .ts-flow-icon {
        width: 72px;
        height: 72px;
        border-radius: var(--radius-xl);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid;
        position: relative;
        transition: all 0.3s ease;
      }

      .ts-flow-step:hover .ts-flow-icon {
        transform: scale(1.1);
      }

      .ts-flow-icon img {
        width: 36px;
        height: 36px;
      }

      .ts-flow-icon i {
        font-size: 1.5rem;
      }

      .ts-flow-label {
        font-size: 0.8125rem;
        font-weight: 700;
        color: var(--text-primary);
      }

      .ts-flow-sub {
        font-size: 0.6875rem;
        color: var(--text-muted);
        max-width: 100px;
      }

      .ts-flow-arrow {
        color: var(--text-muted);
        font-size: 1.25rem;
        flex-shrink: 0;
        padding: 0 var(--space-1);
      }

      /* Flow icon colors */
      .ts-flow-author { background: rgba(50, 79, 255, 0.1); border-color: rgba(50, 79, 255, 0.3); color: #324fff; }
      .ts-flow-test { background: rgba(114, 155, 27, 0.1); border-color: rgba(114, 155, 27, 0.3); color: #729B1B; }
      .ts-flow-document { background: rgba(255, 71, 133, 0.1); border-color: rgba(255, 71, 133, 0.3); color: #ff4785; }
      .ts-flow-build { background: rgba(189, 52, 254, 0.1); border-color: rgba(189, 52, 254, 0.3); color: #bd34fe; }
      .ts-flow-publish { background: rgba(193, 33, 39, 0.1); border-color: rgba(193, 33, 39, 0.3); color: #c12127; }
      .ts-flow-integrate { background: rgba(6, 120, 190, 0.1); border-color: rgba(6, 120, 190, 0.3); color: #0678be; }

      .ts-flow-cem-note {
        text-align: center;
        margin-top: var(--space-10);
        padding: var(--space-6);
        border-radius: var(--radius-xl);
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(6, 182, 212, 0.04));
        border: 1px solid rgba(139, 92, 246, 0.2);
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
      }

      .ts-flow-cem-note-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--wc-accent);
        margin-bottom: var(--space-2);
      }

      .ts-flow-cem-note-text {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.6;
      }

      /* ============================================
         SECTION 6: PERFORMANCE BENCHMARKS
         ============================================ */
      .ts-perf-section {
        background: var(--surface-0);
        border-top: 1px solid var(--surface-3);
        border-bottom: 1px solid var(--surface-3);
      }

      .ts-perf-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--space-6);
        max-width: 1100px;
        margin: 0 auto;
      }

      .ts-perf-card {
        padding: var(--space-8);
        border-radius: var(--radius-2xl);
        background: var(--surface-1);
        border: 1px solid var(--surface-3);
        text-align: center;
        transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .ts-perf-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
        background: var(--surface-2);
      }

      .ts-perf-icon {
        font-size: 1.75rem;
        margin-bottom: var(--space-4);
      }

      .ts-perf-value {
        font-size: 2.5rem;
        font-weight: 900;
        font-family: var(--font-mono);
        line-height: 1;
        margin-bottom: var(--space-2);
      }

      .ts-perf-metric {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: var(--space-2);
      }

      .ts-perf-desc {
        font-size: 0.8125rem;
        color: var(--text-muted);
        line-height: 1.5;
      }

      .ts-perf-bar-container {
        margin-top: var(--space-4);
        background: var(--surface-3);
        border-radius: var(--radius-full);
        height: 6px;
        overflow: hidden;
      }

      .ts-perf-bar {
        height: 100%;
        border-radius: var(--radius-full);
        transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1);
      }

      /* ============================================
         SECTION 7: FUTURE-PROOF GUARANTEES
         ============================================ */
      .ts-future-section {
        background: var(--surface-0);
      }

      .ts-timeline {
        max-width: 800px;
        margin: 0 auto;
        position: relative;
        padding-left: var(--space-12);
      }

      .ts-timeline::before {
        content: '';
        position: absolute;
        left: 18px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(180deg, var(--wc-cyan), var(--wc-accent), var(--wc-green));
      }

      .ts-timeline-item {
        position: relative;
        padding-bottom: var(--space-10);
        padding-left: var(--space-6);
      }

      .ts-timeline-item:last-child {
        padding-bottom: 0;
      }

      .ts-timeline-dot {
        position: absolute;
        left: calc(-1 * var(--space-12) + 10px);
        top: 4px;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 3px solid;
        background: var(--surface-0);
        z-index: 1;
      }

      .ts-timeline-dot.ts-dot-cyan { border-color: var(--wc-cyan); box-shadow: 0 0 12px rgba(6, 182, 212, 0.4); }
      .ts-timeline-dot.ts-dot-accent { border-color: var(--wc-accent); box-shadow: 0 0 12px rgba(102, 126, 234, 0.4); }
      .ts-timeline-dot.ts-dot-green { border-color: var(--wc-green); box-shadow: 0 0 12px rgba(16, 185, 129, 0.4); }
      .ts-timeline-dot.ts-dot-amber { border-color: var(--wc-amber); box-shadow: 0 0 12px rgba(245, 158, 11, 0.4); }
      .ts-timeline-dot.ts-dot-electric { border-color: var(--wc-electric); box-shadow: 0 0 12px rgba(59, 130, 246, 0.4); }

      .ts-timeline-title {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: var(--space-2);
      }

      .ts-timeline-desc {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        line-height: 1.7;
      }

      .ts-timeline-tag {
        display: inline-block;
        font-size: 0.6875rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: var(--space-1) var(--space-3);
        border-radius: var(--radius-full);
        margin-bottom: var(--space-2);
      }

      .ts-tag-standard {
        background: rgba(6, 182, 212, 0.12);
        color: var(--wc-cyan);
      }

      .ts-tag-native {
        background: rgba(16, 185, 129, 0.12);
        color: var(--wc-green);
      }

      .ts-tag-open {
        background: rgba(139, 92, 246, 0.12);
        color: var(--wc-accent);
      }

      /* Framework churn contrast */
      .ts-churn-container {
        max-width: 800px;
        margin: var(--space-12) auto 0;
        padding: var(--space-8);
        border-radius: var(--radius-2xl);
        background: var(--surface-1);
        border: 1px solid var(--surface-3);
      }

      .ts-churn-title {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: var(--space-6);
        text-align: center;
      }

      .ts-churn-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--space-4);
      }

      .ts-churn-item {
        padding: var(--space-4);
        border-radius: var(--radius-lg);
        background: rgba(239, 68, 68, 0.04);
        border: 1px solid rgba(239, 68, 68, 0.1);
        text-align: center;
      }

      .ts-churn-item-label {
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: var(--space-1);
      }

      .ts-churn-item-versions {
        font-size: 0.75rem;
        color: var(--text-muted);
        font-family: var(--font-mono);
      }

      .ts-churn-vs {
        text-align: center;
        margin-top: var(--space-6);
        padding: var(--space-4);
        border-radius: var(--radius-lg);
        background: rgba(6, 182, 212, 0.06);
        border: 1px solid rgba(6, 182, 212, 0.15);
      }

      .ts-churn-vs-text {
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--wc-cyan);
      }

      /* ============================================
         FOOTER CTA
         ============================================ */
      .ts-footer-cta {
        padding: var(--space-24) var(--space-8);
        text-align: center;
        background: linear-gradient(180deg, var(--surface-0), var(--surface-1));
      }

      .ts-footer-cta-inner {
        max-width: 700px;
        margin: 0 auto;
      }

      .ts-footer-cta h2 {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 900;
        letter-spacing: -0.035em;
        margin-bottom: var(--space-5);
        background: linear-gradient(135deg, var(--wc-cyan), var(--wc-electric), var(--wc-accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .ts-footer-cta p {
        font-size: 1.125rem;
        color: var(--text-secondary);
        margin-bottom: var(--space-10);
        line-height: 1.7;
      }

      .ts-footer-cta-buttons {
        display: flex;
        gap: var(--space-4);
        justify-content: center;
        flex-wrap: wrap;
      }

      .ts-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-4) var(--space-8);
        border-radius: var(--radius-xl);
        font-size: 0.9375rem;
        font-weight: 700;
        transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
        cursor: pointer;
        border: none;
        text-decoration: none;
      }

      .ts-btn-solid {
        background: linear-gradient(135deg, #06b6d4, #3b82f6);
        color: white;
        box-shadow: 0 4px 20px rgba(6, 182, 212, 0.3);
      }

      .ts-btn-solid:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(6, 182, 212, 0.4);
        color: white;
      }

      .ts-btn-ghost {
        background: transparent;
        color: var(--text-secondary);
        border: 1px solid var(--glass-border-strong);
      }

      .ts-btn-ghost:hover {
        color: var(--text-primary);
        background: var(--glass-bg-strong);
        transform: translateY(-2px);
      }

      .ts-btn-arrow {
        transition: transform 0.2s ease;
      }

      .ts-btn:hover .ts-btn-arrow {
        transform: translateX(4px);
      }

      /* ============================================
         RESPONSIVE
         ============================================ */
      @media (max-width: 1024px) {
        .ts-stack-container {
          flex-direction: column;
        }

        .ts-stack-sidebar {
          width: 100%;
          flex-direction: row;
          gap: var(--space-4);
          padding: var(--space-4) var(--space-6);
        }

        .ts-stack-sidebar::before {
          display: none;
        }

        .ts-flow-pipeline {
          gap: var(--space-2);
        }

        .ts-flow-step {
          min-width: 100px;
          padding: var(--space-4) var(--space-2);
        }
      }

      @media (max-width: 768px) {
        .ts-topbar {
          padding: var(--space-2) var(--space-4);
        }

        .ts-topbar-right {
          display: none;
        }

        .ts-section-inner {
          padding: var(--space-16) var(--space-4);
        }

        .ts-bundle-row {
          grid-template-columns: 100px 1fr 50px;
          gap: var(--space-2);
        }

        .ts-bundle-label {
          font-size: 0.8125rem;
        }

        .ts-comp-table {
          font-size: 0.75rem;
        }

        .ts-comp-table th,
        .ts-comp-table td {
          padding: var(--space-2) var(--space-3);
        }

        .ts-comparison {
          padding: var(--space-6);
        }

        .ts-flow-pipeline {
          flex-direction: column;
          gap: 0;
        }

        .ts-flow-arrow {
          transform: rotate(90deg);
          padding: var(--space-1) 0;
        }

        .ts-flow-step {
          flex-direction: row;
          text-align: left;
          gap: var(--space-4);
          min-width: auto;
          width: 100%;
          max-width: 300px;
        }

        .ts-flow-icon {
          width: 56px;
          height: 56px;
          flex-shrink: 0;
        }

        .ts-flow-icon img {
          width: 28px;
          height: 28px;
        }

        .ts-timeline {
          padding-left: var(--space-10);
        }

        .ts-timeline::before {
          left: 14px;
        }

        .ts-timeline-dot {
          left: calc(-1 * var(--space-10) + 6px);
          width: 16px;
          height: 16px;
        }

        .ts-footer-cta-buttons {
          flex-direction: column;
          align-items: center;
        }
      }

      @media (max-width: 480px) {
        .ts-bundle-row {
          grid-template-columns: 80px 1fr 40px;
        }

        .ts-bundle-track {
          height: 32px;
        }

        .ts-perf-grid {
          grid-template-columns: 1fr;
        }

        .ts-churn-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
