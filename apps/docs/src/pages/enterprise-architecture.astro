---
/**
 * Enterprise Architecture - Full visual experience page.
 *
 * Standalone Astro page showcasing HELIX's enterprise-grade architecture:
 * 1. Hero - "Enterprise by Default"
 * 2. TypeScript Strategy - Strict mode, zero any, full type safety
 * 3. CEM Pipeline - JSDoc → CEM → Storybook + Docs + IDE + Drupal
 * 4. Three-Tier Token Architecture - Global → Brand → Component
 * 5. Quality Automation - Testing pyramid with real tools
 * 6. Documentation Strategy - Write once, publish everywhere
 * 7. Footer CTA
 */
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro';
---

<ShowcaseLayout
  title="Enterprise Architecture"
  description="100% TypeScript, CEM-driven documentation, three-tier W3C DTCG design tokens, and automated quality pipelines. Enterprise architecture that scales."
>
  <style is:inline>
    /* Page-specific gradient-hero override */
    :root { --gradient-hero: linear-gradient(135deg, #0a0a1a 0%, #0f1030 40%, #0a0a2e 100%); }

    /* Top Navigation */
    .ea-topbar { position:fixed; top:0; left:0; right:0; z-index:100; display:flex; align-items:center; justify-content:space-between; padding:var(--space-3) var(--space-8); background:rgba(10,10,20,0.85); backdrop-filter:blur(16px) saturate(180%); -webkit-backdrop-filter:blur(16px) saturate(180%); border-bottom:1px solid rgba(255,255,255,0.06); }
    .ea-topbar-left { display:flex; align-items:center; gap:var(--space-4); }
    .ea-back-link { display:inline-flex; align-items:center; gap:var(--space-2); font-size:0.875rem; font-weight:600; color:var(--text-secondary); transition:all 0.2s ease; padding:var(--space-2) var(--space-3); border-radius:var(--radius-md); }
    .ea-back-link:hover { color:var(--text-primary); background:var(--glass-bg-strong); }
    .ea-topbar-title { font-size:0.875rem; font-weight:700; color:var(--text-primary); }
    .ea-topbar-right { display:flex; align-items:center; gap:var(--space-4); }
    .ea-topbar-link { font-size:0.8125rem; font-weight:500; color:var(--text-secondary); display:inline-flex; align-items:center; gap:var(--space-2); padding:var(--space-2) var(--space-3); border-radius:var(--radius-md); transition:all 0.2s ease; }
    .ea-topbar-link:hover { color:var(--text-primary); background:var(--glass-bg-strong); }

    /* Hero */
    .ea-hero { position:relative; min-height:100vh; display:flex; align-items:center; justify-content:center; text-align:center; padding:var(--space-24) var(--space-8); background:var(--gradient-hero); overflow:hidden; }
    .ea-hero-grid { position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px); background-size:60px 60px; }
    .ea-hero-orb { position:absolute; border-radius:50%; pointer-events:none; }
    .ea-hero-orb-1 { width:500px; height:500px; background:radial-gradient(circle,rgba(6,182,212,0.2),transparent 70%); top:-10%; right:-5%; animation:float-slow 20s ease-in-out infinite, orb-pulse 8s ease-in-out infinite; }
    .ea-hero-orb-2 { width:400px; height:400px; background:radial-gradient(circle,rgba(139,92,246,0.15),transparent 70%); bottom:-5%; left:-5%; animation:float-slow 25s ease-in-out infinite reverse, orb-pulse 10s ease-in-out infinite 2s; }
    .ea-hero-orb-3 { width:300px; height:300px; background:radial-gradient(circle,rgba(16,185,129,0.12),transparent 70%); top:30%; left:15%; animation:float-slow 18s ease-in-out infinite 3s, orb-pulse 12s ease-in-out infinite 4s; }
    .ea-hero-content { position:relative; z-index:2; max-width:800px; }
    .ea-hero-badge { display:inline-flex; align-items:center; gap:var(--space-2); padding:var(--space-2) var(--space-4); background:var(--glass-bg-strong); border:1px solid var(--glass-border-strong); border-radius:var(--radius-full); font-size:0.8125rem; font-weight:600; color:var(--wc-cyan); margin-bottom:var(--space-8); animation:fadeInDown 0.8s ease-out; }
    .ea-hero-badge-dot { width:8px; height:8px; border-radius:50%; background:var(--wc-cyan); box-shadow:0 0 8px var(--wc-cyan); }
    .ea-hero-title { font-size:clamp(2.5rem,7vw,4.5rem); font-weight:800; letter-spacing:-0.04em; line-height:1.15; margin-bottom:var(--space-6); animation:fadeInUp 1s ease-out 0.2s both; }
    .ea-hero-title .gradient-text { background:var(--gradient-cyan-purple); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .ea-hero-subtitle { font-size:clamp(1.125rem,2.5vw,1.5rem); color:var(--text-secondary); font-weight:400; letter-spacing:-0.01em; margin-bottom:var(--space-6); animation:fadeInUp 1s ease-out 0.4s both; }
    .ea-hero-description { font-size:1.0625rem; color:var(--text-muted); line-height:1.8; max-width:600px; margin:0 auto; animation:fadeInUp 1s ease-out 0.6s both; }
    .ea-hero-scroll { position:absolute; bottom:var(--space-8); left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:var(--space-2); color:var(--text-muted); font-size:0.75rem; font-weight:500; letter-spacing:0.05em; text-transform:uppercase; animation:scroll-fade 2s ease-in-out infinite; }
    .ea-hero-scroll-line { width:1px; height:24px; background:linear-gradient(to bottom,var(--text-muted),transparent); }

    /* Sections */
    .ea-section { position:relative; }
    .ea-section-inner { max-width:1200px; margin:0 auto; padding:var(--space-24) var(--space-8); }
    .ea-section-header { text-align:center; margin-bottom:var(--space-16); }
    .ea-section-label { display:inline-block; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; padding:var(--space-1) var(--space-4); border-radius:var(--radius-full); margin-bottom:var(--space-4); background:rgba(102,126,234,0.08); color:var(--wc-accent); border:1px solid rgba(102,126,234,0.15); }
    .ea-section-title { font-size:clamp(2rem,5vw,3rem); margin-bottom:var(--space-4); }
    .ea-section-description { font-size:1.0625rem; color:var(--text-secondary); max-width:700px; margin:0 auto; line-height:1.8; }

    /* Cards */
    .ea-card { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-xl); padding:var(--space-8) var(--space-6); transition:all 0.5s cubic-bezier(0.22,1,0.36,1); position:relative; overflow:hidden; }
    .ea-card::before { content:''; position:absolute; inset:0; border-radius:inherit; padding:1.5px; background:conic-gradient(from var(--gradient-angle),#667eea,#764ba2,#f093fb,#06b6d4,#667eea); -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0); -webkit-mask-composite:xor; mask-composite:exclude; opacity:0; transition:opacity 0.5s ease; pointer-events:none; animation:border-rotate 4s linear infinite; }
    .ea-card::after { content:''; position:absolute; width:250px; height:250px; border-radius:50%; background:radial-gradient(circle,rgba(102,126,234,0.1),transparent 70%); opacity:0; transition:opacity 0.5s ease; pointer-events:none; top:var(--mouse-y,50%); left:var(--mouse-x,50%); transform:translate(-50%,-50%); }
    .ea-card:hover::before { opacity:1; }
    .ea-card:hover::after { opacity:1; }
    .ea-card:hover { transform:translateY(-6px); box-shadow:var(--shadow-xl),var(--glow-subtle); background:var(--surface-2); }

    .ea-card-icon { width:64px; height:64px; border-radius:var(--radius-xl); display:flex; align-items:center; justify-content:center; font-size:1.5rem; margin-bottom:var(--space-5); position:relative; z-index:1; }
    .ea-card-title { font-size:1.25rem; font-weight:700; margin-bottom:var(--space-3); color:var(--text-primary); position:relative; z-index:1; }
    .ea-card-desc { font-size:0.9375rem; color:var(--text-secondary); line-height:1.7; position:relative; z-index:1; }

    /* TypeScript Section */
    .ea-ts-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:var(--space-6); }
    .ea-ts-config { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-xl); padding:var(--space-6); }
    .ea-ts-config-title { font-size:0.875rem; font-weight:700; color:var(--wc-cyan); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:var(--space-4); display:flex; align-items:center; gap:var(--space-2); }
    .ea-ts-rule { display:flex; align-items:flex-start; gap:var(--space-3); padding:var(--space-3) 0; border-bottom:1px solid rgba(255,255,255,0.04); }
    .ea-ts-rule:last-child { border-bottom:none; }
    .ea-ts-rule i { color:var(--wc-green); margin-top:0.2em; flex-shrink:0; }
    .ea-ts-rule-text { font-size:0.875rem; color:var(--text-secondary); line-height:1.6; }
    .ea-ts-rule-text code { color:var(--wc-cyan); background:rgba(6,182,212,0.08); padding:0.1em 0.4em; border-radius:4px; font-size:0.8125rem; }
    .ea-ts-comparison { display:grid; grid-template-columns:1fr 1fr; gap:var(--space-6); margin-top:var(--space-8); }
    .ea-ts-example { background:var(--surface-1); border-radius:var(--radius-lg); overflow:hidden; border:1px solid var(--surface-3); }
    .ea-ts-example-header { padding:var(--space-3) var(--space-4); font-size:0.8125rem; font-weight:700; display:flex; align-items:center; gap:var(--space-2); }
    .ea-ts-example-bad .ea-ts-example-header { background:rgba(239,68,68,0.08); color:var(--wc-red); border-bottom:1px solid rgba(239,68,68,0.15); }
    .ea-ts-example-good .ea-ts-example-header { background:rgba(16,185,129,0.08); color:var(--wc-green); border-bottom:1px solid rgba(16,185,129,0.15); }
    .ea-ts-example pre { padding:var(--space-4); font-size:0.8125rem; line-height:1.7; color:#d6deeb; white-space:pre; overflow-x:auto; margin:0; }

    /* CEM Pipeline */
    .ea-pipeline { display:flex; align-items:center; justify-content:center; gap:var(--space-4); flex-wrap:wrap; padding:var(--space-8) 0; }
    .ea-pipeline-step { display:flex; flex-direction:column; align-items:center; gap:var(--space-2); text-align:center; min-width:120px; }
    .ea-pipeline-icon { width:72px; height:72px; border-radius:var(--radius-xl); display:flex; align-items:center; justify-content:center; font-size:1.75rem; transition:all 0.3s ease; }
    .ea-pipeline-icon:hover { transform:scale(1.1); }
    .ea-pipeline-label { font-size:0.875rem; font-weight:700; color:var(--text-primary); }
    .ea-pipeline-sub { font-size:0.75rem; color:var(--text-muted); }
    .ea-pipeline-arrow { font-size:1.25rem; color:var(--text-muted); }
    .ea-pipeline-outputs { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--space-4); margin-top:var(--space-8); }
    .ea-pipeline-output { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-lg); padding:var(--space-5); text-align:center; transition:all 0.3s ease; }
    .ea-pipeline-output:hover { background:var(--surface-2); transform:translateY(-4px); }
    .ea-pipeline-output-icon { font-size:1.5rem; margin-bottom:var(--space-3); }
    .ea-pipeline-output-title { font-size:0.9375rem; font-weight:700; color:var(--text-primary); margin-bottom:var(--space-1); }
    .ea-pipeline-output-desc { font-size:0.8125rem; color:var(--text-muted); line-height:1.5; }

    /* Token Tiers */
    .ea-tiers { display:flex; flex-direction:column; gap:var(--space-6); }
    .ea-tier { display:grid; grid-template-columns:200px 1fr; gap:var(--space-6); align-items:start; padding:var(--space-6); background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-xl); transition:all 0.3s ease; }
    .ea-tier:hover { background:var(--surface-2); border-color:var(--glass-border-strong); }
    .ea-tier-label { display:flex; flex-direction:column; align-items:center; text-align:center; gap:var(--space-2); }
    .ea-tier-icon { width:64px; height:64px; border-radius:var(--radius-xl); display:flex; align-items:center; justify-content:center; font-size:1.5rem; }
    .ea-tier-name { font-size:1.125rem; font-weight:700; color:var(--text-primary); }
    .ea-tier-tag { font-size:0.6875rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; padding:var(--space-1) var(--space-3); border-radius:var(--radius-full); }
    .ea-tier-content { display:flex; flex-direction:column; gap:var(--space-3); }
    .ea-tier-desc { font-size:0.9375rem; color:var(--text-secondary); line-height:1.7; }
    .ea-tier-examples { display:flex; flex-wrap:wrap; gap:var(--space-2); }
    .ea-tier-example { font-family:var(--font-mono); font-size:0.75rem; padding:var(--space-1) var(--space-3); border-radius:var(--radius-sm); background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.06); color:var(--text-secondary); }
    .ea-tier-arrow { display:flex; justify-content:center; padding:var(--space-2) 0; color:var(--text-muted); font-size:1.25rem; }

    /* Quality */
    .ea-quality-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-6); }
    .ea-quality-card { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-xl); padding:var(--space-6); text-align:center; transition:all 0.3s ease; }
    .ea-quality-card:hover { background:var(--surface-2); transform:translateY(-4px); }
    .ea-quality-icon { width:56px; height:56px; border-radius:var(--radius-lg); display:flex; align-items:center; justify-content:center; font-size:1.25rem; margin:0 auto var(--space-4); }
    .ea-quality-title { font-size:1rem; font-weight:700; color:var(--text-primary); margin-bottom:var(--space-2); }
    .ea-quality-tool { font-family:var(--font-mono); font-size:0.75rem; padding:var(--space-1) var(--space-3); border-radius:var(--radius-full); background:rgba(255,255,255,0.04); color:var(--text-muted); display:inline-block; margin-bottom:var(--space-3); }
    .ea-quality-desc { font-size:0.875rem; color:var(--text-secondary); line-height:1.6; }

    /* Stats */
    .ea-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--space-6); margin-top:var(--space-12); }
    .ea-stat { text-align:center; }
    .ea-stat-value { font-size:2.5rem; font-weight:800; letter-spacing:-0.03em; margin-bottom:var(--space-1); }
    .ea-stat-label { font-size:0.875rem; color:var(--text-secondary); font-weight:500; }

    /* Footer CTA */
    .ea-footer-cta { border-top:1px solid var(--surface-3); }
    .ea-footer-cta-inner { max-width:800px; margin:0 auto; padding:var(--space-24) var(--space-8); text-align:center; }
    .ea-footer-cta-inner h2 { font-size:clamp(1.75rem,4vw,2.5rem); margin-bottom:var(--space-4); }
    .ea-footer-cta-inner p { font-size:1.0625rem; color:var(--text-secondary); line-height:1.8; margin-bottom:var(--space-8); }
    .ea-footer-cta-buttons { display:flex; gap:var(--space-4); justify-content:center; flex-wrap:wrap; }
    .ea-btn { display:inline-flex; align-items:center; gap:var(--space-2); padding:var(--space-3) var(--space-6); border-radius:var(--radius-full); font-weight:600; font-size:0.9375rem; transition:all 0.3s ease; text-decoration:none; }
    .ea-btn-solid { background:var(--gradient-primary); color:white; border:none; box-shadow:var(--shadow-md), var(--glow-subtle); }
    .ea-btn-solid:hover { transform:translateY(-2px); box-shadow:var(--shadow-lg), var(--glow-primary); color:white; }
    .ea-btn-ghost { background:var(--glass-bg); color:var(--text-secondary); border:1px solid var(--glass-border-strong); }
    .ea-btn-ghost:hover { background:var(--glass-bg-strong); color:var(--text-primary); transform:translateY(-2px); }
    .ea-btn-arrow { transition:transform 0.2s ease; }
    .ea-btn:hover .ea-btn-arrow { transform:translateX(4px); }

    /* Color helpers */
    .icon-cyan { background:linear-gradient(135deg,rgba(6,182,212,0.15),rgba(6,182,212,0.05)); border:1px solid rgba(6,182,212,0.2); color:var(--wc-cyan); }
    .icon-green { background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(16,185,129,0.05)); border:1px solid rgba(16,185,129,0.2); color:var(--wc-green); }
    .icon-accent { background:linear-gradient(135deg,rgba(139,92,246,0.15),rgba(139,92,246,0.05)); border:1px solid rgba(139,92,246,0.2); color:var(--wc-accent); }
    .icon-pink { background:linear-gradient(135deg,rgba(236,72,153,0.15),rgba(236,72,153,0.05)); border:1px solid rgba(236,72,153,0.2); color:var(--wc-pink); }
    .icon-amber { background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(245,158,11,0.05)); border:1px solid rgba(245,158,11,0.2); color:var(--wc-amber); }
    .icon-electric { background:linear-gradient(135deg,rgba(59,130,246,0.15),rgba(59,130,246,0.05)); border:1px solid rgba(59,130,246,0.2); color:var(--wc-electric); }
    .tag-cyan { background:rgba(6,182,212,0.1); color:var(--wc-cyan); border:1px solid rgba(6,182,212,0.2); }
    .tag-green { background:rgba(16,185,129,0.1); color:var(--wc-green); border:1px solid rgba(16,185,129,0.2); }
    .tag-accent { background:rgba(139,92,246,0.1); color:var(--wc-accent); border:1px solid rgba(139,92,246,0.2); }

    /* Responsive */
    @media (max-width:1100px) {
      .ea-ts-grid { grid-template-columns:1fr; }
      .ea-ts-comparison { grid-template-columns:1fr; }
      .ea-pipeline-outputs { grid-template-columns:repeat(2,1fr); }
      .ea-tier { grid-template-columns:1fr; text-align:center; }
      .ea-quality-grid { grid-template-columns:1fr; }
      .ea-stats { grid-template-columns:repeat(2,1fr); }
    }

    @media (max-width:768px) {
      .ea-topbar { padding:var(--space-3) var(--space-4); }
      .ea-topbar-title { display:none; }
      .ea-hero { min-height:auto; padding:calc(var(--space-24) + var(--space-8)) var(--space-4) var(--space-16); }
      .ea-hero-scroll { display:none; }
      .ea-section-inner { padding:var(--space-16) var(--space-4); }
      .ea-pipeline { flex-direction:column; }
      .ea-pipeline-arrow { transform:rotate(90deg); }
      .ea-pipeline-outputs { grid-template-columns:1fr; }
      .ea-stats { grid-template-columns:1fr; gap:var(--space-4); }
      .ea-footer-cta-buttons { flex-direction:column; align-items:stretch; }
      .ea-btn { width:100%; justify-content:center; }
    }

    @media (prefers-reduced-motion:reduce) {
      .ea-hero-orb { animation:none !important; opacity:0.15; }
    }

    .ea-btn:focus-visible, .ea-back-link:focus-visible, .ea-topbar-link:focus-visible {
      outline:3px solid var(--wc-accent); outline-offset:3px;
    }
  </style>

  <nav class="ea-topbar" aria-label="Page navigation">
    <div class="ea-topbar-left">
      <a href="/" class="ea-back-link" aria-label="Back to HELIX Dashboard">
        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
        Dashboard
      </a>
      <span class="ea-topbar-title" aria-hidden="true">|</span>
      <span class="ea-topbar-title">Enterprise Architecture</span>
    </div>
    <div class="ea-topbar-right">
      <a href="/pre-planning/architecture/" class="ea-topbar-link">
        <i class="fa-solid fa-book" aria-hidden="true"></i>
        Full Docs
      </a>
      <a href="/design-tokens/overview/" class="ea-topbar-link">
        <i class="fa-solid fa-palette" aria-hidden="true"></i>
        Design Tokens
      </a>
    </div>
  </nav>

  <main id="main-content">
    <!-- SECTION 1: HERO -->
    <section class="ea-hero" aria-label="Enterprise Architecture">
      <div class="ea-hero-grid" aria-hidden="true"></div>
      <div class="ea-hero-orb ea-hero-orb-1" aria-hidden="true"></div>
      <div class="ea-hero-orb ea-hero-orb-2" aria-hidden="true"></div>
      <div class="ea-hero-orb ea-hero-orb-3" aria-hidden="true"></div>

      <div class="ea-hero-content">
        <div class="ea-hero-badge">
          <span class="ea-hero-badge-dot" aria-hidden="true"></span>
          Enterprise Grade
        </div>
        <h1 class="ea-hero-title">Enterprise<br /><span class="gradient-text">by Default</span></h1>
        <p class="ea-hero-subtitle">TypeScript-first. CEM-driven. Token-powered.</p>
        <p class="ea-hero-description">
          Not enterprise as an afterthought. Every architectural choice --
          from strict TypeScript to W3C design tokens to the Custom Elements Manifest pipeline --
          was made to serve teams building at scale.
        </p>
      </div>

      <div class="mouse-scroll-wrap mouse-scroll-wrap--absolute" aria-hidden="true">
        <div class="mouse-scroll-body"><div class="mouse-scroll-wheel"></div></div>
        <span class="mouse-scroll-label">Scroll</span>
      </div>
    </section>

    <!-- SECTION 2: TYPESCRIPT STRATEGY -->
    <section class="ea-section" aria-label="TypeScript strategy">
      <div class="ea-section-inner">
        <div class="ea-section-header scroll-reveal">
          <span class="ea-section-label">Type Safety</span>
          <h2 class="ea-section-title">100% TypeScript. Zero Exceptions.</h2>
          <p class="ea-section-description">
            Strict mode is not optional. Every component, every utility, every test
            is fully typed. The compiler catches bugs before they reach production.
          </p>
        </div>

        <div class="ea-ts-grid">
          <div class="ea-ts-config scroll-reveal scroll-reveal-delay-1">
            <div class="ea-ts-config-title">
              <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
              tsconfig.json Rules
            </div>
            <div class="ea-ts-rule"><i class="fa-solid fa-check" aria-hidden="true"></i><div class="ea-ts-rule-text"><code>"strict": true</code> -- all strict checks enabled</div></div>
            <div class="ea-ts-rule"><i class="fa-solid fa-check" aria-hidden="true"></i><div class="ea-ts-rule-text"><code>"noUncheckedIndexedAccess": true</code> -- arrays can be undefined</div></div>
            <div class="ea-ts-rule"><i class="fa-solid fa-check" aria-hidden="true"></i><div class="ea-ts-rule-text"><code>"noImplicitOverride": true</code> -- explicit override keyword</div></div>
            <div class="ea-ts-rule"><i class="fa-solid fa-check" aria-hidden="true"></i><div class="ea-ts-rule-text"><code>"exactOptionalPropertyTypes": true</code> -- undefined vs missing</div></div>
