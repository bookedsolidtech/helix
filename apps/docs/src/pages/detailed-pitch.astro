---
/**
 * Detailed Pitch - 5-Minute Scrollable Experience
 *
 * 5 focused sections with visual flair:
 * 1. Who I Am (experience, track record)
 * 2. The Plan (HELIX architecture overview)
 * 3. The Team/Organization (this system is proof)
 * 4. Why This Stack (2026 technology choices)
 * 5. The Ask + Next Steps
 *
 * Target audience: Technical leads, CTOs, hiring managers with 5 minutes.
 */
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro';
---

<ShowcaseLayout
  title="The 5-Minute Pitch"
  description="A concise 5-minute walkthrough of the HELIX enterprise healthcare web component architecture, the engineer behind it, and why this stack was chosen."
>
    <style is:inline>
      /* ============================================
         DETAILED PITCH - PAGE-SPECIFIC CSS
         ============================================ */

      /* Override shared --gradient-hero for this page's darker palette */
      :root {
        --gradient-hero: linear-gradient(135deg, #0a0a18 0%, #0f1030 40%, #0a0a2e 100%);
      }

      /* Override shared pulse-ring: this page uses box-shadow ring, not scale/opacity */
      @keyframes pulse-ring {
        0% { box-shadow: 0 0 0 0 rgba(102,126,234,0.4); }
        70% { box-shadow: 0 0 0 15px rgba(102,126,234,0); }
        100% { box-shadow: 0 0 0 0 rgba(102,126,234,0); }
      }

      /* Floating Pitch Nav */
      .pitch-nav {
        position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%); z-index: 200;
        display: flex; align-items: center; gap: 0.25rem; padding: 0.375rem;
        background: rgba(10,10,20,0.9); backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid var(--glass-border-strong); border-radius: var(--radius-full);
        box-shadow: var(--shadow-xl);
      }
      .pitch-nav-link {
        display: inline-flex; align-items: center; gap: 0.375rem;
        padding: 0.5rem 1rem; font-size: 0.8125rem; font-weight: 600;
        color: var(--text-secondary); border-radius: var(--radius-full);
        transition: all 0.25s ease; white-space: nowrap;
      }
      .pitch-nav-link:hover { color: var(--text-primary); background: var(--glass-bg-strong); }
      .pitch-nav-link.active { color: white; background: var(--gradient-primary); box-shadow: 0 2px 12px rgba(102,126,234,0.3); }
      .pitch-nav-divider { width: 1px; height: 20px; background: var(--glass-border-strong); margin: 0 0.25rem; }
      .pitch-nav-home {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; font-size: 0.875rem; color: var(--text-muted);
        border-radius: 50%; transition: all 0.25s ease;
      }
      .pitch-nav-home:hover { color: var(--text-primary); background: var(--glass-bg-strong); }

      /* Snap scroll container — desktop only */
      @media (min-width: 1025px) {
        .dp-container {
          height: 100vh;
          overflow-y: scroll;
          scroll-snap-type: y mandatory;
          scroll-behavior: smooth;
        }
        .dp-snap-section {
          scroll-snap-align: start;
        }
      }
      @media (max-width: 1024px) {
        .dp-container {
          scroll-snap-type: none !important;
          scroll-behavior: auto !important;
        }
      }

      /* Hero */
      .dp-hero {
        position: relative; min-height: 100vh; display: flex; align-items: center;
        justify-content: center; text-align: center; padding: var(--space-24) var(--space-8);
        background: var(--gradient-hero); overflow: hidden;
      }
      .dp-hero-particles {
        position: absolute; inset: 0; pointer-events: none;
        background-image:
          radial-gradient(1.5px 1.5px at 10% 20%, rgba(102,126,234,0.3) 50%, transparent 50%),
          radial-gradient(1px 1px at 30% 65%, rgba(6,182,212,0.25) 50%, transparent 50%),
          radial-gradient(1.5px 1.5px at 50% 10%, rgba(236,72,153,0.2) 50%, transparent 50%),
          radial-gradient(1px 1px at 70% 80%, rgba(16,185,129,0.25) 50%, transparent 50%),
          radial-gradient(1.5px 1.5px at 90% 40%, rgba(139,92,246,0.3) 50%, transparent 50%);
        animation: particle-drift 60s linear infinite;
      }
      .dp-hero-grid {
        position: absolute; inset: 0; pointer-events: none;
        background-image: linear-gradient(rgba(255,255,255,0.015) 1px,transparent 1px),
          linear-gradient(90deg,rgba(255,255,255,0.015) 1px,transparent 1px);
        background-size: 60px 60px;
      }
      .dp-hero-orb { position: absolute; border-radius: 50%; pointer-events: none; }
      .dp-hero-orb-1 { width: 500px; height: 500px; background: radial-gradient(circle,rgba(6,182,212,0.15),transparent 70%); top: -10%; right: -5%; animation: float-slow 20s ease-in-out infinite, orb-pulse 8s ease-in-out infinite; }
      .dp-hero-orb-2 { width: 400px; height: 400px; background: radial-gradient(circle,rgba(139,92,246,0.12),transparent 70%); bottom: -5%; left: -5%; animation: float-slow 25s ease-in-out infinite reverse, orb-pulse 10s ease-in-out infinite 2s; }
      .dp-hero-content { position: relative; z-index: 2; max-width: 800px; }
      .dp-hero-badge {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.5rem 1.25rem; background: var(--glass-bg-strong);
        border: 1px solid var(--glass-border-strong); border-radius: var(--radius-full);
        font-size: 0.8125rem; font-weight: 600; color: var(--wc-cyan);
        margin-bottom: var(--space-8); animation: fadeInDown 0.8s ease-out;
      }
      .dp-hero-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--wc-cyan); box-shadow: 0 0 8px var(--wc-cyan); animation: pulse-ring 2s ease-out infinite; }
      .dp-hero-title { font-size: clamp(2.5rem, 7vw, 4.5rem); font-weight: 800; letter-spacing: -0.04em; margin-bottom: var(--space-6); animation: fadeInUp 1s ease-out 0.2s both; }
      .dp-hero-title .gradient-text { background: var(--gradient-cyan-purple); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
      .dp-hero-subtitle { font-size: clamp(1.125rem, 2.5vw, 1.375rem); color: var(--text-secondary); font-weight: 400; margin-bottom: var(--space-4); animation: fadeInUp 1s ease-out 0.4s both; }
      .dp-hero-scroll { position: absolute; bottom: 5rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: var(--space-2); color: var(--text-muted); font-size: 0.75rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; animation: scroll-fade 2s ease-in-out infinite; z-index: 10; }
      .dp-hero-scroll-line { width: 1px; height: 24px; background: linear-gradient(to bottom, var(--text-muted), transparent); }

      /* Sections */
      .dp-section { position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
      .dp-section-inner { max-width: 1100px; margin: 0 auto; padding: var(--space-16) var(--space-8); width: 100%; }
      .dp-section-alt { background: var(--surface-1); border-top: 1px solid var(--surface-3); border-bottom: 1px solid var(--surface-3); }
      .dp-section-header { text-align: center; margin-bottom: var(--space-12); }
      .dp-section-num {
        display: inline-flex; align-items: center; justify-content: center;
        width: 40px; height: 40px; border-radius: 50%;
        font-size: 1rem; font-weight: 800; margin-bottom: var(--space-4);
      }
      .dp-section-label {
        display: inline-block; font-size: 0.75rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.1em;
        padding: var(--space-1) var(--space-4); border-radius: var(--radius-full);
        margin-bottom: var(--space-4);
      }
      .dp-section-title { font-size: clamp(1.75rem, 4vw, 2.75rem); margin-bottom: var(--space-4); }
      .dp-section-desc { font-size: 1.0625rem; color: var(--text-secondary); max-width: 700px; margin: 0 auto; line-height: 1.8; }

      /* Cards */
      .dp-card {
        background: var(--surface-1); border: 1px solid var(--surface-3);
        border-radius: var(--radius-xl); padding: var(--space-6);
        transition: all 0.4s cubic-bezier(0.22,1,0.36,1); position: relative; overflow: hidden;
      }
      .dp-card::before {
        content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
        background: conic-gradient(from var(--gradient-angle), #667eea, #764ba2, #f093fb, #06b6d4, #667eea);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor; mask-composite: exclude;
        opacity: 0; transition: opacity 0.5s ease; pointer-events: none;
        animation: border-rotate 4s linear infinite;
      }
      .dp-card:hover::before { opacity: 1; }
      .dp-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-xl), var(--glow-subtle); background: var(--surface-2); }

      .dp-card-icon {
        width: 56px; height: 56px; border-radius: var(--radius-xl);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.25rem; margin-bottom: var(--space-4); position: relative; z-index: 1;
      }
      .dp-card-title { font-size: 1.125rem; font-weight: 700; margin-bottom: var(--space-2); position: relative; z-index: 1; }
      .dp-card-desc { font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7; position: relative; z-index: 1; }

      /* Color helpers */
      .icon-cyan { background:linear-gradient(135deg,rgba(6,182,212,0.15),rgba(6,182,212,0.05)); border:1px solid rgba(6,182,212,0.2); color:var(--wc-cyan); }
      .icon-green { background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(16,185,129,0.05)); border:1px solid rgba(16,185,129,0.2); color:var(--wc-green); }
      .icon-accent { background:linear-gradient(135deg,rgba(139,92,246,0.15),rgba(139,92,246,0.05)); border:1px solid rgba(139,92,246,0.2); color:var(--wc-accent); }
      .icon-pink { background:linear-gradient(135deg,rgba(236,72,153,0.15),rgba(236,72,153,0.05)); border:1px solid rgba(236,72,153,0.2); color:var(--wc-pink); }
      .icon-amber { background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(245,158,11,0.05)); border:1px solid rgba(245,158,11,0.2); color:var(--wc-amber); }
      .icon-electric { background:linear-gradient(135deg,rgba(59,130,246,0.15),rgba(59,130,246,0.05)); border:1px solid rgba(59,130,246,0.2); color:var(--wc-electric); }
      .label-cyan { background:rgba(6,182,212,0.08); color:var(--wc-cyan); border:1px solid rgba(6,182,212,0.15); }
      .label-green { background:rgba(16,185,129,0.08); color:var(--wc-green); border:1px solid rgba(16,185,129,0.15); }
      .label-accent { background:rgba(139,92,246,0.08); color:var(--wc-accent); border:1px solid rgba(139,92,246,0.15); }
      .label-pink { background:rgba(236,72,153,0.08); color:var(--wc-pink); border:1px solid rgba(236,72,153,0.15); }
      .label-amber { background:rgba(245,158,11,0.08); color:var(--wc-amber); border:1px solid rgba(245,158,11,0.15); }
      .num-cyan { background:rgba(6,182,212,0.12); color:var(--wc-cyan); border:1px solid rgba(6,182,212,0.25); }
      .num-green { background:rgba(16,185,129,0.12); color:var(--wc-green); border:1px solid rgba(16,185,129,0.25); }
      .num-accent { background:rgba(139,92,246,0.12); color:var(--wc-accent); border:1px solid rgba(139,92,246,0.25); }
      .num-pink { background:rgba(236,72,153,0.12); color:var(--wc-pink); border:1px solid rgba(236,72,153,0.25); }
      .num-amber { background:rgba(245,158,11,0.12); color:var(--wc-amber); border:1px solid rgba(245,158,11,0.25); }

      /* Section 1: Who I Am - Timeline */
      .dp-timeline { display: grid; grid-template-columns: 120px 1fr; gap: 0; position: relative; }
      .dp-timeline::before {
        content: ''; position: absolute; left: 119px; top: 0; bottom: 0; width: 2px;
        background: linear-gradient(to bottom, var(--wc-cyan), var(--wc-accent), var(--wc-pink), var(--wc-green));
      }
      .dp-timeline-item { display: contents; }
      .dp-timeline-year {
        padding: var(--space-6) var(--space-4) var(--space-6) 0;
        text-align: right; font-family: var(--font-mono); font-size: 0.875rem;
        font-weight: 700; position: relative;
      }
      .dp-timeline-year::after {
        content: ''; position: absolute; right: -6px; top: 50%; transform: translateY(-50%);
        width: 12px; height: 12px; border-radius: 50%; border: 2px solid var(--surface-0);
      }
      .dp-timeline-content {
        padding: var(--space-6) 0 var(--space-6) var(--space-8);
        border-bottom: 1px solid rgba(255,255,255,0.04);
      }
      .dp-timeline-content:last-child { border-bottom: none; }
      .dp-timeline-title { font-size: 1rem; font-weight: 700; margin-bottom: var(--space-1); }
      .dp-timeline-desc { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; }

      /* Stats inline */
      .dp-stats-row {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4);
        margin-top: var(--space-8);
      }
      .dp-stat { text-align: center; padding: var(--space-4); background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: var(--radius-lg); }
      .dp-stat-value { font-size: 2rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1.2; }
      .dp-stat-label { font-size: 0.8125rem; color: var(--text-muted); margin-top: var(--space-1); }

      /* Section 2: Architecture diagram */
      .dp-arch-diagram {
        display: grid; grid-template-columns: 1fr auto 1fr auto 1fr;
        align-items: center; gap: var(--space-3); margin-bottom: var(--space-8);
      }
      .dp-arch-box {
        background: var(--surface-1); border: 1px solid var(--surface-3);
        border-radius: var(--radius-xl); padding: var(--space-5) var(--space-4);
        text-align: center; transition: all 0.3s ease;
      }
      .dp-arch-box:hover { background: var(--surface-2); transform: translateY(-2px); }
      .dp-arch-icon { font-size: 1.5rem; margin-bottom: var(--space-2); }
      .dp-arch-label { font-size: 0.9375rem; font-weight: 700; margin-bottom: var(--space-1); }
      .dp-arch-sub { font-size: 0.75rem; color: var(--text-muted); line-height: 1.4; }
      .dp-arch-arrow { font-size: 1.25rem; color: var(--text-muted); text-align: center; }

      .dp-arch-outputs { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-3); }
      .dp-arch-output {
        background: var(--surface-1); border: 1px solid var(--surface-3);
        border-radius: var(--radius-lg); padding: var(--space-4); text-align: center;
        transition: all 0.3s ease;
      }
      .dp-arch-output:hover { background: var(--surface-2); transform: translateY(-2px); }
      .dp-arch-output-icon { font-size: 1.25rem; margin-bottom: var(--space-2); }
      .dp-arch-output-label { font-size: 0.8125rem; font-weight: 700; }

      /* Section 3: Proof grid */
      .dp-proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); }

      /* Section 4: Comparison table */
      .dp-comparison {
        width: 100%; border-collapse: collapse;
        background: var(--surface-1); border-radius: var(--radius-xl); overflow: hidden;
        border: 1px solid var(--surface-3);
      }
      .dp-comparison th {
        padding: var(--space-4) var(--space-5); text-align: left;
        font-size: 0.8125rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.05em; color: var(--text-muted);
        background: var(--surface-2); border-bottom: 1px solid var(--surface-3);
      }
      .dp-comparison td {
        padding: var(--space-3) var(--space-5); font-size: 0.9375rem;
        border-bottom: 1px solid rgba(255,255,255,0.03);
      }
      .dp-comparison tr:last-child td { border-bottom: none; }
      .dp-comparison .dp-tech-name { font-weight: 700; color: var(--text-primary); }
      .dp-comparison .dp-tech-why { color: var(--text-secondary); }
      .dp-comparison .dp-tech-badge {
        display: inline-block; padding: 0.125rem 0.5rem;
        border-radius: var(--radius-full); font-size: 0.6875rem;
        font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em;
      }

      /* Code block */
      .dp-code-block {
        background: var(--surface-1); border: 1px solid var(--surface-3);
        border-radius: var(--radius-lg); overflow: hidden; margin-top: var(--space-6);
      }
      .dp-code-header {
        padding: var(--space-2) var(--space-4); background: var(--surface-2);
        border-bottom: 1px solid var(--surface-3); display: flex; align-items: center;
        gap: var(--space-2); font-size: 0.75rem; font-weight: 600; color: var(--text-muted);
      }
      .dp-code-dots { display: flex; gap: 6px; }
      .dp-code-dot { width: 10px; height: 10px; border-radius: 50%; }
      .dp-code-block pre {
        padding: var(--space-5); font-size: 0.8125rem; line-height: 1.7;
        color: #d6deeb; overflow-x: auto; margin: 0;
      }

      /* CTA */
      .dp-cta-section { border-top: 1px solid var(--surface-3); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
      .dp-cta-inner { max-width: 800px; margin: 0 auto; padding: var(--space-24) var(--space-8); text-align: center; }
      .dp-cta-inner h2 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: var(--space-4); }
      .dp-cta-inner p { font-size: 1.0625rem; color: var(--text-secondary); line-height: 1.8; margin-bottom: var(--space-8); }
      .dp-cta-buttons { display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap; }

      .dp-btn {
        display: inline-flex; align-items: center; gap: var(--space-2);
        padding: var(--space-3) var(--space-6); border-radius: var(--radius-full);
        font-weight: 600; font-size: 0.9375rem; transition: all 0.3s ease; text-decoration: none;
      }
      .dp-btn-solid { background: var(--gradient-primary); color: white; border: none; box-shadow: var(--shadow-md), var(--glow-subtle); }
      .dp-btn-solid:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg), var(--glow-primary); color: white; }
      .dp-btn-ghost { background: var(--glass-bg); color: var(--text-secondary); border: 1px solid var(--glass-border-strong); }
      .dp-btn-ghost:hover { background: var(--glass-bg-strong); color: var(--text-primary); transform: translateY(-2px); }
      .dp-btn-arrow { transition: transform 0.2s ease; }
      .dp-btn:hover .dp-btn-arrow { transform: translateX(4px); }

      /* Responsive */
      @media (max-width: 1024px) {
        .dp-arch-diagram { grid-template-columns: 1fr; gap: var(--space-2); }
        .dp-arch-arrow { transform: rotate(90deg); }
        .dp-arch-outputs { grid-template-columns: repeat(2, 1fr); }
        .dp-stats-row { grid-template-columns: repeat(2, 1fr); }
        .dp-proof-grid { grid-template-columns: 1fr; }
      }

      @media (max-width: 768px) {
        .dp-hero { min-height: auto; padding: calc(var(--space-24) + var(--space-8)) var(--space-4) var(--space-16); }
        .dp-hero-scroll { display: none; }
        .dp-section-inner { padding: var(--space-16) var(--space-4); }
        .dp-timeline { grid-template-columns: 1fr; }
        .dp-timeline::before { display: none; }
        .dp-timeline-year { text-align: left; padding: var(--space-2) 0 0; }
        .dp-timeline-year::after { display: none; }
        .dp-timeline-content { padding: 0 0 var(--space-6); }
        .dp-stats-row { grid-template-columns: 1fr 1fr; }
        .dp-arch-outputs { grid-template-columns: 1fr; }
        .dp-comparison { font-size: 0.875rem; }
        .dp-comparison th, .dp-comparison td { padding: var(--space-3); }
        .dp-cta-buttons { flex-direction: column; align-items: stretch; }
        .dp-btn { width: 100%; justify-content: center; }
        .pitch-nav { bottom: 1rem; left: 0.5rem; right: 0.5rem; transform: none; justify-content: center; }
        .pitch-nav-link { padding: 0.5rem 0.75rem; font-size: 0.75rem; min-height: 44px; }
        .pitch-nav-home { min-width: 44px; min-height: 44px; }
      }

      /* Page-specific reduced motion rules */
      @media (prefers-reduced-motion: reduce) {
        .dp-hero-orb { animation: none !important; opacity: 0.15; }
      }

      .dp-btn:focus-visible, .pitch-nav-link:focus-visible, .pitch-nav-home:focus-visible {
        outline: 3px solid var(--wc-accent); outline-offset: 3px;
      }
    </style>

    <!-- Floating pitch navigation -->
    <nav class="pitch-nav" aria-label="Pitch pages">
      <a href="/" class="pitch-nav-home" aria-label="Back to Dashboard">
        <i class="fa-solid fa-house" aria-hidden="true"></i>
      </a>
      <div class="pitch-nav-divider" aria-hidden="true"></div>
      <a href="/elevator-pitch/" class="pitch-nav-link">
        <i class="fa-solid fa-bolt" aria-hidden="true"></i>
        30s
      </a>
      <a href="/detailed-pitch/" class="pitch-nav-link active" aria-current="page">
        <i class="fa-solid fa-clock" aria-hidden="true"></i>
        5 min
      </a>
      <a href="/full-presentation/" class="pitch-nav-link">
        <i class="fa-solid fa-presentation-screen" aria-hidden="true"></i>
        30 min
      </a>
    </nav>

    <main id="main-content" class="dp-container">
      <!-- HERO -->
      <section class="dp-hero dp-snap-section" aria-label="5-Minute Pitch">
        <div class="dp-hero-particles" aria-hidden="true"></div>
        <div class="dp-hero-grid" aria-hidden="true"></div>
        <div class="dp-hero-orb dp-hero-orb-1" aria-hidden="true"></div>
        <div class="dp-hero-orb dp-hero-orb-2" aria-hidden="true"></div>

        <div class="dp-hero-content">
          <div class="dp-hero-badge">
            <span class="dp-hero-badge-dot" aria-hidden="true"></span>
            5-Minute Walkthrough
          </div>
          <h1 class="dp-hero-title">The Engineer.<br/><span class="gradient-text">The Architecture. The Plan.</span></h1>
          <p class="dp-hero-subtitle">
            Everything you need to evaluate this candidacy -- in five focused sections.
          </p>
        </div>

        <div class="mouse-scroll-wrap mouse-scroll-wrap--absolute" aria-hidden="true">
          <div class="mouse-scroll-body"><div class="mouse-scroll-wheel"></div></div>
          <span class="mouse-scroll-label">Scroll</span>
        </div>
      </section>

      <!-- SECTION 1: WHO I AM -->
      <section class="dp-section dp-snap-section" aria-label="Who I Am">
        <div class="dp-section-inner">
          <div class="dp-section-header scroll-reveal">
