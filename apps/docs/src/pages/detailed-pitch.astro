          <div class="dp-timeline scroll-reveal scroll-reveal-delay-1">
            <div class="dp-timeline-item">
              <div class="dp-timeline-year" style="color:var(--wc-cyan);">
                ~1996
                <span style="position:absolute;right:-6px;top:50%;transform:translateY(-50%);width:12px;height:12px;border-radius:50%;background:var(--wc-cyan);border:2px solid var(--surface-0);"></span>
