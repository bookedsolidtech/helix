                        <i class="fa-solid fa-copy te-copy-row-icon"></i>
                      </div>
                      <div class="te-copy-row" data-copy={t.rgba} title={`Copy RGBA: ${t.rgba}`}>
                        <span class="te-copy-row-label">RGB</span>
