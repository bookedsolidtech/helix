    <!-- ===== SPACING ===== -->
    <div class="te-panel" id="panel-spacing" role="tabpanel">
      <h2 class="te-panel-title"><span class="gradient-text">Spacing Scale</span></h2>
      <p class="te-panel-desc">
        {(tokensByCategory['space'] ?? []).length} spacing tokens from 0 to 16rem, providing
        a consistent spatial rhythm across all components.
      </p>

      <div class="te-space-list">
        {spaceTokens.map(t => {
          const numericValue = parseFloat(t.value);
          const unit = t.value.replace(String(numericValue), '');
          const maxRem = 16;
          const remValue = unit === 'rem' ? numericValue : numericValue / 16;
          const pct = Math.min((remValue / maxRem) * 100, 100);
          return (
            <div class="te-space-row">
              <span class="te-space-name">{t.name.replace('--hx-', '')}</span>
              <div class="te-space-bar-wrap">
                <div class="te-space-bar" style={`width: ${pct}%;`}></div>
              </div>
              <span class="te-space-val">{t.value}</span>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ===== TYPOGRAPHY ===== -->
