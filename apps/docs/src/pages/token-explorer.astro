          <span class="te-stat-label">Color Ramps</span>
        </div>
        <div class="te-stat">
          <span class="te-stat-value">{darkTokenEntries.length}</span>
          <span class="te-stat-label">Dark Overrides</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Tab Navigation -->
  <div class="te-tabs-section">
    <div class="te-tabs" role="tablist">
      {tabs.map((tab, i) => (
        <button
