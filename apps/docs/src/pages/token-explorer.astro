    <!-- ===== DARK MODE ===== -->
    <div class="te-panel" id="panel-darkmode" role="tabpanel">
      <h2 class="te-panel-title"><span class="gradient-text">Dark Mode Overrides</span></h2>
      <p class="te-panel-desc">
        {darkTokenEntries.length} tokens are overridden in dark mode. These are applied via
        <code style="color: var(--wc-cyan); background: rgba(6,182,212,0.08); padding: 0.1em 0.4em; border-radius: 4px;">[data-theme="dark"]</code>
        or <code style="color: var(--wc-cyan); background: rgba(6,182,212,0.08); padding: 0.1em 0.4em; border-radius: 4px;">@media (prefers-color-scheme: dark)</code>.
      </p>

      <div style="overflow-x: auto;">
        <table class="te-dark-table">
          <thead>
            <tr>
              <th>Token</th>
              <th>Dark Value</th>
              <th>Resolved</th>
            </tr>
          </thead>
          <tbody>
            {darkTokenEntries.map(t => {
              const resolved = resolveTokenRef(t.value, tokenMap);
              const hex = isHexColor(resolved) ? resolved : null;
              return (
                <tr>
                  <td>{t.name}</td>
                  <td>{t.value}</td>
                  <td>
                    {hex && (
                      <span
                        class="te-dark-swatch-inline"
                        style={`background: ${hex};`}
                      ></span>
                    )}
                    {resolved}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <script is:inline>
    (function() {
      /* --- Tab switching --- */
      var tabs = document.querySelectorAll('.te-tab');
      var panels = document.querySelectorAll('.te-panel');

      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          var targetId = tab.getAttribute('data-tab');

          tabs.forEach(function(t) {
            t.classList.remove('active');
            t.setAttribute('aria-selected', 'false');
          });
          panels.forEach(function(p) {
            p.classList.remove('active');
          });

          tab.classList.add('active');
          tab.setAttribute('aria-selected', 'true');

          var panel = document.getElementById('panel-' + targetId);
          if (panel) {
            panel.classList.add('active');
          }
        });
      });

      /* --- Click-to-copy for color swatch values --- */
      var copyRows = document.querySelectorAll('.te-copy-row[data-copy]');
      copyRows.forEach(function(row) {
        row.addEventListener('click', function(e) {
          e.stopPropagation();
          var value = row.getAttribute('data-copy');
          if (!value) return;

          var icon = row.querySelector('.te-copy-row-icon');

          navigator.clipboard.writeText(value).then(function() {
            /* Switch icon to checkmark and add copied class */
            row.classList.add('copied');
            if (icon) {
              icon.classList.remove('fa-copy');
              icon.classList.add('fa-check');
            }

            /* Revert after 1.5s */
            setTimeout(function() {
              row.classList.remove('copied');
              if (icon) {
                icon.classList.remove('fa-check');
                icon.classList.add('fa-copy');
              }
            }, 1500);
          }).catch(function() {
            /* Fallback for older browsers / insecure contexts */
            var textArea = document.createElement('textarea');
            textArea.value = value;
            textArea.style.position = 'fixed';
            textArea.style.left = '-9999px';
            textArea.style.opacity = '0';
            document.body.appendChild(textArea);
            textArea.select();
            try {
              document.execCommand('copy');
              row.classList.add('copied');
              if (icon) {
                icon.classList.remove('fa-copy');
                icon.classList.add('fa-check');
              }
              setTimeout(function() {
                row.classList.remove('copied');
                if (icon) {
                  icon.classList.remove('fa-check');
                  icon.classList.add('fa-copy');
                }
              }, 1500);
            } catch (err) {
              /* silently fail */
            }
            document.body.removeChild(textArea);
          });
        });
      });
    })();
  </script>
</ShowcaseLayout>
