            const dur = parts[0] || '250ms';
            const ease = parts[1] || 'ease';
            return (
              <div class="te-motion-row" style={`--dur: ${dur}; --ease: ${ease};`}>
                <span class="te-motion-name">{t.key}</span>
                <div class="te-motion-demo">
                  <div class="te-motion-dot"></div>
