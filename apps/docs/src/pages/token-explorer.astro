---
/**
 * Token Explorer -- Interactive Design Token Reference
 *
 * Imports live token data from @helixui/tokens and renders an interactive
 * reference page with color swatches, spacing visualization, typography
 * specimens, shadow cards, border previews, motion tokens, and dark mode
 * override tables.
 *
 * Uses ShowcaseLayout for consistent dark-theme aesthetic.
 */
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro';
import { tokenEntries, tokensByCategory, tokenMap, darkTokenEntries } from '@helixui/tokens';
import { getTokenStats, getColorSubgroups, isHexColor, resolveTokenRef, getContrastColor } from '@helixui/tokens/utils';

const stats = getTokenStats(tokenEntries);
const colorSubgroups = getColorSubgroups(tokenEntries);
const tabs = [
  { id: 'colors', label: 'Colors', icon: 'fa-palette' },
  { id: 'spacing', label: 'Spacing', icon: 'fa-arrows-left-right' },
  { id: 'typography', label: 'Typography', icon: 'fa-font' },
  { id: 'shadows', label: 'Shadows', icon: 'fa-moon' },
  { id: 'borders', label: 'Borders', icon: 'fa-border-top-left' },
  { id: 'motion', label: 'Motion', icon: 'fa-shuffle' },
  { id: 'darkmode', label: 'Dark Mode', icon: 'fa-circle-half-stroke' },
];

// HEX to RGBA conversion helper
function hexToRgba(hex: string): string {
  const clean = hex.replace('#', '');
  const r = parseInt(clean.substring(0, 2), 16);
  const g = parseInt(clean.substring(2, 4), 16);
  const b = parseInt(clean.substring(4, 6), 16);
  return `rgba(${r}, ${g}, ${b}, 1)`;
}

// Pre-resolve color values for swatches
const colorSwatchData = colorSubgroups.map(group => ({
  label: group.label,
  tokens: group.tokens.map(t => {
    const resolved = resolveTokenRef(t.value, tokenMap);
    const hex = isHexColor(resolved) ? resolved : null;
    const contrast = hex ? getContrastColor(hex) : '#ffffff';
    const rgba = hex ? hexToRgba(hex) : null;
    const tokenPath = t.path.join('.');
    return { name: t.name, value: t.value, resolved, hex, contrast, key: t.key, rgba, tokenPath };
  }),
}));

// Spacing tokens
const spaceTokens = (tokensByCategory['space'] ?? []).filter(t => t.key !== '0' && t.key !== 'px');

// Font tokens
const fontFamilyTokens = (tokensByCategory['font'] ?? []).filter(t => t.group === 'family');
const fontSizeTokens = (tokensByCategory['font'] ?? []).filter(t => t.group === 'size');
const fontWeightTokens = (tokensByCategory['font'] ?? []).filter(t => t.group === 'weight');
const lineHeightTokens = tokensByCategory['line-height'] ?? [];
const letterSpacingTokens = tokensByCategory['letter-spacing'] ?? [];

// Shadow tokens
const shadowTokens = (tokensByCategory['shadow'] ?? []).filter(t => t.key !== 'none');

// Border tokens
const borderRadiusTokens = (tokensByCategory['border'] ?? []).filter(t => t.group === 'radius');
const borderWidthTokens = (tokensByCategory['border'] ?? []).filter(t => t.group === 'width');

// Motion tokens
const durationTokens = tokensByCategory['duration'] ?? [];
const easingTokens = tokensByCategory['easing'] ?? [];
const transitionTokens = tokensByCategory['transition'] ?? [];
---

<ShowcaseLayout
  title="Token Explorer"
  description="Interactive design token reference for the HELIX design system"
>
  <style is:inline>
    /* ============================================
       TOKEN EXPLORER -- page-specific styles
       ============================================ */

    /* --- Top navigation --- */
    .te-topbar {
      position: fixed; top: 3.5rem; left: 0; right: 0; z-index: 90;
      display: flex; align-items: center; justify-content: space-between;
      padding: var(--space-3) var(--space-8);
      background: rgba(10, 10, 20, 0.85);
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    .te-topbar-left { display: flex; align-items: center; gap: var(--space-4); }
    .te-back-link {
      display: inline-flex; align-items: center; gap: var(--space-2);
      font-size: 0.875rem; font-weight: 600; color: var(--text-secondary);
      transition: all 0.2s ease; padding: var(--space-2) var(--space-3);
      border-radius: var(--radius-md);
    }
    .te-back-link:hover { color: var(--text-primary); background: var(--glass-bg-strong); }
    .te-topbar-title { font-size: 0.875rem; font-weight: 700; color: var(--text-primary); }

    /* --- Hero --- */
    .te-hero {
      position: relative; min-height: 60vh;
      display: flex; align-items: center; justify-content: center;
      text-align: center;
      padding: calc(var(--space-24) + 3.5rem) var(--space-8) var(--space-16);
      background: linear-gradient(135deg, #0a0a1a 0%, #1a0a30 40%, #0a1a2e 100%);
      overflow: hidden;
    }
    .te-hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .te-hero-orb { position: absolute; border-radius: 50%; pointer-events: none; }
    .te-hero-orb-1 {
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(139, 92, 246, 0.2), transparent 70%);
      top: -15%; right: -10%;
      animation: float-slow 20s ease-in-out infinite, orb-pulse 8s ease-in-out infinite;
    }
    .te-hero-orb-2 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(6, 182, 212, 0.15), transparent 70%);
      bottom: -10%; left: -8%;
      animation: float-slow 25s ease-in-out infinite reverse, orb-pulse 10s ease-in-out infinite 2s;
    }
    .te-hero-content { position: relative; z-index: 2; max-width: 800px; }
    .te-hero-badge {
      display: inline-flex; align-items: center; gap: var(--space-2);
      padding: var(--space-2) var(--space-4);
      background: var(--glass-bg-strong); border: 1px solid var(--glass-border-strong);
      border-radius: var(--radius-full);
      font-size: 0.8125rem; font-weight: 600; color: var(--wc-cyan);
      margin-bottom: var(--space-6); animation: fadeInDown 0.8s ease-out;
    }
    .te-hero-badge-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--wc-cyan); box-shadow: 0 0 8px var(--wc-cyan);
    }
    .te-hero-title {
      font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 800;
      letter-spacing: -0.04em; line-height: 1.1;
      margin-bottom: var(--space-6); animation: fadeInUp 1s ease-out 0.2s both;
    }
    .te-hero-subtitle {
      font-size: clamp(1rem, 2vw, 1.25rem); color: var(--text-secondary);
      font-weight: 400; line-height: 1.7; max-width: 600px; margin: 0 auto;
      animation: fadeInUp 1s ease-out 0.4s both;
    }
    .gradient-text {
      background: linear-gradient(135deg, #8b5cf6, #06b6d4);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }

    /* --- Stats row --- */
    .te-stats {
      display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-4);
      margin-top: var(--space-8); animation: fadeInUp 1s ease-out 0.6s both;
    }
    .te-stat {
      display: flex; flex-direction: column; align-items: center;
      padding: var(--space-4) var(--space-6);
      background: var(--glass-bg); border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg); min-width: 120px;
    }
    .te-stat-value {
      font-size: 1.75rem; font-weight: 800;
      background: linear-gradient(135deg, var(--wc-cyan), var(--wc-accent));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .te-stat-label { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-top: var(--space-1); }

    /* --- Tab navigation --- */
    .te-tabs-section {
      position: sticky; top: calc(3.5rem + 3rem); z-index: 80;
      background: rgba(10, 10, 20, 0.92);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding: var(--space-3) var(--space-8);
    }
    .te-tabs {
      display: flex; gap: var(--space-2); max-width: 1200px;
      margin: 0 auto; overflow-x: auto;
      scrollbar-width: none; -ms-overflow-style: none;
    }
    .te-tabs::-webkit-scrollbar { display: none; }
    .te-tab {
      display: inline-flex; align-items: center; gap: var(--space-2);
      padding: var(--space-2) var(--space-4); border-radius: var(--radius-md);
      font-size: 0.8125rem; font-weight: 600; color: var(--text-muted);
      cursor: pointer; white-space: nowrap; transition: all 0.2s ease;
      border: 1px solid transparent; background: transparent;
      font-family: var(--font-body);
    }
    .te-tab:hover { color: var(--text-secondary); background: var(--glass-bg); }
    .te-tab.active {
      color: var(--wc-cyan); background: rgba(6, 182, 212, 0.08);
      border-color: rgba(6, 182, 212, 0.2);
    }

    /* --- Content panels --- */
    .te-content { max-width: 1200px; margin: 0 auto; padding: var(--space-12) var(--space-8) var(--space-24); }
    .te-panel { display: none; }
    .te-panel.active { display: block; }
    .te-panel-title {
      font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800;
      letter-spacing: -0.02em; margin-bottom: var(--space-2);
    }
    .te-panel-desc { font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: var(--space-8); }

    /* --- Color swatches (premium cards) --- */
    .te-color-group { margin-bottom: var(--space-12); }
    .te-color-group-label {
      font-size: 1.0625rem; font-weight: 700; color: var(--text-primary);
      margin-bottom: var(--space-5); text-transform: capitalize;
      display: flex; align-items: center; gap: var(--space-2);
    }
    .te-color-ramp {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--space-4);
    }

    /* --- Individual swatch card --- */
    .te-swatch {
      display: flex; flex-direction: column;
      min-width: 0; border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.025);
      border: 1px solid rgba(255, 255, 255, 0.06);
      overflow: hidden; cursor: default;
      transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                  box-shadow 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                  border-color 0.25s ease;
    }
    .te-swatch:hover {
      transform: translateY(-3px) scale(1.015);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.06);
      border-color: rgba(255, 255, 255, 0.1);
    }

    /* Large color preview area */
    .te-swatch-preview {
      position: relative; height: 88px; width: 100%;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-mono); font-weight: 700; font-size: 0.8125rem;
      letter-spacing: 0.02em;
      transition: height 0.25s ease;
    }
    .te-swatch:hover .te-swatch-preview { height: 92px; }
    .te-swatch-preview-label {
      position: absolute; top: var(--space-2); left: var(--space-2);
      font-size: 0.6875rem; font-weight: 700; opacity: 0.7;
      font-family: var(--font-mono);
    }

    /* Reference swatch (non-hex, var() values) */
    .te-swatch-ref-preview {
      height: 88px; width: 100%;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      background: var(--surface-1); gap: var(--space-1);
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }
    .te-swatch-ref-icon {
      font-size: 1.25rem; color: var(--text-muted); opacity: 0.5;
    }
    .te-swatch-ref-val {
      font-size: 0.625rem; font-weight: 500; font-family: var(--font-mono);
      color: var(--text-muted); text-align: center; padding: 0 var(--space-2);
      word-break: break-all; line-height: 1.3;
    }

    /* Copyable values area below swatch */
    .te-swatch-details {
      display: flex; flex-direction: column; gap: 0;
      padding: var(--space-1) 0;
    }

    /* Each copyable row */
    .te-copy-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 4px var(--space-3); gap: var(--space-2);
      cursor: pointer; position: relative;
      transition: background 0.15s ease;
      min-height: 26px;
    }
    .te-copy-row:hover {
      background: rgba(255, 255, 255, 0.04);
    }
    .te-copy-row-label {
      font-size: 0.5625rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--text-muted); opacity: 0.6;
      flex-shrink: 0; width: 32px;
    }
    .te-copy-row-value {
      font-size: 0.6875rem; font-weight: 500; font-family: var(--font-mono);
      color: var(--text-secondary); white-space: nowrap; overflow: hidden;
      text-overflow: ellipsis; flex: 1; text-align: right;
      transition: color 0.15s ease;
    }
    .te-copy-row:hover .te-copy-row-value {
      color: var(--text-primary);
    }
    .te-copy-row-icon {
      flex-shrink: 0; font-size: 0.625rem; color: var(--text-muted);
      opacity: 0; transition: opacity 0.15s ease, transform 0.15s ease;
      width: 14px; text-align: center;
    }
    .te-copy-row:hover .te-copy-row-icon {
      opacity: 0.6;
    }

    /* Hover tooltip showing full value */
    .te-copy-row::after {
      content: attr(data-copy);
      position: absolute; bottom: 100%; right: 0;
      padding: 5px 10px; border-radius: 6px;
      background: rgba(15, 23, 42, 0.95); border: 1px solid rgba(6, 182, 212, 0.3);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
      font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 500;
      color: var(--text-primary); white-space: nowrap;
      pointer-events: none; opacity: 0; transform: translateY(4px);
      transition: opacity 0.15s ease, transform 0.15s ease;
      z-index: 20;
    }
    .te-copy-row:hover::after {
      opacity: 1; transform: translateY(-2px);
    }

    /* Copied feedback state */
    .te-copy-row.copied .te-copy-row-value {
      color: var(--wc-cyan);
    }
    .te-copy-row.copied .te-copy-row-icon {
      opacity: 1; color: var(--wc-cyan);
      transform: scale(1.2);
    }
    .te-copy-row.copied {
      background: rgba(6, 182, 212, 0.06);
    }
    .te-copy-row.copied::after {
      content: 'Copied!';
      color: var(--wc-cyan); border-color: rgba(6, 182, 212, 0.5);
    }

    /* Divider between preview and details */
    .te-swatch-divider {
      height: 1px; background: rgba(255, 255, 255, 0.05);
      margin: 0;
    }

    /* --- Spacing visualization --- */
    .te-space-list { display: flex; flex-direction: column; gap: var(--space-3); }
    .te-space-row {
      display: grid; grid-template-columns: 160px 1fr 100px; gap: var(--space-4);
      align-items: center; padding: var(--space-2) 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }
    .te-space-name { font-size: 0.8125rem; font-weight: 600; color: var(--text-primary); font-family: var(--font-mono); }
    .te-space-bar-wrap { position: relative; height: 28px; background: var(--surface-1); border-radius: var(--radius-sm); overflow: hidden; }
    .te-space-bar {
      height: 100%; border-radius: var(--radius-sm);
      background: linear-gradient(90deg, rgba(6, 182, 212, 0.6), rgba(139, 92, 246, 0.6));
      transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .te-space-val { font-size: 0.8125rem; font-weight: 600; color: var(--text-muted); font-family: var(--font-mono); text-align: right; }

    /* --- Typography specimens --- */
    .te-type-section { margin-bottom: var(--space-10); }
    .te-type-section-title {
      font-size: 0.875rem; font-weight: 700; color: var(--wc-cyan);
      text-transform: uppercase; letter-spacing: 0.05em;
      margin-bottom: var(--space-4); display: flex; align-items: center; gap: var(--space-2);
    }
    .te-type-specimen {
      display: grid; grid-template-columns: 180px 1fr; gap: var(--space-4);
      align-items: baseline; padding: var(--space-3) 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }
    .te-type-meta {
      display: flex; flex-direction: column; gap: 2px;
    }
    .te-type-name { font-size: 0.8125rem; font-weight: 600; color: var(--text-primary); font-family: var(--font-mono); }
    .te-type-value { font-size: 0.6875rem; color: var(--text-muted); font-family: var(--font-mono); }
    .te-type-sample { color: var(--text-primary); line-height: 1.4; }
    .te-type-weight-row {
      display: flex; gap: var(--space-6); flex-wrap: wrap;
      padding: var(--space-3) 0; border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }
    .te-type-weight-item { display: flex; flex-direction: column; gap: 2px; min-width: 140px; }
    .te-type-weight-sample { font-size: 1.25rem; color: var(--text-primary); }
    .te-type-weight-label { font-size: 0.75rem; color: var(--text-muted); font-family: var(--font-mono); }

    /* --- Shadow cards --- */
    .te-shadow-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--space-6); }
    .te-shadow-card {
      background: var(--surface-1); border: 1px solid var(--surface-3);
      border-radius: var(--radius-xl); padding: var(--space-8) var(--space-6);
      text-align: center; transition: transform 0.3s ease;
    }
    .te-shadow-card:hover { transform: translateY(-4px); }
    .te-shadow-label { font-size: 0.875rem; font-weight: 700; color: var(--text-primary); margin-bottom: var(--space-2); font-family: var(--font-mono); }
    .te-shadow-value { font-size: 0.6875rem; color: var(--text-muted); font-family: var(--font-mono); word-break: break-all; }

    /* --- Border previews --- */
    .te-border-section { margin-bottom: var(--space-10); }
    .te-border-grid { display: flex; flex-wrap: wrap; gap: var(--space-6); }
    .te-border-item { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); }
    .te-border-shape {
      width: 72px; height: 72px; background: var(--glass-bg-strong);
      border: 2px solid rgba(6, 182, 212, 0.4);
      display: flex; align-items: center; justify-content: center;
      transition: border-color 0.2s ease;
    }
    .te-border-shape:hover { border-color: var(--wc-cyan); }
    .te-border-name { font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); font-family: var(--font-mono); }
    .te-border-val { font-size: 0.6875rem; color: var(--text-muted); font-family: var(--font-mono); }

    .te-width-grid { display: flex; flex-wrap: wrap; gap: var(--space-8); align-items: flex-end; }
    .te-width-item { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); }
    .te-width-bar { width: 80px; background: var(--wc-cyan); border-radius: 2px; }

    /* --- Motion tokens --- */
    .te-motion-section { margin-bottom: var(--space-10); }
    .te-motion-list { display: flex; flex-direction: column; gap: var(--space-3); }
    .te-motion-row {
      display: grid; grid-template-columns: 200px 1fr 120px; gap: var(--space-4);
      align-items: center; padding: var(--space-3) var(--space-4);
      background: var(--surface-1); border: 1px solid var(--surface-3);
      border-radius: var(--radius-md);
    }
    .te-motion-name { font-size: 0.8125rem; font-weight: 600; color: var(--text-primary); font-family: var(--font-mono); }
    .te-motion-demo { position: relative; height: 4px; background: var(--surface-3); border-radius: 2px; overflow: visible; }
    .te-motion-dot {
      position: absolute; top: -6px; left: 0;
      width: 16px; height: 16px; border-radius: 50%;
      background: linear-gradient(135deg, var(--wc-cyan), var(--wc-accent));
      box-shadow: 0 0 8px rgba(6, 182, 212, 0.4);
    }
    .te-motion-row:hover .te-motion-dot {
      animation: motionSlide var(--dur, 300ms) var(--ease, ease) forwards;
    }
    @keyframes motionSlide {
      0% { left: 0; }
      100% { left: calc(100% - 16px); }
    }
    .te-motion-val { font-size: 0.8125rem; color: var(--text-muted); font-family: var(--font-mono); text-align: right; }

    .te-easing-visual {
      position: relative; height: 60px; background: var(--surface-1);
      border: 1px solid var(--surface-3); border-radius: var(--radius-md);
      overflow: hidden; margin-top: var(--space-2);
    }
    .te-easing-curve {
      position: absolute; bottom: 0; left: 0; width: 100%; height: 100%;
    }

    /* --- Dark mode table --- */
    .te-dark-table {
      width: 100%; border-collapse: collapse;
      font-size: 0.8125rem; font-family: var(--font-mono);
    }
    .te-dark-table thead th {
      text-align: left; padding: var(--space-3) var(--space-4);
      font-weight: 700; color: var(--wc-cyan);
      border-bottom: 2px solid rgba(6, 182, 212, 0.2);
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .te-dark-table tbody td {
      padding: var(--space-2) var(--space-4);
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      color: var(--text-secondary);
    }
    .te-dark-table tbody tr:hover { background: var(--glass-bg); }
    .te-dark-swatch-inline {
      display: inline-block; width: 14px; height: 14px;
      border-radius: 3px; vertical-align: middle; margin-right: var(--space-1);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* --- Responsive --- */
    @media (max-width: 768px) {
      .te-topbar { padding: var(--space-2) var(--space-4); }
      .te-hero { min-height: 50vh; padding-top: calc(var(--space-16) + 3.5rem); }
      .te-stats { gap: var(--space-2); }
      .te-stat { min-width: 90px; padding: var(--space-3) var(--space-4); }
      .te-stat-value { font-size: 1.25rem; }
      .te-content { padding: var(--space-8) var(--space-4) var(--space-16); }
      .te-space-row { grid-template-columns: 130px 1fr 70px; gap: var(--space-2); }
      .te-type-specimen { grid-template-columns: 1fr; }
      .te-motion-row { grid-template-columns: 1fr; gap: var(--space-2); }
