                        <span class="te-copy-row-value">{t.tokenPath}</span>
                        <i class="fa-solid fa-copy te-copy-row-icon"></i>
                      </div>
                      <div class="te-copy-row" data-copy={t.name} title={`Copy CSS variable: ${t.name}`}>
                        <span class="te-copy-row-label">CSS</span>
                        <span class="te-copy-row-value">{t.name}</span>
                        <i class="fa-solid fa-copy te-copy-row-icon"></i>
                      </div>
                      <div class="te-copy-row" data-copy={t.hex.toUpperCase()} title={`Copy HEX: ${t.hex.toUpperCase()}`}>
