          <div class="te-type-specimen">
            <div class="te-type-meta">
              <span class="te-type-name">{t.key}</span>
              <span class="te-type-value">{t.value}</span>
            </div>
            <span class="te-type-sample" style={`font-size: ${t.value};`}>
