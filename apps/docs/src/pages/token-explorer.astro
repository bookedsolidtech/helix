    <!-- ===== COLORS ===== -->
    <div class={`te-panel active`} id="panel-colors" role="tabpanel">
      <h2 class="te-panel-title"><span class="gradient-text">Color System</span></h2>
      <p class="te-panel-desc">
        8 color ramps (primary, secondary, accent, neutral, success, warning, error, info) with
        50-950 shades each, plus semantic tokens for text, surface, border, focus, and selection.
      </p>

      {colorSwatchData.map(group => (
        <div class="te-color-group">
          <div class="te-color-group-label">
            <i class="fa-solid fa-circle" style={
              group.tokens[0]?.hex
                ? `color: ${group.tokens[0].hex}; font-size: 0.625rem;`
                : 'color: var(--text-muted); font-size: 0.625rem;'
            }></i>
            {group.label}
            <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: 400;">
              ({group.tokens.length} tokens)
            </span>
          </div>
          <div class="te-color-ramp">
            {group.tokens.map(t => (
              <div class="te-swatch" title={`${t.name}: ${t.resolved}`}>
                {t.hex ? (
                  <Fragment>
                    <div
                      class="te-swatch-preview"
                      style={`background: ${t.hex}; color: ${t.contrast};`}
                    >
                      <span class="te-swatch-preview-label" style={`color: ${t.contrast};`}>{t.key}</span>
                      {t.hex.toUpperCase()}
                    </div>
                    <div class="te-swatch-divider"></div>
                    <div class="te-swatch-details">
                      <div class="te-copy-row" data-copy={t.tokenPath} title={`Copy token path: ${t.tokenPath}`}>
