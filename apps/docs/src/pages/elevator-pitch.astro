---
/**
 * Elevator Pitch - 30-Second Billboard Landing Page
 *
 * Single-screen, punchy, no-scroll-needed pitch page.
 * Giant headline, animated stat counters, one-liner value props.
 * "The Ask" -- role, value, differentiator.
 *
 * Target audience: HR, hiring managers, technical leads scanning quickly.
 */
import ShowcaseLayout from '../layouts/ShowcaseLayout.astro';
---

<ShowcaseLayout
  title="The 30-Second Pitch"
  description="28 years of engineering experience, distilled into an enterprise web component architecture. The pitch in 30 seconds."
>
    <style is:inline>
      /* ============================================
         ELEVATOR PITCH - 30-SECOND BILLBOARD
         Page-specific styles only (shared tokens,
         base, animations, utilities via ShowcaseLayout)
         ============================================ */

      /* Override: this page uses a different hero gradient */
      :root {
        --gradient-hero: linear-gradient(135deg, #0a0a18 0%, #0f1030 30%, #1a0a2e 60%, #0a0a18 100%);
      }

      /* Override: this page needs the box-shadow version of pulse-ring for .ep-badge-dot */
      @keyframes pulse-ring {
        0% { box-shadow: 0 0 0 0 rgba(102,126,234,0.4); }
        70% { box-shadow: 0 0 0 15px rgba(102,126,234,0); }
        100% { box-shadow: 0 0 0 0 rgba(102,126,234,0); }
      }

      /* Floating Pitch Nav */
      .pitch-nav {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 200;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.375rem;
        background: rgba(10,10,20,0.9);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid var(--glass-border-strong);
        border-radius: var(--radius-full);
        box-shadow: var(--shadow-xl);
      }
      .pitch-nav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.5rem 1rem;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--text-secondary);
        border-radius: var(--radius-full);
        transition: all 0.25s ease;
        white-space: nowrap;
      }
      .pitch-nav-link:hover { color: var(--text-primary); background: var(--glass-bg-strong); }
      .pitch-nav-link.active {
        color: white;
        background: var(--gradient-primary);
        box-shadow: 0 2px 12px rgba(102,126,234,0.3);
      }
      .pitch-nav-divider {
        width: 1px;
        height: 20px;
        background: var(--glass-border-strong);
        margin: 0 0.25rem;
      }
      .pitch-nav-home {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        font-size: 0.875rem;
        color: var(--text-muted);
        border-radius: 50%;
        transition: all 0.25s ease;
      }
      .pitch-nav-home:hover { color: var(--text-primary); background: var(--glass-bg-strong); }

      /* Full-screen hero */
      .ep-billboard {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 5.5rem 2rem 2rem;
        background: var(--gradient-hero);
        overflow: hidden;
      }

      /* Particle background */
      .ep-particles {
        position: absolute;
        inset: 0;
        background-image:
          radial-gradient(1.5px 1.5px at 10% 20%, rgba(102,126,234,0.3) 50%, transparent 50%),
          radial-gradient(1px 1px at 30% 65%, rgba(6,182,212,0.25) 50%, transparent 50%),
          radial-gradient(1.5px 1.5px at 50% 10%, rgba(236,72,153,0.2) 50%, transparent 50%),
          radial-gradient(1px 1px at 70% 80%, rgba(16,185,129,0.25) 50%, transparent 50%),
          radial-gradient(1.5px 1.5px at 90% 40%, rgba(139,92,246,0.3) 50%, transparent 50%),
          radial-gradient(1px 1px at 15% 90%, rgba(245,158,11,0.2) 50%, transparent 50%),
          radial-gradient(1.5px 1.5px at 85% 15%, rgba(6,182,212,0.2) 50%, transparent 50%);
        animation: particle-drift 60s linear infinite;
        pointer-events: none;
      }

      /* Grid overlay */
      .ep-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
        background-size: 80px 80px;
        pointer-events: none;
      }

      /* Orbs */
      .ep-orb { position: absolute; border-radius: 50%; pointer-events: none; }
      .ep-orb-1 { width: 600px; height: 600px; background: radial-gradient(circle, rgba(102,126,234,0.15), transparent 70%); top: -15%; right: -10%; animation: float-slow 22s ease-in-out infinite, orb-pulse 8s ease-in-out infinite; }
      .ep-orb-2 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(6,182,212,0.12), transparent 70%); bottom: -10%; left: -8%; animation: float-slow 28s ease-in-out infinite reverse, orb-pulse 10s ease-in-out infinite 2s; }
      .ep-orb-3 { width: 350px; height: 350px; background: radial-gradient(circle, rgba(236,72,153,0.1), transparent 70%); top: 20%; left: 10%; animation: float-slow 18s ease-in-out infinite 5s, orb-pulse 12s ease-in-out infinite 4s; }
      .ep-orb-4 { width: 250px; height: 250px; background: radial-gradient(circle, rgba(16,185,129,0.08), transparent 70%); bottom: 25%; right: 15%; animation: float-slow 20s ease-in-out infinite 3s, orb-pulse 9s ease-in-out infinite 1s; }

      /* Content container */
      .ep-content {
        position: relative;
        z-index: 2;
        max-width: 1100px;
        width: 100%;
        text-align: center;
      }

      /* Badge */
      .ep-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        background: var(--glass-bg-strong);
        border: 1px solid var(--glass-border-strong);
        border-radius: var(--radius-full);
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--wc-cyan);
        margin-bottom: 2rem;
        animation: fadeInDown 0.6s ease-out;
      }
      .ep-badge-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: var(--wc-cyan);
        box-shadow: 0 0 8px var(--wc-cyan);
        animation: pulse-ring 2s ease-out infinite;
      }

      /* Headline */
      .ep-headline {
        font-size: clamp(2.75rem, 8vw, 5.5rem);
        font-weight: 900;
        letter-spacing: -0.05em;
        line-height: 1.05;
        margin-bottom: 1.5rem;
        animation: fadeInUp 0.8s ease-out 0.15s both;
      }
      .ep-headline .gradient-text {
        background: linear-gradient(135deg, #667eea 0%, #8b5cf6 30%, #ec4899 60%, #06b6d4 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Subtitle */
      .ep-subtitle {
        font-size: clamp(1.125rem, 2.5vw, 1.5rem);
        color: var(--text-secondary);
        font-weight: 400;
        margin-bottom: 3rem;
        animation: fadeInUp 0.8s ease-out 0.3s both;
      }
      .ep-subtitle strong {
        color: var(--text-primary);
        font-weight: 600;
      }

      /* Stats row */
      .ep-stats {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1rem;
        margin-bottom: 3rem;
        animation: fadeInUp 0.8s ease-out 0.45s both;
      }
      .ep-stat {
        padding: 1.25rem 0.5rem;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-xl);
        transition: all 0.3s ease;
      }
      .ep-stat:hover {
        background: var(--glass-bg-strong);
        border-color: var(--glass-border-strong);
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
      }
      .ep-stat-value {
        font-size: clamp(1.75rem, 3.5vw, 2.75rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 0.25rem;
      }
      .ep-stat-label {
        font-size: 0.8125rem;
        color: var(--text-muted);
        font-weight: 500;
        line-height: 1.3;
      }

      /* Value props */
      .ep-props {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 3rem;
        animation: fadeInUp 0.8s ease-out 0.6s both;
      }
      .ep-prop {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg);
        text-align: left;
        transition: all 0.3s ease;
      }
      .ep-prop:hover {
        background: var(--glass-bg-strong);
        border-color: var(--glass-border-strong);
        transform: translateY(-2px);
      }
      .ep-prop-icon {
        width: 36px;
        height: 36px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
        flex-shrink: 0;
      }
      .ep-prop-text {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.5;
      }
      .ep-prop-text strong {
        color: var(--text-primary);
        display: block;
        font-size: 0.9375rem;
        margin-bottom: 0.125rem;
      }

      /* The Ask */
      .ep-ask {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        animation: fadeInUp 0.8s ease-out 0.75s both;
      }
      .ep-ask-label {
        font-size: 0.875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
      }
      .ep-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 2rem;
        border-radius: var(--radius-full);
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        text-decoration: none;
      }
      .ep-btn-solid {
        background: var(--gradient-primary);
        color: white;
        border: none;
        box-shadow: 0 4px 16px rgba(102,126,234,0.3), var(--glow-subtle);
      }
      .ep-btn-solid:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 32px rgba(102,126,234,0.4), var(--glow-primary);
        color: white;
      }
      .ep-btn-ghost {
        background: var(--glass-bg);
        color: var(--text-secondary);
        border: 1px solid var(--glass-border-strong);
      }
      .ep-btn-ghost:hover {
        background: var(--glass-bg-strong);
        color: var(--text-primary);
        transform: translateY(-3px);
      }
      .ep-btn-arrow { transition: transform 0.2s ease; }
      .ep-btn:hover .ep-btn-arrow { transform: translateX(4px); }

      /* Color helpers */
      .icon-cyan { background:linear-gradient(135deg,rgba(6,182,212,0.15),rgba(6,182,212,0.05)); border:1px solid rgba(6,182,212,0.2); color:var(--wc-cyan); }
      .icon-green { background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(16,185,129,0.05)); border:1px solid rgba(16,185,129,0.2); color:var(--wc-green); }
      .icon-accent { background:linear-gradient(135deg,rgba(139,92,246,0.15),rgba(139,92,246,0.05)); border:1px solid rgba(139,92,246,0.2); color:var(--wc-accent); }
      .icon-pink { background:linear-gradient(135deg,rgba(236,72,153,0.15),rgba(236,72,153,0.05)); border:1px solid rgba(236,72,153,0.2); color:var(--wc-pink); }
      .icon-amber { background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(245,158,11,0.05)); border:1px solid rgba(245,158,11,0.2); color:var(--wc-amber); }

      /* Proof line */
      .ep-proof {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--glass-border);
        animation: fadeIn 1s ease-out 1s both;
      }
      .ep-proof-text {
        font-size: 0.8125rem;
        color: var(--text-muted);
        font-style: italic;
      }
      .ep-proof-text a {
        color: var(--wc-cyan);
        font-style: normal;
        font-weight: 600;
      }

      /* Responsive */
      @media (max-width: 1024px) {
        .ep-stats { grid-template-columns: repeat(3, 1fr); }
        .ep-stats .ep-stat:nth-child(4),
        .ep-stats .ep-stat:nth-child(5) { grid-column: span 1; }
      }

      @media (max-width: 768px) {
        .ep-billboard { padding: 5rem 1rem 6rem; min-height: auto; }
        .ep-stats { grid-template-columns: repeat(2, 1fr); }
        .ep-stats .ep-stat:last-child { grid-column: span 2; }
        .ep-props { grid-template-columns: 1fr; }
        .ep-ask { flex-direction: column; gap: 0.75rem; }
        .ep-btn { width: 100%; justify-content: center; }
        .pitch-nav { bottom: 1rem; left: 0.5rem; right: 0.5rem; transform: none; justify-content: center; }
        .pitch-nav-link { padding: 0.5rem 0.75rem; font-size: 0.75rem; min-height: 44px; }
        .pitch-nav-home { min-width: 44px; min-height: 44px; }
      }

      @media (max-width: 480px) {
        .ep-stats { grid-template-columns: 1fr 1fr; }
        .ep-stats .ep-stat:last-child { grid-column: span 2; }
      }

      /* Page-specific reduced motion: orb fallback */
      @media (prefers-reduced-motion: reduce) {
        .ep-orb { animation: none !important; opacity: 0.15; }
      }

      .ep-btn:focus-visible, .pitch-nav-link:focus-visible, .pitch-nav-home:focus-visible {
        outline: 3px solid var(--wc-accent);
        outline-offset: 3px;
      }
    </style>

    <!-- Floating pitch navigation -->
    <nav class="pitch-nav" aria-label="Pitch pages">
      <a href="/" class="pitch-nav-home" aria-label="Back to Dashboard">
        <i class="fa-solid fa-house" aria-hidden="true"></i>
      </a>
      <div class="pitch-nav-divider" aria-hidden="true"></div>
      <a href="/elevator-pitch/" class="pitch-nav-link active" aria-current="page">
        <i class="fa-solid fa-bolt" aria-hidden="true"></i>
        30s
      </a>
      <a href="/detailed-pitch/" class="pitch-nav-link">
        <i class="fa-solid fa-clock" aria-hidden="true"></i>
        5 min
      </a>
      <a href="/full-presentation/" class="pitch-nav-link">
        <i class="fa-solid fa-presentation-screen" aria-hidden="true"></i>
        30 min
      </a>
    </nav>

    <main id="main-content">
      <section class="ep-billboard" aria-label="30-second elevator pitch">
        <!-- Visual effects -->
        <div class="ep-particles" aria-hidden="true"></div>
        <div class="ep-grid" aria-hidden="true"></div>
        <div class="ep-orb ep-orb-1" aria-hidden="true"></div>
        <div class="ep-orb ep-orb-2" aria-hidden="true"></div>
        <div class="ep-orb ep-orb-3" aria-hidden="true"></div>
        <div class="ep-orb ep-orb-4" aria-hidden="true"></div>

        <div class="ep-content">
          <!-- Badge -->
          <div class="ep-badge">
            <span class="ep-badge-dot" aria-hidden="true"></span>
            Tech Lead Candidate
          </div>

          <!-- Headline -->
          <h1 class="ep-headline">
            Architects Talk.<br />
            <span class="gradient-text">I Deliver.</span>
          </h1>

          <!-- Subtitle -->
          <p class="ep-subtitle">
            <strong>28 years</strong> of shipping production code.
            About to architect and manage an enterprise web component library
            with a <strong>bleeding-edge 2026 stack</strong>.
          </p>

          <!-- Animated Stats -->
          <div class="ep-stats">
            <div class="ep-stat">
              <div class="ep-stat-value" data-count="28" style="background:var(--gradient-cyan-purple);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">0</div>
              <div class="ep-stat-label">Years<br/>Experience</div>
            </div>
            <div class="ep-stat">
              <div class="ep-stat-value" data-count="10000" data-suffix="+" style="background:var(--gradient-green-cyan);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">0</div>
              <div class="ep-stat-label">Lines of<br/>Documentation</div>
            </div>
            <div class="ep-stat">
              <div class="ep-stat-value" data-count="100" data-suffix="%" style="background:var(--gradient-pink-orange);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">0</div>
              <div class="ep-stat-label">TypeScript<br/>Zero Any</div>
            </div>
            <div class="ep-stat">
              <div class="ep-stat-value" data-count="5" style="background:linear-gradient(135deg,var(--wc-amber),var(--wc-pink));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">0</div>
              <div class="ep-stat-label">Immersive<br/>Showcase Pages</div>
            </div>
            <div class="ep-stat">
              <div class="ep-stat-value" data-count="13" style="background:linear-gradient(135deg,var(--wc-green),var(--wc-amber));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">0</div>
              <div class="ep-stat-label">Components<br/>In Development</div>
            </div>
          </div>

          <!-- Value Props -->
          <div class="ep-props">
            <div class="ep-prop">
              <div class="ep-prop-icon icon-cyan"><i class="fa-solid fa-cubes" aria-hidden="true"></i></div>
              <div class="ep-prop-text">
                <strong>Lit 3 + Vite 7 + Storybook 10</strong>
                Bleeding-edge 2026 stack. Framework-agnostic components that work everywhere.
              </div>
            </div>
            <div class="ep-prop">
              <div class="ep-prop-icon icon-green"><i class="fa-solid fa-universal-access" aria-hidden="true"></i></div>
              <div class="ep-prop-text">
                <strong>WCAG 2.2 AAA Target</strong>
                Accessibility-first compliance baked in from day one. Not bolted on.
              </div>
            </div>
            <div class="ep-prop">
              <div class="ep-prop-icon icon-accent"><i class="fa-brands fa-drupal" aria-hidden="true"></i></div>
              <div class="ep-prop-text">
                <strong>Drupal-Native Integration</strong>
                CEM to TWIG to SDC pipeline. Zero coupling, full interop.
              </div>
            </div>
          </div>

          <!-- The Ask -->
          <div class="ep-ask">
            <span class="ep-ask-label">The Ask:</span>
            <a href="/detailed-pitch/" class="ep-btn ep-btn-solid">
              See the Full Plan
              <span class="ep-btn-arrow" aria-hidden="true">&rarr;</span>
            </a>
            <a href="/full-presentation/" class="ep-btn ep-btn-ghost">
              30-Minute Deep Dive
              <span class="ep-btn-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </div>

          <!-- Proof -->
          <div class="ep-proof">
            <p class="ep-proof-text">
              This entire documentation system -- deployed on Vercel with smart build triggers across three production apps --
              is itself a demonstration of how I organize, lead, and execute enterprise infrastructure.
              <a href="/">Explore the site &rarr;</a>
            </p>
          </div>
        </div>
      </section>
    </main>

    <script slot="scripts" is:inline>
      (function () {
        // Animated counters
        var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var counters = document.querySelectorAll('[data-count]');

        function animateCounter(el) {
          var target = parseInt(el.getAttribute('data-count'), 10);
          var suffix = el.getAttribute('data-suffix') || '';
          var duration = 2000;
          var start = 0;
          var startTime = null;

          if (prefersReduced) {
            el.textContent = target.toLocaleString() + suffix;
            return;
          }

          function step(timestamp) {
            if (!startTime) startTime = timestamp;
            var progress = Math.min((timestamp - startTime) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = Math.floor(eased * target);
            el.textContent = current.toLocaleString() + suffix;
            if (progress < 1) {
              requestAnimationFrame(step);
            } else {
              el.textContent = target.toLocaleString() + suffix;
            }
          }

          requestAnimationFrame(step);
        }

        // Trigger counters after a short delay for dramatic effect
        setTimeout(function () {
          counters.forEach(function (el) {
            animateCounter(el);
          });
        }, 500);
      })();
    </script>
</ShowcaseLayout>
