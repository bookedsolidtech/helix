    <script is:inline>
      (function () {
        var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (prefersReduced) {
          document.querySelectorAll('.scroll-reveal').forEach(function (el) {
            el.classList.add('is-visible');
          });
          document.querySelectorAll('.scroll-reveal-bar').forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }

        // Scroll reveal observer
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
        );

        document.querySelectorAll('.scroll-reveal').forEach(function (el) {
          observer.observe(el);
        });

        // Bar fill animation observer
        var barObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                barObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.3, rootMargin: '0px 0px -40px 0px' }
        );

        document.querySelectorAll('.scroll-reveal-bar').forEach(function (el) {
          barObserver.observe(el);
        });

        // Cursor-following spotlight on cards
        document.querySelectorAll('.dx-card').forEach(function (card) {
          card.addEventListener('mousemove', function (e) {
            var rect = card.getBoundingClientRect();
            card.style.setProperty('--mouse-x', (e.clientX - rect.left) + 'px');
            card.style.setProperty('--mouse-y', (e.clientY - rect.top) + 'px');
          });
        });

        // Tab switching
        var tabButtons = document.querySelectorAll('.dx-nav-tab[role="tab"]');
        var tabPanels = document.querySelectorAll('.dx-tab-content');

        tabButtons.forEach(function (btn) {
          btn.addEventListener('click', function () {
            var targetId = btn.getAttribute('data-tab');

            // Update buttons
            tabButtons.forEach(function (b) {
              b.classList.remove('is-active');
              b.setAttribute('aria-selected', 'false');
            });
            btn.classList.add('is-active');
            btn.setAttribute('aria-selected', 'true');

            // Update panels
            tabPanels.forEach(function (panel) {
              panel.classList.remove('is-active');
            });
            var target = document.getElementById(targetId);
            if (target) {
              target.classList.add('is-active');

              // Scroll to top
              window.scrollTo({ top: 0, behavior: 'smooth' });

              // Re-trigger scroll-reveal for newly visible panel
              setTimeout(function () {
                target.querySelectorAll('.scroll-reveal:not(.is-visible)').forEach(function (el) {
                  observer.unobserve(el);
                  observer.observe(el);
                });
                target.querySelectorAll('.scroll-reveal-bar:not(.is-visible)').forEach(function (el) {
                  barObserver.unobserve(el);
                  barObserver.observe(el);
                });
              }, 50);
            }
          });
        });

        // Keyboard navigation for tabs
        tabButtons.forEach(function (btn, index) {
          btn.addEventListener('keydown', function (e) {
            var next = null;
            if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
              next = tabButtons[(index + 1) % tabButtons.length];
            } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
              next = tabButtons[(index - 1 + tabButtons.length) % tabButtons.length];
            }
            if (next) {
              e.preventDefault();
              next.focus();
              next.click();
            }
          });
        });
      })();
    </script>
