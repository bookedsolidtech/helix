---
/**
 * Developer Experience & Quality Pipeline - Full visual experience page.
 *
 * Standalone Astro page (not Starlight content) showcasing operational
 * engineering excellence: developer onboarding, quality automation,
 * and CI/CD delivery pipeline.
 *
 * Tabs:
 * 1. Onboarding & DX - Zero to Component in Under 5 Minutes
 * 2. Quality Pipeline - Four Automated Gates, Zero Manual Steps
 * 3. CI/CD & Delivery - From Commit to CDN in 8 Seconds
 */
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Developer Experience &amp; Quality Pipeline | WC-2026</title>
    <meta
      name="description"
      content="From first clone to production confidence in under 5 minutes. Developer onboarding, automated quality gates, and Turborepo-powered CI/CD delivery."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
      integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <style>
      /* ============================================
         DEVELOPER EXPERIENCE PAGE - Self-contained
         ============================================ */

      @property --gradient-angle {
        syntax: '<angle>';
        initial-value: 0deg;
        inherits: false;
      }

      :root {
        --wc-accent-h: 250;
        --wc-accent-s: 70%;
        --wc-accent-l: 60%;
        --wc-accent: hsl(var(--wc-accent-h), var(--wc-accent-s), var(--wc-accent-l));
        --wc-cyan: #06b6d4;
        --wc-pink: #ec4899;
        --wc-green: #10b981;
        --wc-emerald: #059669;
        --wc-amber: #f59e0b;
        --wc-red: #ef4444;
        --wc-electric: #3b82f6;
        --wc-violet: #8b5cf6;
        --wc-indigo: #6366f1;

        --gradient-primary: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --gradient-hero: linear-gradient(135deg, #0a0a1a 0%, #1a1040 40%, #0f0f2e 100%);
        --gradient-cyan-white: linear-gradient(135deg, #06b6d4, #ffffff);
        --gradient-green-emerald: linear-gradient(135deg, #10b981, #059669);
        --gradient-violet-indigo: linear-gradient(135deg, #8b5cf6, #6366f1);

        --font-heading: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;

        --space-1: 0.25rem; --space-2: 0.5rem; --space-3: 0.75rem;
        --space-4: 1rem; --space-5: 1.25rem; --space-6: 1.5rem;
        --space-8: 2rem; --space-10: 2.5rem; --space-12: 3rem;
        --space-16: 4rem; --space-20: 5rem; --space-24: 6rem;

        --radius-sm: 0.5rem; --radius-md: 0.75rem; --radius-lg: 1rem;
        --radius-xl: 1.5rem; --radius-2xl: 2rem; --radius-full: 9999px;

        --shadow-sm: 0 2px 8px rgba(0,0,0,0.3);
        --shadow-md: 0 4px 16px rgba(0,0,0,0.4);
        --shadow-lg: 0 8px 32px rgba(0,0,0,0.5);
        --shadow-xl: 0 16px 64px rgba(0,0,0,0.6);

        --glass-bg: rgba(255,255,255,0.03);
        --glass-bg-strong: rgba(255,255,255,0.06);
        --glass-border: rgba(255,255,255,0.06);
        --glass-border-strong: rgba(255,255,255,0.12);

        --glow-primary: 0 0 50px rgba(102,126,234,0.25);
        --glow-subtle: 0 0 20px rgba(102,126,234,0.15);

        --surface-0: #0a0a14; --surface-1: #111122;
        --surface-2: #1a1a32; --surface-3: #252545;
        --text-primary: #eaeaf4; --text-secondary: #a8a8c8; --text-muted: #6868a0;
      }

      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: var(--font-body); line-height: 1.6;
        -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
        background: var(--surface-0); color: var(--text-primary);
        scroll-behavior: smooth; overflow-x: clip;
      }

      h1,h2,h3,h4,h5,h6 { font-family: var(--font-heading); font-weight: 700; letter-spacing: -0.025em; line-height: 1.15; }
      code, pre { font-family: var(--font-mono); }
      a { color: var(--wc-accent); text-decoration: none; transition: color 0.2s ease; }
      a:hover { color: hsl(var(--wc-accent-h), var(--wc-accent-s), 75%); }

      /* --- Keyframes --- */
      @keyframes fadeInUp { from { opacity:0; transform:translateY(40px); } to { opacity:1; transform:translateY(0); } }
      @keyframes fadeInDown { from { opacity:0; transform:translateY(-20px); } to { opacity:1; transform:translateY(0); } }
      @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
      @keyframes float-slow { 0%,100% { transform:translate(0,0) scale(1); } 25% { transform:translate(30px,-20px) scale(1.05); } 50% { transform:translate(-10px,-35px) scale(0.97); } 75% { transform:translate(-25px,-10px) scale(1.02); } }
      @keyframes float-drift { 0%,100% { transform:translate(0,0) rotate(0deg); } 33% { transform:translate(20px,15px) rotate(2deg); } 66% { transform:translate(-15px,-20px) rotate(-2deg); } }
      @keyframes orb-pulse { 0%,100% { opacity:0.3; filter:blur(100px); } 50% { opacity:0.5; filter:blur(120px); } }
      @keyframes pulse-glow { 0%,100% { box-shadow:0 0 8px rgba(74,222,128,0.4); } 50% { box-shadow:0 0 24px rgba(74,222,128,0.7); } }
      @keyframes border-rotate { 0% { --gradient-angle:0deg; } 100% { --gradient-angle:360deg; } }
      @keyframes scroll-fade { 0% { opacity:1; transform:translateX(-50%) translateY(0); } 100% { opacity:0; transform:translateX(-50%) translateY(12px); } }
      @keyframes particle-drift { 0% { background-position:0 0, 200px 200px, 400px 100px; } 100% { background-position:800px 800px, 1000px 1000px, 1200px 900px; } }
      @keyframes bar-fill { from { width: 0; } }
      @keyframes pulse-ring { 0% { transform:scale(0.8); opacity:1; } 100% { transform:scale(2); opacity:0; } }
      @keyframes shimmer { 0% { background-position:-200% 0; } 100% { background-position:200% 0; } }

      /* --- Scroll Reveal --- */
      .scroll-reveal { opacity:0; transform:translateY(40px); transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1), filter 0.8s cubic-bezier(0.22,1,0.36,1); filter:blur(4px); }
      .scroll-reveal.is-visible { opacity:1; transform:translateY(0); filter:blur(0); }
      .scroll-reveal-delay-1 { transition-delay:0.1s; } .scroll-reveal-delay-2 { transition-delay:0.2s; }
      .scroll-reveal-delay-3 { transition-delay:0.3s; } .scroll-reveal-delay-4 { transition-delay:0.4s; }
      .scroll-reveal-delay-5 { transition-delay:0.5s; } .scroll-reveal-delay-6 { transition-delay:0.6s; }

      /* Scroll-reveal bar fill */
      .scroll-reveal-bar { --bar-width: 0%; }
      .scroll-reveal-bar.is-visible { --bar-width: var(--target-width, 80%); }

      /* ==========================================
         TOP NAVIGATION BAR
         ========================================== */
      .dx-topbar { position:fixed; top:0; left:0; right:0; z-index:100; display:flex; align-items:center; justify-content:space-between; padding:var(--space-3) var(--space-8); background:rgba(10,10,20,0.85); backdrop-filter:blur(16px) saturate(180%); -webkit-backdrop-filter:blur(16px) saturate(180%); border-bottom:1px solid rgba(255,255,255,0.06); }
      .dx-topbar-left { display:flex; align-items:center; gap:var(--space-4); }
      .dx-back-link { display:inline-flex; align-items:center; gap:var(--space-2); font-size:0.875rem; font-weight:600; color:var(--text-secondary); transition:all 0.2s ease; padding:var(--space-2) var(--space-3); border-radius:var(--radius-md); }
      .dx-back-link:hover { color:var(--text-primary); background:var(--glass-bg-strong); }
      .dx-topbar-title { font-size:0.875rem; font-weight:700; color:var(--text-primary); letter-spacing:-0.01em; }
      .dx-topbar-right { display:flex; align-items:center; gap:var(--space-3); }
      .dx-topbar-link { display:inline-flex; align-items:center; gap:var(--space-2); font-size:0.8125rem; font-weight:600; color:var(--text-muted); padding:var(--space-2) var(--space-4); border-radius:var(--radius-md); border:1px solid rgba(255,255,255,0.08); transition:all 0.2s ease; }
      .dx-topbar-link:hover { color:var(--wc-accent); border-color:rgba(102,126,234,0.3); background:rgba(102,126,234,0.06); }

      /* ==========================================
         STICKY TAB NAV (3-tab content switcher)
         ========================================== */
      .dx-section-nav { position:sticky; top:3.9rem; z-index:90; background:rgba(10,10,20,0.92); backdrop-filter:blur(20px) saturate(180%); -webkit-backdrop-filter:blur(20px) saturate(180%); border-bottom:1px solid rgba(255,255,255,0.08); }
      .dx-section-nav-inner { display:flex; max-width:1200px; margin:0 auto; padding:0.5rem; gap:0.5rem; }
      .dx-nav-tab { flex:1; display:flex; flex-direction:column; align-items:center; gap:0.25rem; padding:0.75rem 1.5rem; border-radius:0.75rem; border:1px solid transparent; background:transparent; color:rgba(255,255,255,0.45); cursor:pointer; transition:all 0.25s ease; font-family:var(--font-heading); }
      .dx-nav-tab i { font-size:1.25rem; opacity:0.5; transition:all 0.25s ease; }
      .dx-nav-tab-label { font-size:0.9375rem; font-weight:700; letter-spacing:-0.01em; }
      .dx-nav-tab-subtitle { font-size:0.6875rem; font-weight:500; text-transform:uppercase; letter-spacing:0.06em; opacity:0.5; }
      .dx-nav-tab:hover { color:rgba(255,255,255,0.8); background:rgba(255,255,255,0.04); }
      .dx-nav-tab:hover i { opacity:0.9; }
      .dx-nav-tab.is-active { color:white; background:rgba(102,126,234,0.1); border-color:rgba(102,126,234,0.25); box-shadow:0 0 20px rgba(102,126,234,0.08); }
      .dx-nav-tab.is-active i { opacity:1; color:var(--wc-accent); }
      .dx-nav-tab.is-active .dx-nav-tab-subtitle { opacity:0.8; }
      .dx-nav-tab:focus-visible { outline:2px solid var(--wc-accent); outline-offset:2px; }

      /* Tab-specific active colors */
      .dx-nav-tab[data-tab="tab-dx"].is-active { background:rgba(6,182,212,0.1); border-color:rgba(6,182,212,0.25); box-shadow:0 0 20px rgba(6,182,212,0.08); }
      .dx-nav-tab[data-tab="tab-dx"].is-active i { color:var(--wc-cyan); }
      .dx-nav-tab[data-tab="tab-quality"].is-active { background:rgba(16,185,129,0.1); border-color:rgba(16,185,129,0.25); box-shadow:0 0 20px rgba(16,185,129,0.08); }
      .dx-nav-tab[data-tab="tab-quality"].is-active i { color:var(--wc-green); }
      .dx-nav-tab[data-tab="tab-cicd"].is-active { background:rgba(139,92,246,0.1); border-color:rgba(139,92,246,0.25); box-shadow:0 0 20px rgba(139,92,246,0.08); }
      .dx-nav-tab[data-tab="tab-cicd"].is-active i { color:var(--wc-violet); }

      /* Tab content panels */
      .dx-tab-content { display:none; }
      .dx-tab-content.is-active { display:block; }

      /* ==========================================
         HERO (shared base, color variants per tab)
         ========================================== */
      .dx-hero { min-height:100vh; min-height:100dvh; display:flex; flex-direction:column; align-items:center; justify-content:center; position:relative; overflow:hidden; isolation:isolate; padding:var(--space-24) var(--space-8) var(--space-16); }
      .dx-hero::before { content:''; position:absolute; inset:0; background:var(--gradient-hero); z-index:-3; }
      .dx-hero::after { content:''; position:absolute; inset:0; background-image:radial-gradient(circle at 20% 30%, rgba(6,120,190,0.04) 2px, transparent 2px), radial-gradient(circle at 60% 70%, rgba(102,126,234,0.04) 3px, transparent 3px), radial-gradient(circle at 80% 20%, rgba(236,72,153,0.03) 2px, transparent 2px); background-size:800px 800px; animation:particle-drift 60s linear infinite; opacity:0.6; z-index:-2; }
      .dx-hero-orb { position:absolute; border-radius:50%; filter:blur(100px); opacity:0.3; z-index:-1; pointer-events:none; }
      .dx-hero-orb-1 { width:600px; height:600px; top:-200px; right:-100px; animation:float-slow 20s ease-in-out infinite, orb-pulse 8s ease-in-out infinite; }
      .dx-hero-orb-2 { width:400px; height:400px; bottom:-100px; left:-80px; animation:float-slow 25s ease-in-out infinite reverse, orb-pulse 10s ease-in-out infinite; }
      .dx-hero-orb-3 { width:350px; height:350px; top:40%; left:15%; animation:float-drift 18s ease-in-out infinite, orb-pulse 7s ease-in-out infinite; }
      .dx-hero-grid { position:absolute; inset:0; z-index:-1; background-image:linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size:60px 60px; mask-image:radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 70%); -webkit-mask-image:radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 70%); }
      .dx-hero-content { text-align:center; max-width:900px; z-index:1; }
      .dx-hero-badge { display:inline-flex; align-items:center; gap:var(--space-3); padding:var(--space-2) var(--space-6); border-radius:var(--radius-full); background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); backdrop-filter:blur(20px); color:rgba(255,255,255,0.85); font-size:0.875rem; font-weight:500; letter-spacing:0.02em; margin-bottom:var(--space-10); animation:fadeInDown 0.8s cubic-bezier(0.22,1,0.36,1) backwards; }
      .dx-hero-badge-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
      .dx-hero-title { font-size:clamp(2.5rem,8vw,5rem); font-weight:900; line-height:1.15; margin-bottom:var(--space-6); letter-spacing:-0.04em; animation:fadeInUp 0.9s cubic-bezier(0.22,1,0.36,1) 0.1s backwards; }
      .dx-hero-subtitle { font-size:clamp(1.125rem,2.5vw,1.5rem); font-weight:300; margin-bottom:var(--space-8); animation:fadeInUp 0.9s cubic-bezier(0.22,1,0.36,1) 0.2s backwards; }
      .dx-hero-description { font-size:clamp(1rem,1.5vw,1.25rem); color:rgba(255,255,255,0.55); max-width:700px; margin:0 auto var(--space-12); line-height:1.75; animation:fadeInUp 0.9s cubic-bezier(0.22,1,0.36,1) 0.3s backwards; }
      .dx-hero-scroll { position:absolute; bottom:var(--space-10); left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:var(--space-2); color:rgba(255,255,255,0.3); font-size:0.6875rem; font-weight:500; letter-spacing:0.2em; text-transform:uppercase; animation:fadeIn 1s ease 1.5s backwards; }
      .dx-hero-scroll-line { width:1px; height:40px; background:linear-gradient(to bottom, rgba(255,255,255,0.3), transparent); position:relative; overflow:hidden; }
      .dx-hero-scroll-line::after { content:''; position:absolute; top:-100%; left:0; width:100%; height:100%; background:linear-gradient(to bottom, transparent, white, transparent); animation:scroll-fade 2s ease-in-out infinite; }

      /* Tab 1 hero: Cyan */
      .dx-hero-dx .dx-hero-title { background:linear-gradient(180deg, rgba(6,182,212,1) 0%, rgba(255,255,255,0.8) 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
      .dx-hero-dx .dx-hero-subtitle { background:linear-gradient(90deg, rgba(6,182,212,0.9), rgba(255,255,255,0.9)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
      .dx-hero-dx .dx-hero-badge-dot { background:var(--wc-cyan); animation:pulse-glow 2s ease infinite; box-shadow:0 0 8px var(--wc-cyan); }
      .dx-hero-dx .dx-hero-orb-1 { background:radial-gradient(circle, rgba(6,182,212,0.4), transparent 70%); }
      .dx-hero-dx .dx-hero-orb-2 { background:radial-gradient(circle, rgba(6,182,212,0.2), transparent 70%); }
      .dx-hero-dx .dx-hero-orb-3 { background:radial-gradient(circle, rgba(56,189,248,0.2), transparent 70%); }

      /* Tab 2 hero: Green/Emerald */
      .dx-hero-quality .dx-hero-title { background:linear-gradient(180deg, rgba(16,185,129,1) 0%, rgba(5,150,105,0.8) 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
      .dx-hero-quality .dx-hero-subtitle { background:linear-gradient(90deg, rgba(16,185,129,0.9), rgba(52,211,153,0.9)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
      .dx-hero-quality .dx-hero-badge-dot { background:var(--wc-green); box-shadow:0 0 8px var(--wc-green); animation:pulse-glow 2s ease infinite; }
      .dx-hero-quality .dx-hero-orb-1 { background:radial-gradient(circle, rgba(16,185,129,0.35), transparent 70%); }
      .dx-hero-quality .dx-hero-orb-2 { background:radial-gradient(circle, rgba(5,150,105,0.25), transparent 70%); }
      .dx-hero-quality .dx-hero-orb-3 { background:radial-gradient(circle, rgba(52,211,153,0.2), transparent 70%); }

      /* Tab 3 hero: Purple/Violet */
      .dx-hero-cicd .dx-hero-title { background:linear-gradient(180deg, rgba(139,92,246,1) 0%, rgba(99,102,241,0.8) 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
      .dx-hero-cicd .dx-hero-subtitle { background:linear-gradient(90deg, rgba(139,92,246,0.9), rgba(167,139,250,0.9)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
      .dx-hero-cicd .dx-hero-badge-dot { background:var(--wc-violet); box-shadow:0 0 8px var(--wc-violet); animation:pulse-glow 2s ease infinite; }
      .dx-hero-cicd .dx-hero-orb-1 { background:radial-gradient(circle, rgba(139,92,246,0.35), transparent 70%); }
      .dx-hero-cicd .dx-hero-orb-2 { background:radial-gradient(circle, rgba(99,102,241,0.25), transparent 70%); }
      .dx-hero-cicd .dx-hero-orb-3 { background:radial-gradient(circle, rgba(167,139,250,0.2), transparent 70%); }

      /* ==========================================
         SECTIONS (shared)
         ========================================== */
      .dx-section { position:relative; }
      .dx-section-inner { max-width:1200px; margin:0 auto; padding:var(--space-24) var(--space-8); }
      .dx-section-header { text-align:center; margin-bottom:var(--space-16); }
      .dx-section-label { display:inline-block; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; padding:var(--space-1) var(--space-4); border-radius:var(--radius-full); margin-bottom:var(--space-4); }
      .dx-section-label-cyan { background:rgba(6,182,212,0.08); color:var(--wc-cyan); border:1px solid rgba(6,182,212,0.15); }
      .dx-section-label-green { background:rgba(16,185,129,0.08); color:var(--wc-green); border:1px solid rgba(16,185,129,0.15); }
      .dx-section-label-violet { background:rgba(139,92,246,0.08); color:var(--wc-violet); border:1px solid rgba(139,92,246,0.15); }
      .dx-section-label-amber { background:rgba(245,158,11,0.08); color:var(--wc-amber); border:1px solid rgba(245,158,11,0.15); }
      .dx-section-title { font-size:clamp(2rem,5vw,3rem); margin-bottom:var(--space-4); }
      .dx-section-description { font-size:1.0625rem; color:var(--text-secondary); max-width:700px; margin:0 auto; line-height:1.8; }

      /* ==========================================
         CARDS
         ========================================== */
      .dx-card { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-xl); padding:var(--space-8) var(--space-6); transition:all 0.5s cubic-bezier(0.22,1,0.36,1); position:relative; overflow:hidden; }
      .dx-card::before { content:''; position:absolute; inset:0; border-radius:inherit; padding:1.5px; background:conic-gradient(from var(--gradient-angle), #667eea, #764ba2, #f093fb, #06b6d4, #667eea); -webkit-mask:linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); -webkit-mask-composite:xor; mask-composite:exclude; opacity:0; transition:opacity 0.5s ease; pointer-events:none; animation:border-rotate 4s linear infinite; }
      .dx-card:hover::before { opacity:1; }
      .dx-card:hover { transform:translateY(-6px); box-shadow:var(--shadow-xl), var(--glow-subtle); background:var(--surface-2); }
      .dx-card-icon { width:64px; height:64px; border-radius:var(--radius-xl); display:flex; align-items:center; justify-content:center; font-size:1.5rem; margin-bottom:var(--space-5); position:relative; z-index:1; }
      .dx-card-title { font-size:1.25rem; font-weight:700; margin-bottom:var(--space-3); color:var(--text-primary); position:relative; z-index:1; }
      .dx-card-desc { font-size:0.9375rem; color:var(--text-secondary); line-height:1.7; position:relative; z-index:1; }

      /* Color icon helpers */
      .icon-cyan { background:linear-gradient(135deg,rgba(6,182,212,0.15),rgba(6,182,212,0.05)); border:1px solid rgba(6,182,212,0.2); color:var(--wc-cyan); }
      .icon-green { background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(16,185,129,0.05)); border:1px solid rgba(16,185,129,0.2); color:var(--wc-green); }
      .icon-violet { background:linear-gradient(135deg,rgba(139,92,246,0.15),rgba(139,92,246,0.05)); border:1px solid rgba(139,92,246,0.2); color:var(--wc-violet); }
      .icon-amber { background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(245,158,11,0.05)); border:1px solid rgba(245,158,11,0.2); color:var(--wc-amber); }
      .icon-pink { background:linear-gradient(135deg,rgba(236,72,153,0.15),rgba(236,72,153,0.05)); border:1px solid rgba(236,72,153,0.2); color:var(--wc-pink); }
      .icon-electric { background:linear-gradient(135deg,rgba(59,130,246,0.15),rgba(59,130,246,0.05)); border:1px solid rgba(59,130,246,0.2); color:var(--wc-electric); }
      .icon-red { background:linear-gradient(135deg,rgba(239,68,68,0.15),rgba(239,68,68,0.05)); border:1px solid rgba(239,68,68,0.2); color:var(--wc-red); }

      /* ==========================================
         CODE BLOCKS
         ========================================== */
      .dx-code-block { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-lg); overflow:hidden; }
      .dx-code-titlebar { display:flex; align-items:center; gap:var(--space-3); padding:var(--space-3) var(--space-4); background:rgba(0,0,0,0.3); border-bottom:1px solid var(--surface-3); }
      .dx-code-dot { width:10px; height:10px; border-radius:50%; }
      .dx-code-dot:nth-child(1) { background:#ff5f57; }
      .dx-code-dot:nth-child(2) { background:#ffbd2e; }
      .dx-code-dot:nth-child(3) { background:#28c840; }
      .dx-code-filename { font-family:var(--font-mono); font-size:0.75rem; color:var(--text-muted); margin-left:var(--space-2); }
      .dx-code-body { padding:var(--space-4) var(--space-5); overflow-x:auto; }
      .dx-code-body pre { font-size:0.8125rem; line-height:1.7; color:#d6deeb; white-space:pre; margin:0; }

      /* Syntax highlighting */
      .dx-code-body .cmt { color:#637777; font-style:italic; }
      .dx-code-body .kw { color:#c792ea; }
      .dx-code-body .fn { color:#82aaff; }
      .dx-code-body .str { color:#ecc48d; }
      .dx-code-body .val { color:#addb67; }
      .dx-code-body .tag { color:#7fdbca; }
      .dx-code-body .attr { color:#addb67; }
      .dx-code-body .var { color:#d6deeb; }
      .dx-code-body .num { color:#f78c6c; }
      .dx-code-body .prop-hl { color:#ffcb6b; }

      /* ==========================================
         TAB 1: ONBOARDING TIMELINE
         ========================================== */
      .dx-timeline { position:relative; padding-left:3rem; }
      .dx-timeline::before { content:''; position:absolute; left:1rem; top:0; bottom:0; width:2px; background:linear-gradient(to bottom, var(--wc-cyan), var(--wc-green), var(--wc-violet)); border-radius:1px; }
      .dx-timeline-step { position:relative; padding-bottom:var(--space-10); }
      .dx-timeline-step:last-child { padding-bottom:0; }
      .dx-timeline-marker { position:absolute; left:-2.5rem; top:0; width:2.5rem; height:2.5rem; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:0.875rem; z-index:2; }
      .dx-timeline-marker-cyan { background:rgba(6,182,212,0.15); border:2px solid var(--wc-cyan); color:var(--wc-cyan); }
      .dx-timeline-marker-green { background:rgba(16,185,129,0.15); border:2px solid var(--wc-green); color:var(--wc-green); }
      .dx-timeline-marker-violet { background:rgba(139,92,246,0.15); border:2px solid var(--wc-violet); color:var(--wc-violet); }
      .dx-timeline-marker-amber { background:rgba(245,158,11,0.15); border:2px solid var(--wc-amber); color:var(--wc-amber); }
      .dx-timeline-marker-pink { background:rgba(236,72,153,0.15); border:2px solid var(--wc-pink); color:var(--wc-pink); }
      .dx-timeline-card { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-lg); padding:var(--space-5) var(--space-6); transition:all 0.3s ease; }
      .dx-timeline-card:hover { background:var(--surface-2); transform:translateX(4px); }
      .dx-timeline-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:var(--space-2); flex-wrap:wrap; gap:var(--space-2); }
      .dx-timeline-title { font-size:1.125rem; font-weight:700; color:var(--text-primary); display:flex; align-items:center; gap:var(--space-2); }
      .dx-timeline-title i { font-size:1rem; }
      .dx-timeline-time { font-family:var(--font-mono); font-size:0.75rem; font-weight:700; padding:var(--space-1) var(--space-3); border-radius:var(--radius-full); }
      .dx-timeline-time-cyan { background:rgba(6,182,212,0.1); color:var(--wc-cyan); border:1px solid rgba(6,182,212,0.2); }
      .dx-timeline-time-green { background:rgba(16,185,129,0.1); color:var(--wc-green); border:1px solid rgba(16,185,129,0.2); }
      .dx-timeline-time-violet { background:rgba(139,92,246,0.1); color:var(--wc-violet); border:1px solid rgba(139,92,246,0.2); }
      .dx-timeline-time-amber { background:rgba(245,158,11,0.1); color:var(--wc-amber); border:1px solid rgba(245,158,11,0.2); }
      .dx-timeline-time-pink { background:rgba(236,72,153,0.1); color:var(--wc-pink); border:1px solid rgba(236,72,153,0.2); }
      .dx-timeline-desc { font-size:0.9375rem; color:var(--text-secondary); line-height:1.6; }
      .dx-timeline-cmd { font-family:var(--font-mono); font-size:0.8125rem; color:var(--wc-cyan); background:rgba(6,182,212,0.06); padding:var(--space-2) var(--space-3); border-radius:var(--radius-sm); margin-top:var(--space-2); display:inline-block; border:1px solid rgba(6,182,212,0.12); }

      /* ==========================================
         TAB 1: MONOREPO TOPOLOGY
         ========================================== */
      .dx-topo-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-6); }
      .dx-topo-card { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-xl); padding:var(--space-6); text-align:center; transition:all 0.3s ease; }
      .dx-topo-card:hover { background:var(--surface-2); transform:translateY(-4px); border-color:var(--glass-border-strong); }
      .dx-topo-icon { width:56px; height:56px; border-radius:var(--radius-lg); display:flex; align-items:center; justify-content:center; font-size:1.25rem; margin:0 auto var(--space-4); }
      .dx-topo-name { font-family:var(--font-mono); font-size:0.875rem; font-weight:700; color:var(--text-primary); margin-bottom:var(--space-2); }
      .dx-topo-desc { font-size:0.875rem; color:var(--text-secondary); line-height:1.6; margin-bottom:var(--space-3); }
      .dx-topo-tags { display:flex; flex-wrap:wrap; justify-content:center; gap:var(--space-2); }
      .dx-topo-tag { font-family:var(--font-mono); font-size:0.6875rem; padding:var(--space-1) var(--space-2); border-radius:var(--radius-sm); background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.06); color:var(--text-muted); }
      .dx-turbo-banner { background:var(--surface-1); border:1px solid rgba(6,182,212,0.2); border-radius:var(--radius-xl); padding:var(--space-6); margin-top:var(--space-8); display:flex; align-items:center; gap:var(--space-6); }
      .dx-turbo-icon { width:72px; height:72px; border-radius:var(--radius-xl); display:flex; align-items:center; justify-content:center; font-size:2rem; flex-shrink:0; }
      .dx-turbo-content { flex:1; }
      .dx-turbo-title { font-size:1.125rem; font-weight:700; color:var(--text-primary); margin-bottom:var(--space-2); }
      .dx-turbo-desc { font-size:0.9375rem; color:var(--text-secondary); line-height:1.6; }

      /* ==========================================
         TAB 1: IDE MOCKUP
         ========================================== */
      .dx-ide { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-xl); overflow:hidden; max-width:700px; margin:0 auto; }
      .dx-ide-titlebar { display:flex; align-items:center; gap:var(--space-3); padding:var(--space-3) var(--space-4); background:rgba(0,0,0,0.4); border-bottom:1px solid var(--surface-3); }
      .dx-ide-body { position:relative; padding:var(--space-6); }
      .dx-ide-line { display:flex; align-items:center; gap:var(--space-2); font-family:var(--font-mono); font-size:0.8125rem; line-height:2; color:#d6deeb; }
      .dx-ide-line-num { color:var(--text-muted); width:2rem; text-align:right; flex-shrink:0; font-size:0.75rem; }
      .dx-ide-dropdown { position:absolute; top:4.5rem; left:8rem; background:var(--surface-2); border:1px solid var(--glass-border-strong); border-radius:var(--radius-md); padding:var(--space-2) 0; min-width:280px; box-shadow:var(--shadow-xl); z-index:5; }
      .dx-ide-suggestion { display:flex; align-items:center; gap:var(--space-3); padding:var(--space-2) var(--space-3); font-family:var(--font-mono); font-size:0.8125rem; color:var(--text-secondary); transition:background 0.15s ease; }
      .dx-ide-suggestion:first-child { background:rgba(6,182,212,0.1); color:var(--text-primary); }
      .dx-ide-suggestion-icon { width:20px; height:20px; border-radius:4px; display:flex; align-items:center; justify-content:center; font-size:0.625rem; font-weight:700; flex-shrink:0; }
      .dx-ide-suggestion-prop { color:var(--wc-cyan); }
      .dx-ide-suggestion-type { margin-left:auto; font-size:0.6875rem; color:var(--text-muted); }

      /* ==========================================
         TAB 1: DOC PIPELINE FLOW
         ========================================== */
      .dx-flow { display:flex; align-items:center; justify-content:center; gap:var(--space-4); flex-wrap:wrap; padding:var(--space-6) 0; }
      .dx-flow-source { display:flex; flex-direction:column; align-items:center; gap:var(--space-2); text-align:center; }
      .dx-flow-icon { width:72px; height:72px; border-radius:var(--radius-xl); display:flex; align-items:center; justify-content:center; font-size:1.75rem; transition:all 0.3s ease; }
      .dx-flow-icon:hover { transform:scale(1.1); }
      .dx-flow-label { font-size:0.875rem; font-weight:700; color:var(--text-primary); }
      .dx-flow-sub { font-size:0.75rem; color:var(--text-muted); }
      .dx-flow-arrow { font-size:1.25rem; color:var(--text-muted); }
      .dx-flow-outputs { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-4); margin-top:var(--space-8); }
      .dx-flow-output { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-lg); padding:var(--space-5); text-align:center; transition:all 0.3s ease; }
      .dx-flow-output:hover { background:var(--surface-2); transform:translateY(-4px); }
      .dx-flow-output-icon { font-size:1.5rem; margin-bottom:var(--space-3); }
      .dx-flow-output-title { font-size:0.9375rem; font-weight:700; color:var(--text-primary); margin-bottom:var(--space-1); }
      .dx-flow-output-desc { font-size:0.8125rem; color:var(--text-muted); line-height:1.5; }

      /* ==========================================
         TAB 2: TESTING PYRAMID
         ========================================== */
      .dx-pyramid { display:flex; flex-direction:column; align-items:center; gap:var(--space-4); }
      .dx-pyramid-level { border-radius:var(--radius-xl); padding:var(--space-5) var(--space-6); transition:all 0.4s ease; cursor:default; display:flex; align-items:center; gap:var(--space-5); }
      .dx-pyramid-level:hover { transform:scale(1.03); }
      .dx-pyramid-level-4 { width:45%; background:var(--surface-1); border:1px solid rgba(139,92,246,0.25); }
      .dx-pyramid-level-4:hover { border-color:rgba(139,92,246,0.5); box-shadow:0 0 30px rgba(139,92,246,0.1); }
      .dx-pyramid-level-3 { width:60%; background:var(--surface-1); border:1px solid rgba(236,72,153,0.25); }
      .dx-pyramid-level-3:hover { border-color:rgba(236,72,153,0.5); box-shadow:0 0 30px rgba(236,72,153,0.1); }
      .dx-pyramid-level-2 { width:75%; background:var(--surface-1); border:1px solid rgba(245,158,11,0.25); }
      .dx-pyramid-level-2:hover { border-color:rgba(245,158,11,0.5); box-shadow:0 0 30px rgba(245,158,11,0.1); }
      .dx-pyramid-level-1 { width:90%; background:var(--surface-1); border:1px solid rgba(16,185,129,0.25); }
      .dx-pyramid-level-1:hover { border-color:rgba(16,185,129,0.5); box-shadow:0 0 30px rgba(16,185,129,0.1); }
      .dx-pyramid-icon { width:48px; height:48px; border-radius:var(--radius-lg); display:flex; align-items:center; justify-content:center; font-size:1.25rem; flex-shrink:0; }
      .dx-pyramid-info { flex:1; }
      .dx-pyramid-label { font-size:0.8125rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:var(--space-1); }
      .dx-pyramid-name { font-size:1.125rem; font-weight:700; color:var(--text-primary); margin-bottom:var(--space-1); }
      .dx-pyramid-tool { font-family:var(--font-mono); font-size:0.75rem; padding:var(--space-1) var(--space-3); border-radius:var(--radius-full); background:rgba(255,255,255,0.04); color:var(--text-muted); display:inline-block; margin-bottom:var(--space-2); }
      .dx-pyramid-desc { font-size:0.875rem; color:var(--text-secondary); line-height:1.6; }

      /* ==========================================
         TAB 2: SHIFT-LEFT COMPARISON
         ========================================== */
      .dx-shift-grid { display:grid; grid-template-columns:1fr 1fr; gap:var(--space-6); }
      .dx-shift-card { background:var(--surface-1); border-radius:var(--radius-xl); padding:var(--space-6); overflow:hidden; }
      .dx-shift-card-bad { border:1px solid rgba(239,68,68,0.2); }
      .dx-shift-card-good { border:1px solid rgba(16,185,129,0.2); }
      .dx-shift-header { display:flex; align-items:center; gap:var(--space-3); margin-bottom:var(--space-6); }
      .dx-shift-icon { width:40px; height:40px; border-radius:var(--radius-md); display:flex; align-items:center; justify-content:center; font-size:1rem; }
      .dx-shift-title { font-size:1.125rem; font-weight:700; }
      .dx-shift-bar-row { display:flex; align-items:center; gap:var(--space-3); margin-bottom:var(--space-4); }
      .dx-shift-bar-label { font-size:0.8125rem; color:var(--text-secondary); min-width:80px; }
      .dx-shift-bar-track { flex:1; height:8px; background:rgba(255,255,255,0.04); border-radius:4px; overflow:hidden; }
      .dx-shift-bar-fill { height:100%; border-radius:4px; transition:width 1s cubic-bezier(0.22,1,0.36,1); width:var(--bar-width); }
      .dx-shift-bar-fill-red { background:linear-gradient(90deg, var(--wc-red), var(--wc-pink)); }
      .dx-shift-bar-fill-green { background:linear-gradient(90deg, var(--wc-green), var(--wc-cyan)); }
      .dx-shift-bar-value { font-family:var(--font-mono); font-size:0.75rem; color:var(--text-muted); min-width:36px; text-align:right; }

      /* ==========================================
         TAB 2: COVERAGE DASHBOARD
         ========================================== */
      .dx-coverage-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:var(--space-6); }
      .dx-coverage-card { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-xl); padding:var(--space-6); text-align:center; transition:all 0.3s ease; }
      .dx-coverage-card:hover { background:var(--surface-2); transform:translateY(-4px); }
      .dx-coverage-ring { width:100px; height:100px; border-radius:50%; margin:0 auto var(--space-4); position:relative; display:flex; align-items:center; justify-content:center; }
      .dx-coverage-ring::before { content:''; position:absolute; inset:0; border-radius:50%; }
      .dx-coverage-value { font-size:1.5rem; font-weight:800; letter-spacing:-0.03em; position:relative; z-index:1; }
      .dx-coverage-label { font-size:0.9375rem; font-weight:700; color:var(--text-primary); margin-bottom:var(--space-1); }
      .dx-coverage-desc { font-size:0.8125rem; color:var(--text-muted); line-height:1.5; }

      /* ==========================================
         TAB 3: PIPELINE FLOW
         ========================================== */
      .dx-pipeline { display:flex; align-items:stretch; gap:0; overflow-x:auto; padding:var(--space-4) 0; }
      .dx-pipeline-step { flex:1; min-width:120px; display:flex; flex-direction:column; align-items:center; gap:var(--space-3); text-align:center; position:relative; padding:var(--space-4); }
      .dx-pipeline-step::after { content:''; position:absolute; right:-1px; top:50%; width:24px; height:2px; background:linear-gradient(90deg, var(--wc-violet), rgba(139,92,246,0.3)); transform:translateY(-50%); }
      .dx-pipeline-step:last-child::after { display:none; }
      .dx-pipeline-step-icon { width:56px; height:56px; border-radius:var(--radius-lg); display:flex; align-items:center; justify-content:center; font-size:1.25rem; transition:all 0.3s ease; }
      .dx-pipeline-step-icon:hover { transform:scale(1.1); }
      .dx-pipeline-step-label { font-size:0.8125rem; font-weight:700; color:var(--text-primary); }
      .dx-pipeline-step-time { font-family:var(--font-mono); font-size:0.6875rem; color:var(--text-muted); }

      /* ==========================================
         TAB 3: BUILD COMPARISON
         ========================================== */
      .dx-build-grid { display:grid; grid-template-columns:1fr 1fr; gap:var(--space-6); }
      .dx-build-card { background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-xl); padding:var(--space-8) var(--space-6); text-align:center; transition:all 0.3s ease; }
      .dx-build-card:hover { background:var(--surface-2); }
      .dx-build-value { font-size:3rem; font-weight:900; letter-spacing:-0.04em; margin-bottom:var(--space-2); }
      .dx-build-label { font-size:1rem; font-weight:700; color:var(--text-primary); margin-bottom:var(--space-3); }
      .dx-build-bar { height:12px; border-radius:6px; background:rgba(255,255,255,0.04); overflow:hidden; margin-bottom:var(--space-3); }
      .dx-build-bar-fill { height:100%; border-radius:6px; transition:width 1.5s cubic-bezier(0.22,1,0.36,1); width:var(--bar-width); }
      .dx-build-desc { font-size:0.875rem; color:var(--text-muted); line-height:1.6; }

      /* ==========================================
         TAB 3: DISTRIBUTION / RELEASE
         ========================================== */
      .dx-dist-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--space-6); }
      .dx-release-flow { display:flex; flex-direction:column; gap:var(--space-4); max-width:600px; margin:0 auto; }
      .dx-release-step { display:flex; align-items:center; gap:var(--space-4); background:var(--surface-1); border:1px solid var(--surface-3); border-radius:var(--radius-lg); padding:var(--space-4) var(--space-5); transition:all 0.3s ease; }
      .dx-release-step:hover { background:var(--surface-2); transform:translateX(4px); }
      .dx-release-num { width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.875rem; font-weight:800; flex-shrink:0; }
      .dx-release-info { flex:1; }
      .dx-release-name { font-size:0.9375rem; font-weight:700; color:var(--text-primary); }
      .dx-release-desc { font-size:0.8125rem; color:var(--text-muted); }

      /* ==========================================
         FOOTER CTA
         ========================================== */
      .dx-footer-cta { text-align:center; padding:var(--space-24) var(--space-8); background:var(--surface-0); border-top:1px solid var(--surface-3); }
      .dx-footer-cta-inner { max-width:700px; margin:0 auto; }
      .dx-footer-cta h2 { font-size:clamp(1.75rem,4vw,2.5rem); font-weight:800; letter-spacing:-0.03em; margin-bottom:var(--space-4); color:var(--text-primary); }
      .dx-footer-cta p { font-size:1.0625rem; color:var(--text-secondary); margin-bottom:var(--space-8); line-height:1.7; }
      .dx-footer-cta-buttons { display:flex; gap:var(--space-4); justify-content:center; flex-wrap:wrap; }

      /* Buttons */
      .dx-btn { display:inline-flex; align-items:center; gap:var(--space-2); padding:var(--space-4) var(--space-8); font-size:1rem; font-weight:600; text-decoration:none; border-radius:var(--radius-lg); transition:all 0.3s cubic-bezier(0.22,1,0.36,1); cursor:pointer; border:none; white-space:nowrap; min-height:48px; line-height:1; }
      .dx-btn-solid { background:var(--gradient-primary); color:white; box-shadow:var(--shadow-md); }
      .dx-btn-solid:hover { transform:translateY(-3px); box-shadow:var(--shadow-xl), var(--glow-primary); color:white; }
      .dx-btn-ghost { background:transparent; color:var(--text-secondary); border:1.5px solid var(--surface-3); }
      .dx-btn-ghost:hover { background:var(--glass-bg-strong); border-color:var(--glass-border-strong); color:var(--text-primary); transform:translateY(-2px); }
      .dx-btn-arrow { transition:transform 0.3s ease; display:inline-block; }
      .dx-btn:hover .dx-btn-arrow { transform:translateX(4px); }

      /* ==========================================
         RESPONSIVE
         ========================================== */
      @media (max-width:1100px) {
        .dx-topo-grid { grid-template-columns:1fr; }
        .dx-flow-outputs { grid-template-columns:1fr; }
        .dx-shift-grid { grid-template-columns:1fr; }
        .dx-coverage-grid { grid-template-columns:repeat(2,1fr); }
        .dx-build-grid { grid-template-columns:1fr; }
        .dx-dist-grid { grid-template-columns:1fr; }
        .dx-pyramid-level-1, .dx-pyramid-level-2, .dx-pyramid-level-3, .dx-pyramid-level-4 { width:100%; }
      }

      @media (max-width:768px) {
        .dx-topbar { padding:var(--space-3) var(--space-4); }
        .dx-topbar-title { display:none; }
        .dx-hero { min-height:auto; padding:calc(var(--space-24) + var(--space-8)) var(--space-4) var(--space-16); }
        .dx-hero-scroll { display:none; }
        .dx-section-inner { padding:var(--space-16) var(--space-4); }
