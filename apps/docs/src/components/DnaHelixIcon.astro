---
/**
 * DnaHelixIcon.astro - Compact 1:1 DNA Helix for Navbar / Icon Usage
 *
 * A miniaturized, square version of the DnaHelixLogo. Designed to sit
 * beside the "HELiX" wordmark in the navbar at 24-28px.
 *
 * Key differences from DnaHelixLogo:
 *   - 1:1 aspect ratio (square) with border-radius for icon/avatar feel
 *   - Fewer nucleotide pairs (10) for clarity at small sizes
 *   - No glow, no shimmer — minimal and crisp
 *   - Continuous rotation only, no hover effects
 *   - Dark background for navbar contrast
 *   - Overflow clipped to contain the helix within the square
 *
 * Performance:
 *   - GPU-accelerated: only `transform` animated
 *   - No JavaScript animation dependencies
 *   - Respects `prefers-reduced-motion: reduce`
 *   - Uses `will-change: transform` on the rotating container only
 */

interface Props {
  /** CSS size value for the icon. Default: "28px" */
  size?: string;
  /** Additional CSS class names */
  class?: string;
}

const {
  size,
  class: className = '',
} = Astro.props;

const sizeStyle = size ? `--icon-size: ${size};` : '';

// 10 nucleotide pairs — enough to convey the helix at icon scale.
// Each pair is rotated 36deg apart (360/10) for one full helical turn.
const pairCount = 10;
const pairs = Array.from({ length: pairCount }, (_, i) => ({
  index: i,
  rotationDeg: i * 36,
  topPercent: (i / (pairCount - 1)) * 100,
}));
---

<div
  class:list={['dna-helix-icon', className]}
  style={sizeStyle}
  role="presentation"
  aria-hidden="true"
>
  <div class="icon-scene">
    <div class="icon-rotator">
      {pairs.map((pair) => (
        <div
          class="icon-pair"
          style={`--pair-index: ${pair.index}; --pair-rotation: ${pair.rotationDeg}deg; --pair-top: ${pair.topPercent}%;`}
        >
          <div class="icon-node icon-node-left"></div>
          <div class="icon-rung"></div>
          <div class="icon-node icon-node-right"></div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  /* ==========================================================
     DNA HELIX ICON - COMPACT 1:1 SQUARE VERSION
     ========================================================== */
  .dna-helix-icon {
    --icon-size: 39px;

    /* Brand gradient stops */
    --dna-color-cyan: #06b6d4;
    --dna-color-purple: #8b5cf6;
    --dna-color-pink: #ec4899;

    /* Timing */
    --icon-spin-duration: 4.5s;

    /* Node sizing — slightly larger proportionally for icon scale */
    --icon-node-size: calc(var(--icon-size) * 0.12);
    --icon-rung-height: calc(var(--icon-size) * 0.04);

    /* Helix radius: how far nodes extend from center in 3D */
    --icon-radius: calc(var(--icon-size) * 0.34);

    position: relative;
    width: var(--icon-size);
    height: var(--icon-size);
    flex-shrink: 0;
    border-radius: 25%;
    overflow: hidden;
    background: rgba(10, 10, 26, 0.6);
    isolation: isolate;
  }

  /* ==========================================================
     3D SCENE - PERSPECTIVE CONTAINER
     Perspective scaled for small container. Overflow hidden
     so the helix is clipped inside the rounded square.
     ========================================================== */
  .icon-scene {
    position: absolute;
    inset: 0;
    perspective: calc(var(--icon-size) * 3);
    perspective-origin: 50% 50%;
    overflow: hidden;
    border-radius: inherit;
  }

  /* ==========================================================
     ROTATOR - CONTINUOUS Y-AXIS SPIN
     Single animated element. 4.5s per rotation.
     ========================================================== */
  .icon-rotator {
    position: absolute;
    /* Extend beyond the square so the helix fills the viewport.
       The 1:1 container only shows the "middle slice". */
    top: -40%;
    bottom: -40%;
    left: 0;
    right: 0;
    transform-style: preserve-3d;
    animation: icon-spin var(--icon-spin-duration) linear infinite;
    will-change: transform;
  }

  @keyframes icon-spin {
    from { transform: rotateY(0deg); }
    to   { transform: rotateY(360deg); }
  }

  /* ==========================================================
     NUCLEOTIDE PAIR
     Positioned vertically within the rotator, rotated around
     Y-axis by its helix angle. The extended rotator height
     means pairs at 0% and 100% are outside the visible square,
     giving the effect of a "cropped middle section".
     ========================================================== */
  .icon-pair {
    position: absolute;
    top: var(--pair-top);
    left: 50%;
    width: 0;
    height: 0;
    transform-style: preserve-3d;
    transform: rotateY(var(--pair-rotation));
  }

  /* ==========================================================
     BACKBONE NODES
     Simplified for icon scale: no box-shadow glow, just
     solid colored circles with the brand gradient.
     ========================================================== */
  .icon-node {
    position: absolute;
    width: var(--icon-node-size);
    height: var(--icon-node-size);
    border-radius: 50%;
    top: calc(var(--icon-node-size) / -2);
    background: var(--dna-color-cyan);
  }

  .icon-node-left {
    left: calc(var(--icon-node-size) / -2);
    transform: translateZ(var(--icon-radius));
  }

  .icon-node-right {
    left: calc(var(--icon-node-size) / -2);
    transform: translateZ(calc(var(--icon-radius) * -1));
  }

  /* Gradient coloring by position (10 pairs, 0-indexed via nth-child)
     Top third (1-3): cyan / pink
     Middle third (4-7): purple / cyan
     Bottom third (8-10): pink / purple */

  /* Top third */
  .icon-pair:nth-child(-n+3) .icon-node-left {
    background: var(--dna-color-cyan);
  }
  .icon-pair:nth-child(-n+3) .icon-node-right {
    background: var(--dna-color-pink);
  }

  /* Middle third */
  .icon-pair:nth-child(n+4):nth-child(-n+7) .icon-node-left {
    background: var(--dna-color-purple);
  }
  .icon-pair:nth-child(n+4):nth-child(-n+7) .icon-node-right {
    background: var(--dna-color-cyan);
  }

  /* Bottom third */
  .icon-pair:nth-child(n+8) .icon-node-left {
    background: var(--dna-color-pink);
  }
  .icon-pair:nth-child(n+8) .icon-node-right {
    background: var(--dna-color-purple);
  }

  /* Smooth gradient transitions at zone boundaries */
  .icon-pair:nth-child(3) .icon-node-left {
    background: linear-gradient(180deg, var(--dna-color-cyan), var(--dna-color-purple));
  }
  .icon-pair:nth-child(3) .icon-node-right {
    background: linear-gradient(180deg, var(--dna-color-pink), var(--dna-color-cyan));
  }
  .icon-pair:nth-child(7) .icon-node-left {
    background: linear-gradient(180deg, var(--dna-color-purple), var(--dna-color-pink));
  }
  .icon-pair:nth-child(7) .icon-node-right {
    background: linear-gradient(180deg, var(--dna-color-cyan), var(--dna-color-purple));
  }

  /* ==========================================================
     CONNECTING RUNGS
     Thin bars stretching between backbone nodes in Z-space.
     Kept subtle at icon scale.
     ========================================================== */
  .icon-rung {
    position: absolute;
    top: calc(var(--icon-rung-height) / -2);
    left: 0;
    width: 0;
    height: var(--icon-rung-height);
    transform-style: preserve-3d;
  }

  .icon-rung::before {
    content: '';
    position: absolute;
    width: calc(var(--icon-radius) * 2);
    height: 100%;
    left: calc(var(--icon-radius) * -1);
    top: 0;
    background: linear-gradient(
      90deg,
      var(--dna-color-pink) 0%,
      rgba(139, 92, 246, 0.25) 50%,
      var(--dna-color-cyan) 100%
    );
    border-radius: calc(var(--icon-rung-height) / 2);
    opacity: 0.3;
  }

  .icon-pair:nth-child(odd) .icon-rung::before {
    opacity: 0.25;
  }
  .icon-pair:nth-child(even) .icon-rung::before {
    opacity: 0.18;
  }

  /* ==========================================================
     EDGE FADING
     Subtle fade at top/bottom edges so the helix appears to
     extend beyond the visible square.
     ========================================================== */
  .icon-scene::before,
  .icon-scene::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 18%;
    z-index: 10;
    pointer-events: none;
  }

  .icon-scene::before {
    top: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 26, 0.7) 0%,
      transparent 100%
    );
  }

  .icon-scene::after {
    bottom: 0;
    background: linear-gradient(
      0deg,
      rgba(10, 10, 26, 0.7) 0%,
      transparent 100%
    );
  }

  /* ==========================================================
     PREFERS-REDUCED-MOTION
     Required for accessibility compliance.
     Show a static, slightly rotated helix.
     ========================================================== */
  @media (prefers-reduced-motion: reduce) {
    .icon-rotator {
      animation: none;
      transform: rotateY(-20deg);
    }
  }
</style>
