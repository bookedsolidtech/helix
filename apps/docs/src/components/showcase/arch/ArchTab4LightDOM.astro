---
/**
 * ArchTab4LightDOM — Tab 4 of the System Architecture page.
 *
 * Contains the "Light DOM Architecture" Decision Record:
 * - Hero section — "Rendering Without Walls"
 * - The Spectrum — Shadow DOM vs Light DOM decision
 * - The Controller — AdoptedStylesheetsController flow
 * - CMS Content — The WYSIWYG problem and hx-prose
 * - Drupal Forms — hx-form dual-mode pattern
 * - System Architecture — full diagram
 * - Recommendation — decision matrix
 */
import {
  codeAdoptedController,
  codeLightDomPattern,
  codeDrupalWysiwyg,
  codeProseWrapper,
  codeFormStandalone,
  codeFormDrupal,
  codeFormInternals,
  codeScopedCss,
} from './ArchCodeExamples';
---

<div id="tab-lightdom" class="da-tab-content" role="tabpanel">
  <!-- HERO -->
  <section class="da-hero da-hero-lightdom" aria-label="Light DOM Architecture Decision">
    <div class="da-hero-grid" aria-hidden="true"></div>
    <div class="da-hero-orb da-hero-orb-1" aria-hidden="true"></div>
    <div class="da-hero-orb da-hero-orb-2" aria-hidden="true"></div>
    <div class="da-hero-orb da-hero-orb-3" aria-hidden="true"></div>

    <div class="da-hero-content">
      <div class="da-hero-badge">
        <span class="da-hero-badge-dot" aria-hidden="true"></span>
        Architecture Decision Record
      </div>

      <h1 class="da-hero-title">Rendering<br />Without Walls</h1>

      <p class="da-hero-subtitle">When Shadow DOM Gets in the Way</p>

      <p class="da-hero-description">
        Shadow DOM is the default for encapsulated UI controls &mdash; buttons, inputs, cards.
        But when content editors control the markup, when Drupal's Form API owns the
        <code>&lt;form&gt;</code> tag, or when CKEditor outputs unpredictable HTML,
        the shadow boundary becomes a <strong>barrier</strong>, not a benefit.
        Light DOM components solve this.
      </p>
    </div>

    <div class="mouse-scroll-wrap mouse-scroll-wrap--absolute" aria-hidden="true">
      <div class="mouse-scroll-body"><div class="mouse-scroll-wheel"></div></div>
      <span class="mouse-scroll-label">Scroll</span>
    </div>
  </section>

  <!-- SECTION 2: THE SPECTRUM -->
  <section class="da-section" aria-label="Shadow DOM vs Light DOM spectrum">
    <div class="da-section-inner">
      <div class="da-section-header scroll-reveal">
        <span class="da-section-label">The Spectrum</span>
        <h2 class="da-section-title">When to Break the Boundary</h2>
        <p class="da-section-description">
          Not every component benefits from Shadow DOM encapsulation. The rendering
          strategy depends on who controls the content inside the component.
        </p>
      </div>

      <div class="da-lightdom-spectrum scroll-reveal scroll-reveal-delay-1">
        <!-- Shadow DOM card -->
        <div class="da-lightdom-choice da-lightdom-choice-shadow">
          <div class="da-lightdom-choice-icon" aria-hidden="true">
            <i class="fa-solid fa-shield-halved"></i>
          </div>
          <h3 class="da-lightdom-choice-title">Shadow DOM</h3>
          <p class="da-lightdom-choice-subtitle">Encapsulated UI Controls</p>
          <p class="da-lightdom-choice-desc">
            The component owns all rendering. Styles are encapsulated.
            External CSS cannot leak in or out. Ideal for <strong>interactive
            controls</strong> with predictable internal markup.
          </p>
          <div class="da-lightdom-choice-tags">
            <span class="da-lightdom-tag da-lightdom-tag-cyan">hx-button</span>
            <span class="da-lightdom-tag da-lightdom-tag-cyan">hx-text-input</span>
            <span class="da-lightdom-tag da-lightdom-tag-cyan">hx-card</span>
            <span class="da-lightdom-tag da-lightdom-tag-cyan">hx-badge</span>
            <span class="da-lightdom-tag da-lightdom-tag-cyan">hx-alert</span>
            <span class="da-lightdom-tag da-lightdom-tag-cyan">hx-select</span>
            <span class="da-lightdom-tag da-lightdom-tag-cyan">hx-checkbox</span>
            <span class="da-lightdom-tag da-lightdom-tag-cyan">hx-switch</span>
          </div>
          <div class="da-lightdom-choice-when">
            <strong>Use when:</strong>
            <ul>
              <li>Component controls all internal markup</li>
              <li>Style isolation is required</li>
              <li>Interactive behavior is self-contained</li>
              <li>Slots project content without styling it</li>
            </ul>
          </div>
        </div>

        <!-- Light DOM card -->
        <div class="da-lightdom-choice da-lightdom-choice-light">
          <div class="da-lightdom-choice-icon" aria-hidden="true">
            <i class="fa-solid fa-lightbulb"></i>
          </div>
          <h3 class="da-lightdom-choice-title">Light DOM</h3>
          <p class="da-lightdom-choice-subtitle">CMS Content Containers</p>
          <p class="da-lightdom-choice-desc">
            The CMS or content editor owns the markup. The component provides
            <strong>styling and behavior</strong> without creating a shadow boundary.
            CSS must reach deeply nested children.
          </p>
          <div class="da-lightdom-choice-tags">
            <span class="da-lightdom-tag da-lightdom-tag-amber">hx-prose</span>
            <span class="da-lightdom-tag da-lightdom-tag-amber">hx-form</span>
            <span class="da-lightdom-tag da-lightdom-tag-amber">hx-container</span>
          </div>
          <div class="da-lightdom-choice-when">
            <strong>Use when:</strong>
            <ul>
              <li>CMS editors control the child markup</li>
              <li>Drupal Form API provides the <code>&lt;form&gt;</code></li>
              <li>WYSIWYG output must be styled directly</li>
              <li>SEO requires content in the main DOM</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: THE CONTROLLER -->
  <section class="da-section" style="border-top: 1px solid var(--surface-3);" aria-label="AdoptedStylesheetsController">
    <div class="da-section-inner">
      <div class="da-section-header scroll-reveal">
        <span class="da-section-label">The Controller</span>
        <h2 class="da-section-title">Scoped CSS Without Shadow DOM</h2>
        <p class="da-section-description">
          The <code style="background: rgba(255,255,255,0.08); padding: 0.15em 0.5em; border-radius: 4px; font-family: var(--font-mono);">AdoptedStylesheetsController</code>
          injects CSS into the document via the Adopted Stylesheets API,
          with automatic deduplication and cleanup.
        </p>
      </div>

      <!-- 4-step flow diagram -->
      <div class="da-adopted-flow scroll-reveal scroll-reveal-delay-1">
        <div class="da-adopted-step">
          <div class="da-adopted-step-num" aria-hidden="true">1</div>
          <div class="da-adopted-step-icon" aria-hidden="true"><i class="fa-solid fa-file-import"></i></div>
          <h4 class="da-adopted-step-title">CSS Imported</h4>
          <p class="da-adopted-step-desc">Scoped CSS string imported from <code>.styles.ts</code> barrel file</p>
        </div>
        <div class="da-adopted-arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></div>
        <div class="da-adopted-step">
          <div class="da-adopted-step-num" aria-hidden="true">2</div>
          <div class="da-adopted-step-icon" aria-hidden="true"><i class="fa-solid fa-gear"></i></div>
          <h4 class="da-adopted-step-title">Controller Init</h4>
          <p class="da-adopted-step-desc">Controller created with host, cssText, and target root</p>
        </div>
        <div class="da-adopted-arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></div>
        <div class="da-adopted-step">
          <div class="da-adopted-step-num" aria-hidden="true">3</div>
          <div class="da-adopted-step-icon" aria-hidden="true"><i class="fa-solid fa-layer-group"></i></div>
          <h4 class="da-adopted-step-title">Deduplicated</h4>
          <p class="da-adopted-step-desc">Global cache ensures one <code>CSSStyleSheet</code> per unique CSS string</p>
        </div>
        <div class="da-adopted-arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></div>
        <div class="da-adopted-step">
          <div class="da-adopted-step-num" aria-hidden="true">4</div>
          <div class="da-adopted-step-icon" aria-hidden="true"><i class="fa-solid fa-syringe"></i></div>
          <h4 class="da-adopted-step-title">Injected</h4>
          <p class="da-adopted-step-desc">Added to <code>document.adoptedStyleSheets</code>, removed on disconnect</p>
        </div>
      </div>

      <!-- Code blocks: controller usage + light dom pattern -->
      <div class="da-adopted-code-grid scroll-reveal scroll-reveal-delay-2">
        <div>
          <span class="da-code-label da-code-label-twig">Controller Usage</span>
          <div class="da-code-block">
            <div class="da-code-titlebar">
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-filename">hx-prose.ts</span>
            </div>
            <div class="da-code-body"><pre set:html={codeAdoptedController} /></div>
          </div>
        </div>
        <div>
          <span class="da-code-label da-code-label-html">Render Pattern</span>
          <div class="da-code-block">
            <div class="da-code-titlebar">
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-filename">light-dom-pattern.ts</span>
            </div>
            <div class="da-code-body"><pre set:html={codeLightDomPattern} /></div>
          </div>
        </div>
      </div>

      <!-- Three benefit callouts -->
      <div class="da-adopted-benefits scroll-reveal scroll-reveal-delay-3">
        <div class="da-adopted-benefit">
          <i class="fa-solid fa-clone" aria-hidden="true"></i>
          <div>
            <strong>No Duplication</strong>
            <p>Global cache keyed by CSS text &mdash; 100 instances of <code>hx-prose</code> create only one <code>CSSStyleSheet</code>.</p>
          </div>
        </div>
        <div class="da-adopted-benefit">
          <i class="fa-solid fa-crosshairs" aria-hidden="true"></i>
          <div>
            <strong>Scoped Selectors</strong>
            <p>All rules are tag-qualified: <code>hx-prose h2</code>, <code>hx-form label</code>. No risk of global style leaks.</p>
          </div>
        </div>
        <div class="da-adopted-benefit">
          <i class="fa-solid fa-broom" aria-hidden="true"></i>
          <div>
            <strong>Auto Cleanup</strong>
            <p>Stylesheet is removed from <code>adoptedStyleSheets</code> when the last instance disconnects.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: CMS CONTENT -->
  <section class="da-section" style="border-top: 1px solid var(--surface-3);" aria-label="CMS content and WYSIWYG">
    <div class="da-section-inner">
      <div class="da-section-header scroll-reveal">
        <span class="da-section-label">CMS Content</span>
        <h2 class="da-section-title">When the Editor Owns the Markup</h2>
        <p class="da-section-description">
          CKEditor, the WYSIWYG at the heart of Drupal, outputs unpredictable HTML.
          Field wrappers, media embeds, tables, blockquotes &mdash; all generated at
          authoring time. Shadow DOM cannot style any of it.
        </p>
      </div>

      <!-- The WYSIWYG problem explanation -->
      <div class="da-prose-problem scroll-reveal scroll-reveal-delay-1">
        <div class="da-prose-problem-icon" aria-hidden="true">
          <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <div>
          <h3 class="da-prose-problem-title">The WYSIWYG Problem</h3>
          <p class="da-prose-problem-text">
            Content editors paste from Word, embed media, create tables, and format text
            using CKEditor's toolbar. The resulting HTML is <strong>structurally unpredictable</strong>.
            You cannot slot it. You cannot wrap each element in a shadow-aware template.
            You must style it <strong>as-is, wherever it appears</strong>.
          </p>
        </div>
      </div>

      <!-- Raw vs Wrapped code blocks -->
      <div class="da-prose-code-grid scroll-reveal scroll-reveal-delay-2">
        <div>
          <span class="da-code-label" style="background: rgba(239, 68, 68, 0.12); color: var(--wc-red); border: 1px solid rgba(239, 68, 68, 0.2);">Raw Drupal Output</span>
          <div class="da-code-block">
            <div class="da-code-titlebar">
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-filename">node--article.html.twig</span>
            </div>
            <div class="da-code-body"><pre set:html={codeDrupalWysiwyg} /></div>
          </div>
        </div>
        <div>
          <span class="da-code-label da-code-label-twig">Wrapped in hx-prose</span>
          <div class="da-code-block">
            <div class="da-code-titlebar">
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-filename">node--article.html.twig</span>
            </div>
            <div class="da-code-body"><pre set:html={codeProseWrapper} /></div>
          </div>
        </div>
      </div>

      <!-- Architecture diagram: CSS partials flow -->
      <div class="da-prose-arch scroll-reveal scroll-reveal-delay-3">
        <h3 class="da-prose-arch-title">
          <i class="fa-solid fa-sitemap" aria-hidden="true"></i>
          CSS Architecture
        </h3>
        <div class="da-prose-arch-flow">
          <div class="da-prose-arch-col">
            <div class="da-prose-arch-label">CSS Partials</div>
            <div class="da-prose-arch-items">
              <span>typography.css</span>
              <span>tables.css</span>
              <span>media.css</span>
              <span>blockquotes.css</span>
              <span>lists.css</span>
              <span>code.css</span>
              <span>links.css</span>
            </div>
          </div>
          <div class="da-prose-arch-arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></div>
          <div class="da-prose-arch-col">
            <div class="da-prose-arch-label">Scoped Barrel</div>
            <div class="da-prose-arch-items">
              <span>prose.scoped.css</span>
            </div>
          </div>
          <div class="da-prose-arch-arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></div>
          <div class="da-prose-arch-col">
            <div class="da-prose-arch-label">Controller</div>
            <div class="da-prose-arch-items">
              <span>AdoptedStylesheets</span>
            </div>
          </div>
          <div class="da-prose-arch-arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></div>
          <div class="da-prose-arch-col">
            <div class="da-prose-arch-label">Document</div>
            <div class="da-prose-arch-items">
              <span>adoptedStyleSheets</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Scoped CSS example -->
      <div class="scroll-reveal scroll-reveal-delay-4" style="max-width: 700px; margin: 0 auto;">
        <span class="da-code-label da-code-label-html">Scoped Selectors</span>
        <div class="da-code-block">
          <div class="da-code-titlebar">
            <span class="da-code-dot"></span>
            <span class="da-code-dot"></span>
            <span class="da-code-dot"></span>
            <span class="da-code-filename">prose.scoped.css</span>
          </div>
          <div class="da-code-body"><pre set:html={codeScopedCss} /></div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 5: DRUPAL FORMS -->
  <section class="da-section" style="border-top: 1px solid var(--surface-3);" aria-label="Drupal Form API integration">
    <div class="da-section-inner">
      <div class="da-section-header scroll-reveal">
        <span class="da-section-label">Drupal Forms</span>
        <h2 class="da-section-title">The Form API Challenge</h2>
        <p class="da-section-description">
          Drupal's Form API generates the <code>&lt;form&gt;</code> tag, CSRF tokens,
          AJAX wrappers, and submission handlers. A Shadow DOM component cannot wrap
          this without breaking form participation. <code>hx-form</code> solves this
          with a dual-mode pattern.
        </p>
      </div>

      <!-- Two mode cards -->
      <div class="da-form-modes scroll-reveal scroll-reveal-delay-1">
        <div class="da-form-mode">
          <div class="da-form-mode-header">
            <div class="da-form-mode-icon" aria-hidden="true" style="background: linear-gradient(135deg, rgba(6, 182, 212, 0.15), rgba(102, 126, 234, 0.08)); border-color: rgba(6, 182, 212, 0.2); color: var(--wc-cyan);">
              <i class="fa-solid fa-rocket"></i>
            </div>
            <div>
              <h3 class="da-form-mode-title">Standalone Mode</h3>
              <p class="da-form-mode-subtitle">With <code>action</code> attribute</p>
            </div>
          </div>
          <p class="da-form-mode-desc">
            When <code>action</code> is set, <code>hx-form</code> renders a native
            <code>&lt;form&gt;</code> element. Client-side validation, <code>hx-submit</code>
            events, and direct HTTP submission all work out of the box.
          </p>
          <div class="da-code-block" style="margin-top: var(--space-4);">
            <div class="da-code-titlebar">
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-filename">contact-form.html.twig</span>
            </div>
            <div class="da-code-body"><pre set:html={codeFormStandalone} /></div>
          </div>
        </div>

        <div class="da-form-mode">
          <div class="da-form-mode-header">
            <div class="da-form-mode-icon" aria-hidden="true" style="background: linear-gradient(135deg, rgba(245, 158, 11, 0.15), rgba(239, 68, 68, 0.08)); border-color: rgba(245, 158, 11, 0.2); color: var(--wc-amber);">
              <i class="fa-brands fa-drupal"></i>
            </div>
            <div>
              <h3 class="da-form-mode-title">Drupal-Wrapped Mode</h3>
              <p class="da-form-mode-subtitle">Without <code>action</code> &mdash; bare <code>&lt;slot&gt;</code></p>
            </div>
          </div>
          <p class="da-form-mode-desc">
            When no <code>action</code> is set, <code>hx-form</code> renders only a
            <code>&lt;slot&gt;</code>. Drupal provides its own <code>&lt;form&gt;</code>
            tag with CSRF tokens and AJAX handlers. The component only injects styling.
          </p>
          <div class="da-code-block" style="margin-top: var(--space-4);">
            <div class="da-code-titlebar">
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-filename">form--webform.html.twig</span>
            </div>
            <div class="da-code-body"><pre set:html={codeFormDrupal} /></div>
          </div>
        </div>
      </div>

      <!-- ElementInternals flow -->
      <div class="da-section-header scroll-reveal" style="margin-top: var(--space-16);">
        <span class="da-section-label">Form Participation</span>
        <h2 class="da-section-title" style="font-size: clamp(1.5rem, 3vw, 2.25rem);">ElementInternals Bridge</h2>
        <p class="da-section-description">
          Shadow DOM form controls use <code>ElementInternals</code> to participate
          in native <code>&lt;form&gt;</code> elements &mdash; reporting values, validity,
          and labels to the parent form.
        </p>
      </div>

      <!-- Internals flow steps -->
      <div class="da-form-internals-flow scroll-reveal scroll-reveal-delay-1">
        <div class="da-form-internals-step">
          <code>formAssociated = true</code>
          <span>Declares form participation</span>
        </div>
        <div class="da-form-internals-arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></div>
        <div class="da-form-internals-step">
          <code>attachInternals()</code>
          <span>Gets the internals API</span>
        </div>
        <div class="da-form-internals-arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></div>
        <div class="da-form-internals-step">
          <code>setFormValue()</code>
          <span>Reports value to form</span>
        </div>
        <div class="da-form-internals-arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></div>
        <div class="da-form-internals-step">
          <code>setValidity()</code>
          <span>Reports validation state</span>
        </div>
      </div>

      <!-- Code block: form internals pattern -->
      <div class="scroll-reveal scroll-reveal-delay-2" style="max-width: 700px; margin: 0 auto var(--space-12);">
        <span class="da-code-label da-code-label-html">ElementInternals Pattern</span>
        <div class="da-code-block">
          <div class="da-code-titlebar">
            <span class="da-code-dot"></span>
            <span class="da-code-dot"></span>
            <span class="da-code-dot"></span>
            <span class="da-code-filename">hx-text-input.ts</span>
          </div>
          <div class="da-code-body"><pre set:html={codeFormInternals} /></div>
        </div>
      </div>

      <!-- Three benefit callouts -->
      <div class="da-form-benefits scroll-reveal scroll-reveal-delay-3">
        <div class="da-adopted-benefit">
          <i class="fa-solid fa-check-double" aria-hidden="true"></i>
          <div>
            <strong>Native Validation</strong>
            <p>Constraint validation API works across Shadow DOM &mdash; <code>:invalid</code> pseudo-class, custom messages, and browser-native UI.</p>
          </div>
        </div>
        <div class="da-adopted-benefit">
          <i class="fa-solid fa-database" aria-hidden="true"></i>
          <div>
            <strong>FormData Integration</strong>
            <p><code>new FormData(form)</code> automatically includes values from Shadow DOM controls with <code>formAssociated</code>.</p>
          </div>
        </div>
        <div class="da-adopted-benefit">
          <i class="fa-brands fa-drupal" aria-hidden="true"></i>
          <div>
            <strong>Drupal Compatible</strong>
            <p>Drupal behaviors, AJAX handlers, and Form API validation work with hx-* form controls without modification.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 6: SYSTEM ARCHITECTURE -->
  <section class="da-section" style="border-top: 1px solid var(--surface-3);" aria-label="System architecture diagram">
    <div class="da-section-inner">
      <div class="da-section-header scroll-reveal">
        <span class="da-section-label">Architecture</span>
        <h2 class="da-section-title">How It All Works Together</h2>
        <p class="da-section-description">
          The complete rendering architecture: Shadow DOM for encapsulated controls,
          Light DOM with adopted stylesheets for CMS content containers.
        </p>
      </div>

      <div class="da-arch-diagram scroll-reveal scroll-reveal-delay-1">
        <!-- Document layer -->
        <div class="da-arch-layer da-arch-layer-doc">
          <div class="da-arch-layer-label">
            <i class="fa-solid fa-globe" aria-hidden="true"></i>
            Document
          </div>
          <div class="da-arch-layer-desc">adoptedStyleSheets &bull; Global design tokens &bull; CSS custom properties cascade</div>
        </div>

        <!-- Two branches -->
        <div class="da-arch-branches">
          <!-- Shadow DOM branch -->
          <div class="da-arch-branch da-arch-branch-shadow">
            <div class="da-arch-branch-header">
              <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
              Shadow DOM
            </div>
            <div class="da-arch-branch-body">
              <div class="da-arch-branch-section">
                <div class="da-arch-branch-label">Styling</div>
