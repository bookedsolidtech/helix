---
/**
 * ArchTab2ComponentLoading — Tab 2 of the System Architecture page.
 *
 * Contains the "Component Loading" Architecture Decision Record:
 * - Hero section (loading variant)
 * - Three loading strategies comparison cards
 * - Performance comparison bars
 * - Drupal integration flow diagram
 * - Code examples (Twig + shared runtime)
 * - Real-world pattern examples (card, button, form)
 */
import {
  codeLoadingSingleBundle,
  codeLoadingPerComponent,
  codeLoadingHybridGroups,
  codeLoadingTwigAttach,
  codeLoadingSharedRuntime,
  codeExampleCard,
  codeExampleButton,
  codeExampleForm,
} from './ArchCodeExamples';
---

<div id="tab-loading" class="da-tab-content" role="tabpanel">
  <section class="da-hero da-hero-loading" aria-label="Component Loading Strategy Decision">
    <div class="da-hero-grid" aria-hidden="true"></div>
    <div class="da-hero-orb da-hero-orb-1" aria-hidden="true"></div>
    <div class="da-hero-orb da-hero-orb-2" aria-hidden="true"></div>
    <div class="da-hero-orb da-hero-orb-3" aria-hidden="true"></div>

    <div class="da-hero-content">
      <div class="da-hero-badge">
        <span class="da-hero-badge-dot" aria-hidden="true"></span>
        Architecture Decision Record
      </div>

      <h1 class="da-hero-title">How Components<br />Reach the Browser</h1>

      <p class="da-hero-subtitle">Bundle Strategy: One File, Many Files, or Smart Groups?</p>

      <p class="da-hero-description">
        The second critical architecture decision: how do web components
        get delivered to each page? A single monolithic bundle, individual
        per-component files, or intelligent context-based groups? The right
        strategy means <strong>fast first paint</strong> and <strong>zero wasted bytes</strong>.
      </p>
    </div>

    <div class="mouse-scroll-wrap mouse-scroll-wrap--absolute" aria-hidden="true">
      <div class="mouse-scroll-body"><div class="mouse-scroll-wheel"></div></div>
      <span class="mouse-scroll-label">Scroll</span>
    </div>
  </section>

  <!-- ============================================
       SECTION 7: COMPONENT LOADING STRATEGIES
       ============================================ -->
  <section id="loading" class="da-section da-loading-section" aria-label="Component loading strategies">
    <div class="da-section-inner">
      <div class="da-section-header scroll-reveal">
        <span class="da-section-label">Loading Strategies</span>
        <h2 class="da-section-title">How Components Reach the Browser</h2>
        <p class="da-section-description">
          The architecture decision does not stop at props vs. slots. How you
          physically load web component JavaScript into Drupal pages has a
          direct impact on performance, cacheability, and maintainability.
        </p>
      </div>

      <!-- Visual 1: Three-Strategy Comparison Cards -->
      <div class="da-loading-strategies">
        <!-- Strategy A: Single Bundle -->
        <div class="da-loading-card scroll-reveal scroll-reveal-delay-1">
          <div class="da-loading-icon da-loading-icon-single" aria-hidden="true">
            <i class="fa-solid fa-box"></i>
          </div>
          <div class="da-loading-card-title">Single Bundle</div>
          <div class="da-loading-card-subtitle">"Load Everything"</div>

          <div class="da-loading-visual" aria-label="One large block representing all components" role="img">
            <div class="da-loading-block da-loading-block-single">ALL COMPONENTS</div>
          </div>

          <div class="da-loading-size da-loading-size-amber">
            <i class="fa-solid fa-weight-hanging" aria-hidden="true"></i>
            ~220KB per page
          </div>

          <div class="da-loading-ratings">
            <div class="da-loading-rating">
              <span class="da-loading-rating-label">
                <i class="fa-solid fa-bolt" aria-hidden="true"></i>
                FCP Impact
              </span>
              <div class="da-loading-rating-dots" aria-label="Poor - 1 out of 5">
                <span class="da-loading-rating-dot filled-red"></span>
                <span class="da-loading-rating-dot"></span>
                <span class="da-loading-rating-dot"></span>
                <span class="da-loading-rating-dot"></span>
                <span class="da-loading-rating-dot"></span>
              </div>
            </div>
            <div class="da-loading-rating">
              <span class="da-loading-rating-label">
                <i class="fa-solid fa-database" aria-hidden="true"></i>
                Cache Efficiency
              </span>
              <div class="da-loading-rating-dots" aria-label="OK - 3 out of 5">
                <span class="da-loading-rating-dot filled-amber"></span>
                <span class="da-loading-rating-dot filled-amber"></span>
                <span class="da-loading-rating-dot filled-amber"></span>
                <span class="da-loading-rating-dot"></span>
                <span class="da-loading-rating-dot"></span>
              </div>
            </div>
            <div class="da-loading-rating">
              <span class="da-loading-rating-label">
                <i class="fa-solid fa-wrench" aria-hidden="true"></i>
                Setup Complexity
              </span>
              <div class="da-loading-rating-dots" aria-label="Easy - 5 out of 5">
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
              </div>
            </div>
          </div>

          <div class="da-loading-code">
            <div class="da-code-block">
              <div class="da-code-titlebar">
                <span class="da-code-dot"></span>
                <span class="da-code-dot"></span>
                <span class="da-code-dot"></span>
                <span class="da-code-filename">helix.libraries.yml</span>
              </div>
              <div class="da-code-body">
                <pre set:html={codeLoadingSingleBundle} />
              </div>
            </div>
          </div>
        </div>

        <!-- Strategy B: Per-Component -->
        <div class="da-loading-card scroll-reveal scroll-reveal-delay-2">
          <div class="da-loading-icon da-loading-icon-per" aria-hidden="true">
            <i class="fa-solid fa-cubes"></i>
          </div>
          <div class="da-loading-card-title">Per-Component Libraries</div>
          <div class="da-loading-card-subtitle">"Surgical Loading"</div>

          <div class="da-loading-visual" aria-label="Many small blocks, each a separate component" role="img">
            <div class="da-loading-block da-loading-block-per">card</div>
            <div class="da-loading-block da-loading-block-per">btn</div>
            <div class="da-loading-block da-loading-block-per">nav</div>
            <div class="da-loading-block da-loading-block-per">hero</div>
            <div class="da-loading-block da-loading-block-per">tab</div>
            <div class="da-loading-block da-loading-block-per">acc</div>
          </div>

          <div class="da-loading-size da-loading-size-cyan">
            <i class="fa-solid fa-weight-hanging" aria-hidden="true"></i>
            ~5-15KB per page
          </div>

          <div class="da-loading-ratings">
            <div class="da-loading-rating">
              <span class="da-loading-rating-label">
                <i class="fa-solid fa-bolt" aria-hidden="true"></i>
                FCP Impact
              </span>
              <div class="da-loading-rating-dots" aria-label="Excellent - 5 out of 5">
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
              </div>
            </div>
            <div class="da-loading-rating">
              <span class="da-loading-rating-label">
                <i class="fa-solid fa-database" aria-hidden="true"></i>
                Cache Efficiency
              </span>
              <div class="da-loading-rating-dots" aria-label="Good - 4 out of 5">
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot"></span>
              </div>
            </div>
            <div class="da-loading-rating">
              <span class="da-loading-rating-label">
                <i class="fa-solid fa-wrench" aria-hidden="true"></i>
                Setup Complexity
              </span>
              <div class="da-loading-rating-dots" aria-label="Medium - 2 out of 5">
                <span class="da-loading-rating-dot filled-amber"></span>
                <span class="da-loading-rating-dot filled-amber"></span>
                <span class="da-loading-rating-dot"></span>
                <span class="da-loading-rating-dot"></span>
                <span class="da-loading-rating-dot"></span>
              </div>
            </div>
          </div>

          <div class="da-loading-code">
            <div class="da-code-block">
              <div class="da-code-titlebar">
                <span class="da-code-dot"></span>
                <span class="da-code-dot"></span>
                <span class="da-code-dot"></span>
                <span class="da-code-filename">helix.libraries.yml</span>
              </div>
              <div class="da-code-body">
                <pre set:html={codeLoadingPerComponent} />
              </div>
            </div>
          </div>
        </div>

        <!-- Strategy C: Hybrid Groups (Recommended) -->
        <div class="da-loading-card da-loading-card-recommended scroll-reveal scroll-reveal-delay-3">
          <span class="da-loading-badge">Recommended</span>
          <div class="da-loading-icon da-loading-icon-hybrid" aria-hidden="true">
            <i class="fa-solid fa-boxes-stacked"></i>
          </div>
          <div class="da-loading-card-title">Hybrid Groups</div>
          <div class="da-loading-card-subtitle">"Smart Bundles"</div>

          <div class="da-loading-visual" aria-label="Three grouped blocks by usage context" role="img">
            <div class="da-loading-block da-loading-block-group">core</div>
            <div class="da-loading-block da-loading-block-group">navigation</div>
            <div class="da-loading-block da-loading-block-group">content</div>
            <div class="da-loading-block da-loading-block-group">forms</div>
          </div>

          <div class="da-loading-size da-loading-size-green">
            <i class="fa-solid fa-weight-hanging" aria-hidden="true"></i>
            ~30-60KB per group
          </div>

          <div class="da-loading-ratings">
            <div class="da-loading-rating">
              <span class="da-loading-rating-label">
                <i class="fa-solid fa-bolt" aria-hidden="true"></i>
                FCP Impact
              </span>
              <div class="da-loading-rating-dots" aria-label="Great - 4 out of 5">
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot"></span>
              </div>
            </div>
            <div class="da-loading-rating">
              <span class="da-loading-rating-label">
                <i class="fa-solid fa-database" aria-hidden="true"></i>
                Cache Efficiency
              </span>
              <div class="da-loading-rating-dots" aria-label="Excellent - 5 out of 5">
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
                <span class="da-loading-rating-dot filled-green"></span>
              </div>
            </div>
            <div class="da-loading-rating">
              <span class="da-loading-rating-label">
                <i class="fa-solid fa-wrench" aria-hidden="true"></i>
                Setup Complexity
              </span>
              <div class="da-loading-rating-dots" aria-label="Moderate - 3 out of 5">
                <span class="da-loading-rating-dot filled-amber"></span>
                <span class="da-loading-rating-dot filled-amber"></span>
                <span class="da-loading-rating-dot filled-amber"></span>
                <span class="da-loading-rating-dot"></span>
                <span class="da-loading-rating-dot"></span>
              </div>
            </div>
          </div>

          <div class="da-loading-code">
            <div class="da-code-block">
              <div class="da-code-titlebar">
                <span class="da-code-dot"></span>
                <span class="da-code-dot"></span>
                <span class="da-code-dot"></span>
                <span class="da-code-filename">helix.libraries.yml</span>
              </div>
              <div class="da-code-body">
                <pre set:html={codeLoadingHybridGroups} />
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Visual 2: Performance Impact Comparison -->
      <div class="da-perf-comparison scroll-reveal scroll-reveal-delay-2">
        <div class="da-flow-subtitle">Performance Impact Comparison</div>
        <div class="da-flow-desc">
          Side-by-side metrics showing how each loading strategy affects
          real-world performance. Bars animate when scrolled into view.
        </div>

        <div class="da-perf-grid">
          <!-- Initial Page Load -->
          <div class="da-perf-metric">
            <div class="da-perf-metric-header">
              <div class="da-perf-metric-icon" aria-hidden="true">
                <i class="fa-solid fa-download"></i>
              </div>
              <div>
                <div class="da-perf-metric-title">Initial Page Load</div>
                <div class="da-perf-metric-desc">KB transferred on first visit</div>
              </div>
            </div>
            <div class="da-perf-bars">
              <div class="da-perf-bar-row">
                <span class="da-perf-bar-label">Single Bundle</span>
                <div class="da-perf-bar-track">
                  <div class="da-perf-bar-fill da-perf-bar-fill-amber scroll-reveal-bar" style="--bar-width: 100%;">220KB</div>
                </div>
                <span class="da-perf-bar-value">220KB</span>
              </div>
              <div class="da-perf-bar-row">
                <span class="da-perf-bar-label">Per-Component</span>
                <div class="da-perf-bar-track">
                  <div class="da-perf-bar-fill da-perf-bar-fill-cyan scroll-reveal-bar" style="--bar-width: 11%;">25KB</div>
                </div>
                <span class="da-perf-bar-value">25KB</span>
              </div>
              <div class="da-perf-bar-row">
                <span class="da-perf-bar-label">Hybrid Groups</span>
                <div class="da-perf-bar-track">
                  <div class="da-perf-bar-fill da-perf-bar-fill-green scroll-reveal-bar" style="--bar-width: 27%;">60KB</div>
                </div>
                <span class="da-perf-bar-value">60KB</span>
              </div>
            </div>
          </div>

          <!-- HTTP Requests -->
          <div class="da-perf-metric">
            <div class="da-perf-metric-header">
              <div class="da-perf-metric-icon" aria-hidden="true">
                <i class="fa-solid fa-arrow-right-arrow-left"></i>
              </div>
              <div>
                <div class="da-perf-metric-title">HTTP Requests</div>
                <div class="da-perf-metric-desc">Script requests per page load</div>
              </div>
            </div>
            <div class="da-perf-bars">
              <div class="da-perf-bar-row">
                <span class="da-perf-bar-label">Single Bundle</span>
                <div class="da-perf-bar-track">
                  <div class="da-perf-bar-fill da-perf-bar-fill-amber scroll-reveal-bar" style="--bar-width: 10%;">1</div>
                </div>
                <span class="da-perf-bar-value">1 req</span>
              </div>
              <div class="da-perf-bar-row">
                <span class="da-perf-bar-label">Per-Component</span>
                <div class="da-perf-bar-track">
                  <div class="da-perf-bar-fill da-perf-bar-fill-cyan scroll-reveal-bar" style="--bar-width: 80%;">3-8</div>
                </div>
                <span class="da-perf-bar-value">3-8 req</span>
              </div>
              <div class="da-perf-bar-row">
                <span class="da-perf-bar-label">Hybrid Groups</span>
                <div class="da-perf-bar-track">
                  <div class="da-perf-bar-fill da-perf-bar-fill-green scroll-reveal-bar" style="--bar-width: 30%;">2-3</div>
                </div>
                <span class="da-perf-bar-value">2-3 req</span>
              </div>
            </div>
          </div>

          <!-- Cache Hit Rate -->
          <div class="da-perf-metric">
            <div class="da-perf-metric-header">
              <div class="da-perf-metric-icon" aria-hidden="true">
                <i class="fa-solid fa-bolt"></i>
              </div>
              <div>
                <div class="da-perf-metric-title">Cache Hit Rate</div>
                <div class="da-perf-metric-desc">After navigating to a second page</div>
              </div>
            </div>
            <div class="da-perf-bars">
              <div class="da-perf-bar-row">
                <span class="da-perf-bar-label">Single Bundle</span>
                <div class="da-perf-bar-track">
                  <div class="da-perf-bar-fill da-perf-bar-fill-amber scroll-reveal-bar" style="--bar-width: 100%;">100%</div>
                </div>
                <span class="da-perf-bar-value">100%</span>
              </div>
              <div class="da-perf-bar-row">
                <span class="da-perf-bar-label">Per-Component</span>
                <div class="da-perf-bar-track">
                  <div class="da-perf-bar-fill da-perf-bar-fill-cyan scroll-reveal-bar" style="--bar-width: 60%;">~60%</div>
                </div>
                <span class="da-perf-bar-value">~60%</span>
              </div>
              <div class="da-perf-bar-row">
                <span class="da-perf-bar-label">Hybrid Groups</span>
                <div class="da-perf-bar-track">
                  <div class="da-perf-bar-fill da-perf-bar-fill-green scroll-reveal-bar" style="--bar-width: 90%;">~90%</div>
                </div>
                <span class="da-perf-bar-value">~90%</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Visual 3: Drupal Integration Flow -->
      <div class="da-flow-section scroll-reveal scroll-reveal-delay-2">
        <div class="da-flow-subtitle">How Per-Component Loading Works in Practice</div>
        <div class="da-flow-desc">
          From content creation to Custom Element upgrade, every step is designed
          to deliver only the JavaScript each page actually needs.
        </div>

        <div class="da-flow-steps">
          <div class="da-flow-step">
            <div class="da-flow-step-header">
              <div class="da-flow-step-number">1</div>
              <div class="da-flow-step-icon" aria-hidden="true">
                <i class="fa-solid fa-pen-to-square"></i>
              </div>
            </div>
            <div class="da-flow-step-title">Content Editor</div>
            <div class="da-flow-step-desc">Creates node with paragraph types (Card, Hero, etc.)</div>
          </div>

          <div class="da-flow-arrow" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></div>

          <div class="da-flow-step">
            <div class="da-flow-step-header">
              <div class="da-flow-step-number">2</div>
              <div class="da-flow-step-icon" aria-hidden="true">
                <i class="fa-brands fa-drupal"></i>
              </div>
            </div>
            <div class="da-flow-step-title">TWIG Template</div>
            <div class="da-flow-step-desc">Renders component and attaches library</div>
            <div class="da-flow-step-code">attach_library('helix/card')</div>
          </div>

          <div class="da-flow-arrow" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></div>

          <div class="da-flow-step">
            <div class="da-flow-step-header">
              <div class="da-flow-step-number">3</div>
              <div class="da-flow-step-icon" aria-hidden="true">
                <i class="fa-solid fa-gears"></i>
              </div>
            </div>
            <div class="da-flow-step-title">Drupal Aggregation</div>
            <div class="da-flow-step-desc">Combines only the needed assets into optimized bundles</div>
          </div>

          <div class="da-flow-arrow" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></div>

          <div class="da-flow-step">
            <div class="da-flow-step-header">
              <div class="da-flow-step-number">4</div>
              <div class="da-flow-step-icon" aria-hidden="true">
                <i class="fa-solid fa-cloud-arrow-down"></i>
              </div>
            </div>
            <div class="da-flow-step-title">Minimal JS Load</div>
            <div class="da-flow-step-desc">Browser downloads only card.js + lit-runtime.js</div>
            <div class="da-flow-step-code">~18KB total (not 220KB)</div>
          </div>

          <div class="da-flow-arrow" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></div>

          <div class="da-flow-step">
            <div class="da-flow-step-header">
              <div class="da-flow-step-number">5</div>
              <div class="da-flow-step-icon" aria-hidden="true">
                <i class="fa-solid fa-wand-magic-sparkles"></i>
              </div>
            </div>
            <div class="da-flow-step-title">CE Upgrade</div>
            <div class="da-flow-step-desc">Custom Elements register and upgrade in the DOM</div>
            <div class="da-flow-step-code">customElements.define()</div>
          </div>
        </div>
      </div>

      <!-- Visual 4: .libraries.yml Code Examples -->
      <div class="da-loading-examples scroll-reveal scroll-reveal-delay-2">
        <div>
          <div class="da-loading-example-label">
            <i class="fa-solid fa-code" aria-hidden="true"></i>
            TWIG Template Integration
          </div>
          <div class="da-code-block">
            <div class="da-code-titlebar">
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-filename">paragraph--card.html.twig</span>
            </div>
            <div class="da-code-body">
              <pre set:html={codeLoadingTwigAttach} />
            </div>
          </div>
        </div>

        <div>
          <div class="da-loading-example-label">
            <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
            Shared Runtime Dependency
          </div>
          <div class="da-code-block">
            <div class="da-code-titlebar">
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-filename">helix.libraries.yml</span>
            </div>
            <div class="da-code-body">
              <pre set:html={codeLoadingSharedRuntime} />
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ============================================
       SECTION 8: CODE EXAMPLES
       ============================================ -->
  <section id="examples" class="da-section" aria-label="Real code examples">
    <div class="da-section-inner">
      <div class="da-section-header scroll-reveal">
        <span class="da-section-label">In Practice</span>
        <h2 class="da-section-title">Real-World Patterns</h2>
        <p class="da-section-description">
          Three components, three strategies. Here is how each approach
          looks in production TWIG templates.
        </p>
      </div>

      <div class="da-examples-grid">
        <!-- Slot-driven card -->
        <div class="da-example scroll-reveal scroll-reveal-delay-1">
          <div class="da-example-title">
            <i class="fa-solid fa-id-card" style="color: var(--wc-pink);" aria-hidden="true"></i>
            Card (Slot-Driven)
          </div>
          <p class="da-example-desc">
            Drupal renders content into named slots. The component provides
            layout, elevation, and interaction patterns.
          </p>
          <div class="da-code-block">
            <div class="da-code-titlebar">
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-dot"></span>
              <span class="da-code-filename">card.html.twig</span>
            </div>
            <div class="da-code-body">
              <pre set:html={codeExampleCard} />
            </div>
          </div>
        </div>

        <!-- Property-driven button -->
        <div class="da-example scroll-reveal scroll-reveal-delay-2">
          <div class="da-example-title">
            <i class="fa-solid fa-hand-pointer" style="color: var(--wc-cyan);" aria-hidden="true"></i>
            Button (Property-Driven)
          </div>
          <p class="da-example-desc">
            All configuration via properties. The component handles
            all rendering, states, and accessibility.
          </p>
          <div class="da-code-block">
