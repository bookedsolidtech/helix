---
/**
 * ScrollRevealScript — shared IntersectionObserver + card mouse-follow script.
 *
 * Props:
 *   cardSelectors  — CSS selectors for cards that get mouse-follow glow (e.g. '.ea-card, .ea-quality-card')
 *   enableBarReveal — whether to also observe .bar-fill elements for width animation
 */
interface Props {
  cardSelectors?: string[];
  enableBarReveal?: boolean;
}

const { cardSelectors = [], enableBarReveal = false } = Astro.props;
const cardSelectorStr = cardSelectors.join(', ');
---

<script is:inline
  data-card-selectors={cardSelectorStr}
  data-enable-bar-reveal={enableBarReveal ? 'true' : ''}
>
  (function () {
    var script = document.currentScript;
    var cardSel = script.getAttribute('data-card-selectors') || '';
    var enableBar = script.getAttribute('data-enable-bar-reveal') === 'true';

    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReduced) {
      document.querySelectorAll('.scroll-reveal').forEach(function (el) {
        el.classList.add('is-visible');
      });
      return;
    }

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
    );

    document.querySelectorAll('.scroll-reveal').forEach(function (el) {
      observer.observe(el);
    });

    if (enableBar) {
      var barObserver = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.style.width = entry.target.dataset.width;
              barObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('.bar-fill').forEach(function (el) {
        barObserver.observe(el);
      });
    }

    if (cardSel) {
      document.querySelectorAll(cardSel).forEach(function (card) {
        card.addEventListener('mousemove', function (e) {
          var rect = card.getBoundingClientRect();
          card.style.setProperty('--mouse-x', (e.clientX - rect.left) + 'px');
          card.style.setProperty('--mouse-y', (e.clientY - rect.top) + 'px');
        });
      });
    }
  })();
</script>
