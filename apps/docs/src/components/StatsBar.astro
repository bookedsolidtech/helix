---
/**
 * StatsBar - Animated metrics strip showcasing key project stats.
 *
 * Features:
 * - Glassmorphic stat cards with animated gradient mesh background
 * - Different gradient colors per stat for visual variety
 * - Scroll-reveal animation with staggered delays
 * - Responsive: 5-across desktop, wraps on mobile
 * - Click to open modal with details
 * - Accessible modals with ESC key support
 */

interface Stat {
  value: string;
  label: string;
  colorClass: string;
  description: string;
  relevance: string;
  docsUrl?: string;
  docsLabel?: string;
  iconClass: string;
}

const stats: Stat[] = [
  {
    value: '14',
    label: 'Components Built',
    colorClass: 'stat-value-cyan',
    iconClass: 'fa-solid fa-puzzle-piece',
    description: 'Production-ready UI components with full test coverage and CEM documentation.',
    relevance: 'From alerts and buttons to complex forms and radio groups—each component is enterprise-grade with accessibility, theming, and Drupal integration as first-class concerns. All components are Lit 3.x web components with Shadow DOM encapsulation.',
    docsUrl: '/component-library/overview/',
    docsLabel: 'Browse Components'
  },
  {
    value: '93.38%',
    label: 'Test Coverage',
    colorClass: 'stat-value-green',
    iconClass: 'fa-solid fa-check-circle',
    description: 'Comprehensive test suite with Vitest browser mode and Playwright.',
    relevance: 'Enterprise-grade quality with extensive unit and integration tests. Every component interaction, accessibility pattern, and edge case is verified. Tests run in real browsers to catch DOM-specific issues before production.',
    docsUrl: '/architecture/testing/',
    docsLabel: 'Testing Strategy'
  },
  {
    value: '100%',
    label: 'TypeScript Strict',
    colorClass: 'stat-value-gradient',
    iconClass: 'fa-solid fa-code',
    description: 'Full TypeScript strict mode with zero any types across the codebase.',
    relevance: 'Enterprise teams demand type safety. Every component, utility, and API is fully typed with JSDoc documentation. Strict mode enabled catches errors at compile-time, not runtime. Your IDE provides intelligent autocomplete for every prop and method.',
    docsUrl: '/architecture/overview/#typescript',
    docsLabel: 'TypeScript Architecture'
  },
  {
    value: 'AA',
    label: 'WCAG 2.1',
    colorClass: 'stat-value-pink',
    iconClass: 'fa-solid fa-universal-access',
    description: 'WCAG 2.1 AA accessibility compliance across all components.',
    relevance: 'HELIX ensures AA compliance minimum with AAA for critical components. Every component includes proper ARIA attributes, keyboard navigation, focus management, and screen reader support. Accessibility is verified through automated and manual testing.',
    docsUrl: '/architecture/accessibility/',
    docsLabel: 'Accessibility Standards'
  },
  {
    value: '2026-02-16',
    label: 'Last Updated',
    colorClass: 'stat-value-gradient',
    iconClass: 'fa-solid fa-calendar-check',
    description: 'Documentation and component library last updated February 16, 2026.',
    relevance: 'Active development with continuous improvements to components, documentation, and tooling. Check the Admin Dashboard for real-time component health metrics, test results, and CEM validation status.',
    docsUrl: 'http://localhost:3159',
    docsLabel: 'Admin Dashboard'
  },
];
---

<section class="stats-section" aria-label="Project statistics">
  <div class="stats-bar">
    {stats.map((stat, i) => (
      <button
        type="button"
        class={`stat-card scroll-reveal scroll-reveal-delay-${i + 1}`}
        aria-label={`View details for ${stat.value} ${stat.label}`}
        data-stat-modal={`stat-${i}`}
      >
        <div class="stat-card-header">
          <i class={`${stat.iconClass} stat-main-icon ${stat.colorClass}`} aria-hidden="true"></i>
          <div class={`stat-value ${stat.colorClass}`}>{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
        <i class="stat-expand-icon fa-solid fa-circle-plus" aria-hidden="true"></i>
      </button>
    ))}
  </div>

  <!-- Modals -->
  {stats.map((stat, i) => (
    <div
      id={`stat-modal-${i}`}
      class="stat-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby={`stat-modal-title-${i}`}
    >
      <div class="stat-modal-content">
        <button
          type="button"
          class="stat-modal-close"
          aria-label="Close modal"
        >
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>

        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
          <i class={`${stat.iconClass}`} style="font-size: 3rem; color: var(--text-muted);" aria-hidden="true"></i>
          <div>
            <div class={`${stat.colorClass}`} style="font-size: 2.5rem; font-weight: 800; line-height: 1;">{stat.value}</div>
            <div style="color: var(--text-muted); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem;">{stat.label}</div>
          </div>
        </div>

        <p style="color: var(--text-secondary); font-size: 1.125rem; line-height: 1.6; margin-bottom: 1.5rem;">{stat.description}</p>

        <div style="background: var(--glass-bg); border-radius: var(--radius-lg); padding: 1.5rem; margin-bottom: 1.5rem; border: 1px solid var(--glass-border);">
          <h4 style="color: var(--text-primary); font-weight: 600; font-size: 1.125rem; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
            <i class="fa-solid fa-lightbulb" style="color: #fbbf24;" aria-hidden="true"></i>
            Why It Matters
          </h4>
          <p style="color: var(--text-secondary); line-height: 1.7;">{stat.relevance}</p>
        </div>

        {stat.docsUrl && (
          <a
            href={stat.docsUrl}
            style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem; background: var(--accent-color); color: white; font-weight: 600; border-radius: var(--radius-md); text-decoration: none; transition: all 0.2s ease;"
            target={stat.docsUrl.startsWith('http') ? '_blank' : undefined}
            rel={stat.docsUrl.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {stat.docsLabel || 'Learn More'}
            <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
          </a>
        )}
      </div>
    </div>
  ))}
</section>

<script>
  // Modal functionality
  document.addEventListener('DOMContentLoaded', () => {
    const statCards = document.querySelectorAll('[data-stat-modal]');

    statCards.forEach((card) => {
      const modalId = card.getAttribute('data-stat-modal');
      if (!modalId) return;
      const modal = document.getElementById(`stat-modal-${modalId.split('-')[1]}`);
      if (!modal) return;

      const closeBtn = modal.querySelector('.stat-modal-close');

      // Open modal
      card.addEventListener('click', () => {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
        // Focus the close button for accessibility
        (closeBtn as HTMLElement)?.focus();
      });

      // Close modal
      const closeModal = () => {
        modal.classList.remove('active');
        document.body.style.overflow = '';
        (card as HTMLElement).focus(); // Return focus to trigger
      };

      closeBtn?.addEventListener('click', closeModal);

      // Close on backdrop click
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeModal();
        }
      });

      // Close on ESC key
      modal.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeModal();
        }
      });
    });
  });
</script>
