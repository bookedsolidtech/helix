    will-change: opacity, transform;
  }

  .sn-showcase .star-1  { width: 2px;   height: 2px;   top: 6%;  left: 10%; --star-dur: 2.2s; --star-delay: 0s;   --star-color: rgba(6, 182, 212, 0.9); }
