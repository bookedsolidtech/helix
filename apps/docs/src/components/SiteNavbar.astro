  .sn-showcase .star-4  { width: 1px;   height: 1px;   top: 28%; left: 90%; --star-dur: 3.8s; --star-delay: 0.3s; --star-color: #fff; }
  .sn-showcase .star-5  { width: 2px;   height: 2px;   top: 35%; left: 52%; --star-dur: 3s;   --star-delay: 1.8s; --star-color: rgba(236, 72, 153, 0.8); }
  .sn-showcase .star-6  { width: 1px;   height: 1px;   top: 15%; left: 45%; --star-dur: 2.4s; --star-delay: 1s;   --star-color: rgba(6, 182, 212, 0.7); }
  .sn-showcase .star-7  { width: 2.5px; height: 2.5px; top: 50%; left: 15%; --star-dur: 3.6s; --star-delay: 0.4s; --star-color: rgba(102, 126, 234, 0.9); }
  .sn-showcase .star-8  { width: 1px;   height: 1px;   top: 58%; left: 85%; --star-dur: 2s;   --star-delay: 1.6s; --star-color: #fff; }
  .sn-showcase .star-9  { width: 1.5px; height: 1.5px; top: 66%; left: 38%; --star-dur: 4s;   --star-delay: 0.5s; --star-color: rgba(139, 92, 246, 0.8); }
  .sn-showcase .star-10 { width: 1px;   height: 1px;   top: 74%; left: 62%; --star-dur: 2.8s; --star-delay: 2.2s; --star-color: rgba(6, 182, 212, 0.7); }
  .sn-showcase .star-11 { width: 1.5px; height: 1.5px; top: 82%; left: 20%; --star-dur: 2.7s; --star-delay: 0.2s; --star-color: #fff; }
  .sn-showcase .star-12 { width: 2px;   height: 2px;   top: 88%; left: 70%; --star-dur: 3.2s; --star-delay: 1.4s; --star-color: rgba(236, 72, 153, 0.8); }
  .sn-showcase .star-13 { width: 1px;   height: 1px;   top: 4%;  left: 94%; --star-dur: 2.3s; --star-delay: 0.8s; --star-color: rgba(102, 126, 234, 0.7); }
  .sn-showcase .star-14 { width: 2.5px; height: 2.5px; top: 44%; left: 6%;  --star-dur: 3.5s; --star-delay: 0.3s; --star-color: rgba(6, 182, 212, 0.9); }
  .sn-showcase .star-15 { width: 1px;   height: 1px;   top: 36%; left: 32%; --star-dur: 4.2s; --star-delay: 2s;   --star-color: #fff; }
  .sn-showcase .star-16 { width: 1.5px; height: 1.5px; top: 92%; left: 48%; --star-dur: 2.5s; --star-delay: 0.7s; --star-color: rgba(139, 92, 246, 0.8); }
  .sn-showcase .star-17 { width: 1px;   height: 1px;   top: 62%; left: 94%; --star-dur: 2.9s; --star-delay: 1.2s; --star-color: rgba(236, 72, 153, 0.6); }
  .sn-showcase .star-18 { width: 1.5px; height: 1.5px; top: 18%; left: 4%;  --star-dur: 3.7s; --star-delay: 0.5s; --star-color: #fff; }
  .sn-showcase .star-19 { width: 2px;   height: 2px;   top: 40%; left: 72%; --star-dur: 2.1s; --star-delay: 1.5s; --star-color: rgba(6, 182, 212, 0.85); }
  .sn-showcase .star-20 { width: 1px;   height: 1px;   top: 52%; left: 42%; --star-dur: 3.3s; --star-delay: 0.9s; --star-color: rgba(102, 126, 234, 0.7); }
  .sn-showcase .star-21 { width: 2px;   height: 2px;   top: 76%; left: 8%;  --star-dur: 2.6s; --star-delay: 2.4s; --star-color: rgba(139, 92, 246, 0.85); }
  .sn-showcase .star-22 { width: 1.5px; height: 1.5px; top: 10%; left: 60%; --star-dur: 3.9s; --star-delay: 0.1s; --star-color: rgba(236, 72, 153, 0.7); }
  .sn-showcase .star-23 { width: 1px;   height: 1px;   top: 96%; left: 30%; --star-dur: 2.2s; --star-delay: 1.8s; --star-color: #fff; }
  .sn-showcase .star-24 { width: 2px;   height: 2px;   top: 30%; left: 16%; --star-dur: 4.4s; --star-delay: 0.6s; --star-color: rgba(6, 182, 212, 0.8); }

  @keyframes sn-star-twinkle {
    0%, 100% { opacity: 0.1; transform: scale(1); }
    30% { opacity: 0.25; }
    50% { opacity: 0.5; transform: scale(1.2); }
    70% { opacity: 0.3; }
  }

  .sn-showcase .mega-sidebar:hover .star {
    opacity: 0.6;
  }

  /* --- Holographic scan-line overlay --- */
  .sn-showcase .sidebar-holo-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      repeating-linear-gradient(
        0deg,
        transparent 0px,
        transparent 2px,
        rgba(102, 126, 234, 0.02) 2px,
        rgba(102, 126, 234, 0.02) 4px
      );
    opacity: 0.7;
  }

  .sn-showcase .sidebar-holo-overlay::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent 0px,
        transparent 40px,
        rgba(6, 182, 212, 0.008) 40px,
        rgba(6, 182, 212, 0.008) 41px
      );
    opacity: 0.5;
  }

  .sn-showcase .sidebar-holo-overlay::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 80px;
    top: -80px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(6, 182, 212, 0.03) 30%,
      rgba(102, 126, 234, 0.02) 50%,
      rgba(139, 92, 246, 0.015) 70%,
      transparent 100%
    );
    animation: sn-holo-scan 9s linear infinite;
    will-change: top;
    opacity: 0.15;
  }

  @keyframes sn-holo-scan {
    0% { top: -80px; }
    100% { top: calc(100% + 80px); }
  }

  .sn-showcase .mega-sidebar:hover .sidebar-holo-overlay::after {
    opacity: 0.25;
  }

  /* --- Glass-morphism depth layers (3 layers) --- */
  .sn-showcase .sidebar-glass-layer {
    position: absolute;
    pointer-events: none;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    z-index: 0;
    transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sn-showcase .sidebar-glass-1 {
    top: 8%;
    left: 6%;
    right: 6%;
    bottom: 58%;
    background: linear-gradient(
      135deg,
      rgba(102, 126, 234, 0.04) 0%,
      rgba(139, 92, 246, 0.025) 100%
    );
    transform: rotate(-1.5deg);
  }

  .sn-showcase .sidebar-glass-2 {
    top: 48%;
    left: 10%;
    right: 10%;
    bottom: 6%;
    background: linear-gradient(
      -45deg,
      rgba(6, 182, 212, 0.04) 0%,
      rgba(102, 126, 234, 0.025) 100%
    );
    transform: rotate(0.8deg);
  }

  .sn-showcase .sidebar-glass-3 {
    top: 25%;
    left: 15%;
    right: 15%;
    bottom: 30%;
    background: linear-gradient(
      90deg,
      rgba(236, 72, 153, 0.02) 0%,
      rgba(139, 92, 246, 0.025) 50%,
      rgba(6, 182, 212, 0.02) 100%
    );
    transform: rotate(-0.3deg);
    border-color: rgba(255, 255, 255, 0.02);
  }

  .sn-showcase .mega-sidebar:hover .sidebar-glass-1 {
    border-color: rgba(255, 255, 255, 0.1);
    background: linear-gradient(
      135deg,
      rgba(102, 126, 234, 0.08) 0%,
      rgba(139, 92, 246, 0.05) 100%
    );
    transform: rotate(-1.5deg) scale(1.03) translateY(-2px);
  }

  .sn-showcase .mega-sidebar:hover .sidebar-glass-2 {
    border-color: rgba(255, 255, 255, 0.08);
    background: linear-gradient(
      -45deg,
      rgba(6, 182, 212, 0.06) 0%,
      rgba(102, 126, 234, 0.04) 100%
    );
    transform: rotate(0.8deg) scale(1.03) translateY(2px);
  }

  .sn-showcase .mega-sidebar:hover .sidebar-glass-3 {
    border-color: rgba(255, 255, 255, 0.06);
    background: linear-gradient(
      90deg,
      rgba(236, 72, 153, 0.05) 0%,
      rgba(139, 92, 246, 0.05) 50%,
      rgba(6, 182, 212, 0.05) 100%
    );
    transform: rotate(-0.3deg) scale(1.05);
  }

  /* --- Energy rings --- */
  .sn-showcase .sidebar-energy-rings {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .sn-showcase .energy-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid transparent;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .sn-showcase .showcase-panel.is-open .energy-ring {
    opacity: 1;
    transition-delay: 500ms;
  }

  .sn-showcase .energy-ring-1 {
    width: 200px;
    height: 200px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-color: rgba(6, 182, 212, 0.08);
    animation: sn-energy-pulse-1 4s ease-in-out infinite;
  }

  .sn-showcase .energy-ring-2 {
    width: 260px;
    height: 260px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-color: rgba(139, 92, 246, 0.06);
    animation: sn-energy-pulse-2 5s ease-in-out infinite 1s;
  }

  .sn-showcase .energy-ring-3 {
    width: 320px;
    height: 320px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-color: rgba(236, 72, 153, 0.04);
    animation: sn-energy-pulse-3 6s ease-in-out infinite 2s;
  }

  @keyframes sn-energy-pulse-1 {
    0%, 100% { transform: translate(-50%, -50%) scale(0.8); opacity: 0; border-color: rgba(6, 182, 212, 0.12); }
    50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.6; border-color: rgba(6, 182, 212, 0.06); }
  }

  @keyframes sn-energy-pulse-2 {
    0%, 100% { transform: translate(-50%, -50%) scale(0.7); opacity: 0; border-color: rgba(139, 92, 246, 0.1); }
    50% { transform: translate(-50%, -50%) scale(1.05); opacity: 0.5; border-color: rgba(139, 92, 246, 0.04); }
  }

  @keyframes sn-energy-pulse-3 {
    0%, 100% { transform: translate(-50%, -50%) scale(0.6); opacity: 0; border-color: rgba(236, 72, 153, 0.08); }
    50% { transform: translate(-50%, -50%) scale(1); opacity: 0.4; border-color: rgba(236, 72, 153, 0.03); }
  }

  .sn-showcase .mega-sidebar:hover .energy-ring-1 {
    border-color: rgba(6, 182, 212, 0.12);
  }

  .sn-showcase .mega-sidebar:hover .energy-ring-2 {
    border-color: rgba(139, 92, 246, 0.08);
  }

  .sn-showcase .mega-sidebar:hover .energy-ring-3 {
    border-color: rgba(236, 72, 153, 0.06);
  }

  /* --- 3D DNA Helix (dominant background element) --- */
  .sn-showcase .sidebar-dna-scene {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 85%;
    height: 90%;
    z-index: 0;
    pointer-events: none;
    perspective: 600px;
    perspective-origin: 50% 50%;
    opacity: 0.4;
    transition: opacity 0.5s ease, transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sn-showcase .mega-sidebar:hover .sidebar-dna-scene {
    opacity: 0.55;
    transform: translate(-50%, -50%) scale(1.04);
  }

  .sn-showcase .sidebar-dna-helix {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 200px;
    transform-style: preserve-3d;
    animation: sn-dna-rotate 10s linear infinite;
    will-change: transform;
    scale: 1.8;
  }

  @keyframes sn-dna-rotate {
    from { transform: translate(-50%, -50%) rotateY(0deg) rotateX(-5deg); }
    to { transform: translate(-50%, -50%) rotateY(360deg) rotateX(-5deg); }
  }

  .sn-showcase .dna-pair {
    position: absolute;
    left: 50%;
    width: 80px;
    height: 5px;
    transform-style: preserve-3d;
    top: calc(var(--pair-i) * 16.5px + 2px);
    transform: translateX(-50%) rotateY(calc(var(--pair-i) * 30deg));
  }

  .sn-showcase .dna-rung {
    position: absolute;
    top: 50%;
    left: 10px;
    right: 10px;
    height: 2px;
    transform: translateY(-50%);
    background: linear-gradient(
      90deg,
      rgba(6, 182, 212, 0.6) 0%,
      rgba(139, 92, 246, 0.4) 50%,
      rgba(236, 72, 153, 0.6) 100%
    );
    border-radius: 1px;
    box-shadow: 0 0 6px rgba(139, 92, 246, 0.15);
  }

  .sn-showcase .dna-node {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    top: 50%;
    transform: translateY(-50%);
  }

  .sn-showcase .dna-node-l {
    left: 0;
    background: radial-gradient(circle, #06b6d4 20%, rgba(6, 182, 212, 0.5) 70%, transparent 100%);
    box-shadow:
      0 0 10px rgba(6, 182, 212, 0.8),
      0 0 20px rgba(6, 182, 212, 0.3),
      0 0 40px rgba(6, 182, 212, 0.1);
  }

  .sn-showcase .dna-node-r {
    right: 0;
    background: radial-gradient(circle, #ec4899 20%, rgba(236, 72, 153, 0.5) 70%, transparent 100%);
    box-shadow:
      0 0 10px rgba(236, 72, 153, 0.8),
      0 0 20px rgba(236, 72, 153, 0.3),
      0 0 40px rgba(236, 72, 153, 0.1);
  }

  .sn-showcase .mega-sidebar:hover .dna-node-l {
    box-shadow:
      0 0 14px rgba(6, 182, 212, 1),
      0 0 30px rgba(6, 182, 212, 0.5),
      0 0 60px rgba(6, 182, 212, 0.2);
  }

  .sn-showcase .mega-sidebar:hover .dna-node-r {
    box-shadow:
      0 0 14px rgba(236, 72, 153, 1),
      0 0 30px rgba(236, 72, 153, 0.5),
      0 0 60px rgba(236, 72, 153, 0.2);
  }

  .sn-showcase .mega-sidebar:hover .dna-rung {
    height: 2.5px;
    background: linear-gradient(
      90deg,
      rgba(6, 182, 212, 0.9) 0%,
      rgba(139, 92, 246, 0.7) 50%,
      rgba(236, 72, 153, 0.9) 100%
    );
    box-shadow: 0 0 12px rgba(139, 92, 246, 0.3);
  }

  /* --- Floating glow particles (8 particles) --- */
  .sn-showcase .sidebar-particles {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .sn-showcase .glow-particle {
    position: absolute;
    border-radius: 50%;
    will-change: transform, opacity;
  }

  .sn-showcase .gp-1 {
    width: 5px; height: 5px; top: 18%; left: 12%;
    background: rgba(6, 182, 212, 0.35);
    box-shadow: 0 0 6px rgba(6, 182, 212, 0.2);
    animation: sn-particle-float-1 5s ease-in-out infinite;
  }

  .sn-showcase .gp-2 {
    width: 4px; height: 4px; top: 38%; left: 82%;
    background: rgba(139, 92, 246, 0.35);
    box-shadow: 0 0 6px rgba(139, 92, 246, 0.2);
    animation: sn-particle-float-2 7s ease-in-out infinite 0.8s;
  }

  .sn-showcase .gp-3 {
    width: 4px; height: 4px; top: 62%; left: 22%;
    background: rgba(236, 72, 153, 0.3);
    box-shadow: 0 0 6px rgba(236, 72, 153, 0.15);
    animation: sn-particle-float-3 6s ease-in-out infinite 1.5s;
  }

  .sn-showcase .gp-4 {
    width: 3px; height: 3px; top: 78%; left: 68%;
    background: rgba(6, 182, 212, 0.25);
    box-shadow: 0 0 4px rgba(6, 182, 212, 0.15);
    animation: sn-particle-float-1 8s ease-in-out infinite 2.5s;
  }

  .sn-showcase .gp-5 {
    width: 4px; height: 4px; top: 8%; left: 58%;
    background: rgba(102, 126, 234, 0.3);
    box-shadow: 0 0 6px rgba(102, 126, 234, 0.15);
    animation: sn-particle-float-2 4.5s ease-in-out infinite 0.3s;
  }

  .sn-showcase .gp-6 {
    width: 3px; height: 3px; top: 48%; left: 42%;
    background: rgba(236, 72, 153, 0.25);
    box-shadow: 0 0 4px rgba(236, 72, 153, 0.15);
    animation: sn-particle-float-3 9s ease-in-out infinite 3.5s;
  }

  .sn-showcase .gp-7 {
    width: 3px; height: 3px; top: 88%; left: 35%;
    background: rgba(102, 126, 234, 0.3);
    box-shadow: 0 0 4px rgba(102, 126, 234, 0.15);
    animation: sn-particle-float-1 7.5s ease-in-out infinite 1s;
  }

  .sn-showcase .gp-8 {
    width: 5px; height: 5px; top: 28%; left: 90%;
    background: rgba(6, 182, 212, 0.3);
    box-shadow: 0 0 6px rgba(6, 182, 212, 0.15);
    animation: sn-particle-float-2 6s ease-in-out infinite 2s;
  }

  @keyframes sn-particle-float-1 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.15; }
    25% { transform: translate(10px, -14px) scale(1.1); opacity: 0.4; }
    50% { transform: translate(-6px, -24px) scale(0.85); opacity: 0.25; }
    75% { transform: translate(5px, -10px) scale(1.05); opacity: 0.45; }
  }

  @keyframes sn-particle-float-2 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.12; }
    33% { transform: translate(-12px, -16px) scale(1.1); opacity: 0.35; }
    66% { transform: translate(8px, -28px) scale(0.8); opacity: 0.25; }
  }

  @keyframes sn-particle-float-3 {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.15; }
    50% { transform: translate(-8px, -18px) scale(1.08); opacity: 0.4; }
  }

  /* --- Content layer --- */
  .sn-showcase .sidebar-content {
    position: relative;
    z-index: 2;
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.875rem;
    height: 100%;
    justify-content: center;
    opacity: 0;
    transform: translateY(16px) scale(0.95);
    transition:
      opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 400ms;
  }

  .sn-showcase .showcase-panel.is-open .sidebar-content {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* --- Eyebrow label --- */
  .sn-showcase .sidebar-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(6, 182, 212, 0.9);
    background: rgba(6, 182, 212, 0.1);
    border: 1px solid rgba(6, 182, 212, 0.2);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    text-shadow: 0 0 14px rgba(6, 182, 212, 0.4);
    box-shadow: 0 0 12px rgba(6, 182, 212, 0.06);
  }

  .sn-showcase .sidebar-eyebrow i {
    font-size: 0.5rem;
    animation: sn-sparkle-spin 3s linear infinite;
  }

  @keyframes sn-sparkle-spin {
    0%, 100% { transform: rotate(0deg) scale(1); }
    25% { transform: rotate(15deg) scale(1.15); }
    50% { transform: rotate(0deg) scale(1); }
    75% { transform: rotate(-15deg) scale(1.15); }
  }

  .sn-showcase .mega-sidebar:hover .sidebar-eyebrow {
    color: #06b6d4;
    background: rgba(6, 182, 212, 0.14);
    border-color: rgba(6, 182, 212, 0.35);
    box-shadow: 0 0 12px rgba(6, 182, 212, 0.08);
    text-shadow: 0 0 14px rgba(6, 182, 212, 0.4);
  }

  /* --- Hero headline with gradient --- */
  .sn-showcase .sidebar-headline {
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.06em;
    position: relative;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.5s ease;
  }

  .sn-showcase .headline-text {
    background: linear-gradient(
      135deg,
      #06b6d4 0%,
      #667eea 20%,
      #8b5cf6 40%,
      #ec4899 60%,
      #06b6d4 80%,
      #667eea 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    animation: sn-headline-gradient-shift 14s ease-in-out infinite;
    filter: drop-shadow(0 0 25px rgba(102, 126, 234, 0.2))
            drop-shadow(0 0 50px rgba(139, 92, 246, 0.1))
            drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
  }

  .sn-showcase .mega-sidebar:hover .sidebar-headline {
    transform: scale(1.02);
  }

  .sn-showcase .mega-sidebar:hover .headline-text {
    filter: drop-shadow(0 0 25px rgba(102, 126, 234, 0.25))
            drop-shadow(0 0 50px rgba(139, 92, 246, 0.12))
            drop-shadow(0 2px 4px rgba(0, 0, 0, 0.35));
  }

  @keyframes sn-headline-gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    25% { background-position: 50% 100%; }
    50% { background-position: 100% 50%; }
    75% { background-position: 50% 0%; }
  }

  /* --- Subtitle --- */
  .sn-showcase .sidebar-subtitle {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.4;
    margin: 0;
    letter-spacing: 0.01em;
    opacity: 1;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sn-showcase .mega-sidebar:hover .sidebar-subtitle {
    opacity: 1;
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 0 0 24px rgba(255, 255, 255, 0.15);
    letter-spacing: 0.04em;
  }

  /* --- Stats as inline pills --- */
  .sn-showcase .sidebar-stats-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    padding: 0.375rem 0;
  }

  .sn-showcase .stat-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.65);
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .sn-showcase .stat-pill-icon {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(102, 126, 234, 0.6);
    flex-shrink: 0;
    animation: sn-stat-dot-pulse 2s ease-in-out infinite;
  }

  .sn-showcase .stat-pill:nth-child(3) .stat-pill-icon {
    background: rgba(139, 92, 246, 0.6);
    animation-delay: 0.4s;
  }

  .sn-showcase .stat-pill:nth-child(5) .stat-pill-icon {
    background: rgba(6, 182, 212, 0.6);
    animation-delay: 0.8s;
  }

  @keyframes sn-stat-dot-pulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.4); box-shadow: 0 0 8px currentColor; }
  }

  .sn-showcase .stat-pill-separator {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .sn-showcase .mega-sidebar:hover .stat-pill {
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 0 12px rgba(255, 255, 255, 0.15);
  }

  .sn-showcase .mega-sidebar:hover .stat-pill-separator {
    background: rgba(102, 126, 234, 0.7);
    box-shadow: 0 0 10px rgba(102, 126, 234, 0.6);
  }

  /* --- CTA indicator with pulse glow --- */
  .sn-showcase .sidebar-cta-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.375rem;
    padding: 0.5625rem 1.375rem;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: white;
    background: linear-gradient(
      135deg,
      rgba(102, 126, 234, 0.3) 0%,
      rgba(139, 92, 246, 0.3) 50%,
      rgba(236, 72, 153, 0.25) 100%
    );
    border: 1.5px solid rgba(102, 126, 234, 0.3);
    transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    animation: sn-cta-mega-pulse 2.5s ease-in-out infinite;
    position: relative;
    overflow: hidden;
  }

  .sn-showcase .cta-shimmer {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.08) 40%,
      rgba(255, 255, 255, 0.15) 50%,
      rgba(255, 255, 255, 0.08) 60%,
      transparent 100%
    );
    animation: sn-cta-shimmer-slide 3s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes sn-cta-shimmer-slide {
    0%, 100% { left: -100%; }
    50% { left: 100%; }
  }

  .sn-showcase .sidebar-cta-indicator::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      rgba(102, 126, 234, 0.2) 0%,
      rgba(139, 92, 246, 0.15) 50%,
      rgba(6, 182, 212, 0.2) 100%
    );
    filter: blur(10px);
    opacity: 0;
    z-index: -1;
    transition: opacity 0.4s ease;
    animation: sn-cta-mega-pulse 2.5s ease-in-out infinite;
  }

  @keyframes sn-cta-mega-pulse {
    0%, 100% {
      box-shadow:
        0 0 12px rgba(102, 126, 234, 0.08),
        0 0 24px rgba(139, 92, 246, 0.04);
    }
    50% {
      box-shadow:
        0 0 18px rgba(102, 126, 234, 0.15),
        0 0 36px rgba(139, 92, 246, 0.06);
    }
  }

  .sn-showcase .mega-sidebar:hover .sidebar-cta-indicator {
    background: linear-gradient(
      135deg,
      rgba(102, 126, 234, 0.38) 0%,
      rgba(139, 92, 246, 0.35) 50%,
      rgba(236, 72, 153, 0.3) 100%
    );
    border-color: rgba(102, 126, 234, 0.5);
    box-shadow:
      0 2px 16px rgba(102, 126, 234, 0.2),
      0 0 30px rgba(139, 92, 246, 0.08);
    transform: translateY(-1px) scale(1.02);
    animation: none;
  }

  .sn-showcase .mega-sidebar:hover .sidebar-cta-indicator::before {
    opacity: 1;
    animation: none;
  }

  .sn-showcase .cta-text {
    position: relative;
    z-index: 1;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sn-showcase .mega-sidebar:hover .cta-text {
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.15);
  }

  .sn-showcase .cta-arrow-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    width: 16px;
    position: relative;
    z-index: 1;
  }

  .sn-showcase .cta-arrow {
    font-size: 0.6875rem;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sn-showcase .mega-sidebar:hover .cta-arrow {
    transform: translateX(2px);
    animation: sn-arrow-nudge 1.5s ease-in-out infinite 0.2s;
  }

  @keyframes sn-arrow-nudge {
    0%, 100% { transform: translateX(2px); }
    50% { transform: translateX(5px); }
  }

  /* --- Desktop width override --- */
  @media (min-width: 50rem) {
    .sn-showcase .mega-sidebar {
      width: 320px;
    }
  }

  /* --- Mobile: full-width stacking --- */
  @media (max-width: 49.99rem) {
    .sn-showcase .mega-sidebar {
      width: 100%;
      border-left: none;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      min-height: 160px;
      order: -1;
    }

    .sn-showcase .sidebar-dna-scene {
      top: 50%;
      left: 0;
      transform: translateY(-50%);
      width: 120px;
      height: 85%;
    }

    .sn-showcase .sidebar-content {
      padding: 1.25rem 1.5rem 1.25rem 130px;
      align-items: flex-start;
      text-align: left;
    }

    .sn-showcase .sidebar-headline {
      font-size: 1.75rem;
    }

    .sn-showcase .headline-text br {
      display: none;
    }

    .sn-showcase .sidebar-stat-row {
      justify-content: flex-start;
    }

    .sn-showcase .mega-sidebar:hover .sidebar-dna-scene {
      transform: translateY(-50%);
    }
  }

  /* ==========================================
     LIGHT THEME ADJUSTMENTS
