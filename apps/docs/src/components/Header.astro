---
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const showcasePages = [
  {
    href: '/enterprise-architecture/',
    icon: 'fa-solid fa-building',
    title: 'Enterprise Architecture',
    desc: 'TypeScript-first, CEM-driven, token-powered',
    colorClass: 'sc-cyan',
    color: '#06b6d4',
    tag: 'Architecture',
  },
  {
    href: '/tech-stack/',
    icon: 'fa-solid fa-layer-group',
    title: 'The 2026 Stack',
    desc: 'Lit 3, Vite 7, Storybook 8, Web Test Runner',
    colorClass: 'sc-accent',
    color: '#8b5cf6',
    tag: 'Tooling',
  },
  {
    href: '/drupal-architecture/',
    icon: 'fa-brands fa-drupal',
    title: 'Drupal Integration',
    desc: 'CEM-to-Drupal pipeline, TWIG templates, SDC',
    colorClass: 'sc-amber',
    color: '#f59e0b',
    tag: 'Integration',
  },
  {
    href: '/healthcare-accessibility/',
    icon: 'fa-solid fa-universal-access',
    title: 'Healthcare & A11y',
    desc: 'WCAG 2.2 AA, Section 508, HIPAA-ready',
    colorClass: 'sc-green',
    color: '#10b981',
    tag: 'Compliance',
  },
  {
    href: '/developer-experience/',
    icon: 'fa-solid fa-rocket',
    title: 'Developer Experience',
    desc: 'Quality pipeline & DX',
    colorClass: 'sc-electric',
    color: '#3b82f6',
    tag: 'DX',
  },
];

const currentPath = Astro.url.pathname;
---

<div class="header sl-flex">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>

  <wc-showcase-dropdown class="showcase-dropdown print:hidden">
    <button
      class="showcase-trigger"
      aria-expanded="false"
      aria-haspopup="true"
      aria-label="Showcase pages"
    >
      <span class="trigger-icon-wrap">
        <i class="fa-solid fa-compass" aria-hidden="true"></i>
      </span>
      <span class="showcase-trigger-text">Showcases</span>
      <i class="fa-solid fa-chevron-down showcase-chevron" aria-hidden="true"></i>
    </button>

    <div class="showcase-panel" role="menu" aria-label="Showcase pages">
      <!-- Molecular particle canvas -->
      <canvas class="panel-particles" aria-hidden="true"></canvas>

      <div class="mega-layout">
        <!-- Left column: showcase cards -->
        <div class="mega-main">
          <div class="mega-main-header">
            <span class="showcase-panel-badge">
              <i class="fa-solid fa-star" aria-hidden="true"></i>
              Visual Experiences
            </span>
          </div>
          <div class="mega-grid">
            {showcasePages.map((page, index) => (
              <a
                href={page.href}
                class:list={['showcase-item', page.colorClass, { 'is-active': currentPath.startsWith(page.href) }]}
                role="menuitem"
                style={`--item-index: ${index}; --item-color: ${page.color};`}
              >
                <div class="showcase-item-icon">
                  <i class={page.icon} aria-hidden="true"></i>
                  <div class="icon-glow" aria-hidden="true"></div>
                </div>
                <div class="showcase-item-text">
                  <div class="showcase-item-title-row">
                    <span class="showcase-item-title">{page.title}</span>
                    <span class="showcase-item-tag">{page.tag}</span>
                  </div>
                  <div class="showcase-item-desc">{page.desc}</div>
                </div>
                <div class="showcase-item-arrow-wrap">
                  <i class="fa-solid fa-arrow-right showcase-item-arrow" aria-hidden="true"></i>
                </div>
                <div class="item-accent-line" aria-hidden="true"></div>
              </a>
            ))}
          </div>
        </div>

        <!-- Right column: featured area -->
        <div class="mega-sidebar">
          <div class="sidebar-content">
            <div class="sidebar-visual" aria-hidden="true">
              <div class="visual-ring ring-1"></div>
              <div class="visual-ring ring-2"></div>
              <div class="visual-ring ring-3"></div>
              <div class="visual-core"></div>
            </div>

            <div class="sidebar-headline">Explore the System</div>
            <p class="sidebar-desc">
              Five immersive deep-dives into enterprise web component architecture, from design tokens to deployment pipelines.
            </p>

            <div class="sidebar-stats">
              <div class="stat-item">
                <span class="stat-value">5</span>
                <span class="stat-label">Showcases</span>
              </div>
              <div class="stat-divider" aria-hidden="true"></div>
              <div class="stat-item">
                <span class="stat-value">15K+</span>
                <span class="stat-label">Lines of Docs</span>
              </div>
              <div class="stat-divider" aria-hidden="true"></div>
              <div class="stat-item">
                <span class="stat-value">2026</span>
                <span class="stat-label">Stack</span>
              </div>
            </div>

            <a href="/enterprise-architecture/" class="sidebar-cta">
              <span>Start Exploring</span>
              <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </wc-showcase-dropdown>

  <div class="sl-flex right-group print:hidden">
    {shouldRenderSearch && <Search />}
    <div class="sl-hidden md:sl-flex right-inner">
      <div class="sl-flex social-icons">
        <SocialIcons />
      </div>
      <ThemeSelect />
      <LanguageSelect />
    </div>
    <button class="logout-btn" type="button" aria-label="Lock site" title="Lock site">
      <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
    </button>
  </div>
</div>

<script>
  class WcShowcaseDropdown extends HTMLElement {
    trigger: HTMLButtonElement;
    panel: HTMLElement;
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D | null = null;
    animFrame: number = 0;
    particles: { x: number; y: number; size: number; vx: number; vy: number; color: string; opacity: number }[] = [];

    constructor() {
      super();
      this.trigger = this.querySelector('.showcase-trigger')!;
      this.panel = this.querySelector('.showcase-panel')!;
      this.canvas = this.querySelector('.panel-particles')!;

      this.trigger.addEventListener('click', () => this.toggle());

      this.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          this.close();
          this.trigger.focus();
        }
      });

      document.addEventListener('click', (e) => {
        if (!this.contains(e.target as Node)) {
          this.close();
        }
      });

      this.panel.addEventListener('keydown', (e) => {
        const items = [...this.panel.querySelectorAll('.showcase-item')] as HTMLElement[];
        const idx = items.indexOf(document.activeElement as HTMLElement);
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          items[(idx + 1) % items.length]?.focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          items[(idx - 1 + items.length) % items.length]?.focus();
        }
      });
    }

    initParticles() {
      const w = this.canvas.width;
      const h = this.canvas.height;
      const colors = [
        'rgba(6, 182, 212,',   // cyan-500
        'rgba(16, 185, 129,',  // emerald-500
        'rgba(102, 126, 234,', // indigo
        'rgba(20, 184, 166,',  // teal-500
        'rgba(59, 130, 246,',  // blue-500
      ];
      this.particles = [];
      const count = 50;
      for (let i = 0; i < count; i++) {
        this.particles.push({
          x: Math.random() * w,
          y: Math.random() * h,
          size: Math.random() * 2 + 0.8,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          color: colors[Math.floor(Math.random() * colors.length)]!,
          opacity: Math.random() * 0.4 + 0.15,
        });
      }
    }

    animateParticles() {
      if (!this.ctx) return;
      const ctx = this.ctx;
      const w = this.canvas.width;
      const h = this.canvas.height;

      ctx.clearRect(0, 0, w, h);

      // Update + draw particles
      for (const p of this.particles) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x > w) p.x = 0;
        if (p.x < 0) p.x = w;
        if (p.y > h) p.y = 0;
        if (p.y < 0) p.y = h;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = p.color + p.opacity + ')';
        ctx.fill();
      }

      // Draw molecular connections
      const maxDist = 100;
      for (let i = 0; i < this.particles.length; i++) {
        const a = this.particles[i]!;
        for (let j = i + 1; j < this.particles.length; j++) {
          const b = this.particles[j]!;
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < maxDist) {
            const alpha = 0.08 * (1 - dist / maxDist);
            ctx.beginPath();
            ctx.strokeStyle = `rgba(6, 182, 212, ${alpha})`;
            ctx.lineWidth = 0.6;
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }

      this.animFrame = requestAnimationFrame(() => this.animateParticles());
    }

    startParticles() {
      const rect = this.panel.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      this.canvas.width = rect.width * dpr;
      this.canvas.height = rect.height * dpr;
      this.canvas.style.width = rect.width + 'px';
      this.canvas.style.height = rect.height + 'px';
      this.ctx = this.canvas.getContext('2d');
      if (this.ctx) {
        this.ctx.scale(dpr, dpr);
        this.canvas.width = rect.width * dpr;
        this.canvas.height = rect.height * dpr;
      }
      this.initParticles();
      this.animateParticles();
    }

    stopParticles() {
      cancelAnimationFrame(this.animFrame);
    }

    toggle() {
      this.trigger.getAttribute('aria-expanded') === 'true' ? this.close() : this.open();
    }

    open() {
      this.trigger.setAttribute('aria-expanded', 'true');
      this.panel.style.display = 'flex';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          this.panel.classList.add('is-open');
          this.startParticles();
        });
      });
    }

    close() {
      this.trigger.setAttribute('aria-expanded', 'false');
      this.panel.classList.remove('is-open');
      this.stopParticles();
      const panel = this.panel;
      setTimeout(() => {
        if (this.trigger.getAttribute('aria-expanded') !== 'true') {
          panel.style.display = 'none';
        }
      }, 350);
    }
  }

  customElements.define('wc-showcase-dropdown', WcShowcaseDropdown);

  // Logout button — clears auth and re-shows PIN gate
  const logoutBtn = document.querySelector('.logout-btn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', () => {
      localStorage.removeItem('wc-auth');
      const gate = document.querySelector('#wc-pin-gate') as HTMLElement | null;
      if (gate && typeof (gate as any).show === 'function') {
        (gate as any).show();
      } else {
        window.location.reload();
      }
    });
  }
</script>

<style>
  /* ==========================================
     HEADER LAYOUT
     ========================================== */
  .header {
    display: flex !important;
    align-items: center;
    gap: var(--sl-nav-gap);
    height: 100%;
  }

  .title-wrapper {
    overflow: clip;
    padding: 0.25rem;
    margin: -0.25rem;
    min-width: 0;
    flex-shrink: 0;
  }

  .right-group {
    margin-left: auto;
    gap: 1rem;
    align-items: center;
    flex-shrink: 0;
  }

  .logout-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--sl-color-gray-4);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s ease;
    opacity: 0.4;
    flex-shrink: 0;
  }

  .logout-btn:hover {
    opacity: 1;
    color: #ef4444;
    background: rgba(239, 68, 68, 0.08);
  }

  .right-inner {
    gap: 1rem;
    align-items: center;
  }

  .social-icons {
    gap: 1rem;
    align-items: center;
  }

  .social-icons::after {
    content: '';
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }

  /* ==========================================
     SHOWCASE DROPDOWN - TRIGGER
     ========================================== */
  .showcase-dropdown {
    position: relative;
    flex-shrink: 0;
  }

  .showcase-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.625rem;
    background: rgba(255, 255, 255, 0.03);
    color: var(--sl-color-gray-2);
    font-family: var(--sl-font);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    white-space: nowrap;
    line-height: 1;
    position: relative;
  }

  .trigger-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 6px;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(139, 92, 246, 0.15));
    font-size: 0.6875rem;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .showcase-trigger:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    color: var(--sl-color-white);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .showcase-trigger:hover .trigger-icon-wrap {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.25), rgba(139, 92, 246, 0.25));
    box-shadow: 0 0 12px rgba(102, 126, 234, 0.2);
  }

  .showcase-trigger[aria-expanded='true'] {
    background: rgba(102, 126, 234, 0.08);
    border-color: rgba(102, 126, 234, 0.3);
    color: var(--sl-color-white);
    box-shadow:
      0 0 0 1px rgba(102, 126, 234, 0.2),
      0 4px 24px rgba(102, 126, 234, 0.15);
  }

  .showcase-trigger[aria-expanded='true'] .trigger-icon-wrap {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.3), rgba(139, 92, 246, 0.3));
    box-shadow: 0 0 16px rgba(102, 126, 234, 0.3);
  }

  .showcase-trigger:focus-visible {
    outline: 3px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .showcase-trigger-text {
    display: none;
  }

  .showcase-chevron {
    font-size: 0.5625rem;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    display: none;
    opacity: 0.6;
  }

  .showcase-trigger[aria-expanded='true'] .showcase-chevron {
    transform: rotate(180deg);
  }

  @media (min-width: 50rem) {
    .showcase-trigger {
      padding: 0.45rem 0.85rem;
    }
    .showcase-trigger-text {
      display: inline;
    }
    .showcase-chevron {
      display: inline;
    }
  }

  /* ==========================================
     SHOWCASE DROPDOWN - MEGA PANEL
     ========================================== */
  .showcase-panel {
    display: none;
    flex-direction: column;
    position: absolute;
    top: calc(100% + 0.75rem);
    left: 0;
    width: 720px;
    max-width: calc(100vw - 2rem);
    padding: 0;
    background: rgba(10, 10, 24, 0.95);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 1rem;
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.55),
      0 8px 32px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    z-index: 200;
    opacity: 0;
    transform: translateY(-12px) scale(0.97);
    transition:
      opacity 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }

  .showcase-panel.is-open {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* Molecular particle canvas */
  .panel-particles {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.6s ease 0.15s;
  }

  .showcase-panel.is-open .panel-particles {
    opacity: 0.7;
  }

  /* Mobile: full-width fixed panel */
  @media (max-width: 49.99rem) {
    .showcase-panel {
      position: fixed;
      top: var(--sl-nav-height);
      left: 0.5rem;
      right: 0.5rem;
      width: auto;
      max-width: none;
      max-height: calc(100vh - var(--sl-nav-height) - 1rem);
      overflow-y: auto;
      transform: translateY(-12px) scale(0.98);
      border-top-left-radius: 0;
      border-top-right-radius: 0;
    }
    .showcase-panel.is-open {
      transform: translateY(0) scale(1);
    }
  }

  /* ==========================================
     MEGA LAYOUT
     ========================================== */
  .mega-layout {
    display: flex;
    position: relative;
    z-index: 1;
  }

  .mega-main {
    flex: 1;
    min-width: 0;
    padding: 0.75rem;
  }

  .mega-sidebar {
    width: 240px;
    flex-shrink: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 49.99rem) {
    .mega-layout {
      flex-direction: column;
    }
    .mega-sidebar {
      width: 100%;
      border-left: none;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }
  }

  /* ==========================================
     MAIN COLUMN HEADER
     ========================================== */
  .mega-main-header {
    padding: 0.25rem 0.5rem 0.5rem;
  }

  .showcase-panel-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(102, 126, 234, 0.7);
  }

  .showcase-panel-badge i {
    font-size: 0.5rem;
  }

  /* ==========================================
     MEGA GRID - SHOWCASE ITEMS
     ========================================== */
  .mega-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .showcase-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem 0.75rem;
    border-radius: 0.75rem;
    text-decoration: none !important;
    color: inherit;
    transition:
      background 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    border: 1px solid transparent;
    position: relative;
    overflow: hidden;
    /* Stagger animation */
    opacity: 0;
    transform: translateX(-8px);
  }

  .showcase-panel.is-open .showcase-item {
    opacity: 1;
    transform: translateX(0);
    transition:
      background 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--item-index, 0) * 50ms + 80ms);
  }

  .showcase-item:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.08);
    transform: translateX(4px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .showcase-item:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: -2px;
  }

  /* Active page indicator */
  .showcase-item.is-active {
    background: rgba(102, 126, 234, 0.06);
    border-color: rgba(102, 126, 234, 0.2);
    box-shadow:
      0 0 20px rgba(102, 126, 234, 0.08),
      inset 0 0 20px rgba(102, 126, 234, 0.03);
  }

  .showcase-item.is-active .item-accent-line {
    opacity: 1 !important;
    width: 3px !important;
  }

  /* Bottom accent line on hover */
  .item-accent-line {
    position: absolute;
    left: 0;
    top: 8px;
    bottom: 8px;
    width: 0;
    border-radius: 0 2px 2px 0;
    background: var(--item-color, #667eea);
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 0 12px var(--item-color, #667eea);
  }

  .showcase-item:hover .item-accent-line {
    opacity: 0.8;
    width: 3px;
  }

  /* ==========================================
     SHOWCASE ITEM - ICON
     ========================================== */
  .showcase-item-icon {
    width: 48px;
    height: 48px;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.125rem;
    flex-shrink: 0;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
  }

  .icon-glow {
    position: absolute;
    inset: -4px;
    border-radius: inherit;
    background: radial-gradient(circle, var(--item-color, transparent) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.3s ease;
    filter: blur(8px);
    pointer-events: none;
  }

  .showcase-item:hover .icon-glow {
    opacity: 0.25;
  }

  .showcase-item:hover .showcase-item-icon {
    transform: scale(1.08);
  }

  /* Color variants for icons */
  .sc-cyan .showcase-item-icon {
    color: #06b6d4;
    background: rgba(6, 182, 212, 0.08);
    border: 1px solid rgba(6, 182, 212, 0.15);
  }
  .sc-cyan:hover .showcase-item-icon {
    background: rgba(6, 182, 212, 0.12);
    border-color: rgba(6, 182, 212, 0.25);
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.15);
  }

  .sc-accent .showcase-item-icon {
