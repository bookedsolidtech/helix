---
/**
 * ComponentLoader — client-side script that imports @helix/library
 * so custom elements register in the browser.
 * Include on any page that renders live web component demos.
 *
 * Uses explicit named imports to prevent tree-shaking from removing
 * the side-effect-only customElements.define() calls.
 */
---

<script>
  import {
    WcButton,
    WcCard,
    WcTextInput,
    WcCheckbox,
    WcSelect,
    WcRadioGroup,
    WcRadio,
    WcAlert,
    WcTextarea,
    WcBadge,
    WcSwitch,
    WcContainer,
    WcForm,
    WcProse,
  } from '@helix/library';

  // Verify registration (dev-only; removed by minifier in production)
  if (import.meta.env.DEV) {
    const expected = [
      'wc-button', 'wc-card', 'wc-text-input', 'wc-checkbox',
      'wc-select', 'wc-radio-group', 'wc-radio', 'wc-alert',
      'wc-textarea', 'wc-badge', 'wc-switch', 'wc-container',
      'wc-form', 'wc-prose',
    ];
    const missing = expected.filter((tag) => !customElements.get(tag));
    if (missing.length) {
      console.warn('[ComponentLoader] Missing registrations:', missing);
    }
  }
</script>
