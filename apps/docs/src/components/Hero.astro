---
/**
 * Hero Section - 2030-forward dramatic full-viewport showcase.
 *
 * Features:
 * - Animated gradient mesh background with floating orbs
 * - Grid pattern overlay for depth
 * - Extreme typography with weight contrast (300 to 900)
 * - Gradient text effects on title and subtitle
 * - Glassmorphic status badge with pulse indicator
 * - Floating code preview window showing real component usage
 * - Scroll indicator with animated line
 * - Fully responsive (mobile hides code preview)
 * - Respects prefers-reduced-motion
 */
---

<section class="hero-section" aria-label="HELIX - Healthcare Elements Library for Interactive eXperiences">
  <!-- Grid pattern for depth -->
  <div class="hero-grid-pattern" aria-hidden="true"></div>

  <!-- Floating ambient orbs -->
  <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-3" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-4" aria-hidden="true"></div>

  <div class="hero-content">
    <!-- Main heading with DNA helix logo -->
    <h1 class="hero-title">
      <svg class="hero-dna-helix" viewBox="0 0 100 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="dna-gradient-1" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:1" />
            <stop offset="50%" style="stop-color:#8b5cf6;stop-opacity:1" />
            <stop offset="100%" style="stop-color:#ec4899;stop-opacity:1" />
          </linearGradient>
          <linearGradient id="dna-gradient-2" x1="100%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" style="stop-color:#ec4899;stop-opacity:1" />
            <stop offset="50%" style="stop-color:#f97316;stop-opacity:1" />
            <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:1" />
          </linearGradient>
          <filter id="dna-glow">
            <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
            <feMerge>
              <feMergeNode in="coloredBlur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>

        <!-- Left strand (helix path) -->
        <path class="dna-strand dna-strand-left" d="M 25,0 Q 10,25 25,50 T 25,100 T 25,150 T 25,200"
              stroke="url(#dna-gradient-1)" stroke-width="3" fill="none" filter="url(#dna-glow)" stroke-linecap="round"/>

        <!-- Right strand (helix path) -->
        <path class="dna-strand dna-strand-right" d="M 75,0 Q 90,25 75,50 T 75,100 T 75,150 T 75,200"
              stroke="url(#dna-gradient-2)" stroke-width="3" fill="none" filter="url(#dna-glow)" stroke-linecap="round"/>

        <!-- Base pairs (connecting lines) -->
        <line class="dna-base" x1="25" y1="12.5" x2="75" y2="12.5" stroke="url(#dna-gradient-1)" stroke-width="2" opacity="0.6"/>
        <line class="dna-base" x1="25" y1="37.5" x2="75" y2="37.5" stroke="url(#dna-gradient-2)" stroke-width="2" opacity="0.6"/>
        <line class="dna-base" x1="25" y1="62.5" x2="75" y2="62.5" stroke="url(#dna-gradient-1)" stroke-width="2" opacity="0.6"/>
        <line class="dna-base" x1="25" y1="87.5" x2="75" y2="87.5" stroke="url(#dna-gradient-2)" stroke-width="2" opacity="0.6"/>
        <line class="dna-base" x1="25" y1="112.5" x2="75" y2="112.5" stroke="url(#dna-gradient-1)" stroke-width="2" opacity="0.6"/>
        <line class="dna-base" x1="25" y1="137.5" x2="75" y2="137.5" stroke="url(#dna-gradient-2)" stroke-width="2" opacity="0.6"/>
        <line class="dna-base" x1="25" y1="162.5" x2="75" y2="162.5" stroke="url(#dna-gradient-1)" stroke-width="2" opacity="0.6"/>
        <line class="dna-base" x1="25" y1="187.5" x2="75" y2="187.5" stroke="url(#dna-gradient-2)" stroke-width="2" opacity="0.6"/>

        <!-- Strand nodes (circles at intersections) -->
        <circle class="dna-node" cx="25" cy="0" r="4" fill="url(#dna-gradient-1)" filter="url(#dna-glow)"/>
        <circle class="dna-node" cx="75" cy="0" r="4" fill="url(#dna-gradient-2)" filter="url(#dna-glow)"/>
        <circle class="dna-node" cx="25" cy="50" r="4" fill="url(#dna-gradient-1)" filter="url(#dna-glow)"/>
        <circle class="dna-node" cx="75" cy="50" r="4" fill="url(#dna-gradient-2)" filter="url(#dna-glow)"/>
        <circle class="dna-node" cx="25" cy="100" r="4" fill="url(#dna-gradient-1)" filter="url(#dna-glow)"/>
        <circle class="dna-node" cx="75" cy="100" r="4" fill="url(#dna-gradient-2)" filter="url(#dna-glow)"/>
        <circle class="dna-node" cx="25" cy="150" r="4" fill="url(#dna-gradient-1)" filter="url(#dna-glow)"/>
        <circle class="dna-node" cx="75" cy="150" r="4" fill="url(#dna-gradient-2)" filter="url(#dna-glow)"/>
        <circle class="dna-node" cx="25" cy="200" r="4" fill="url(#dna-gradient-1)" filter="url(#dna-glow)"/>
        <circle class="dna-node" cx="75" cy="200" r="4" fill="url(#dna-gradient-2)" filter="url(#dna-glow)"/>
      </svg>
      <span class="hero-title-text">HELiX</span>
    </h1>

    <!-- Subtitle - light weight contrast -->
    <p class="hero-subtitle">Healthcare Elements Library for Interactive eXperiences</p>

    <!-- Description -->
    <p class="hero-description">
      Production-ready Lit&nbsp;3.x components with a three-tier design token system,
      WCAG&nbsp;2.1&nbsp;AAA accessibility, and seamless Drupal&nbsp;CMS integration.
      Built for healthcare organizations that refuse to compromise.
    </p>

    <!-- Call to action buttons -->
    <div class="hero-cta">
      <a href="/getting-started/installation/" class="btn btn-primary">
        Get Started
        <span class="btn-arrow" aria-hidden="true">&rarr;</span>
      </a>
      <a href="/pre-planning/overview/" class="btn btn-secondary">
        View Architecture
        <span class="btn-arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>

  </div>

  <!-- Scroll indicator (mouse) — clicks scroll to next section -->
  <div class="mouse-scroll-wrap mouse-scroll-wrap--absolute hero-scroll-btn" role="button" tabindex="0" aria-label="Scroll to content">
    <div class="mouse-scroll-body"><div class="mouse-scroll-wheel"></div></div>
    <span class="mouse-scroll-label">Scroll</span>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.querySelector('.hero-scroll-btn');
    if (!btn) return;
    const scroll = () => {
      const hero = document.querySelector('.hero-section');
      if (!hero) return;
      const next = hero.nextElementSibling as HTMLElement | null;
      if (!next) return;
      const style = getComputedStyle(document.documentElement);
      const navRem = parseFloat(style.getPropertyValue('--sl-nav-height'));
      const fontSize = parseFloat(style.fontSize);
      window.scrollTo({ top: next.offsetTop - (navRem * fontSize), behavior: 'smooth' });
    };
    btn.addEventListener('click', scroll);
    btn.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        scroll();
      }
    });
  });
</script>
