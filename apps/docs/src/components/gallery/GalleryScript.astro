---
/**
 * GalleryScript — All client-side JavaScript for the Component Gallery.
 * Handles scroll reveal, dot nav, search, category filtering, keyboard nav, URL hash.
 */
---

<script is:inline>
(function () {
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── A. Scroll reveal ──────────────────────────────────────────────
  if (prefersReduced) {
    document.querySelectorAll('.scroll-reveal').forEach(function (el) {
      el.classList.add('is-visible');
    });
  } else {
    var revealObserver = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
    );
    document.querySelectorAll('.scroll-reveal').forEach(function (el) {
      revealObserver.observe(el);
    });
  }

  // ── B. Dot navigation ────────────────────────────────────────────
  var dots = document.querySelectorAll('.cg-dot');
  var sections = document.querySelectorAll('.cg-slide');
  var container = document.querySelector('.cg-container');

  dots.forEach(function (dot) {
    dot.addEventListener('click', function () {
      var slideId = dot.getAttribute('data-slide');
      var target = document.getElementById(slideId);
      if (target) {
        target.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth' });
      }
    });
  });

  var dotObserver = new IntersectionObserver(
    function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var id = entry.target.id;
          dots.forEach(function (d) {
            d.classList.toggle('active', d.getAttribute('data-slide') === id);
          });
        }
      });
    },
    { threshold: 0.5, root: container || null }
  );
  sections.forEach(function (s) { dotObserver.observe(s); });

  // ── C. Search filtering ──────────────────────────────────────────
  var searchInput = document.getElementById('cg-search');
  var componentSections = document.querySelectorAll('.cg-slide[data-tag]');

  function filterBySearch(query) {
    var q = (query || '').toLowerCase().trim();
    componentSections.forEach(function (section) {
      var searchable = section.getAttribute('data-searchable') || '';
      var match = !q || searchable.indexOf(q) !== -1;
      section.classList.toggle('cg-hidden', !match);
    });
    updateDotVisibility();
  }

  if (searchInput) {
    searchInput.addEventListener('wc-input', function (e) {
      filterBySearch(e.detail ? e.detail.value : '');
      // Clear category filter when searching
      document.querySelectorAll('.cg-filter-btn').forEach(function (btn) {
        btn.classList.toggle('cg-filter-active', btn.getAttribute('data-category') === 'all');
      });
    });
    searchInput.addEventListener('input', function (e) {
      filterBySearch(e.target.value || '');
    });
  }

  // ── D. Category filtering ────────────────────────────────────────
  var filterBtns = document.querySelectorAll('.cg-filter-btn');

  filterBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var category = btn.getAttribute('data-category');

      // Update active state
      filterBtns.forEach(function (b) { b.classList.remove('cg-filter-active'); });
      btn.classList.add('cg-filter-active');

      // Clear search
      if (searchInput) {
        var innerInput = searchInput.shadowRoot && searchInput.shadowRoot.querySelector('input');
        if (innerInput) innerInput.value = '';
      }

      // Filter sections
      componentSections.forEach(function (section) {
        if (category === 'all') {
          section.classList.remove('cg-hidden');
        } else {
          var sectionCat = section.getAttribute('data-category');
          section.classList.toggle('cg-hidden', sectionCat !== category);
        }
      });
      updateDotVisibility();
    });
  });

  function updateDotVisibility() {
    dots.forEach(function (dot) {
      var slideId = dot.getAttribute('data-slide');
      if (slideId === 'cg-hero') return;
      var section = document.getElementById(slideId);
      if (section) {
        dot.style.display = section.classList.contains('cg-hidden') ? 'none' : '';
      }
    });
  }

  // ── E. Keyboard navigation ──────────────────────────────────────
  document.addEventListener('keydown', function (e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;

    var visibleSections = Array.from(sections).filter(function (s) {
      return !s.classList.contains('cg-hidden');
    });
    if (!visibleSections.length) return;

    var currentIdx = -1;
    visibleSections.forEach(function (s, i) {
      var rect = s.getBoundingClientRect();
      if (rect.top >= -100 && rect.top < window.innerHeight / 2) {
        currentIdx = i;
      }
    });

    var targetIdx = -1;
    if (e.key === 'ArrowDown' || e.key === 'j') {
      targetIdx = Math.min(currentIdx + 1, visibleSections.length - 1);
    } else if (e.key === 'ArrowUp' || e.key === 'k') {
      targetIdx = Math.max(currentIdx - 1, 0);
    } else if (e.key === 'Home') {
      targetIdx = 0;
    } else if (e.key === 'End') {
      targetIdx = visibleSections.length - 1;
    }

    if (targetIdx >= 0 && targetIdx !== currentIdx) {
      e.preventDefault();
      visibleSections[targetIdx].scrollIntoView({
        behavior: prefersReduced ? 'auto' : 'smooth',
      });
    }
  });

  // ── F. URL hash ──────────────────────────────────────────────────
  var hashObserver = new IntersectionObserver(
    function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting && entry.target.id) {
          var newHash = entry.target.id === 'cg-hero' ? '' : entry.target.id;
          if (newHash && history.replaceState) {
            history.replaceState(null, '', '#' + newHash);
          }
        }
      });
    },
    { threshold: 0.5, root: container || null }
  );
  sections.forEach(function (s) { hashObserver.observe(s); });

  // On load, scroll to hash target
  if (location.hash) {
    var hashTarget = document.getElementById(location.hash.substring(1));
    if (hashTarget) {
      setTimeout(function () {
        hashTarget.scrollIntoView({ behavior: 'auto' });
      }, 100);
    }
  }
})();
</script>
