---
/**
 * GalleryHero — Full-VH hero section for the Component Gallery.
 *
 * Shows animated orbs, CEM-driven stats, a search input (dogfooding wc-text-input),
 * and category filter buttons (dogfooding wc-button).
 */
import type { GalleryStats, GalleryCategory } from '../../lib/cem-gallery-utils';
import { getCategoryLabel, getCategoryAccent } from '../../lib/cem-gallery-utils';

interface Props {
  stats: GalleryStats;
  categories: GalleryCategory[];
}

const { stats, categories } = Astro.props;
---

<section class="cg-slide cg-hero" id="cg-hero" aria-label="Component Gallery Hero">
  <div class="cg-particles" aria-hidden="true"></div>
  <div class="cg-grid-bg" aria-hidden="true"></div>
  <div class="cg-orb" style="width:600px;height:600px;background:radial-gradient(circle,rgba(6,182,212,0.15),transparent 70%);top:-15%;right:-10%;animation:float-slow 22s ease-in-out infinite, orb-pulse 8s ease-in-out infinite;" aria-hidden="true"></div>
  <div class="cg-orb" style="width:400px;height:400px;background:radial-gradient(circle,rgba(245,158,11,0.12),transparent 70%);bottom:-10%;left:-8%;animation:float-slow 28s ease-in-out infinite reverse, orb-pulse 10s ease-in-out infinite 2s;" aria-hidden="true"></div>
  <div class="cg-orb" style="width:300px;height:300px;background:radial-gradient(circle,rgba(139,92,246,0.1),transparent 70%);top:30%;left:15%;animation:float-slow 18s ease-in-out infinite 3s;" aria-hidden="true"></div>

  <div class="cg-slide-inner" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.5rem 1.25rem;background:var(--glass-bg-strong);border:1px solid var(--glass-border-strong);border-radius:var(--radius-full);font-size:0.8125rem;font-weight:600;color:var(--wc-cyan);margin-bottom:2rem;animation:fadeInDown 0.8s ease-out;">
      <span style="width:8px;height:8px;border-radius:50%;background:var(--wc-cyan);box-shadow:0 0 8px var(--wc-cyan);animation:pulse-ring 2s ease-out infinite;" aria-hidden="true"></span>
      Component Gallery
    </div>

    <h1 style="font-size:clamp(2.5rem,7vw,4.5rem);font-weight:900;letter-spacing:-0.05em;line-height:1.05;margin-bottom:1.5rem;animation:fadeInUp 0.8s ease-out 0.15s both;">
      The Component<br/>
      <span class="gradient-text">Galaxy</span>
    </h1>

    <p style="font-size:clamp(1.0625rem,2.5vw,1.25rem);color:var(--text-secondary);margin-bottom:2.5rem;animation:fadeInUp 0.8s ease-out 0.3s both;">
      {stats.components} Components. {stats.properties} Properties. One Design System.
    </p>

    <!-- CEM-driven stat counters -->
    <div class="cg-hero-stats scroll-reveal" style="animation:fadeInUp 0.8s ease-out 0.45s both;">
      <div class="cg-hero-stat">
        <span class="cg-hero-stat-value" style="color:var(--wc-cyan);">{stats.components}</span>
        <span class="cg-hero-stat-label">Components</span>
      </div>
      <div class="cg-hero-stat-divider" aria-hidden="true"></div>
      <div class="cg-hero-stat">
        <span class="cg-hero-stat-value" style="color:var(--wc-accent);">{stats.properties}</span>
        <span class="cg-hero-stat-label">Properties</span>
      </div>
      <div class="cg-hero-stat-divider" aria-hidden="true"></div>
      <div class="cg-hero-stat">
        <span class="cg-hero-stat-value" style="color:var(--wc-amber);">{stats.events}</span>
        <span class="cg-hero-stat-label">Events</span>
      </div>
      <div class="cg-hero-stat-divider" aria-hidden="true"></div>
      <div class="cg-hero-stat">
        <span class="cg-hero-stat-value" style="color:var(--wc-green);">{stats.slots}</span>
        <span class="cg-hero-stat-label">Slots</span>
      </div>
    </div>

    <!-- Search (dogfooding wc-text-input) -->
    <div style="max-width:400px;margin:2rem auto 1.5rem;animation:fadeInUp 0.8s ease-out 0.6s both;">
      <wc-text-input id="cg-search" type="search" placeholder="Search components..." aria-label="Search components"></wc-text-input>
    </div>

    <!-- Category filter buttons (dogfooding wc-button) -->
    <div class="cg-hero-filters" style="animation:fadeInUp 0.8s ease-out 0.75s both;">
      <button class="cg-filter-btn cg-filter-active" data-category="all">All</button>
      {categories.map((cat) => (
        <button class="cg-filter-btn" data-category={cat}>{getCategoryLabel(cat)}</button>
      ))}
    </div>

    <!-- Scroll indicator (mouse) -->
    <div class="cg-hero-mouse-wrap" aria-hidden="true">
      <div class="cg-hero-mouse">
        <div class="cg-hero-mouse-wheel"></div>
      </div>
      <span class="cg-hero-mouse-label">Scroll</span>
    </div>
  </div>
</section>
