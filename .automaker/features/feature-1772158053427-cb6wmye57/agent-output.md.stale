  "content": "import type { Config } from 'tailwindcss';\n\n/**\n * Helper to wrap a CSS custom property reference.\n * e.g. cssVar('--hx-color-primary-500') → 'var(--hx-color-primary-500)'\n */\nfunction cssVar(name: string): string {\n  return `var(${name})`;\n}\n\n/**\n * Helper to create a color scale using CSS custom properties.\n * This lets Tailwind utilities reference Helix design tokens dynamically.\n */\nfunction colorScale(prefix: string, shades: string[]): Record<string, string> {\n  return Object.fromEntries(shades.map((shade) => [shade, cssVar(`--hx-${prefix}-${shade}`)]));\n}\n\n/**\n * Standard color scale shades (matches Helix token palette).\n */\nconst PALETTE_SHADES = ['50', '100', '200', '300', '400', '500', '600', '700', '800', '900', '950'];\n\n/**\n * Helix Tailwind CSS preset.\n *\n * Maps Helix design tokens (`--hx-*` CSS custom properties) to Tailwind\n * utility classes. Requires the Helix tokens CSS to be loaded in your\n * application (e.g. via `@helix/tokens/tokens.css`).\n *\n * @example\n * ```js\n * // tailwind.config.js\n * import helixPreset from '@helixds/tailwind-preset';\n *\n * export default {\n *   presets: [helixPreset],\n *   content: ['./src/** /*'],\n * };\n * ```\n */\nconst helixPreset: Partial<Config> = {\n  darkMode: ['selector', '[data-theme=\"dark\"]'],\n\n  theme: {\n    extend: {\n      colors: {\n        // Brand palettes\n        primary: colorScale('color-primary', PALETTE_SHADES),\n        secondary: colorScale('color-secondary', PALETTE_SHADES),\n        accent: colorScale('color-accent', PALETTE_SHADES),\n        neutral: colorScale('color-neutral', PALETTE_SHADES),\n        success: colorScale('color-success', PALETTE_SHADES),\n        warning: colorScale('color-warning', PALETTE_SHADES),\n        error: colorScale('color-error', PALETTE_SHADES),\n        info: colorScale('color-info', PALETTE_SHADES),\n\n        // Semantic surface colors\n        surface: {\n          DEFAULT: cssVar('--hx-color-surface-default'),\n          raised: cssVar('--hx-color-surface-raised'),\n          sunken: cssVar('--hx-color-surface-sunken'),\n          overlay: cssVar('--hx-color-surface-overlay'),\n        },\n\n        // Semantic text colors\n        text: {\n          DEFAULT: cssVar('--hx-color-text-primary'),\n          primary: cssVar('--hx-color-text-primary'),\n          secondary: cssVar('--hx-color-text-secondary'),\n          muted: cssVar('--hx-color-text-muted'),\n          disabled: cssVar('--hx-color-text-disabled'),\n          inverse: cssVar('--hx-color-text-inverse'),\n          link: cssVar('--hx-color-text-link'),\n          'on-primary': cssVar('--hx-color-text-on-primary'),\n          'on-secondary': cssVar('--hx-color-text-on-secondary'),\n          'on-error': cssVar('--hx-color-text-on-error'),\n          'on-success': cssVar('--hx-color-text-on-success'),\n          'on-warning': cssVar('--hx-color-text-on-warning'),\n        },\n\n        // Semantic border colors\n        border: {\n          DEFAULT: cssVar('--hx-color-border-default'),\n          muted: cssVar('--hx-color-border-muted'),\n          strong: cssVar('--hx-color-border-strong'),\n          focus: cssVar('--hx-color-border-focus'),\n        },\n      },\n\n      spacing: {\n        px: cssVar('--hx-space-px'),\n        '0': cssVar('--hx-space-0'),\n        '1': cssVar('--hx-space-1'),\n        '2': cssVar('--hx-space-2'),\n        '3': cssVar('--hx-space-3'),\n        '4': cssVar('--hx-space-4'),\n        '5': cssVar('--hx-space-5'),\n        '6': cssVar('--hx-space-6'),\n        '7': cssVar('--hx-space-7'),\n        '8': cssVar('--hx-space-8'),\n        '10': cssVar('--hx-space-10'),\n        '12': cssVar('--hx-space-12'),\n        '14': cssVar('--hx-space-14'),\n        '16': cssVar('--hx-space-16'),\n        '20': cssVar('--hx-space-20'),\n        '24': cssVar('--hx-space-24'),\n        '28': cssVar('--hx-space-28'),\n        '32': cssVar('--hx-space-32'),\n        '36': cssVar('--hx-space-36'),\n        '40': cssVar('--hx-space-40'),\n        '44': cssVar('--hx-space-44'),\n        '48': cssVar('--hx-space-48'),\n        '52': cssVar('--hx-space-52'),\n        '56': cssVar('--hx-space-56'),\n        '60': cssVar('--hx-space-60'),\n        '64': cssVar('--hx-space-64'),\n        '72': cssVar('--hx-space-72'),\n        '80': cssVar('--hx-space-80'),\n        '96': cssVar('--hx-space-96'),\n      },\n\n      fontFamily: {\n        sans: cssVar('--hx-font-family-sans'),\n        serif: cssVar('--hx-font-family-serif'),\n        mono: cssVar('--hx-font-family-mono'),\n      },\n\n      fontSize: {\n        '2xs': cssVar('--hx-font-size-2xs'),\n        xs: cssVar('--hx-font-size-xs'),\n        sm: cssVar('--hx-font-size-sm'),\n        md: cssVar('--hx-font-size-md'),\n        base: cssVar('--hx-font-size-md'),\n        lg: cssVar('--hx-font-size-lg'),\n        xl: cssVar('--hx-font-size-xl'),\n        '2xl': cssVar('--hx-font-size-2xl'),\n        '3xl': cssVar('--hx-font-size-3xl'),\n        '4xl': cssVar('--hx-font-size-4xl'),\n        '5xl': cssVar('--hx-font-size-5xl'),\n        '6xl': cssVar('--hx-font-size-6xl'),\n      },\n\n      fontWeight: {\n        thin: cssVar('--hx-font-weight-thin'),\n        extralight: cssVar('--hx-font-weight-extralight'),\n        light: cssVar('--hx-font-weight-light'),\n        normal: cssVar('--hx-font-weight-normal'),\n        medium: cssVar('--hx-font-weight-medium'),\n        semibold: cssVar('--hx-font-weight-semibold'),\n        bold: cssVar('--hx-font-weight-bold'),\n        extrabold: cssVar('--hx-font-weight-extrabold'),\n        black: cssVar('--hx-font-weight-black'),\n      },\n\n      lineHeight: {\n        none: cssVar('--hx-line-height-none'),\n        tight: cssVar('--hx-line-height-tight'),\n        snug: cssVar('--hx-line-height-snug'),\n        normal: cssVar('--hx-line-height-normal'),\n        relaxed: cssVar('--hx-line-height-relaxed'),\n        loose: cssVar('--hx-line-height-loose'),\n      },\n\n      letterSpacing: {\n        tighter: cssVar('--hx-letter-spacing-tighter'),\n        tight: cssVar('--hx-letter-spacing-tight'),\n        normal: cssVar('--hx-letter-spacing-normal'),\n        wide: cssVar('--hx-letter-spacing-wide'),\n        wider: cssVar('--hx-letter-spacing-wider'),\n        widest: cssVar('--hx-letter-spacing-widest'),\n      },\n\n      boxShadow: {\n        none: 'none',\n        sm: cssVar('--hx-shadow-sm'),\n        DEFAULT: cssVar('--hx-shadow-md'),\n        md: cssVar('--hx-shadow-md'),\n        lg: cssVar('--hx-shadow-lg'),\n        xl: cssVar('--hx-shadow-xl'),\n        '2xl': cssVar('--hx-shadow-2xl'),\n        inner: cssVar('--hx-shadow-inner'),\n      },\n\n      borderRadius: {\n        none: '0',\n        sm: cssVar('--hx-border-radius-sm'),\n        DEFAULT: cssVar('--hx-border-radius-md'),\n        md: cssVar('--hx-border-radius-md'),\n        lg: cssVar('--hx-border-radius-lg'),\n        xl: cssVar('--hx-border-radius-xl'),\n        '2xl': cssVar('--hx-border-radius-2xl'),\n        full: cssVar('--hx-border-radius-full'),\n      },\n\n      transitionDuration: {\n        fast: cssVar('--hx-duration-fast'),\n        normal: cssVar('--hx-duration-normal'),\n        slow: cssVar('--hx-duration-slow'),\n      },\n\n      transitionTimingFunction: {\n        'ease-in': cssVar('--hx-easing-ease-in'),\n        'ease-out': cssVar('--hx-easing-ease-out'),\n        'ease-in-out': cssVar('--hx-easing-ease-in-out'),\n        spring: cssVar('--hx-easing-spring'),\n      },\n\n      opacity: {\n        '0': '0',\n        '5': cssVar('--hx-opacity-5'),\n        '10': cssVar('--hx-opacity-10'),\n        '20': cssVar('--hx-opacity-20'),\n        '25': cssVar('--hx-opacity-25'),\n        '30': cssVar('--hx-opacity-30'),\n        '40': cssVar('--hx-opacity-40'),\n        '50': cssVar('--hx-opacity-50'),\n        '60': cssVar('--hx-opacity-60'),\n        '70': cssVar('--hx-opacity-70'),\n        '75': cssVar('--hx-opacity-75'),\n        '80': cssVar('--hx-opacity-80'),\n        '90': cssVar('--hx-opacity-90'),\n        '95': cssVar('--hx-opacity-95'),\n        '100': '1',\n      },\n    },\n  },\n};\n\nexport default helixPreset;\n"
}

