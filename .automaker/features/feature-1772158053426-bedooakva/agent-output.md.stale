🔧 Tool: Write
Input: {
  "file_path": "/Volumes/Development/booked/helix/.worktrees/feature-phase-2-component-implement-hx-nav/hx-nav-verify.spec.ts",
  "content": "/**\n * Temporary verification test for hx-nav component.\n * Tests component structure and behavior using a self-contained HTML page.\n * Delete this file after verification.\n */\n\nimport { test, expect } from '@playwright/test';\n\nconst NAV_HTML = `<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>hx-nav verification</title>\n  <script type=\"module\">\n    import { LitElement, html, nothing } from 'https://cdn.jsdelivr.net/gh/lit/dist@3/all/lit-all.min.js';\n    import { classMap } from 'https://cdn.jsdelivr.net/gh/lit/dist@3/all/lit-all.min.js';\n\n    class HelixNav extends LitElement {\n      static properties = {\n        items: { type: Array },\n        orientation: { type: String, reflect: true },\n        label: { type: String },\n        _mobileOpen: { type: Boolean, state: true },\n        _expandedIndex: { type: Number, state: true },\n      };\n\n      constructor() {\n        super();\n        this.items = [];\n        this.orientation = 'horizontal';\n        this.label = 'Main navigation';\n        this._mobileOpen = false;\n        this._expandedIndex = null;\n      }\n\n      _handleToggle() {\n        this._mobileOpen = !this._mobileOpen;\n        if (!this._mobileOpen) this._expandedIndex = null;\n      }\n\n      _handleItemClick(item, index, e) {\n        if (item.children?.length) {\n          e.preventDefault();\n          this._expandedIndex = this._expandedIndex === index ? null : index;\n        } else {\n          this._mobileOpen = false;\n          this._expandedIndex = null;\n          this.dispatchEvent(new CustomEvent('hx-nav-select', { bubbles: true, composed: true, detail: { item } }));\n        }\n      }\n\n      _handleKeydown(e, index, item) {\n        if (e.key === 'Escape') {\n          this._expandedIndex = null;\n        } else if ((e.key === 'Enter' || e.key === ' ') && item.children?.length) {\n          e.preventDefault();\n          this._expandedIndex = this._expandedIndex === index ? null : index;\n        }\n      }\n\n      _renderSubMenu(children, parentIndex) {\n        const isExpanded = this._expandedIndex === parentIndex;\n        return html\\`<ul class=\"nav__submenu\" role=\"menu\" ?hidden=\\${!isExpanded}>\n          \\${children.map(child => html\\`<li role=\"none\">\n            <a part=\"link\" href=\\${child.href || '#'} role=\"menuitem\" aria-current=\\${child.current ? 'page' : nothing}>\\${child.label}</a>\n          </li>\\`)}\n        </ul>\\`;\n      }\n\n      _renderItem(item, index) {\n        const hasChildren = !!item.children?.length;\n        const isExpanded = this._expandedIndex === index;\n\n        if (hasChildren) {\n          return html\\`<li part=\"item\" class=\"nav__item\">\n            <button part=\"link\" aria-expanded=\\${isExpanded ? 'true' : 'false'} aria-haspopup=\"menu\"\n              @click=\\${(e) => this._handleItemClick(item, index, e)}\n              @keydown=\\${(e) => this._handleKeydown(e, index, item)}>\\${item.label}</button>\n            \\${this._renderSubMenu(item.children, index)}\n          </li>\\`;\n        }\n        return html\\`<li part=\"item\" class=\"nav__item\">\n          <a part=\"link\" href=\\${item.href || '#'} aria-current=\\${item.current ? 'page' : nothing}\n            @click=\\${(e) => this._handleItemClick(item, index, e)}>\\${item.label}</a>\n        </li>\\`;\n      }\n\n      render() {\n        return html\\`\n          <nav part=\"nav\" aria-label=\\${this.label}>\n            <button part=\"toggle\" aria-expanded=\\${this._mobileOpen ? 'true' : 'false'} aria-controls=\"nav-list\"\n              @click=\\${this._handleToggle}>Menu</button>\n            <ul part=\"list\" id=\"nav-list\" role=\"list\">\n              \\${this.items.map((item, i) => this._renderItem(item, i))}\n            </ul>\n          </nav>\\`;\n      }\n    }\n\n    customElements.define('hx-nav', HelixNav);\n  </script>\n</head>\n<body>\n  <hx-nav id=\"nav\" label=\"Main navigation\"></hx-nav>\n  <script>\n    const nav = document.getElementById('nav');\n    nav.items = [\n      { label: 'Home', href: '/home', current: true },\n      { label: 'Patients', children: [\n        { label: 'All Patients', href: '/patients' },\n        { label: 'New Intake', href: '/patients/new' }\n      ]},\n      { label: 'Reports', href: '/reports' }\n    ];\n  </script>\n</body>\n</html>`;\n\ntest.describe('hx-nav verification', () => {\n  test.beforeEach(async ({ page }) => {\n    await page.setContent(NAV_HTML.replace(/\\\\/g, ''), { waitUntil: 'networkidle' });\n    // Wait for custom element to render\n    await page.waitForTimeout(2000);\n  });\n\n  test('renders nav landmark with aria-label', async ({ page }) => {\n    const nav = page.locator('hx-nav');\n    await expect(nav).toBeAttached();\n\n    const shadowNav = await nav.evaluate((el) => {\n      const shadow = el.shadowRoot;\n      const navEl = shadow?.querySelector('nav');\n      return navEl?.getAttribute('aria-label');\n    });\n    expect(shadowNav).toBe('Main navigation');\n  });\n\n  test('renders CSS parts: nav, list, item, link, toggle', async ({ page }) => {\n    const nav = page.locator('hx-nav');\n\n    const parts = await nav.evaluate((el) => {\n      const shadow = el.shadowRoot;\n      return {\n        nav: !!shadow?.querySelector('[part=\"nav\"]'),\n        list: !!shadow?.querySelector('[part=\"list\"]'),\n        item: !!shadow?.querySelector('[part=\"item\"]'),\n        link: !!shadow?.querySelector('[part=\"link\"]'),\n        toggle: !!shadow?.querySelector('[part=\"toggle\"]'),\n      };\n    });\n\n    expect(parts.nav).toBe(true);\n    expect(parts.list).toBe(true);\n    expect(parts.item).toBe(true);\n    expect(parts.link).toBe(true);\n    expect(parts.toggle).toBe(true);\n  });\n\n  test('sets aria-current=\"page\" on current item', async ({ page }) => {\n    const nav = page.locator('hx-nav');\n\n    const ariaCurrent = await nav.evaluate((el) => {\n      const shadow = el.shadowRoot;\n      const links = shadow?.querySelectorAll('a[part=\"link\"]');\n      return links?.[0]?.getAttribute('aria-current');\n    });\n\n    expect(ariaCurrent).toBe('page');\n  });\n\n  test('renders submenu trigger with aria-haspopup and aria-expanded', async ({ page }) => {\n    const nav = page.locator('hx-nav');\n\n    const submenuAttrs = await nav.evaluate((el) => {\n      const shadow = el.shadowRoot;\n      const btn = shadow?.querySelector('button[part=\"link\"]');\n      return {\n        haspopup: btn?.getAttribute('aria-haspopup'),\n        expanded: btn?.getAttribute('aria-expanded'),\n      };\n    });\n\n    expect(submenuAttrs.haspopup).toBe('menu');\n    expect(submenuAttrs.expanded).toBe('false');\n  });\n\n  test('toggle button has aria-controls', async ({ page }) => {\n    const nav = page.locator('hx-nav');\n\n    const ariaControls = await nav.evaluate((el) => {\n      const shadow = el.shadowRoot;\n      const toggle = shadow?.querySelector('[part=\"toggle\"]');\n      return toggle?.getAttribute('aria-controls');\n    });\n\n    expect(ariaControls).toBe('nav-list');\n  });\n\n  test('submenu expands when trigger is clicked', async ({ page }) => {\n    const nav = page.locator('hx-nav');\n\n    // Click the submenu trigger button\n    await nav.evaluate((el) => {\n      const shadow = el.shadowRoot;\n      const btn = shadow?.querySelector('button[part=\"link\"]') as HTMLButtonElement;\n      btn?.click();\n    });\n\n    await page.waitForTimeout(100);\n\n    const isExpanded = await nav.evaluate((el) => {\n      const shadow = el.shadowRoot;\n      const btn = shadow?.querySelector('button[part=\"link\"]');\n      return btn?.getAttribute('aria-expanded');\n    });\n\n    expect(isExpanded).toBe('true');\n  });\n\n  test('mobile toggle button toggles aria-expanded', async ({ page }) => {\n    const nav = page.locator('hx-nav');\n\n    await nav.evaluate((el) => {\n      const shadow = el.shadowRoot;\n      const toggle = shadow?.querySelector('[part=\"toggle\"]') as HTMLButtonElement;\n      toggle?.click();\n    });\n\n    await page.waitForTimeout(100);\n\n    const expanded = await nav.evaluate((el) => {\n      const shadow = el.shadowRoot;\n      const toggle = shadow?.querySelector('[part=\"toggle\"]');\n      return toggle?.getAttribute('aria-expanded');\n    });\n\n    expect(expanded).toBe('true');\n  });\n\n  test('orientation attribute reflects correctly', async ({ page }) => {\n    const nav = page.locator('hx-nav');\n\n    await nav.evaluate((el) => {\n      (el as HTMLElement & { orientation: string }).orientation = 'vertical';\n    });\n\n    await page.waitForTimeout(100);\n\n    const attr = await nav.getAttribute('orientation');\n    expect(attr).toBe('vertical');\n  });\n});\n"
}

