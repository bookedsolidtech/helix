{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "paths": {
      "@helix/library": ["../hx-library/src/index.ts"],
      "@helix/library/*": ["../hx-library/src/*"]
    }
  },
  "include": ["src", "scripts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../hx-library" }
  ]
}
