{
  "name": "@helixds/telemetry",
  "version": "0.0.1",
  "description": "Opt-in client-side telemetry SDK for HelixDS — privacy-first, tree-shakable, <2KB gzipped",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite": "^6.2.0"
  }
}
