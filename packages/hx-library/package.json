{
  "name": "@helixui/library",
  "version": "0.1.3",
  "description": "Enterprise Web Component Library built with Lit 3.x",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "src/components/**/*.ts",
    "dist/components/**/*.js",
    "dist/shared/**/*.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./custom-elements.json": "./custom-elements.json",
    "./fouc.css": "./fouc.css"
  },
  "files": [
    "dist",
    "custom-elements.json",
    "fouc.css"
  ],
  "customElements": "custom-elements.json",
  "scripts": {
    "dev": "vite build --watch",
    "generate:barrel": "node scripts/generate-barrel.js",
    "prepare": "node scripts/generate-barrel.js",
    "prebuild": "node scripts/generate-barrel.js",
    "build": "vite build && npm run cem",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:cross-browser": "vitest run --config vitest.config.cross-browser.ts",
    "test:coverage": "vitest run --coverage.enabled",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "cem": "custom-elements-manifest analyze --litelement --globs \"src/components/**/*.ts\" --exclude \"**/*.stories.ts\" --exclude \"**/*.styles.ts\"",
    "lint": "eslint src/",
    "clean": "rm -rf dist custom-elements.json"
  },
  "dependencies": {
    "@helixui/tokens": "*",
    "lit": "^3.3.2"
  },
  "peerDependencies": {
    "@floating-ui/dom": "^1.7.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bookedsolidtech/helix.git",
    "directory": "packages/hx-library"
  },
  "license": "MIT",
  "homepage": "https://helix.bookedsolid.com",
  "bugs": "https://github.com/bookedsolidtech/helix/issues",
  "keywords": [
    "web-components",
    "lit",
    "healthcare",
    "design-system",
    "custom-elements"
  ],
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@vitest/browser": "^3.0.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "axe-core": "^4.11.1",
    "playwright": "^1.50.0",
    "typescript": "^5.7.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.0"
  }
}
