{
  "name": "@helix/tokens",
  "version": "0.0.1",
  "private": true,
  "description": "Design tokens for the WC-2026 enterprise healthcare web component library",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css": {
      "types": "./dist/css.d.ts",
      "import": "./dist/css.js",
      "default": "./dist/css.js"
    },
    "./lit": {
      "types": "./dist/lit.d.ts",
      "import": "./dist/lit.js",
      "default": "./dist/lit.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.json": "./src/tokens.json"
  },
  "files": [
    "dist",
    "src/tokens.json"
  ],
  "scripts": {
    "build": "tsc && npx tsx scripts/generate-css.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
