{
  "name": "@helix/tokens",
  "version": "0.0.1",
  "private": true,
  "description": "Design tokens for the WC-2026 enterprise healthcare web component library",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./css": {
      "types": "./src/css.ts",
      "import": "./src/css.ts",
      "default": "./src/css.ts"
    },
    "./lit": {
      "types": "./src/lit.ts",
      "import": "./src/lit.ts",
      "default": "./src/lit.ts"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "import": "./src/utils.ts",
      "default": "./src/utils.ts"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.json": "./src/tokens.json"
  },
  "files": [
    "dist",
    "src/tokens.json"
  ],
  "scripts": {
    "build": "tsc && node sd.config.mjs",
    "build:sd": "node sd.config.mjs",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "style-dictionary": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
