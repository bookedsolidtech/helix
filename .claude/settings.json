{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npm run hooks:type-check-strict",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "npm run hooks:no-hardcoded-values",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "npm run hooks:test-coverage-gate",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "npm run hooks:bundle-size-guard",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "npm run hooks:cem-accuracy-check",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "npm run hooks:a11y-regression-guard",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "npm run hooks:event-type-safety",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "npm run hooks:jsdoc-coverage",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
