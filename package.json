{
  "name": "wc-2026",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Enterprise Healthcare Web Component Library - Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "kill-ports": "bash scripts/kill-ports.sh",
    "restart": "npm run kill-ports && turbo dev",
    "dev": "turbo dev",
    "dev:docs": "turbo dev --filter=docs",
    "dev:storybook": "turbo dev --filter=@helix/storybook",
    "dev:library": "turbo dev --filter=@helix/library",
    "build": "turbo build",
    "build:docs": "turbo build --filter=docs",
    "build:library": "turbo build --filter=@helix/library",
    "build:storybook": "turbo build --filter=@helix/storybook",
    "type-check": "turbo type-check",
    "type-check:watch": "turbo type-check --watch",
    "lint": "turbo lint",
    "lint:fix": "turbo lint --fix",
    "clean": "turbo clean",
    "cem": "turbo cem --filter=@helix/library",
    "generate-docs": "tsx scripts/generate-component-docs.ts",
    "preview:docs": "turbo preview --filter=docs",
    "dev:admin": "turbo dev --filter=@helix/admin",
    "build:admin": "turbo build --filter=@helix/admin",
    "test": "turbo test",
    "test:library": "turbo test --filter=@helix/library",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:all": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html,astro}\"",
    "pre-commit-check": "bash scripts/pre-commit-check.sh",
    "pre-push-check": "bash scripts/pre-push-check.sh",
    "hooks:type-check-strict": "tsx scripts/hooks/type-check-strict.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "node -e \"try { require('husky').install() } catch (e) {}\""
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.0.0",
    "eslint-plugin-lit": "^1.15.0",
    "eslint-plugin-wc": "^2.2.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "ts-morph": "^27.0.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.2"
}
