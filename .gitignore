testing/static-html/helix-bundle.js
testing/static-html/helix-bundle.css

# MCP server test coverage reports
apps/mcp-servers/*/coverage/

# Worktrees (embedded git repos — never track)
.worktrees/

# Library registry (per-install, not shared)
apps/admin/src/data/library-registry.json

# protoLabs Studio (entire directory — runtime state, settings, features, archives)
.automaker/
.automaker-lock

# MCP health scorer output (regenerated on demand)
packages/.mcp-wc/

# Local MCP config (contains absolute paths, machine-specific)
.mcp.json
mcpwc.config.json

# Internal workstream results (analysis artifacts, not source)
.workstream-results/

# Claude Code internal files (reports, reviews, health history)
# Agent definitions (.claude/agents/) are kept — they are project source
.claude/settings.json
.claude/docs-generation-progress.json
.claude/docs-outline.json
.claude/docs/
.claude/health-history/
.claude/issues/
.claude/reports/
.claude/platform-review-*.json
.claude/*.md
!.claude/agents/

