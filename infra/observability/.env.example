# Supabase self-hosted environment variables
# Phase 4: Observability Platform — wc-2026/helix
#
# Copy this file to .env and fill in all required values before running
# docker compose up. Never commit .env to source control.

# ── Required secrets ─────────────────────────────────────────────────────────

# PostgreSQL superuser password (min 20 chars recommended)
POSTGRES_PASSWORD=

# JWT secret used to sign Supabase tokens (min 32 chars, random)
JWT_SECRET=

# Supabase anon key — generate with: supabase gen keys --project-ref <id>
# Or for local dev: supabase start will print these values
ANON_KEY=

# Supabase service role key — grants full DB access; keep secret
SERVICE_ROLE_KEY=

# Supabase Studio admin password
DASHBOARD_PASSWORD=

# Realtime secret key base (min 64 chars, random)
REALTIME_SECRET_KEY_BASE=

# ── Optional / defaulted ─────────────────────────────────────────────────────

# External URL exposed to clients (default: local)
API_EXTERNAL_URL=http://localhost:8000

# Application site URL (used by GoTrue for redirects)
SITE_URL=http://localhost:3000

# PostgreSQL port exposed on the host
POSTGRES_PORT=5432

# Kong gateway ports
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# Supabase Studio port
STUDIO_PORT=3000

# Studio display names
STUDIO_DEFAULT_ORGANIZATION=wc-2026
STUDIO_DEFAULT_PROJECT=Observability

# Logflare (analytics) — leave blank to disable
LOGFLARE_API_KEY=

# JWT expiry in seconds (default: 1 hour)
JWT_EXPIRY=3600

# ── Cloud (Supabase-hosted) overrides ────────────────────────────────────────
# When using Supabase Cloud instead of self-hosting, only these vars are needed:

# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
